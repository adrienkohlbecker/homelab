#!/usr/bin/env bash
# Notify the operator that a cross-cut change landed without auto-fan-out.
#
# Called from the notify-cross-cut job of test.yml when the detect job
# reported cross_cut=true. Sends mail via the Mailgun HTTP API directly
# rather than going through the host's postfix relay (the runner runs
# inside ci-image and would have to widen lab's postfix to listen on
# the podman bridge -- not worth it for one notification path).
#
# Required env (GitHub Actions repo secrets, set in the workflow's `env:`):
#   MAILGUN_API_KEY        -- the Mailgun API key (api:<key>)
#   MAILGUN_DOMAIN         -- the Mailgun-controlled domain (e.g. noreply.fahm.fr)
#
# Optional env (always populated by GitHub Actions):
#   GITHUB_SHA, GITHUB_REPOSITORY, GITHUB_SERVER_URL, GITHUB_RUN_ID
#   MAIL_TO                -- override recipient (default adrien.kohlbecker@gmail.com)
set -euo pipefail

: "${MAILGUN_API_KEY:?MAILGUN_API_KEY must be set}"
: "${MAILGUN_DOMAIN:?MAILGUN_DOMAIN must be set}"

mail_to="${MAIL_TO:-adrien.kohlbecker@gmail.com}"
sha="${GITHUB_SHA:-$(git rev-parse HEAD)}"
short_sha="${sha:0:8}"
author=$(git show -s --format='%an <%ae>' "$sha" 2>/dev/null || echo unknown)
subject_line=$(git show -s --format='%s' "$sha" 2>/dev/null || echo '<no subject>')

# Re-derive affected cross-cut files; cheaper than threading the list
# through the detect job's outputs and we want a self-contained script.
base=$(git rev-parse HEAD~1 2>/dev/null || echo '')
if [ -n "$base" ]; then
  affected=$(git diff --name-only "$base" HEAD | grep -E '^(group_vars/all\.yml|group_vars/test\.yml|host_vars/.*-qemu.*\.yml|test/(testrole|testall|machine)\.py|mise\.toml)$' || true)
else
  affected="<no parent commit>"
fi

run_url="${GITHUB_SERVER_URL:-https://github.com}/${GITHUB_REPOSITORY:-repo}/actions/runs/${GITHUB_RUN_ID:-?}"

body=$(
  cat <<EOF
Commit: $short_sha by $author
Subject: $subject_line

Affected cross-cut files:
$(
    # shellcheck disable=SC2001  # multi-line indent prefix is clearer with sed than ${//}
    sed 's/^/  /' <<<"$affected"
  )

Auto-fan-out was skipped to avoid lighting up the entire role universe.
To run a targeted subset, open the Actions tab and dispatch \`test\` with
one of:

  roles=foo,bar,baz
  roles=foo:lab,bar
  roles=ALL

Run: $run_url
EOF
)

curl -sS --fail-with-body \
  --user "api:$MAILGUN_API_KEY" \
  "https://api.eu.mailgun.net/v3/$MAILGUN_DOMAIN/messages" \
  -F from="homelab-ci@$MAILGUN_DOMAIN" \
  -F to="$mail_to" \
  -F subject="[homelab CI] cross-cut detected on $short_sha" \
  -F text="$body" >/dev/null

echo "mail sent to $mail_to (cross-cut on $short_sha)"
