#!/usr/bin/env bash
# Verify the static fan-out matrix in test.yml and test-nightly.yml is
# in sync with the role universe. Backs up the current files, re-runs
# ci:gen-test-matrix, diffs against the backup, and restores -- so the
# check doesn't disturb the working tree whether it passes or fails.
# Adding a role without re-running gen is caught at lint time.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

f1=.gitea/workflows/test.yml
f2=.gitea/workflows/test-nightly.yml
b1=$(mktemp)
b2=$(mktemp)
# Backup-then-restore (not `git checkout`) so the lint check doesn't
# clobber pending edits the operator hasn't staged yet.
cp "$f1" "$b1"
cp "$f2" "$b2"
trap 'mv -f "$b1" "$f1"; mv -f "$b2" "$f2"' EXIT

mise run ci:gen-test-matrix >/dev/null

drift=0
diff -u "$b1" "$f1" >&2 || drift=1
diff -u "$b2" "$f2" >&2 || drift=1
if [ $drift -ne 0 ]; then
  echo "error: static test matrix is out of date. Run \`mise run ci:gen-test-matrix\` and commit the result." >&2
  exit 1
fi
