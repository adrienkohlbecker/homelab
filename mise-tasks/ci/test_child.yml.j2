# Generated by mise-tasks/ci/detect.py from mise-tasks/ci/test_child.yml.j2 -- do not edit.
# The parent `detect` job writes this; the `test_cells` trigger runs it.
#
# One job per cell (role:variant[:ubuntu]), all extending the shared `.cell`
# scaffold; an optional site-converge job; and a no-op placeholder so the
# artifact is always a valid pipeline even when the downstream trigger is gated
# off (GitLab evaluates `rules` at pipeline-creation time, so a runtime
# "any cells?" flag cannot gate the trigger). See notes/ci_aws_nested_qemu_cells.md.
default:
  interruptible: true
  tags:
    - fox-docker-aws

# Cells are split evenly across two display stages because the GitLab UI only
# renders the first 100 jobs of a stage; `needs: []` keeps them one parallel
# DAG, so test2 never waits on test1.
stages:
{% for stage in stages %}
  - {{ stage }}
{% endfor %}

.cell:
  stage: test1
  needs: []
{% if manual_cells %}
  # SKIP_TEST_CELLS=true: the child pipeline is still built and triggered, but
  # every cell (each extends .cell, incl. _site_test) is an optional manual job
  # -- none auto-runs and none gates the parent (allow_failure), so the operator
  # click-starts only the cells they want. allow_failure also keeps these out of
  # green-base detection (detect.py _pipeline_ran_cells ignores allow_failure
  # cells), so a skip pipeline never anchors a future diff as if it had tested.
  when: manual
  allow_failure: true
{% endif %}
  # Qemu cells run directly on a protected shell runner. No job image, no EC2
  # launch prelude: test/testrole.py uses the local qemu harness. The aws_qemu
  # target hydrates the promoted qemu base images from AWS S3 via GitLab OIDC
  # before booting; the lab target boots images already on local disk (its bake
  # writes them into /mnt/scratch/homelab_ci), so it skips hydration.
  tags:
    - {{ cell_runner_tag }}
{% if image_oidc %}
  id_tokens:
    GITLAB_OIDC_TOKEN:
      aud: sts.amazonaws.com
{% endif %}
  # Harness --timeout is 25m (1500s); the job timeout leaves headroom for the
  # prelude + cell teardown.
  timeout: 30m
  variables:
    # Cloud-environment flag: true when the guest egresses through AWS (the
    # aws_qemu target), so the harness (Machine.in_aws) makes roles pick the
    # in-region EC2 mirrors + public DNS over the LAN Nexus / AdGuard VIP.
    HOMELAB_TEST_IN_AWS: "{{ "true" if in_aws else "false" }}"
    # Pin the legacy slirp guest NIC. passt intermittently fails to answer the
    # guest's first-boot DHCP, so the guest never gets a NIC and the cell stalls
    # to the ssh-wait deadline (harness exit 124). The race is not limited to the
    # ZFSBootMenu initramfs (rd.neednet=1, absent from the box test images):
    # under the synchronized cell-launch burst the qemu hosts now run, passt
    # drops the plain systemd-networkd first-boot DHCP too -- a full-matrix
    # re-enable went ~84/138 cells red on the ssh-wait timeout. passt only
    # engages in CI (macOS
    # + the jammy host fall back via _passt_available), so this disables it
    # fleet-wide without removing the passt code. Drop this line to re-enable
    # once passt's DHCP-under-burst race is fixed (resolve_net_backend reads
    # HOMELAB_NET_BACKEND=slirp).
    HOMELAB_NET_BACKEND: slirp
    # Restrict ansible to the test identity; the prod identity is undecryptable
    # in CI by design (CLAUDE.md: Vault ids).
    ANSIBLE_VAULT_IDENTITY_LIST: test@vault-client.sh
{% if baked_toolchain %}
    # The qemu-host AMI bakes the mise tool tree and uv cache at these paths
    # (packer/aws/qemu_host.pkr.hcl). The instance executor runs the job in a
    # non-login shell, so without these the before_script's `ci:bootstrap`
    # ignores the baked caches and re-downloads the whole
    # toolchain on every fresh host (~20s of the cold-start tail). Set here
    # rather than in the runner config so tuning them is a repo change with no
    # fox converge. The baked /opt/venv is intentionally not reused: each job
    # keeps its own .venv built from the warm cache, so cells running
    # concurrently on one host (capacity_per_instance > 1) never share a venv.
    MISE_DATA_DIR: /opt/mise
    UV_CACHE_DIR: /opt/uv-cache
    UV_LINK_MODE: copy
{% endif %}
  before_script:
    - test -n "${HOMELAB_VAULT_PASSWORD_TEST:-}" || { echo "HOMELAB_VAULT_PASSWORD_TEST CI/CD variable is not set" >&2; exit 1; }
    # Same drift self-heal as .hosted, against the active mise tool tree.
    - mise run ci:bootstrap
{% if image_oidc %}
    # GitLab OIDC works on the shell runner too. The same branch-safe cell role
    # has read-only access to the promoted qemu bundles used by qemu cells.
    - source mise-tasks/ci/aws-oidc.sh {{ cell_role_arn }} "{{ target }}-cell-$CI_JOB_ID" --cache-dir
    # box/box_deps boot a promoted S3 image bundle; minimal has none -- the
    # harness downloads its Ubuntu cloud image at runtime
    # (Machine._ensure_minimal_cloudimg), so there is nothing to hydrate for it.
    - if [ "${VARIANT:-box}" != "minimal" ]; then mise run ci:hydrate-qemu-images "${VARIANT:-box}" --ubuntu "${UBUNTU:-jammy}"; fi
{% else %}
    # The lab target boots images straight from /mnt/scratch/homelab_ci (the lab
    # bake writes them there); nothing to authenticate or hydrate here.
{% endif %}
  artifacts:
    when: on_failure
    expire_in: 30 days
    paths:
      - test/out/
{% if site_test %}

# _site_test is the critical-path cell (longest run, ~40m). A dedicated leading
# `site` stage makes GitLab seed it with the lowest build ids so a runner picks
# it up first instead of queueing it behind the cell matrix; needs:[] (from
# .cell) keeps it -- and every cell -- starting in parallel, so the leading
# stage orders job ids and groups the UI without gating anything.
"_site_test:box":
  extends: .cell
  stage: site
  # Route the critical-path converge to its own runner (a dedicated single-host
  # 4-vCPU pool on aws_qemu) so it runs uncontended and the role-cell pool can
  # drain without waiting on it. Equals the cell tag until that pool is live.
  tags:
    - {{ site_runner_tag }}
  timeout: 60m
  script:
    # External watchdog, same rationale as the cell script below: GNU timeout
    # backstops site_test.py's in-process asyncio deadline against a wedged
    # event loop. 3060 = 3000 + the harness's 60s teardown grace.
    #
    # Capture, log, then re-exit the harness code (same as the cell script) so
    # the exit code is auditable from the job log.
    - |
      rc=0
      mise exec -- timeout --kill-after=30s 3060 test/site_test.py --timeout 3000 || rc=$?
      echo "harness exit code: $rc"
      exit $rc
{% endif %}
{% for group in cell_groups %}
{% for cell in group.cells %}

"{{ cell.spec }}":
  extends: .cell
  stage: {{ group.stage }}
  variables:
    ROLE: {{ cell.role }}
    VARIANT: {{ cell.machine }}
    UBUNTU: {{ cell.ubuntu }}
  script:
    # External watchdog around the harness. testrole.py enforces --timeout 1500
    # in-process via asyncio.timeout, but that only fires while the event loop
    # stays responsive; GNU timeout is loop-independent, so a wedged harness is
    # killed near the deadline instead of riding the 30m job timeout. SIGTERM
    # lets testrole.py unwind and tear down its qemu VM; --kill-after SIGKILLs
    # if that unwind itself hangs. 1560 = 1500 + the harness's 60s teardown
    # grace (Machine.WRAPPER_GRACE_SECONDS).
    #
    # Capture, log, then re-exit the harness code rather than letting it ride out
    # as the script's implicit status, so the exit code is auditable from the
    # job log.
    - |
      rc=0
      mise exec -- timeout --kill-after=30s 1560 test/testrole.py "$ROLE" --machine "$VARIANT" --ubuntu "$UBUNTU" --timeout 1500 --benchmark || rc=$?
      echo "harness exit code: $rc"
      exit $rc
{% endfor %}
{% endfor %}
{% if not cells and not site_test %}

no_cells:
  stage: test1
  # The trigger is gated off (HAVE_CELLS=false) so this never runs; it only
  # keeps the artifact a syntactically valid pipeline.
  script:
    - echo "no role-relevant changes; nothing to test"
{% endif %}
