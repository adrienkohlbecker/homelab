# Generated by mise-tasks/ci/detect.py from mise-tasks/ci/test_child.yml.j2 -- do not edit.
# The parent `detect` job writes this; the `test_cells` trigger runs it.
#
# One job per cell (role:variant[:ubuntu]), all extending the shared `.cell`
# scaffold; an optional site-converge job; and a no-op placeholder so the
# artifact is always a valid pipeline even when the downstream trigger is gated
# off (GitLab evaluates `rules` at pipeline-creation time, so a runtime
# "any cells?" flag cannot gate the trigger). See notes/ci_aws_test_cells.md.
default:
  interruptible: true
{% if use_ci_image %}
  # Pin the CI image explicitly (the child is self-contained). The default tag
  # keeps the trivial no_cells placeholder on the always-on fox runner; the real
  # cells override to the ephemeral coordinator via .cell, so a no-cell pipeline
  # never boots a coordinator just to echo "nothing to test".
  image: "$CI_REGISTRY_IMAGE/ci:latest"
{% endif %}
  tags:
    - fox-docker-aws

# Cells are split evenly across two display stages because the GitLab UI only
# renders the first 100 jobs of a stage; `needs: []` keeps them one parallel
# DAG, so test2 never waits on test1.
stages:
{% for stage in stages %}
  - {{ stage }}
{% endfor %}

.cell:
  stage: test1
  needs: []
{% if use_ci_image %}
  # The AWS test-cell fan-out runs on the ephemeral coordinator (gitlab_runner's
  # docker-autoscaler / fleeting runner), NOT the on-fox docker runner: per
  # pipeline it clones one Hetzner box, runs the whole matrix (all cells share
  # the one coordinator at capacity_per_instance=60), and scales to zero. Each
  # coordinator boots with an empty image store, so the first cell pulls the
  # current ci:latest only if detect did not already warm this coordinator. In
  # the normal path detect pulls with policy=always in the parent pipeline and
  # cells use if-not-present to reuse that local image without registry re-checks.
  # Overrides the default fox-docker-aws tag. See notes/ci_aws_test_cells.md
  # "Phase 2".
  tags:
    - {{ cell_runner_tag }}
  image:
    name: "$CI_REGISTRY_IMAGE/ci:latest"
    pull_policy: if-not-present
  id_tokens:
    GITLAB_OIDC_TOKEN:
      aud: sts.amazonaws.com
{% else %}
  # Qemu shell targets run directly on protected shell runners. No job image, no
  # EC2 launch prelude: test/testrole.py uses the local qemu harness through
  # HOMELAB_TEST_BACKEND=qemu. GitLab OIDC hydrates the promoted qemu base
  # images from S3 before booting.
  tags:
    - {{ cell_runner_tag }}
  id_tokens:
    GITLAB_OIDC_TOKEN:
      aud: sts.amazonaws.com
{% endif %}
  # Harness --timeout is 25m (1500s); the job timeout leaves headroom for the
  # prelude + cell teardown.
  timeout: 30m
{% if retry_spot_interruption %}
  # testrole.py exits 86 on a post-hoc spot-interruption classification
  # (notes/ci_aws_test_cells.md); retry the cell once.
  retry:
    max: 1
    exit_codes:
      - 86
{% endif %}
  variables:
    HOMELAB_TEST_BACKEND: {{ backend }}
    # Restrict ansible to the test identity; the prod identity is undecryptable
    # in CI by design (CLAUDE.md: Vault ids).
    ANSIBLE_VAULT_IDENTITY_LIST: test@vault-client.sh
  before_script:
{% if use_ci_image %}
    # Fail before the launch, not at the SSH wait, when prerequisites are
    # missing (the same guard style as ami_box_deps / fox_image).
    - test -n "${CI_CELL_SSH_KEY:-}" || { echo "CI_CELL_SSH_KEY CI/CD variable is not set" >&2; exit 1; }
{% endif %}
    - test -n "${HOMELAB_VAULT_PASSWORD_TEST:-}" || { echo "HOMELAB_VAULT_PASSWORD_TEST CI/CD variable is not set" >&2; exit 1; }
    # Same drift self-heal as .hosted, against the active mise tool tree.
    - mise install
    # Shell runners do not activate mise shims; `mise exec` exposes the tool
    # tree consistently there while staying harmless inside the CI image.
    - mise exec -- uv sync --locked
{% if use_ci_image %}
    # GitLab's id_tokens deliver the OIDC JWT in an env var; the AWS CLI's
    # AssumeRoleWithWebIdentity provider wants a file path.
    - export AWS_WEB_IDENTITY_TOKEN_FILE="$CI_PROJECT_DIR/.aws_web_identity_token"
    - echo "$GITLAB_OIDC_TOKEN" > "$AWS_WEB_IDENTITY_TOKEN_FILE"
    - export AWS_ROLE_ARN={{ cell_role_arn }}
    - export AWS_ROLE_SESSION_NAME="cell-$CI_JOB_ID"
    # Smoke the OIDC chain before launching an instance.
    - mise exec -- aws --region eu-central-1 sts get-caller-identity
    # The Ec2Machine SSHes as the operator identity over the agent (no key file
    # in the repo); load the dedicated cell key into a fresh agent. GitLab
    # file-type variables arrive without the trailing newline OpenSSH requires
    # (and sometimes with CRLF), so ssh-add rejects the raw variable with
    # "error in libcrypto"; normalise into a private 600 copy -- strip CR,
    # guarantee a trailing newline -- before loading it.
    - cell_key="$(mktemp)"
    - chmod 600 "$cell_key"
    - printf '%s\n' "$(tr -d '\r' < "$CI_CELL_SSH_KEY")" > "$cell_key"
    - eval "$(ssh-agent -s)"
    - ssh-add "$cell_key"
{% endif %}
{% if hydrate_qemu %}
    # GitLab OIDC works on the shell runner too. The same branch-safe cell role
    # has read-only access to the promoted qemu bundles used by qemu cells.
    - export AWS_WEB_IDENTITY_TOKEN_FILE="$CI_PROJECT_DIR/.aws_web_identity_token"
    - echo "$GITLAB_OIDC_TOKEN" > "$AWS_WEB_IDENTITY_TOKEN_FILE"
    - export AWS_ROLE_ARN={{ cell_role_arn }}
    - export AWS_ROLE_SESSION_NAME="{{ target }}-cell-$CI_JOB_ID"
    - mise exec -- aws --region eu-central-1 sts get-caller-identity
    - mise run ci:hydrate-qemu-images "${VARIANT:-box}" --ubuntu "${UBUNTU:-jammy}"
{% endif %}
    # Pass the PAT through to `mise install` when one is configured, and from
    # there to the guest's `mise install` for backend-launched cells.
    - if [ -n "${MISE_GITHUB_TOKEN:-}" ]; then export GITHUB_TOKEN="$MISE_GITHUB_TOKEN"; fi
  artifacts:
    when: on_failure
    expire_in: 30 days
    paths:
      - test/out/
{% if site_test %}

# _site_test is the critical-path cell (longest run, ~40m). A dedicated leading
# `site` stage makes GitLab seed it with the lowest build ids so a runner picks
# it up first instead of queueing it behind the cell matrix; needs:[] (from
# .cell) keeps it -- and every cell -- starting in parallel, so the leading
# stage orders job ids and groups the UI without gating anything.
"_site_test:box":
  extends: .cell
  stage: site
  timeout: 60m
  script:
    # External watchdog, same rationale as the cell script below: GNU timeout
    # backstops site_test.py's in-process asyncio deadline against a wedged
    # event loop. 2460 = 2400 + the harness's 60s teardown grace.
    #
    # Capture, log, then re-exit the harness code (same as the cell script): a
    # spot-interrupted run exits 86 (the retry: exit_codes signal in .cell), and
    # echoing the raw code makes the retry-or-not decision auditable from the
    # job log when a cell does not retry as expected.
    - |
      rc=0
      mise exec -- timeout --kill-after=30s 2460 test/site_test.py --timeout 2400 || rc=$?
      echo "harness exit code: $rc"
      exit $rc
{% endif %}
{% for group in cell_groups %}
{% for cell in group.cells %}

"{{ cell.spec }}":
  extends: .cell
  stage: {{ group.stage }}
  variables:
    ROLE: {{ cell.role }}
    VARIANT: {{ cell.variant }}
    UBUNTU: {{ cell.ubuntu }}
  script:
    # External watchdog around the harness. testrole.py enforces --timeout 1500
    # in-process via asyncio.timeout, but that only fires while the event loop
    # stays responsive; GNU timeout is loop-independent, so a wedged harness is
    # killed near the deadline instead of riding the 30m job timeout. SIGTERM
    # lets testrole.py unwind and tear down its EC2 cell; --kill-after SIGKILLs
    # if that unwind itself hangs (the cell still self-terminates via its
    # EventBridge expiry schedule). 1560 = 1500 + the harness's 60s teardown
    # grace (Machine.WRAPPER_GRACE_SECONDS).
    #
    # Capture, log, then re-exit the harness code rather than letting it ride out
    # as the script's implicit status: a spot-interrupted cell exits 86 (the
    # retry: exit_codes signal in .cell), and echoing the raw code makes the
    # retry-or-not decision auditable from the job log -- a cell that classified
    # a spot interruption yet did not retry shows whether 86 actually reached
    # the runner.
    - |
      rc=0
      mise exec -- timeout --kill-after=30s 1560 test/testrole.py "$ROLE" --machine "$VARIANT" --ubuntu "$UBUNTU" --timeout 1500 --benchmark || rc=$?
      echo "harness exit code: $rc"
      exit $rc
{% endfor %}
{% endfor %}
{% if not cells and not site_test %}

no_cells:
  stage: test1
  # The trigger is gated off (HAVE_CELLS=false) so this never runs; it only
  # keeps the artifact a syntactically valid pipeline.
  script:
    - echo "no role-relevant changes; nothing to test"
{% endif %}
