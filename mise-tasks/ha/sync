#!/usr/bin/env python3
#MISE description="Sync HA GUI YAML files (automations/scripts/scenes) between the ha_gui_config submodule and lab. Default mode: pull then push."
#USAGE arg "<mode>" help="pull | push | sync (default)" default="sync"
"""
Bidirectional sync for /mnt/services/homeassistant/{automations,scripts,scenes}.yaml.

The submodule at roles/homeassistant/files/ha_gui_config/ is the source of
truth. A movable tag `last_synced_to_host` records the commit whose tree
matches the live host state; sync directionality is detected by comparing
host file shas against blobs at that tag.

- pull: scp host -> submodule, commit if changed, advance tag.
- push: refuse if host has diverged from the tag (GUI edited since last
        pull); otherwise scp submodule -> host, advance tag, hit
        /api/services/<domain>/reload for each changed file.

HA reload needs HA_API_TOKEN in the environment -- long-lived bearer
token minted in HA UI -> Profile -> Security. The mise.toml [env]
block resolves it from 1Password (op://). Without the token the push
still lands the files on disk and prints a warning; reload manually
via Developer Tools -> YAML or restart the homeassistant unit.
"""

from __future__ import annotations

import hashlib
import os
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

# Re-exec under `op run --` so op:// references in mise's [env] (notably
# HA_API_TOKEN) get resolved to real secret values. Without this the
# script sees the literal "op://Lab/<item>/password" string and HA's API
# rejects it as a bad bearer.
if os.environ.get("HA_API_TOKEN", "").startswith("op://") and not os.environ.get("_HA_SYNC_OP_RESOLVED"):
    _op = shutil.which("op")
    if _op:
        _env = {**os.environ, "_HA_SYNC_OP_RESOLVED": "1"}
        sys.exit(subprocess.run([_op, "run", "--", sys.executable, __file__, *sys.argv[1:]], env=_env).returncode)

REPO_ROOT = Path(__file__).resolve().parents[2]
SUBMODULE = REPO_ROOT / "roles/homeassistant/files/ha_gui_config"
HOST = "lab"
HOST_DIR = "/mnt/services/homeassistant"
HA_URL = "https://homeassistant.lab.fahm.fr"
SYNCED_TAG = "last_synced_to_host"

# filename -> HA reload service domain
FILES = {
    "automations.yaml": "automation",
    "scripts.yaml": "script",
    "scenes.yaml": "scene",
}


def sh(cmd: list[str], cwd: Path | None = None, check: bool = True) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, cwd=cwd, check=check, capture_output=True, text=True)


def sh_bytes(cmd: list[str], cwd: Path | None = None) -> bytes:
    return subprocess.run(cmd, cwd=cwd, check=True, capture_output=True).stdout


def host_sha(filename: str) -> str:
    r = sh(["ssh", HOST, f"sudo sha256sum {HOST_DIR}/{filename}"])
    return r.stdout.split()[0]


def blob_sha_at(ref: str, filename: str) -> str:
    return hashlib.sha256(sh_bytes(["git", "show", f"{ref}:{filename}"], cwd=SUBMODULE)).hexdigest()


def assert_submodule_ready() -> None:
    if not (SUBMODULE / ".git").exists():
        sys.exit(f"submodule not initialized at {SUBMODULE}; run `git submodule update --init {SUBMODULE.relative_to(REPO_ROOT)}`")
    r = sh(["git", "status", "--porcelain"], cwd=SUBMODULE)
    if r.stdout.strip():
        sys.exit(f"refusing: submodule working tree has uncommitted changes:\n{r.stdout}\ncommit or stash first.")


def has_tag(name: str) -> bool:
    r = sh(["git", "tag", "-l", name], cwd=SUBMODULE, check=False)
    return name in r.stdout.split()


def advance_synced_tag() -> None:
    """Move SYNCED_TAG to HEAD (locally + on origin)."""
    sh(["git", "tag", "-f", SYNCED_TAG], cwd=SUBMODULE)
    sh(["git", "push", "origin", "--force", f"refs/tags/{SYNCED_TAG}"], cwd=SUBMODULE)


def fetch_from_host() -> None:
    """sudo-cat each host file into the submodule working tree."""
    for f in FILES:
        with (SUBMODULE / f).open("wb") as out:
            subprocess.run(["ssh", HOST, f"sudo cat {HOST_DIR}/{f}"], stdout=out, check=True)


def upload_to_host(filenames: list[str]) -> None:
    """scp via /tmp + sudo install so owner/mode/backup all happen atomically."""
    pid = os.getpid()
    for f in filenames:
        tmp_remote = f"/tmp/.ha_sync_{pid}_{f}"
        sh(["scp", "-q", str(SUBMODULE / f), f"{HOST}:{tmp_remote}"])
        sh(["ssh", HOST, f"sudo install -o homeassistant -g homeassistant -m 0600 -b {tmp_remote} {HOST_DIR}/{f} " f"&& sudo rm -f {tmp_remote}"])


def trigger_reload(domains: list[str]) -> None:
    """Curl the HA REST API directly. Needs HA_API_TOKEN in env."""
    token = os.environ.get("HA_API_TOKEN", "").strip()
    if not token:
        print(
            "WARN: HA_API_TOKEN unset; skipping HA reload. Files landed on disk; " "reload manually via Developer Tools -> YAML.",
            file=sys.stderr,
        )
        return
    for d in sorted(set(domains)):
        url = f"{HA_URL}/api/services/{d}/reload"
        req = urllib.request.Request(
            url,
            method="POST",
            data=b"{}",
            headers={"Authorization": f"Bearer {token}", "Content-Type": "application/json"},
        )
        try:
            with urllib.request.urlopen(req, timeout=10) as resp:
                print(f"reload {d}: HTTP {resp.status}")
        except urllib.error.HTTPError as e:
            print(f"WARN: reload {d} failed: HTTP {e.code} {e.reason}", file=sys.stderr)
        except urllib.error.URLError as e:
            print(f"WARN: reload {d} failed: {e.reason}", file=sys.stderr)


def do_pull() -> None:
    assert_submodule_ready()
    sh(["git", "fetch", "--tags", "--force"], cwd=SUBMODULE)
    sh(["git", "pull", "--ff-only", "--quiet"], cwd=SUBMODULE)
    fetch_from_host()
    if not sh(["git", "status", "--porcelain"], cwd=SUBMODULE).stdout.strip():
        if not has_tag(SYNCED_TAG) or sh(["git", "rev-parse", SYNCED_TAG], cwd=SUBMODULE).stdout.strip() != sh(["git", "rev-parse", "HEAD"], cwd=SUBMODULE).stdout.strip():
            advance_synced_tag()
            print("pull: no host changes; advanced tag to HEAD")
        else:
            print("pull: in sync, no-op")
        return
    ts = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    sh(["git", "add", "-A"], cwd=SUBMODULE)
    sh(["git", "commit", "-m", f"pull: capture GUI edits from lab ({ts})"], cwd=SUBMODULE)
    sh(["git", "push", "origin", "main"], cwd=SUBMODULE)
    advance_synced_tag()
    print(f"pull: committed GUI edits + pushed (tag now at {sh(['git', 'rev-parse', '--short', 'HEAD'], cwd=SUBMODULE).stdout.strip()})")


def do_push() -> None:
    assert_submodule_ready()
    sh(["git", "fetch", "--tags", "--force"], cwd=SUBMODULE)
    sh(["git", "pull", "--ff-only", "--quiet"], cwd=SUBMODULE)
    if not has_tag(SYNCED_TAG):
        sys.exit(f"refusing: no {SYNCED_TAG} tag. Run `mise run ha:pull` once to establish the baseline.")
    diverged = []
    for f in FILES:
        if host_sha(f) != blob_sha_at(SYNCED_TAG, f):
            diverged.append(f)
    if diverged:
        msg = [f"refusing: host diverged from {SYNCED_TAG} (GUI edited since last sync):"]
        msg += [f"  {f}" for f in diverged]
        msg.append("\nrun `mise run ha:pull` to capture GUI edits, then retry push.")
        sys.exit("\n".join(msg))
    changed = [(f, d) for f, d in FILES.items() if blob_sha_at("HEAD", f) != blob_sha_at(SYNCED_TAG, f)]
    if not changed:
        print("push: HEAD matches host, nothing to do")
        return
    files = [f for f, _ in changed]
    upload_to_host(files)
    advance_synced_tag()
    print(f"push: uploaded {files}")
    trigger_reload([d for _, d in changed])


MODES = {"pull": do_pull, "push": do_push}


def main() -> None:
    mode = (sys.argv[1] if len(sys.argv) > 1 else "sync").strip()
    if mode == "sync":
        do_pull()
        do_push()
    elif mode in MODES:
        MODES[mode]()
    else:
        sys.exit(f"unknown mode {mode!r}; use pull | push | sync")


if __name__ == "__main__":
    main()
