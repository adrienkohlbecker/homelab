#!/usr/bin/env bash
#MISE description="Build ubuntu-zfs and ubuntu-zfs-lab in parallel"
#USAGE flag "--ubuntu <name>" help="Ubuntu release codename" default="jammy"
#USAGE flag "--upstream" help="Forwarded to packer:build for each sub-build."
# shellcheck disable=SC2154  # usage_* vars are injected by mise from the #USAGE spec
set -euo pipefail

ubuntu="${usage_ubuntu}"
upstream_flag=""
[ "${usage_upstream:-false}" = "true" ] && upstream_flag="--upstream"

# `:::` runs the two sub-tasks in parallel under mise.
mise run packer:build zfs --ubuntu "${ubuntu}" ${upstream_flag} \
  ::: packer:build zfs-lab --ubuntu "${ubuntu}" ${upstream_flag}
