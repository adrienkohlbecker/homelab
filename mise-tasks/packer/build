#!/usr/bin/env bash
#MISE description="Build a packer image variant and verify it boots"
#MISE interactive=true
#USAGE arg "<variant>" help="Variant: zfs or zfs-lab"
#USAGE flag "--ubuntu <name>" help="Ubuntu release codename" default="jammy"
#USAGE flag "--upstream" help="Pull apt packages and the cloud image from upstream Ubuntu mirrors during the build instead of via the lab Nexus proxy. The shipped image always points at upstream regardless."
# shellcheck disable=SC2154  # usage_* vars are injected by mise from the #USAGE spec
set -euo pipefail

ubuntu="${usage_ubuntu}"
variant="${usage_variant}"
upstream="${usage_upstream:-false}"

artdir="${QEMU_DIR}/${ubuntu}/ubuntu-${variant}"
new="${artdir}.new"

# Wipe a stale .new from a prior aborted run; packer would otherwise
# refuse to write into a non-empty output_directory.
rm -rf "${new}"

# packer/qemu.pkr.hcl runs verify + compress as post-processors. Arch
# and image_format come from mise.toml's PKR_VAR_* env.

# PACKER_FLAGS expands to multiple flags; intentional word-split.
# shellcheck disable=SC2086
packer build ${PACKER_FLAGS} \
  -var "ubuntu_name=${ubuntu}" \
  -var "upstream_mirrors=${upstream}" \
  -var "zbm_version=${ZBM_VERSION}" \
  -var "output_directory=${new}" \
  "-only=qemu.ubuntu-${variant}" \
  packer

# Atomic-ish swap: drop the previous final dir and rename .new in.
# The packer post-processors already removed the unused cloud-image
# disk, verified the boot, and (on Mac) compressed; everything under
# .new is keepable as-is. Only the swap stays here so a failed build
# leaves ${artdir} untouched at the previous good artifact.
rm -rf "${artdir}"
mv "${new}" "${artdir}"
