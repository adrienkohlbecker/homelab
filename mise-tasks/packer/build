#!/usr/bin/env bash
#MISE description="Build packer image variant(s) and verify they boot"
#MISE interactive=true
#USAGE arg "<variants>..." help="Variants to build (zfs and/or zfs-lab); empty = all" default=""
#USAGE flag "--ubuntu <name>" help="Ubuntu release codename" default="jammy"
#USAGE flag "--upstream" help="Pull apt packages and the cloud image from upstream Ubuntu mirrors during the build instead of via the lab Nexus proxy. The shipped image always points at upstream regardless."
# shellcheck disable=SC2154  # usage_* vars are injected by mise from the #USAGE spec
set -euo pipefail

ubuntu="${usage_ubuntu}"
upstream="${usage_upstream:-false}"

# Default to all variants if none provided.
read -r -a variants <<<"${usage_variants:-}"
[ ${#variants[@]} -eq 0 ] && variants=(zfs zfs-lab)

for variant in "${variants[@]}"; do
  case "$variant" in
  zfs | zfs-lab) ;;
  *)
    echo "unknown variant: $variant (expected zfs or zfs-lab)" >&2
    exit 1
    ;;
  esac
done

base="${QEMU_DIR}/${ubuntu}"

# Wipe stale .new dirs from prior aborted runs; packer would otherwise
# refuse to write into a non-empty output_directory.
for variant in "${variants[@]}"; do
  rm -rf "${base}/ubuntu-${variant}.new"
done

# Build -only filter from variants. Packer parallelizes the matched
# sources internally (one VM per source, non-overlapping host_port and
# vnc_port ranges declared per source in qemu.pkr.hcl).
only=""
for variant in "${variants[@]}"; do
  only+="${only:+,}qemu.ubuntu-${variant}"
done

# PACKER_FLAGS expands to multiple flags; intentional word-split.
# shellcheck disable=SC2086
packer build ${PACKER_FLAGS} \
  -var "ubuntu_name=${ubuntu}" \
  -var "upstream_mirrors=${upstream}" \
  -var "zbm_version=${ZBM_VERSION}" \
  -var "output_base=${base}" \
  "-only=${only}" \
  packer

# Atomic-ish swap: drop the previous final dir and rename .new in,
# per variant. verify-boot ran inside packer so the .new dirs are
# known-good by this point.
for variant in "${variants[@]}"; do
  artdir="${base}/ubuntu-${variant}"
  rm -rf "${artdir}"
  mv "${artdir}.new" "${artdir}"
done
