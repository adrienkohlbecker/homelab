#!/usr/bin/env bash
#MISE description="Build a packer image variant and verify it boots"
#MISE interactive=true
#USAGE arg "<variant>" help="Variant: zfs or zfs-lab"
#USAGE flag "--ubuntu <name>" help="Ubuntu release codename" default="jammy"
#USAGE flag "--upstream" help="Pull apt packages and the cloud image from upstream Ubuntu mirrors during the build instead of via the lab Nexus proxy. The shipped image always points at upstream regardless."
#USAGE flag "--no-verify" help="Skip the post-build packer:verify smoke test (boot + systemctl is-system-running)."
# shellcheck disable=SC2154  # usage_* vars are injected by mise from the #USAGE spec
set -euo pipefail

ubuntu="${usage_ubuntu}"
variant="${usage_variant}"
upstream="${usage_upstream:-false}"

artdir="${QEMU_DIR}/${ubuntu}/ubuntu-${variant}"
new="${artdir}.new"

# Wipe a stale .new from a prior aborted run; packer would otherwise
# refuse to write into a non-empty output_directory.
rm -rf "${new}"

arch="$(uname -m | sed s/arm64/aarch64/)"

# PACKER_FLAGS expands to multiple flags; intentional word-split.
# shellcheck disable=SC2086
packer build ${PACKER_FLAGS} \
  -var "ubuntu_name=${ubuntu}" \
  -var "arch=${arch}" \
  -var "upstream_mirrors=${upstream}" \
  -var "zbm_version=${ZBM_VERSION}" \
  -var "output_directory=${new}" \
  "-only=qemu.ubuntu-${variant}" \
  packer

# Atomic-ish swap: drop the previous final dir and rename .new in.
# Packer's post-processor already removed the unused vda cloud-image
# disk; everything else under .new is keepable as-is.
rm -rf "${artdir}"
mv "${new}" "${artdir}"

if [ "${usage_no_verify:-false}" != "true" ]; then
  mise run packer:verify "${variant}" --ubuntu "${ubuntu}"
fi

# Compress the shipped disks here (not in packer post-processors) so a
# failed boot test short-circuits before we burn cycles compressing.
# qemu's disk_compression flag only handles the primary VMName disk
# (which the cleanup post-processor deletes); additional disks need
# this loop. Then write the sha256sum manifest covering the compressed
# disks plus efivars.fd.
for disk in "${artdir}"/packer-ubuntu-*; do
  echo "==> compressing $(basename "${disk}")"
  qemu-img convert -c -O qcow2 "${disk}" "${disk}.tmp"
  mv "${disk}.tmp" "${disk}"
done
echo "==> writing sha256sum"
(cd "${artdir}" && sha256sum efivars.fd kernel initrd cmdline packer-ubuntu-*) >"${artdir}/sha256sum.tmp"
mv "${artdir}/sha256sum.tmp" "${artdir}/sha256sum"
