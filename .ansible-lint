# .ansible-lint — the conventions these rules back are documented in CLAUDE.md.

# No profile. The `shared`/`production` profiles pull in galaxy + meta rules
# (meta-no-info, galaxy[*], meta-runtime) that don't apply here — roles carry
# meta/test.yml, not galaxy metadata. We curate enable/skip explicitly instead.
profile: null

# exclude_paths are parsed relative to THIS file, not the CWD.
exclude_paths:
  - .cache/
  - .claude/
  # Leftover packer tmp* build trees each hold a full repo copy; descending into
  # them inflates wall-clock ~7x (~10s → ~70s).
  - packer/artifacts/
  # HA GUI submodule: home-assistant YAML, not ansible content. ansible-lint
  # can't load the blueprints (load-failure) and mis-lints the automation files.
  - roles/homeassistant/files/ha_gui_config/
  # Harness driver playbooks reference `_role_under_test`, injected at runtime —
  # they don't syntax-check standalone.
  - test/playbooks/

# Loop vars must be `__`-prefixed or `{role}_`-prefixed.
loop_var_prefix: "^(__|{role}_)"
# Var names: lowercase snake_case (plus ansible's own identifier rules).
var_naming_pattern: "^[a-z_][a-z0-9_]*$"

use_default_rules: true
# shell-strict-mode enforces `set -euo pipefail` + executable:/bin/bash on
# production shell tasks (test scaffolding is exempt — see the rule's docstring).
# require-backup enforces `backup: true` on file-writing tasks (copy/template/
# replace/lineinfile/...); genuine exceptions carry `# noqa: require-backup`.
rulesdir:
  - ./lint/ansible_rules/

skip_list:
  # Bare ansible.builtin.* names are the repo convention; FQCN is reserved for
  # other collections (CLAUDE.md → Coding Style & Naming). Skip the whole rule,
  # not just fqcn[action]/[action-core]: the rule's matchtask still RUNS when only
  # sub-tags are skipped, and it logs a spurious WARNING on the systemd_unit
  # helper's deliberate `action: "{{ _module }}"` dynamic dispatch (it can't
  # resolve a templated module's FQCN). fqcn[canonical] has zero matches here.
  - fqcn
  # Handlers are banned (CLAUDE.md Hard Rule) — restarts run off *_result.changed,
  # so the "use a handler" rule is permanently wrong here.
  - no-handler
  # YAML formatting is owned by yamllint + .yamllint (brackets/commas house
  # style). ansible-lint's `yaml` rule re-applies yamllint's full default set and
  # diverges (flags files yamllint passes), so delegate to yamllint rather than
  # run two YAML linters that disagree. Want stricter YAML? Edit .yamllint.
  - yaml
  # Loop vars with no prefix at all — too noisy to gate on for now.
  - loop-var-prefix[missing]

# Opt-in rules (not loaded by default) we do want enforced.
enable_list:
  - args
  - empty-string-compare
  - no-log-password
  - no-prompting
  - no-same-owner
  - loop-var-prefix

# Rules that surface as warnings, never failures.
warn_list:
  - experimental

# Don't fetch requirements.yml / refresh schemas at lint time.
offline: true
