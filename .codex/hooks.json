{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.agents/hooks/lint_before_git_push.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.agents/hooks/lint_ansible_on_edit.sh"
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.agents/hooks/tf_validate_on_edit.sh"
          }
        ]
      }
    ]
  }
}
