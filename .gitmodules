[submodule "roles/homeassistant/files/ha_gui_config"]
	path = roles/homeassistant/files/ha_gui_config
	url = git@github.com:adrienkohlbecker/homelab_ha_config.git
	# ha:sync constantly rewrites the working tree (host scp during pull,
	# local edits before commit) and advances the submodule's own HEAD
	# past the pinned commit on every push. `all` keeps both the dirty
	# work tree and that pointer divergence out of the parent's git
	# status / diff, so the submodule never shows up here at all. The
	# pinned SHA is not load-bearing: ha:sync deploys from the submodule's
	# own working tree / origin, never the parent's recorded SHA. To move
	# the pointer deliberately, `git add --force` the submodule path —
	# plain `git add` / `status` won't surface it under `all`.
	ignore = all
