#!/bin/bash
# shellcheck source=../../bash/files/functions.sh
source /usr/local/lib/functions.sh
# No f_require_root (unlike zfs_health.sh): upssched exec's this as upsmon's
# RUN_AS_USER (nut), not root, so a root assertion would abort every dispatch.

EVENT=${1:-}
case $EVENT in
"")
  echo >&2 "Missing event argument"
  echo >&2 "Usage: nut-notify EVENT"
  exit 1
  ;;
online)
  MSG="UPS is back online"
  ;;
onbatt)
  MSG="UPS is on battery"
  ;;
lowbatt)
  MSG="UPS is on battery and has a low battery (is critical)"
  ;;
fsd)
  MSG="UPS is being shutdown by the primary (FSD = Forced Shutdown)"
  ;;
commok)
  MSG="Communications established with the UPS"
  ;;
commbad)
  MSG="Communications lost to the UPS"
  ;;
shutdown)
  MSG="The system is being shutdown"
  ;;
replbatt)
  MSG="The UPS battery is bad and needs to be replaced"
  ;;
# NOCOMM is SYSLOG+WALL-only in upsmon.conf (no EXEC), so upssched never
# dispatches it -- this arm is for a manual `nut-notify nocomm` invocation.
nocomm)
  MSG="A UPS is unavailable (can't be contacted for monitoring)"
  ;;
noparent)
  MSG="upsmon parent process died - shutdown impossible"
  ;;
# nut 2.8+ device-status events (the fleet is migrating to it). upssched only
# dispatches these once upsmon emits them, so the arms stay inert on 2.7.4.
bypass)
  MSG="UPS is on bypass - the load is NOT protected by the battery"
  ;;
over)
  MSG="UPS is overloaded"
  ;;
cal)
  MSG="UPS is calibrating its battery"
  ;;
*)
  echo >&2 "unexpected event $EVENT"
  exit 1
  ;;
esac

UPS='{{ nut_monitor_ups }}'

# Several of these events (commbad, nocomm, noparent, fsd) fire precisely
# when upsd/the UPS is unreachable, and functions.sh runs us under errexit
# -- so query upsd once (one round-trip against a possibly-flaky link, not
# three) and tolerate failure, or the notification mail never goes out. The
# here-strings below avoid a SIGPIPE-under-pipefail abort from `| head`.
UPSC=$(upsc "$UPS" 2>/dev/null || true)
STAT=$(awk -F': ' '$1=="ups.status"{print $2; exit}' <<<"$UPSC")
BATT=$(awk -F': ' '$1=="battery.charge"{print $2; exit}' <<<"$UPSC")
RUNTIME_SEC=$(awk -F': ' '$1=="battery.runtime"{print $2; exit}' <<<"$UPSC")

# ups.status/battery.charge are device-reported over SNMP (semi-trusted). awk's
# line-based extraction already bounds embedded newlines; strip any residual
# control chars so a crafted value can't smuggle a spoofed line into the mail
# body below. RUNTIME_SEC is separately constrained to ^[0-9]+$ further down.
STAT=${STAT//[[:cntrl:]]/}
BATT=${BATT//[[:cntrl:]]/}

# battery.runtime is seconds-to-empty; the Eaton's snmp-ups reports it as a
# float ("1341.00"), and it is absent/non-numeric on a failed query -- either
# of which would trip errexit in date. Accept an optional fraction and drop it
# (whole seconds are enough for HH:MM:SS); fall back to unknown otherwise.
if [[ $RUNTIME_SEC =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
  RUNTIME=$(date -d@"${RUNTIME_SEC%.*}" -u +%H:%M:%S)
else
  RUNTIME=unknown
fi
DATE=$(date --iso-8601=seconds)

# `mail` is provided by mailutils, installed by the postfix role (ordered
# before nut in site.yml). RUNTIME is a %s argument, not part of the format
# string, so a stray %/\ in the value can't corrupt the body.
printf "%s\n\nStatus Page: https://nut.{{ inventory_hostname }}.{{ domain }}/upsstats.cgi?host=%s\nDate: %s\nStatus: %s\nBattery charge: %s\nRuntime: %s\n\n" \
  "$MSG" "$UPS" "$DATE" "${STAT:-unknown}" "${BATT:-unknown}" "$RUNTIME" |
  mail -s "UPS event $EVENT on {{ inventory_hostname }}" root
