#jinja2: lstrip_blocks: True
# Managed by ansible (roles/gitlab_runner) -- do not edit on the host.
#
# GitLab Runner config: Docker executor against gitlab_runner's rootless
# podman socket. Jobs for the AWS test cells (notes/ci_aws_test_cells.md) run
# inside the project CI image on this host and drive single-use EC2 spot
# instances from there -- the container is the orchestration sandbox, not the
# test fixture. Tags / locked / run-untagged / protected all live server-side
# with the glrt- runner registration, not in this file.
# Orchestration slots, not compute: each job is an `aws`-CLI/ssh/ansible
# loop against a remote EC2 cell, so the bound is fox's memory for idle
# CI-image containers, not CPU. Real capacity is the spot vCPU quota.
concurrent = {{ gitlab_runner_concurrent }}
# JSON logs parse cleanly in fluentbit (the repo's only log consumer); the
# default `runner` format is ANSI-decorated and needs a custom parser.
log_format = "json"
# Graceful-shutdown drain: on SIGQUIT (systemctl stop/restart) the runner stops
# claiming jobs and waits up to this many seconds for in-flight jobs to finish
# before force-exiting. The default is 30s -- far too short to wind a cell
# matrix down -- so hold it ~30 min, enough to cover the longest jobs (AMI
# bakes). The unit's TimeoutStopSec sits just past this bound (1860s) so
# systemd only SIGKILLs a runner too wedged to run the drain at all.
shutdown_timeout = 1800
# Prometheus metrics + pprof, loopback-only (fox's netdata go.d prometheus
# collector scrapes it). Unauthenticated, and the pprof debug endpoints cannot
# be disabled separately from metrics -- accepted on loopback (any local
# process can trigger profiling), but re-evaluate if this listener ever moves
# off 127.0.0.1.
listen_address = "127.0.0.1:{{ service_ports.gitlab_runner }}"

[[runners]]
  name = "{{ inventory_hostname }}-docker-aws"
  url = "https://gitlab.com"
  # glrt- authentication token from creating the runner in the GitLab project
  # (Settings -> CI/CD -> Runners -> New project runner). Vaulted in host_vars.
  token = "{{ gitlab_runner_token }}"
  executor = "docker"
  # Per-runner cap on jobs run directly on this host. Bounds the on-fox CI
  # footprint independently of the global `concurrent` (which has to be raised
  # for the coordinator fleet) so a wide pipeline can't schedule the whole
  # fan-out onto fox. 0 = no per-runner cap (bounded only by `concurrent`).
  limit = {{ gitlab_runner_docker_limit }}

  [runners.docker]
    # gitlab_runner's rootless podman socket (socket-activated; linger keeps
    # the user manager alive). Rootless keeps the runner non-root-equivalent
    # on this host.
    host = "unix:///run/user/{{ gitlab_runner_user.uid }}/podman/podman.sock"
    # Default job image: the project CI image (mise tool tree + warm uv
    # cache baked in -- see .gitlab-ci.yml's ci_image job). Jobs may still
    # name another image; the runner is locked to this project so there is
    # no allowed_images policy to maintain.
    image = "registry.gitlab.com/akohlbecker/homelab/ci:latest"
    # Job containers orchestrate remote EC2 cells over ssh/https only -- no
    # devices, no nested containers, no privileges.
    privileged = false
{% if gitlab_runner_coordinator_enabled | default(false) %}

# Coordinator runner: a docker-autoscaler executor that clones an ephemeral
# Hetzner CX53 per pipeline via fleeting-plugin-hetzner, runs the AWS-cell
# fan-out from inside the CI image ON the coordinator, and scales back to zero
# when idle (notes/ci_aws_test_cells.md). Independent of the docker runner
# above -- that one stays for small jobs run directly on the host. The hcloud
# token lives only here on the manager; it never reaches the coordinator where
# job code runs.
[[runners]]
  name = "{{ inventory_hostname }}-coordinator-aws"
  url = "https://gitlab.com"
  # Second glrt- project runner, distinct from the docker runner's token above.
  # Vaulted in host_vars; tags/run-untagged/locked live server-side.
  token = "{{ gitlab_runner_coordinator_token }}"
  executor = "docker-autoscaler"
  # Per-runner concurrency cap (NOT the global `concurrent` above, which is the
  # fleet-wide ceiling). For an autoscaler runner this is max_instances ×
  # capacity_per_instance -- the most jobs one coordinator fleet can take.
  limit = {{ gitlab_runner_max_instances * gitlab_runner_capacity_per_instance }}

  [runners.docker]
    # The job container the autoscaler starts on the coordinator's dockerd.
    # Pulled per-pipeline over the coordinator's NVMe (one ~40s pull, reused
    # across the run), keeping the snapshot decoupled from ci_image rebuilds.
    image = "registry.gitlab.com/akohlbecker/homelab/ci:latest"
    privileged = false

  [runners.autoscaler]
    # PATH-resolved binary /usr/local/bin/fleeting-plugin-hetzner (NOT an OCI
    # ref); installed + pinned by tasks/main.yml.
    plugin = "fleeting-plugin-hetzner"
    # One coordinator fans out the whole pipeline: capacity matches the AWS
    # 60-spot/region quota (the real ceiling). max_use_count 0 reuses the
    # instance across jobs; max_instances 1 holds a single coordinator.
    capacity_per_instance = {{ gitlab_runner_capacity_per_instance }}
    max_use_count = 0
    max_instances = {{ gitlab_runner_max_instances }}
    # Tear the coordinator down on `gitlab-runner` stop so a manager restart
    # never strands a billable CX53.
    delete_instances_on_shutdown = true
    # Hold scheduling onto a freshly cloned coordinator until its dockerd is
    # actually serving -- the snapshot enables docker, but cloud-init + service
    # start lag SSH-up by a few seconds.
    instance_ready_command = "docker info"

    [runners.autoscaler.plugin_config]
      # Required by the plugin: the name prefix for the cloned servers (they
      # boot as ci-coordinator-<random>). Matches the pool label / reserved IP /
      # firewall name so the whole coordinator fleet shares one identifier.
      name = "ci-coordinator"
      # hcloud API token (manager-side only). Vaulted in host_vars.
      token = "{{ gitlab_runner_hcloud_token }}"
      location = "{{ gitlab_runner_location }}"
      server_type = "{{ gitlab_runner_server_type }}"
      # Numeric snapshot id resolved from the role=ci-coordinator label at
      # converge (docker-autoscaler needs an id, not a name). ubuntu-24.04 is a
      # harmless qemu-only fallback -- the coordinator path never boots there.
      image = "{{ gitlab_runner_resolved_image | default('ubuntu-24.04') }}"
      # Attach each coordinator to fox's private `hetzner` network so the
      # manager drives it over the private IP (use_external_addr=false below);
      # the reserved public IP stays egress-only.
      private_networks = ["hetzner"]
      # The coordinator claims a public IPv6 from the reserved-IP pool. fleeting
      # validates BOTH address families of the pool selector (terraform reserves
      # hcloud_primary_ip.ci_coordinator_v6 alongside the v4), so the coordinator
      # has to accept the v6 -- forcing public_ipv6_disabled true reproduces
      # scale-up failing "could not get ipv6 from pool" even with the v6 reserved.
      public_ipv6_disabled = false
      # Assign the reserved egress IP (terraform hcloud_primary_ip.ci_coordinator,
      # labelled pool=ci-coordinator) so the AWS cell SG can allowlist one stable
      # /32 despite scale-to-zero.
      public_ip_pool_enabled = true
      public_ip_pool_selector = "pool=ci-coordinator"

      [runners.autoscaler.plugin_config.labels]
        # Drives both the firewall auto-attach (terraform apply_to
        # label_selector) and the public-IP-pool selection above.
        pool = "ci-coordinator"
        manager = "{{ inventory_hostname }}"

    [runners.autoscaler.connector_config]
      # cloud-init injects fleeting's ephemeral key into root; the manager
      # reaches the coordinator over the private network, so no public SSH hole.
      username = "root"
      use_external_addr = false

    [[runners.autoscaler.policy]]
      # Scale to zero between pipelines; keep one warm instance for idle_time
      # after the last job so a burst of pipelines reuses a coordinator.
      idle_count = 0
      idle_time = "{{ gitlab_runner_idle_time }}"
{% endif %}
