
# Loads default set of integrations. Do not remove.
default_config:

# Load frontend themes from the themes folder
frontend:
  themes: !include_dir_merge_named themes

automation: !include automations.yaml
script: !include scripts.yaml
scene: !include scenes.yaml
sensor: !include sensors.yaml
template: !include templates.yaml
input_number: !include input_numbers.yaml
input_select: !include input_selects.yaml
timer: !include timers.yaml
# Daily Daikin write tally + safety cap for the HVAC Room Control loops
# (reset at 00:00 by the HVAC Write Counter Reset automation).
counter: !include counters.yaml
# climate_template platform from HACS (litinoveweedle/hass-template-climate):
# per-room dashboard thermostats wrapping the Daikin units.
climate: !include climate.yaml

# Default "Overview" dashboard stays storage-mode (UI-editable). Repo-owned
# dashboards are YAML-mode: authored in the ha_gui_config clone under dashboards/
# and deployed by `mise run ha:sync push` (read-only in the UI, re-read on load).
# Each needs an explicit entry here — HA can't glob a dashboards/ dir.
# The url_path key MUST contain a hyphen (HA rejects single-word custom paths),
# so the dashboard is served at /climate-control.
lovelace:
  mode: storage
  dashboards:
    climate-control:
      mode: yaml
      title: Climate
      icon: mdi:home-thermometer
      show_in_sidebar: true
      filename: dashboards/climate.yaml

# notify.family fans one message out to both phones. Consumed by household
# alerts in automations.yaml (water leak, humidifier-empty, dog-walk reminder)
# so those don't duplicate per-phone notify calls. The mobile_app_* notify
# services it references are created by default_config; this just bundles them.
notify:
  - platform: group
    name: family
    services:
      - service: mobile_app_adriens_iphone
      - service: mobile_app_iphone_de_{{ spouse_firstname }}

recorder:
  db_url: sqlite:////config/db/home-assistant_v2.db

http:
  use_x_forwarded_for: true
  trusted_proxies:
    # nginx (host-native) proxies via 127.0.0.1:8123. The published-port
    # DNAT lands on HA's podman-bridge IP and SNAT rewrites the source
    # to the bridge gateway. HA therefore sees the connection as
    # coming from somewhere inside the netavark default pool, not from
    # 127.0.0.1, so trusted_proxies has to cover that prefix.
    #
    # Trade-off: trusting the whole /16 also trusts every sibling
    # container on every other netavark-allocated bridge -- a compromise
    # on any of them lets the attacker spoof X-Forwarded-For and bypass
    # any HA client-IP allowlist or rate-limit. The narrower fix is to
    # trust only the bridge subnets HA actually joins; deferred today
    # because the threat model (compromised sibling container) is
    # low-prob in this homelab.
    - {{ podman_bridge_pool }}
