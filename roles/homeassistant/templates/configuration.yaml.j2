
# Loads default set of integrations. Do not remove.
default_config:

# Load frontend themes from the themes folder
frontend:
  themes: !include_dir_merge_named themes

automation: !include automations.yaml
script: !include scripts.yaml
scene: !include scenes.yaml
sensor: !include sensors.yaml
template: !include templates.yaml

# Hysteresis thresholds for HVAC mode flip + blind shading. Single source
# of truth — referenced by the HVAC Cooling/Heating automations
# (numeric_state triggers) and by the sun_driven_shutter blueprint (which
# derives its shade engagement threshold from hvac_heat_to_cool minus a
# 0.5°C margin, so blinds shade just before the AC would flip). Wider
# dead band than the original 19.5/20.5 to reduce mode bouncing in
# shoulder seasons (sustained ±1.5°C swings around setpoint no longer
# flip the AC).
input_number:
  hvac_cool_to_heat:
    name: HVAC flip-to-heat threshold
    initial: 19.0
    min: 15.0
    max: 21.0
    step: 0.1
    unit_of_measurement: "°C"
    icon: mdi:thermometer-low
  hvac_heat_to_cool:
    name: HVAC flip-to-cool threshold
    initial: 22.0
    min: 20.0
    max: 25.0
    step: 0.1
    unit_of_measurement: "°C"
    icon: mdi:thermometer-high

recorder:
  db_url: sqlite:////config/db/home-assistant_v2.db

http:
  use_x_forwarded_for: true
  trusted_proxies:
    # nginx (host-native) proxies via 127.0.0.1:8123. The published-port
    # DNAT lands on HA's mosquitto-bridge IP and SNAT rewrites the source
    # to that bridge's gateway. HA therefore sees the connection as
    # coming from somewhere inside the netavark default pool, not from
    # 127.0.0.1, so trusted_proxies has to cover that prefix.
    #
    # Trade-off: trusting the whole /16 also trusts every sibling
    # container on every other netavark-allocated bridge -- a compromise
    # on any of them lets the attacker spoof X-Forwarded-For and bypass
    # any HA client-IP allowlist or rate-limit. The narrower fix is to
    # pin mosquitto's subnet to a fixed /24 outside the auto-pool and
    # trust only that; deferred today because it's a cross-role change
    # and the threat model (compromised sibling container) is low-prob
    # in this homelab.
    - {{ podman_bridge_pool }}
