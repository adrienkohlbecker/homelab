#!/usr/sbin/nft -f

# nftables `define` directives centralize values referenced more than
# once below — nft's parser checks the name is resolvable at load time,
# so a typo (`$WAN_IFCAE`) fails loudly rather than rendering as an
# empty string. `nft list ruleset` still emits the expanded form, so
# external scrapers (and _verify.yml's VRRP assertion) are unaffected.
define WAN_IFACE = "{{ default_interface }}"
define HOME_LAN = {{ site_subnets.home }}
define WG_SUBNET = {{ wireguard_subnet }}
define PODMAN_DEFAULT = {{ podman_default_network }}
define PODMAN_POOL = {{ podman_bridge_pool }}

# Atomic full-replace of just our table — netavark / libvirt / fail2ban
# tables in the same kernel ruleset (under iptables-nft compat) are
# untouched. This is the killer simplification over iptables-restore,
# which flushed every chain in every table the file referenced.
#
# Idempotent idiom: `add table` is a no-op if the table exists,
# `delete table` then removes the whole table (sets, chains, maps), and
# `table { ... }` adds it fresh. A previous form used `flush table`
# instead of `delete`, which only flushes rules — set DEFINITIONS
# persist across the flush, so re-declaring a `flags constant` set
# whose ifname elements now resolve to a different ifindex than the
# kernel's stored value fails with EBUSY (the test caught this: at
# role-apply time `wg0` doesn't exist, at re-apply time the netns
# veth has created it). All three commands batch through netlink
# atomically under `nft -f`.
add table ip homelab
delete table ip homelab
table ip homelab {

    # Named counters declared at table scope. Rules below reference
    # them via `counter name "X"` instead of inlining anonymous
    # counters. _verify.yml's JSON walk filters
    # `nftables.counter[].name` rather than rule comments — more
    # robust than the previous comment-based filter (which broke on
    # em-dashes and was sensitive to rule reorders).
    counter input_nonsyn {}
    counter input_silenced {}
    counter input_catchall {}
    counter icmp_overflow {}
    counter vrrp_accept {}
    counter dnscrypt_accept {}
    counter aardvark_accept {}
    counter mdns_accept {}
    counter wireguard_accept {}
    counter mosh_accept {}
    counter netbios_accept {}
    counter forward_nonsyn {}
    counter forward_catchall {}
    counter input_unscoped_tcp {}
    counter input_admin_tcp {}
    counter input_transmission {}
    counter input_nut_podman {}
    counter input_loopback {}
    counter input_icmp_accept {}

    # Admin services (samba/nut/mosh/NetBIOS) require an (iif, saddr)
    # *intersection*, not union: home-LAN saddrs must arrive on the WAN
    # iface (which is also the LAN iface behind the UDM), and wg-subnet
    # saddrs must arrive on wg0. A concatenated set expresses the pair
    # directly so adding a future site (brumath, bonniers) is one
    # element edit, not a fan-out of duplicate rules.
    #
    # The earlier shape used two separate sets keyed independently
    # (lan_admin_ifaces × lan_admin_sources), which let
    # iif=$WAN_IFACE + saddr=$WG_SUBNET (and vice-versa) through. The
    # only mitigation against that was rp_filter=1; if policy routing
    # ever broke rp_filter, an attacker on the WAN iface forging an
    # RFC1918 saddr in $WG_SUBNET would have been accepted.
    set lan_admin_pairs {
        typeof iifname . ip saddr
        flags interval, constant
        elements = {
            $WAN_IFACE . $HOME_LAN comment "home LAN via WAN iface",
            "wg0" . $WG_SUBNET comment "wireguard peer via wg0",
        }
    }

    # Ingress ifaces for FORWARD reach into published containers + for
    # the catch-all TCP reject (LAN-side fast-fail). Pinning iif keeps
    # an attacker on a future LAN bridge / guest VLAN / mgmt net from
    # speculatively probing these paths.
    set lan_admin_ifaces {
        type ifname
        flags constant
        elements = {
            $WAN_IFACE comment "WAN-facing iface (LAN saddrs arrive via UDM)",
            "wg0" comment "wireguard tunnel",
        }
    }

    ##################################################
    #                   INPUT CHAIN                  #
    ##################################################
    chain input {
        type filter hook input priority filter; policy drop;

        # Established/related and loopback unconditionally; INVALID
        # dropped. After these, every remaining packet is NEW — no
        # rule below needs an explicit ct-state qualifier.
        ct state established,related accept
        iif lo counter name "input_loopback" accept
        ct state invalid drop

        # TCP NEW must have SYN. Conntrack's loose mode (default)
        # classifies mid-stream non-SYN packets as NEW rather than
        # INVALID, so without this an attacker could probe TCP
        # services with crafted ACKs. `counter` so _verify.yml can
        # assert the rule actually fired (matched by comment).
        tcp flags & (fin|syn|rst|ack) != syn counter name "input_nonsyn" drop comment "input non-syn drop"

        # DNS allows. Source-scope what doesn't need WAN reach: 5053/
        # 5333 are container DNS (consumers live on podman bridges); 5353
        # mDNS is link-local on the home LAN. dnscrypt only listens on
        # the default bridge gateway (10.88.0.1), but aardvark-dns binds
        # the gateway IP of every dns-enabled named bridge — those are
        # allocated from netavark's default_subnet_pools[0], hence the
        # podman_bridge_pool prefix here. Without this second subnet,
        # the saddr scope rejects every cross-bridge container-name
        # lookup (paperless → redis, z2m → mosquitto) at INPUT before
        # aardvark even sees them. Accept TCP alongside UDP on 5053 so
        # clients can fall back to TCP when a response would be
        # UDP-truncated (pihole does this opportunistically); we kept it
        # UDP-only originally and saw ~2 TCP drops/day from pihole.
        ip saddr $PODMAN_DEFAULT meta l4proto { tcp, udp } th dport {{ service_ports.dnscrypt_proxy }} counter name "dnscrypt_accept" accept comment "dnscrypt-proxy (default bridge only, TCP+UDP)"
        ip saddr { $PODMAN_DEFAULT, $PODMAN_POOL } udp dport 5333 counter name "aardvark_accept" accept comment "aardvark-dns (post-DNAT from gateway:53, all podman bridges)"
        iifname $WAN_IFACE ip saddr $HOME_LAN udp dport 5353 counter name "mdns_accept" accept comment "mDNS (home LAN)"

        # Wireguard ingress only on the WAN iface. Pinning iif means
        # an attacker on a future LAN bridge can't speculatively send
        # to udp/51820 from inside.
        iifname $WAN_IFACE udp dport {{ service_ports.wireguard }} counter name "wireguard_accept" accept comment "wireguard (WAN ingress only)"

        # Transmission BitTorrent peer port — WAN-only, both TCP (peer
        # wire protocol) and UDP (µTP + DHT). The UDM port-forwards
        # 51413 to lab:51413; transmission's host listener (created by
        # `--publish 0.0.0.0:51413` in transmission.service.j2) accepts
        # both protocols. Without these rules, peers can find us via
        # tracker announces but can't actually connect — visible as
        # external SRC=… DPT=51413 drops in INPUT.
        iifname $WAN_IFACE meta l4proto { tcp, udp } th dport {{ service_ports.transmission_bt }} counter name "input_transmission" accept comment "transmission BT peers (WAN ingress)"

        # Mosh sessions originate from admin clients on the home LAN
        # or via wireguard, never from raw WAN.
        iifname . ip saddr @lan_admin_pairs udp dport 60000-61000 counter name "mosh_accept" accept comment "Mosh"

        # TCP allows. SSH/HTTP/HTTPS are wide-open (admin + public);
        # Samba and nut are admin services scoped via the set.
        tcp dport { 22, 80, 443 } counter name "input_unscoped_tcp" accept comment "SSH/HTTP/HTTPS"
        iifname . ip saddr @lan_admin_pairs tcp dport { 445, {{ service_ports.nut }} } counter name "input_admin_tcp" accept comment "Samba/nut (admin)"

        # NetBIOS for nmbd (137 = name service, 138 = datagram). Same
        # admin scope as Samba — these are the legacy SMB browsing
        # broadcasts and only make sense from trusted LAN/wireguard.
        # Most of the volume is lab's own nmbd announcements coming
        # back through INPUT via broadcast loopback on both eth0
        # (10.123.0.2) and wg0 (10.123.64.2); the rest is real SMB
        # clients (MBP, pug) doing name resolution.
        iifname . ip saddr @lan_admin_pairs udp dport { 137, 138 } counter name "netbios_accept" accept comment "NetBIOS (nmbd, admin)"

        # Container access to NUT: homeassistant's NUT integration
        # connects from its podman bridge IP (currently the mosquitto
        # bridge) to lab's LAN IP at 3493. The admin rule above scopes
        # by lan_admin_sources which intentionally excludes containers
        # — broaden access here on port 3493 only (not 445; containers
        # shouldn't reach Samba) for any podman bridge in the pool.
        # Without this, HA's NUT integration silently fails — observed
        # as ~300 SYN-retry drops/day at INPUT.
        #
        # Known gap: this trusts every container on every podman bridge,
        # not just HA's. upsd exposes INSTCMD (UPS shutdown) — a
        # compromised container could power-off the rack. Tightening
        # needs either pinning HA's bridge subnet here or restricting
        # NUT clients via upsd.users; not implemented (home-environment
        # trade).
        ip saddr $PODMAN_POOL tcp dport {{ service_ports.nut }} counter name "input_nut_podman" accept comment "nut (podman bridges, e.g. HA NUT integration)"

        # ICMP — only echo-request, rate-limited. Other ICMP types
        # come back as RELATED. Overflow drops silently rather than
        # falling through to the catch-all reject. `counter` so the
        # overflow path can be functionally verified — without it, a
        # regression that raises the rate to 1000/sec or drops the
        # trailing drop would not be caught.
        icmp type echo-request limit rate 10/second burst 20 packets counter name "input_icmp_accept" accept
        icmp type echo-request counter name "icmp_overflow" drop comment "icmp echo overflow drop"

        # keepalived runs in unicast mode (not multicast 224.0.0.18)
        # with peers on the home LAN (see roles/pihole/templates/
        # keepalived.conf.j2). Scope VRRP to LAN ingress + LAN saddr
        # so nothing on WAN / wg0 / podman bridges can inject proto
        # 112 packets to churn election state.
        iifname $WAN_IFACE ip saddr $HOME_LAN ip protocol vrrp counter name "vrrp_accept" accept comment "keepalived (VRRP, LAN unicast)"

        # LAN broadcast/discovery noise. Every entry here was identified
        # from a 24h journal sweep of the catch-all log+drop below; each
        # is recurring and benign, and silencing them keeps the log
        # signal-to-noise high. Drop (not reject) to avoid ICMP-amplifying
        # responses back at broadcast sources.
        #   67    — DHCP DISCOVER from 0.0.0.0 (IoT devices booting, UDM
        #           is the DHCP server, lab isn't)
        #   1900  — SSDP/UPnP M-SEARCH (homeassistant doing UPnP
        #           discovery on its podman bridge)
        #   5351  — NAT-PMP (plex trying to auto-open ports; UDM doesn't
        #           speak NAT-PMP, port forwards are manual)
        #   10001 — UBNT discovery protocol; UniFi gateway broadcasts
        #           4-byte `01 00 00 00` every ~10s on every VLAN it
        #           has an interface in. ~6k/day. We don't run a UBNT
        #           agent on this host
        #   57621 — Spotify Connect LAN discovery (Adrien's MBP)
        udp dport { 67, 1900, 5351, 10001, 57621 } counter name "input_silenced" drop comment "input silenced LAN noise"

        # Catch-all: log+drop UDP and non-TCP/UDP protocols silently
        # to avoid ICMP amplification (every spoofed UDP probe would
        # otherwise echo an ICMP port-unreachable back to the spoofed
        # victim). TCP from a trusted iface (LAN / wg0) gets a RST so
        # admin tools fail fast; from WAN we silently drop so closed
        # ports don't confirm host existence to internet scanners.
        limit rate 5/minute burst 10 packets log prefix "[nftables] INPUT:DROP: "
        iifname @lan_admin_ifaces meta l4proto tcp reject with tcp reset
        counter name "input_catchall" drop comment "input catch-all drop"
    }

    ##################################################
    #                  FORWARD CHAIN                 #
    ##################################################
    # Interface naming: `wg0` is the literal iface name from the
    # wireguard role; podman bridges follow the `podmanN` pattern
    # (podman0 = default bridge, podman1+ = named bridges allocated
    # from podman_bridge_pool). nft's prefix-wildcard `iifname "podman*"`
    # collapses the per-bridge fan-out into one rule. The WAN iface
    # (eth0 on prod, enpXsY on test VMs) is templated via the
    # group_vars `default_interface` because it does vary per host.
    chain forward {
        type filter hook forward priority filter; policy drop;

        ct state established,related accept
        ct state invalid drop

        # Mirror of input ! --syn drop — see input rule for the
        # conntrack tcp_loose rationale. Counter for _verify.yml.
        tcp flags & (fin|syn|rst|ack) != syn counter name "forward_nonsyn" drop comment "forward non-syn drop"

        # Egress paths from internal interfaces. SNAT for the reply
        # path comes from POSTROUTING below for the default bridge,
        # and from netavark's per-bridge NETAVARK-* chains in `ip nat`
        # for every other named bridge — netavark masquerades any
        # saddr-in-its-own-subnet packet whose daddr is outside that
        # subnet, so we don't have to add SNAT rules per bridge here.
        # The egress oifname set is "anything that isn't another
        # podman bridge" — deliberately covers WAN, the home LAN
        # (containers reaching the UDM / other LAN hosts), host VLAN
        # sub-interfaces (the iot macvlan parent on lab), wireguard,
        # libvirt — without hardcoding host-specific iface names.
        # Cross-bridge container traffic still has to go through the
        # DNAT-reach rule below; direct podman → podman is still
        # dropped.
        iifname "wg0" oifname $WAN_IFACE accept comment "wg → WAN"
        iifname "podman*" oifname != "podman*" accept comment "podman → external (WAN/LAN/wireguard)"

        # Reach containers via netavark's DNAT. Three ingress paths,
        # all targeting any podman bridge:
        #   - WAN: external clients hitting a published container
        #   - wg0: wireguard peers hitting a published container
        #   - any podman bridge: a container querying a VIP/host-IP
        #     that PREROUTING DNATs back into a bridge (e.g. container
        #     → 10.123.1.224:53 → DNAT to pihole at 10.88.0.76, or
        #     nginx → 127.0.0.1:8123 → DNAT to homeassistant at
        #     10.89.0.21). Without these accepts, the multi-base-chain
        #     interaction with netavark drops them: netavark's chain
        #     accepts the egress, but our default-drop forward fires
        #     regardless (any chain's drop wins under nft hook
        #     semantics, even if another chain returned accept).
        # WAN/wg0 scoping still prevents reachability from any future
        # interface (guest VLAN, mgmt net) we haven't trusted.
        #
        # Known gap on the second rule: trusts any container to reach
        # any DNAT-marked tuple — including 0.0.0.0-published services
        # on the host's LAN IP and other bridges via their gateway IPs.
        # A compromised container (e.g. transmission running untrusted
        # BT peer code) could pivot to internal services this way.
        # Tightening would need an oifname allowlist of bridges that
        # should be cross-reachable, or a dport blacklist for sensitive
        # services; not implemented (home-environment trade).
        iifname @lan_admin_ifaces oifname "podman*" \
            ct status dnat accept comment "Reach containers (LAN + wireguard ingress)"
        iifname "podman*" oifname "podman*" ct status dnat \
            accept comment "container → VIP → container (cross- or same-bridge DNAT)"

        # Catch-all log+drop. Counter for _verify.yml.
        limit rate 5/minute burst 10 packets log prefix "[nftables] FORWARD:REJECT: "
        counter name "forward_catchall" drop comment "forward catch-all"
    }

    ##################################################
    #                POSTROUTING / NAT               #
    ##################################################
    # Source-scoped so we never silently NAT traffic from a future
    # interface (guest VLAN, mgmt net, an extra macvlan) we hadn't
    # considered. Two real customers: containers on podman0 and
    # wireguard clients reaching the internet through us.
    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
        ip saddr $PODMAN_DEFAULT oifname $WAN_IFACE masquerade comment "NAT container egress"
        ip saddr $WG_SUBNET oifname $WAN_IFACE masquerade comment "NAT wireguard-client egress"
    }
}
