#jinja2: lstrip_blocks: True
# redis.service #######################################################################
[Unit]
Description=redis
After=network-online.target
Wants=network-online.target
StartLimitInterval=600
StartLimitBurst=3
{% if zfs_root %}
{% if zfs_has_services_mount %}
After=zfs_mount_mnt_services.service
Requires=zfs_mount_mnt_services.service
{% endif %}
After=zfs_autosnapshot.target
PartOf=zfs_autosnapshot.target
{% endif %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutSec=120
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --name redis \
    --init \
    --security-opt=no-new-privileges \
    --log-driver journald \
    --log-opt tag="redis" \
    --volume /mnt/services/redis:/data \
    --secret=redis_password,type=mount,target=redis_password \
    --user {{ redis_user.uid }}:{{ redis_user.group }} \
    --network redis \
    --publish 127.0.0.1:{{ service_ports.redis }}:6379/tcp \
    --health-cmd '["sh","-c","redis-cli -a $$(cat /run/secrets/redis_password) --no-auth-warning ping | grep PONG"]' \
    --health-startup-cmd '["sh","-c","redis-cli -a $$(cat /run/secrets/redis_password) --no-auth-warning ping | grep PONG"]' \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "100s" \
    --stop-timeout 120 \
    docker.io/redis:7.4 \
    sh -c 'exec redis-server --save 60 1 --loglevel warning --requirepass $$(cat /run/secrets/redis_password)'
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
{% if zfs_root %}
WantedBy=zfs_autosnapshot.target
{% endif %}
