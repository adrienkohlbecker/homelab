#jinja2: lstrip_blocks: True
# Rendered to /mnt/services/redis/redis.conf; the container reads it at
# /data/redis.conf via the existing /mnt/services/redis:/data bind mount.
# requirepass is deliberately NOT here -- it stays in the podman secret and is
# passed on the redis-server command line so the password never lands on disk.

# Snapshot to /data/dump.rdb after 60s if >=1 key changed. RDB-only (no AOF):
# a clean SIGTERM -- the nightly zfs_autosnapshot stop/start, and any
# `systemctl restart` -- triggers a final save so keys survive; an *unclean*
# crash loses up to 60s of writes, accepted for a transient Celery broker.
dir /data
save 60 1

loglevel warning

# Bound redis's dataset so an undrained broker can't grow until it OOMs the
# host. noeviction (not an LRU policy) makes redis return errors to the
# producer rather than silently dropping queued Celery tasks.
maxmemory 450mb
maxmemory-policy noeviction

# maxmemory bounds the dataset but NOT per-client connection buffers, which are
# accounted separately. Cap them too so a slow or stuck Celery consumer can't
# grow its output buffer past the container and OOM the host -- the same
# failure mode maxmemory above defends against.
maxmemory-clients 10%

# Disable the admin command surface a consumer never needs. With one shared
# password an otherwise-compromised consumer could `CONFIG SET dir` + `SAVE` to
# write an arbitrary RDB anywhere redis can (a file-write RCE), load a module,
# `REPLICAOF` an attacker host to wipe-and-replace the broker, or burn CPU with
# a Lua `EVAL` script. paperless's Celery transport (kombu) needs only ordinary
# list/pubsub data commands. An empty replacement name disables the command;
# ACLs are the modern alternative but overkill for a single shared-password
# broker.
rename-command CONFIG ""
rename-command DEBUG ""
rename-command MODULE ""
rename-command REPLICAOF ""
rename-command SLAVEOF ""
rename-command EVAL ""
rename-command EVALSHA ""
rename-command FUNCTION ""
rename-command SCRIPT ""
