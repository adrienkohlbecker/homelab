[retriever]
type = SimpleIMAPSSLRetriever
server = imap.gmail.com
username = {{ root_email }}
password = {{ gmail_app_password }}
record_mailbox = false
# Folder name is locale-dependent — Gmail localises it to UI language
# (e.g. "[Gmail]/Tous les messages" for fr-locale). If a fetch returns
# zero messages silently, check the Gmail UI language setting.
mailboxes = ("[Gmail]/All Mail",)

[destination]
type = Maildir
path = /mnt/services/getmail/

[options]
read_all = false
delivered_to = false
received = false
# Per-message audit trail (size, mailbox, msgid, sender, recipient, delivery
# path). Lives next to the maildir so it doesn't flow to journald and the
# centralized fluentbit → openobserve pipeline.
message_log = /mnt/services/getmail/messages.log
# Bound a wedged TCP socket — Gmail occasionally drops connections
# without FIN, and the unit's TimeoutStartSec is the only other backstop.
socket_timeout = 180
# Google has retained app passwords for 2FA accounts (only Less Secure
# App Access was killed, in 2022); no sunset announced. When that
# changes, swap the password line above for:
#   use_xoauth2 = true
#   password_command = ("/usr/bin/getmail-gmail-xoauth-tokens", "/mnt/services/getmail/oauth2.json")
# Bootstrap requires a Google Cloud OAuth2 client + one-time consent flow.
