[retriever]
type = SimpleIMAPSSLRetriever
server = imap.gmail.com
port = 993
username = {{ root_email }}
# Gmail's UI displays 16-char app passwords as 4 space-separated groups
# (`xxxx xxxx xxxx xxxx`) for readability — the actual auth string is
# the 16-char form without spaces. trim handles any trailing newline
# from vault round-tripping; replace handles a copy-pasted-from-UI
# password that kept its display spaces. Both are no-ops if the secret
# was already stored in canonical form.
password = {{ gmail_app_password | trim | replace(' ', '') }}
# Verify the server cert against the system CA bundle and require its
# subject CN/SAN to match imap.gmail.com. Without these, getmail6 will
# happily complete an IMAPS handshake against any cert the system
# trusts, so any MITM with a valid-for-anything cert (or no cert
# validation at all on older versions) would silently capture the app
# password. ssl_version is intentionally unset so Python's
# PROTOCOL_TLS_CLIENT negotiates the highest supported TLS (incl. 1.3).
ca_certs = /etc/ssl/certs/ca-certificates.crt
ssl_cert_hostname = imap.gmail.com
# Explicit: don't set the \Seen flag on Gmail's side when fetching.
# Matches the SimpleIMAPSSLRetriever default; pinning here defends
# against a future upstream default flip silently changing the Gmail
# UI's read/unread state for fetched mail.
use_peek = true
record_mailbox = false
# Folder name is locale-dependent — Gmail localises it to UI language
# (e.g. "[Gmail]/Tous les messages" for fr-locale). If a fetch returns
# zero messages silently, check the Gmail UI language setting.
mailboxes = ("[Gmail]/All Mail",)

[destination]
type = Maildir
path = /mnt/services/getmail/

[options]
read_all = false
delivered_to = false
received = false
# Per-message audit trail (size, mailbox, msgid, sender, recipient, delivery
# path). Lives next to the maildir so it doesn't flow to journald and the
# centralized fluentbit → openobserve pipeline.
message_log = /mnt/services/getmail/messages.log
# Bound a wedged TCP socket — Gmail occasionally drops connections
# without FIN, and the unit's TimeoutStartSec is the only other backstop.
socket_timeout = 180
# Google has retained app passwords for 2FA accounts (only Less Secure
# App Access was killed, in 2022); no sunset announced. When that
# changes, swap the password line above for:
#   use_xoauth2 = true
#   password_command = ("/usr/bin/getmail-gmail-xoauth-tokens", "/mnt/services/getmail/oauth2.json")
# Bootstrap requires a Google Cloud OAuth2 client + one-time consent flow.
