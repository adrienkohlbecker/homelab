#jinja2: lstrip_blocks: True
# lidarr.service #######################################################################
[Unit]
Description=lidarr
After=network-online.target
Wants=network-online.target
StartLimitInterval=600
StartLimitBurst=3
{% if zfs_root %}
{% if zfs_has_services_mount %}
After=zfs_mount_mnt_services.service
Requires=zfs_mount_mnt_services.service
After=zfs_mount_mnt_services_sqlite.service
Requires=zfs_mount_mnt_services_sqlite.service
{% endif %}
{% if zfs_has_scratch_mount %}
After=zfs_mount_mnt_scratch.service
Requires=zfs_mount_mnt_scratch.service
{% endif %}
{% if zfs_has_media_mount %}
After=zfs_mount_mnt_media.service
Requires=zfs_mount_mnt_media.service
{% endif %}
After=zfs_autosnapshot.target
PartOf=zfs_autosnapshot.target
{% endif %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutSec=120
# Exceed the container's --stop-timeout (120s) so a slow graceful shutdown --
# during which lidarr writes config.xml back -- finishes before systemd's stop
# deadline SIGKILLs it and skips the writeback.
TimeoutStopSec=180
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --name lidarr \
    --security-opt=no-new-privileges \
    --log-driver journald \
    --log-opt tag="lidarr" \
    --env PUID={{ lidarr_user.uid }} \
    --env PGID={{ media_group.gid }} \
    --env UMASK=002 \
    --env TZ={{ system_timezone }} \
    --volume /mnt/services/lidarr:/config \
    --volume /mnt/services/sqlite/lidarr:/mnt/services/sqlite/lidarr \
    --volume /mnt/media:/media \
    --volume /mnt/scratch/lidarr:/scratch/lidarr \
    --network media \
    --publish 127.0.0.1:{{ service_ports.lidarr }}:{{ service_ports.lidarr }}/tcp \
    --health-cmd         {{ ('http://localhost:' ~ service_ports.lidarr ~ '/ping') | podman_health_curl }} \
    --health-startup-cmd {{ ('http://localhost:' ~ service_ports.lidarr ~ '/ping') | podman_health_curl }} \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "100s" \
    --stop-timeout 120 \
    {{ lidarr_image }}
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
{% if zfs_root %}
WantedBy=zfs_autosnapshot.target
{% endif %}
