# Standard reverse-proxy forwarded headers. Included by `location /` in
# site.conf.j2 so there is one canonical set, and available to
# server_conf/location_conf snippets that declare their own location -- which
# inherits none of the site's proxy_set_headers, so an un-included location
# would silently forward Host / X-Forwarded-* wrong. Pull it in with
# `include snippets/proxy_params.conf;`. $connection_upgrade is the websocket
# upgrade map defined in nginx.conf.j2.
proxy_set_header Host              $host;
proxy_set_header Upgrade           $http_upgrade;
proxy_set_header Connection        $connection_upgrade;
proxy_set_header X-Real-IP         $remote_addr;
proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Proto $scheme;
proxy_set_header X-Forwarded-Host  $host;
proxy_set_header X-Forwarded-Port  $server_port;
