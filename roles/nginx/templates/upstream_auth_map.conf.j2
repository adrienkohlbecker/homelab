# Per-user upstream Authorization map for the {{ nginx_site_args.subdomain }} vhost,
# dropped by nginx_site when upstream_authorization is set. Keyed on $authelia_user,
# which auth_request_set captures from Authelia's Remote-User inside the vhost's
# `location /`. A map -- not a rewrite-phase `if ($authelia_user = ...) set` -- because
# if/set run in the rewrite phase, BEFORE auth_request (access phase) populates
# $authelia_user, so the comparison never matched and the injection silently no-oped.
# A map variable is instead evaluated lazily, when `proxy_set_header Authorization`
# reads it in the content phase (after auth), so it sees the authenticated user.
#
# It lives at http scope (conf.d) because `map` is not valid inside server{}; the
# helper validates it together with the vhost in a single `nginx -t` because the two
# cross-reference each other's variables ($authelia_user here <- the vhost's
# auth_request_set; $nginx_upstream_auth_<sub> in the vhost <- this map), so neither
# passes validation alone.
#
# default $http_authorization: a cookieless machine client bypasses Authelia in
# /internal/authelia (returns 204, no Remote-User), so $authelia_user is empty and the
# default forwards the client's own token untouched. A mapped Authelia browser user
# gets their assigned token (overriding any stale Authorization the SPA replayed); an
# unmapped authed user with no token gets an empty Authorization, so the upstream falls
# back to its native sign-in (break-glass).
map $authelia_user $nginx_upstream_auth_{{ nginx_site_args.subdomain | replace('-', '_') }} {
    default $http_authorization;
{% for user, header in nginx_site_args.upstream_authorization.items() %}
    "{{ user }}" "{{ header }}";
{% endfor %}
}
