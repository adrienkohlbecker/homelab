{# HTTP/2: nginx >= 1.25.1 takes the `http2 on;` directive (set in http{}
   below) and warns on the legacy `listen ... http2` parameter; jammy/1.18 and
   noble/1.24 only understand the listen parameter. Blacklist-gate both so a
   future release flips to the directive automatically. #}
{% set _http2_listen = ' http2' if ansible_distribution_release in ['jammy', 'noble'] else '' %}
user                 www-data;
pid                  /run/nginx.pid;
worker_processes     auto;
worker_rlimit_nofile 65535;

# Load modules
include              /etc/nginx/modules-enabled/*.conf;

events {
    multi_accept       on;
    worker_connections 65535;
}

http {
    charset                utf-8;
    sendfile               on;
    tcp_nopush             on;
    tcp_nodelay            on;
    server_tokens          off;
{% if ansible_distribution_release not in ['jammy', 'noble'] %}
    http2                  on;
{% endif %}
    log_not_found          off;
    types_hash_max_size    2048;
    types_hash_bucket_size 64;
    client_max_body_size   16M;

    # Default bucket size (64) overflows with our ~46 subdomains × 3 server_names each.
    server_names_hash_bucket_size 128;

    # MIME -- absolute path so the install-time `nginx -t -c %s` validate
    # resolves it against /etc/nginx, not the temp dir of the rendered copy
    # (a relative include resolves against the config file's own directory).
    include                /etc/nginx/mime.types;
    default_type           application/octet-stream;

    # gzip — set once here, inherited by every server/location below
    gzip                   on;
    gzip_vary              on;
    gzip_proxied           any;
    gzip_comp_level        6;
    # Default is 20 bytes, which gzips tiny JSON/204/error bodies where the
    # gzip framing overhead exceeds the payload; 1024 still covers HTML/CSS/JS.
    gzip_min_length        1024;
    # text/javascript is the modern JS content-type (RFC 9239); nginx's own
    # mime.types and most upstreams now label .js with it, so list it alongside
    # the legacy application/javascript or proxied JS ships uncompressed.
    gzip_types             text/plain text/css text/xml text/javascript application/json application/javascript application/wasm application/rss+xml application/atom+xml application/manifest+json image/svg+xml;

    # Logging. $request includes the full request line ("GET /path?q=1
    # HTTP/1.1"), which would leak a credential a site takes as a URL param.
    # Redact such params from the request line before logging so they don't
    # land on disk. `apikey` covers SABnzbd's admin key (it takes the key only
    # as a query param). If another site picks a query-param secret, extend
    # this map.
    #
    # The token class is [^& ] (space included): this matches against $request
    # -- the full request line, which ends in " HTTP/1.1" -- so the trailing
    # space must terminate the token too.
    map $request $request_safe {
        "~*^(.*?[?&])apikey=[^& ]*(.*)$"  "$1apikey=REDACTED$2";
        default                            $request;
    }

    # Forward-auth unauthenticated-response mode. When the Authelia auth_request
    # subrequest 401s, the per-vhost @authelia_unauth handler (site.conf.j2)
    # redirects to the portal only for top-level navigations and returns a bare
    # 401 otherwise. A 302 to Authelia's cross-origin HTML portal cannot be
    # followed by an XHR/fetch: an SPA polling an authed endpoint without a valid
    # session (e.g. InfluxDB's UI after a rejected token) would otherwise spin in
    # a tight app<->auth.<domain> redirect loop instead of rendering its own
    # error. Sec-Fetch-Mode: navigate marks a real navigation; cors/same-origin/
    # no-cors mark a fetch. An empty value (pre-Sec-Fetch browser or a non-browser
    # client) keeps the legacy redirect so a plain GET still reaches the portal.
    map $http_sec_fetch_mode $authelia_unauth_redirect {
        navigate 1;
        ""       1;
        default  0;
    }

    # $authelia_user / $authelia_groups carry the Authelia identity into the
    # `custom` access log below. Each is populated per-request by an
    # `auth_request_set` in the auth: required vhosts' `location /`
    # (site.conf.j2); these http-scope maps give the names an always-declared
    # empty default. Without a declaration, a host with no auth vhost rendered
    # -- the nginx role's own converge (nginx_static_proxies defaults to []) or
    # install.yml's `nginx -t -c %s` on a fresh host before any site exists --
    # fails config-test with `unknown "authelia_user" variable`. Both `map` and
    # `auth_request_set` register the name CHANGEABLE, so the per-vhost
    # auth_request_set value overrides this default when auth runs; a request
    # that never reaches an auth_request'd location logs the empty default.
    map $host $authelia_user   { default ""; }
    map $host $authelia_groups { default ""; }

    # The Authelia identity sits just before the TLS fields so SSO failures are
    # legible in the access log: "$authelia_user" / "$authelia_groups" are the
    # forward-auth identity (captured per-vhost by auth_request_set, defaulted by
    # the maps above). The identity fields are location-scoped: on a request that
    # didn't run auth_request (a bypassed path, or a vhost with no auth) they log
    # the empty default -- itself a useful signal.
    # $ssl_protocol/$ssl_cipher trail the line so netdata's web_log collector
    # can chart the TLS-version/cipher distribution per vhost; on a plaintext
    # :80 request they are unset and nginx logs each as `-`, keeping the field
    # count stable so the positional CSV parse in files/web_log.conf still lines up.
    # Any change to this field list must move in lockstep with all three
    # downstream consumers: roles/nginx/files/web_log.conf (netdata's positional
    # CSV collector), roles/fluentbit/files/parsers_nginx.conf (the Fluent Bit
    # ingest regex) and roles/lnav/files/formats/fluentbit_lnav.json (lnav's
    # field map + its embedded sample line).
    log_format custom      '$remote_addr - $remote_user [$time_local] $host "$request_safe" $server_name $status $body_bytes_sent $request_length $request_time $upstream_response_time "$http_referer" "$http_user_agent" "$authelia_user" "$authelia_groups" $ssl_protocol $ssl_cipher';
    access_log             /var/log/nginx/access.log custom buffer=512k flush=5s;
    error_log              stderr warn;

    # SSL
    ssl_session_timeout    1d;
    ssl_session_cache      shared:SSL:10m;
    ssl_session_tickets    off;
    # These vhosts serve small interactive admin UIs, not bulk media: a 4k TLS
    # record ships the first byte sooner (better TTFB) than the 16k default,
    # which trades latency for throughput on large responses.
    ssl_buffer_size        4k;

    # generated 2026-05-29, TLSRef Guideline v6.0, nginx 1.18.0 (UNSUPPORTED; end-of-life), OpenSSL 3.0.2 (OLD: missing PQC hybrid MLKEMs), intermediate config, HSTS
    # https://configurator.tlsref.org/#server=nginx&version=1.18.0&config=intermediate&openssl=3.0.2&hsts&guideline=6.0
    ssl_protocols          TLSv1.2 TLSv1.3;
    ssl_ecdh_curve         X25519:prime256v1:secp384r1;
    ssl_ciphers            ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;
{% if ansible_distribution_release not in ['jammy'] %}
    # Honour the client's ChaCha20 preference (phones/tablets without AES-NI
    # are faster on ChaCha20). Also the only lever over the TLSv1.3 suite set,
    # which ssl_ciphers does not control. Needs nginx >= 1.19.4 (not jammy/1.18);
    # blacklist-gated so future releases pick it up automatically.
    ssl_conf_command       Options PrioritizeChaCha;
{% endif %}

    # OCSP stapling disabled: Let's Encrypt shut down its OCSP responder in 2025
    # (in favor of CRLs), so issued certs no longer carry an OCSP URL and nginx
    # warns "ssl_stapling ignored". CRL handling is client-side.

    # SSL
    ssl_certificate         /etc/letsencrypt/live/{{ inventory_hostname }}.{{ domain }}/fullchain.pem;
    ssl_certificate_key     /etc/letsencrypt/live/{{ inventory_hostname }}.{{ domain }}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/{{ inventory_hostname }}.{{ domain }}/chain.pem;

    # Connection header for WebSocket reverse proxy
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ""      close;
    }

    # on/off form of $scheme for the legacy X-Forwarded-Ssl header (some apps
    # build self-referential URLs from it rather than X-Forwarded-Proto). Keyed
    # on $scheme so it stays correct on the cleartext :80 leg of enable_http
    # sites, where it must report off.
    map $scheme $proxy_x_forwarded_ssl {
        default off;
        https   on;
    }

    # Default servers for missing Host header, or header not matching configured site
    server {
        listen              80 default_server;
{% if nginx_ipv6 %}
        listen              [::]:80 default_server;
{% endif %}
        server_name         _;
        return              404;
    }
    server {
        listen              443 default_server ssl{{ _http2_listen }};
{% if nginx_ipv6 %}
        listen              [::]:443 default_server ssl{{ _http2_listen }};
{% endif %}
{% if ansible_distribution_release not in ['jammy'] %}
        # Reject the TLS handshake for absent/unmatched SNI rather than
        # completing it with the host cert and returning 404 — keeps the
        # real cert off scanners hitting the IP with a bogus SNI. Needs
        # nginx >= 1.19.4 (not on jammy/1.18); blacklist-gated so future
        # releases pick it up automatically.
        ssl_reject_handshake on;
{% else %}
        server_name         _;
        return              404;
{% endif %}
    }

    # Load configs
    include /etc/nginx/conf.d/*.conf;
    include /etc/nginx/sites-enabled/*;
}
