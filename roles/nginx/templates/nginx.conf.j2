# Generated by nginxconfig.io
# https://www.digitalocean.com/community/tools/nginx?domains.0.php.php=false&domains.0.reverseProxy.reverseProxy=true&domains.0.routing.root=false

user                 www-data;
pid                  /run/nginx.pid;
worker_processes     auto;
worker_rlimit_nofile 65535;

# Load modules
include              /etc/nginx/modules-enabled/*.conf;

events {
    multi_accept       on;
    worker_connections 65535;
}

http {
    charset                utf-8;
    sendfile               on;
    tcp_nopush             on;
    tcp_nodelay            on;
    server_tokens          off;
    log_not_found          off;
    types_hash_max_size    2048;
    types_hash_bucket_size 64;
    client_max_body_size   16M;

    # Default bucket size (64) overflows with our ~46 subdomains Ă— 3 server_names each.
    server_names_hash_bucket_size 128;

    # MIME
    include                mime.types;
    default_type           application/octet-stream;

    # Logging. $request includes the full request line ("GET /path?q=1
    # HTTP/1.1"), which would leak any URL-param secret a site uses (see
    # nginx_site_args.bypass_query_param in roles/nginx/tasks/site.yml).
    # Redact `auth_token=...` from the request line before logging so
    # the token doesn't land on disk. Generic enough to cover any future
    # site using the same param name. If another site picks a different
    # param name, extend this map.
    map $request $request_safe {
        "~*^(.*?[?&])auth_token=[^& ]*(.*)$"  "$1auth_token=REDACTED$2";
        default                                $request;
    }

    # Distinguish machine clients from Authelia-authed browsers for the
    # bypass-on-Authorization shortcut in /internal/authelia (sites with
    # `upstream_authorization` set). Machine clients (Telegraf, HA,
    # Grafana) hit the vhost with `Authorization: Token <t>` and no
    # Authelia cookie -- we want them to skip the auth_request round-
    # trip and forward their token straight through. Browsers that hold
    # an Authelia session cookie must NEVER bypass, because some SPAs
    # (InfluxDB v2 is one) inject a stale `Authorization` header from
    # localStorage onto every XHR, which would otherwise trigger the
    # bypass too -- the browser's auth_request never runs, the if-set
    # chain doesn't match (no $authelia_user), and the stale token
    # gets forwarded to the upstream and rejected (401).
    #
    # Match: empty session cookie AND non-empty Authorization. We can't
    # express the conjunction with nginx's `if` directive, so the
    # decision lives in this http-scope map and the location-scope `if`
    # just tests the resulting 0/1.
    map "$cookie_authelia_session:$http_authorization" $authelia_bypass {
        default       0;
        "~^:.+"       1;
    }

    # Extract the `auth_token` query param value from the parent request
    # URI for use by /internal/authelia bypass logic. Inside an
    # auth_request subrequest $args/$arg_X refer to the subrequest's
    # own URI (which is just "/internal/authelia", carrying no query),
    # NOT the parent's â€” so $arg_auth_token is always empty there.
    # $request_uri, by contrast, preserves the parent's full URI
    # including query string across the subrequest, so we parse it
    # from there. Param name is locked to `auth_token` (matches
    # $request_safe redaction); the bypass_query_param.name field
    # in nginx_site_args is documentary today, change both maps in
    # lockstep if you ever need a different name.
    map $request_uri $req_auth_token {
        "~[?&]auth_token=([^&]+)"  $1;
        default                     "";
    }
    log_format custom      '$remote_addr - $remote_user [$time_local] $host "$request_safe" $server_name $status $body_bytes_sent $request_length $request_time $upstream_response_time "$http_referer" "$http_user_agent"';
    access_log             /var/log/nginx/access.log custom buffer=512k flush=5s;
    error_log              stderr warn;

    # SSL
    ssl_session_timeout    1d;
    ssl_session_cache      shared:SSL:10m;
    ssl_session_tickets    off;

    # Diffie-Hellman parameter for DHE ciphersuites
    ssl_dhparam            /etc/nginx/dhparam.pem;

    # Mozilla Intermediate configuration
    ssl_protocols          TLSv1.2 TLSv1.3;
    ssl_ciphers            ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;

    # OCSP stapling disabled: Let's Encrypt shut down its OCSP responder in 2025
    # (in favor of CRLs), so issued certs no longer carry an OCSP URL and nginx
    # warns "ssl_stapling ignored". CRL handling is client-side.

    # SSL
    ssl_certificate         /etc/letsencrypt/live/{{ inventory_hostname }}.{{ domain }}/fullchain.pem;
    ssl_certificate_key     /etc/letsencrypt/live/{{ inventory_hostname }}.{{ domain }}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/{{ inventory_hostname }}.{{ domain }}/chain.pem;

    # Connection header for WebSocket reverse proxy
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ""      close;
    }

    map $remote_addr $proxy_forwarded_elem {

        # IPv4 addresses can be sent as-is
        ~^[0-9.]+$        "for=$remote_addr";

        # IPv6 addresses need to be bracketed and quoted
        ~^[0-9A-Fa-f:.]+$ "for=\"[$remote_addr]\"";

        # Unix domain socket names cannot be represented in RFC 7239 syntax
        default           "for=unknown";
    }

    map $http_forwarded $proxy_add_forwarded {

        # If the incoming Forwarded header is syntactically valid, append to it
        "~^(,[ \\t]*)*([!#$%&'*+.^_`|~0-9A-Za-z-]+=([!#$%&'*+.^_`|~0-9A-Za-z-]+|\"([\\t \\x21\\x23-\\x5B\\x5D-\\x7E\\x80-\\xFF]|\\\\[\\t \\x21-\\x7E\\x80-\\xFF])*\"))?(;([!#$%&'*+.^_`|~0-9A-Za-z-]+=([!#$%&'*+.^_`|~0-9A-Za-z-]+|\"([\\t \\x21\\x23-\\x5B\\x5D-\\x7E\\x80-\\xFF]|\\\\[\\t \\x21-\\x7E\\x80-\\xFF])*\"))?)*([ \\t]*,([ \\t]*([!#$%&'*+.^_`|~0-9A-Za-z-]+=([!#$%&'*+.^_`|~0-9A-Za-z-]+|\"([\\t \\x21\\x23-\\x5B\\x5D-\\x7E\\x80-\\xFF]|\\\\[\\t \\x21-\\x7E\\x80-\\xFF])*\"))?(;([!#$%&'*+.^_`|~0-9A-Za-z-]+=([!#$%&'*+.^_`|~0-9A-Za-z-]+|\"([\\t \\x21\\x23-\\x5B\\x5D-\\x7E\\x80-\\xFF]|\\\\[\\t \\x21-\\x7E\\x80-\\xFF])*\"))?)*)?)*$" "$http_forwarded, $proxy_forwarded_elem";

        # Otherwise, replace it
        default "$proxy_forwarded_elem";
    }

    # Default servers for missing Host header, or header not matching configured site
    server {
        listen              80 default_server;
{% if nginx_ipv6 | default(false) %}
        listen              [::]:80 default_server;
{% endif %}
        server_name         _;
        return              404;
    }
    server {
        listen              443 default_server ssl http2;
{% if nginx_ipv6 | default(false) %}
        listen              [::]:443 default_server ssl http2;
{% endif %}
        server_name         _;
        return              404;
    }

    # Load configs
    include /etc/nginx/conf.d/*.conf;
    include /etc/nginx/sites-enabled/*;
}
