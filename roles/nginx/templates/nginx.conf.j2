# Generated by nginxconfig.io
# https://www.digitalocean.com/community/tools/nginx?domains.0.php.php=false&domains.0.reverseProxy.reverseProxy=true&domains.0.routing.root=false

{# HTTP/2: nginx >= 1.25.1 takes the `http2 on;` directive (set in http{}
   below) and warns on the legacy `listen ... http2` parameter; jammy/1.18 and
   noble/1.24 only understand the listen parameter. Blacklist-gate both so a
   future release flips to the directive automatically. #}
{% set _http2_listen = ' http2' if ansible_distribution_release in ['jammy', 'noble'] else '' %}
user                 www-data;
pid                  /run/nginx.pid;
worker_processes     auto;
worker_rlimit_nofile 65535;

# Load modules
include              /etc/nginx/modules-enabled/*.conf;

events {
    multi_accept       on;
    worker_connections 65535;
}

http {
    charset                utf-8;
    sendfile               on;
    tcp_nopush             on;
    tcp_nodelay            on;
    server_tokens          off;
{% if ansible_distribution_release not in ['jammy', 'noble'] %}
    http2                  on;
{% endif %}
    log_not_found          off;
    types_hash_max_size    2048;
    types_hash_bucket_size 64;
    client_max_body_size   16M;

    # Default bucket size (64) overflows with our ~46 subdomains × 3 server_names each.
    server_names_hash_bucket_size 128;

    # MIME -- absolute path so the install-time `nginx -t -c %s` validate
    # resolves it against /etc/nginx, not the temp dir of the rendered copy
    # (a relative include resolves against the config file's own directory).
    include                /etc/nginx/mime.types;
    default_type           application/octet-stream;

    # gzip — set once here, inherited by every server/location below
    gzip                   on;
    gzip_vary              on;
    gzip_proxied           any;
    gzip_comp_level        6;
    # Default is 20 bytes, which gzips tiny JSON/204/error bodies where the
    # gzip framing overhead exceeds the payload; 1024 still covers HTML/CSS/JS.
    gzip_min_length        1024;
    gzip_types             text/plain text/css text/xml application/json application/javascript application/rss+xml application/atom+xml image/svg+xml;

    # Logging. $request includes the full request line ("GET /path?q=1
    # HTTP/1.1"), which would leak any URL-param secret a site uses (see
    # nginx_site_args.bypass_query_param in roles/nginx/tasks/site.yml).
    # Redact `auth_token=...` from the request line before logging so
    # the token doesn't land on disk. Generic enough to cover any future
    # site using the same param name. If another site picks a different
    # param name, extend this map.
    map $request $request_safe {
        "~*^(.*?[?&])auth_token=[^& ]*(.*)$"  "$1auth_token=REDACTED$2";
        default                                $request;
    }

    # Distinguish machine clients from Authelia-authed browsers for the
    # bypass-on-Authorization shortcut in /internal/authelia (sites with
    # `upstream_authorization` set). Machine clients (Telegraf, HA,
    # Grafana) hit the vhost with `Authorization: Token <t>` and no
    # Authelia cookie -- we want them to skip the auth_request round-
    # trip and forward their token straight through. Browsers that hold
    # an Authelia session cookie must NEVER bypass, because some SPAs
    # (InfluxDB v2 is one) inject a stale `Authorization` header from
    # localStorage onto every XHR, which would otherwise trigger the
    # bypass too -- the browser's auth_request never runs, the if-set
    # chain doesn't match (no $authelia_user), and the stale token
    # gets forwarded to the upstream and rejected (401).
    #
    # Match: empty session cookie AND non-empty Authorization. We can't
    # express the conjunction with nginx's `if` directive, so the
    # decision lives in this http-scope map and the location-scope `if`
    # just tests the resulting 0/1.
    #
    # SECURITY: a 1 here admits the request without consulting Authelia, so
    # for cookieless clients the UPSTREAM becomes the sole authenticator --
    # any non-empty Authorization value is accepted at this layer. Only pair
    # `upstream_authorization` with an upstream that validates the credential
    # itself (InfluxDB does). The empty-cookie requirement is what stops a
    # logged-in browser's stale localStorage token from bypassing.
    map "$cookie_authelia_session:$http_authorization" $authelia_bypass {
        # volatile: recompute per request/subrequest context rather than caching
        # the first evaluation -- this gates an auth bypass and is read inside
        # the /internal/authelia subrequest, whose header context differs.
        volatile;
        default       0;
        "~^:.+"       1;
    }

    # Extract the `auth_token` query param value from the parent request
    # URI for use by /internal/authelia bypass logic. Inside an
    # auth_request subrequest $args/$arg_X refer to the subrequest's
    # own URI (which is just "/internal/authelia", carrying no query),
    # NOT the parent's — so $arg_auth_token is always empty there.
    # $request_uri, by contrast, preserves the parent's full URI
    # including query string across the subrequest, so we parse it
    # from there. Param name is locked to `auth_token` (matches the
    # $request_safe redaction here and the $args strip in site.conf.j2);
    # change all three in lockstep if you ever need a different name.
    map $request_uri $req_auth_token {
        # volatile: same reasoning as $authelia_bypass -- the bypass `if` reads
        # this inside the auth subrequest, so don't serve a cached value.
        volatile;
        "~[?&]auth_token=([^&]+)"  $1;
        default                     "";
    }
    # $ssl_protocol/$ssl_cipher trail the line so netdata's web_log collector
    # can chart the TLS-version/cipher distribution per vhost; on a plaintext
    # :80 request they are unset and nginx logs each as `-`, keeping the field
    # count stable so the positional CSV parse in files/web_log.conf still lines up.
    log_format custom      '$remote_addr - $remote_user [$time_local] $host "$request_safe" $server_name $status $body_bytes_sent $request_length $request_time $upstream_response_time "$http_referer" "$http_user_agent" $ssl_protocol $ssl_cipher';
    access_log             /var/log/nginx/access.log custom buffer=512k flush=5s;
    error_log              stderr warn;

    # SSL
    ssl_session_timeout    1d;
    ssl_session_cache      shared:SSL:10m;
    ssl_session_tickets    off;
    # These vhosts serve small interactive admin UIs, not bulk media: a 4k TLS
    # record ships the first byte sooner (better TTFB) than the 16k default,
    # which trades latency for throughput on large responses.
    ssl_buffer_size        4k;

    # Diffie-Hellman parameter for DHE ciphersuites
    ssl_dhparam            /etc/nginx/dhparam.pem;

    # Mozilla Intermediate configuration
    ssl_protocols          TLSv1.2 TLSv1.3;
    ssl_ciphers            ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384:DHE-RSA-CHACHA20-POLY1305;
{% if ansible_distribution_release not in ['jammy'] %}
    # Honour the client's ChaCha20 preference (phones/tablets without AES-NI
    # are faster on ChaCha20). Also the only lever over the TLSv1.3 suite set,
    # which ssl_ciphers does not control. Needs nginx >= 1.19.4 (not jammy/1.18);
    # blacklist-gated so future releases pick it up automatically.
    ssl_conf_command       Options PrioritizeChaCha;
{% endif %}

    # OCSP stapling disabled: Let's Encrypt shut down its OCSP responder in 2025
    # (in favor of CRLs), so issued certs no longer carry an OCSP URL and nginx
    # warns "ssl_stapling ignored". CRL handling is client-side.

    # SSL
    ssl_certificate         /etc/letsencrypt/live/{{ inventory_hostname }}.{{ domain }}/fullchain.pem;
    ssl_certificate_key     /etc/letsencrypt/live/{{ inventory_hostname }}.{{ domain }}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/{{ inventory_hostname }}.{{ domain }}/chain.pem;

    # Connection header for WebSocket reverse proxy
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ""      close;
    }

    # Default servers for missing Host header, or header not matching configured site
    server {
        listen              80 default_server;
{% if nginx_ipv6 | default(false) %}
        listen              [::]:80 default_server;
{% endif %}
        server_name         _;
        return              404;
    }
    server {
        listen              443 default_server ssl{{ _http2_listen }};
{% if nginx_ipv6 | default(false) %}
        listen              [::]:443 default_server ssl{{ _http2_listen }};
{% endif %}
{% if ansible_distribution_release not in ['jammy'] %}
        # Reject the TLS handshake for absent/unmatched SNI rather than
        # completing it with the host cert and returning 404 — keeps the
        # real cert off scanners hitting the IP with a bogus SNI. Needs
        # nginx >= 1.19.4 (not on jammy/1.18); blacklist-gated so future
        # releases pick it up automatically.
        ssl_reject_handshake on;
{% else %}
        server_name         _;
        return              404;
{% endif %}
    }

    # Load configs
    include /etc/nginx/conf.d/*.conf;
    include /etc/nginx/sites-enabled/*;
}
