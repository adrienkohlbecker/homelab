server {
  listen              443 ssl http2;
{% if nginx_ipv6 | default(false) %}
  listen              [::]:443 ssl http2;
{% endif %}
{% if nginx_site_args.enable_http | default(false) %}
  listen              80;
{% if nginx_ipv6 | default(false) %}
  listen              [::]:80;
{% endif %}
{% endif %}

  server_name         {{ nginx_site_args.subdomain }} {{ nginx_site_args.subdomain }}.{{ inventory_hostname }}.{{ domain }} {{ nginx_site_args.subdomain }}.{{ domain}};

  # security headers
  add_header X-XSS-Protection          "1; mode=block" always;
  add_header X-Content-Type-Options    "nosniff" always;
  add_header Referrer-Policy           "same-origin" always;
{% if not (nginx_site_args.csp_passthrough | default(false)) %}
  add_header Content-Security-Policy   "{% if nginx_site_args.csp_additional is defined %}{{ nginx_site_args.csp_additional }}; {% endif %}default-src {% if nginx_site_args.csp_default_src is defined %}{{ nginx_site_args.csp_default_src }} {% endif %}{{ nginx_csp_default }}; frame-ancestors {% if nginx_site_args.csp_frame_ancestors is defined %}{{ nginx_site_args.csp_frame_ancestors }}{% else %}'self'{% endif %}; report-uri https://csplogger.{{ inventory_hostname }}.{{ domain }}/log; report-to csp-endpoint;" always;
{% endif %}
  add_header Permissions-Policy        "interest-cohort=()" always;
  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
  add_header Reporting-Endpoints       'csp-endpoint="https://csplogger.{{ inventory_hostname }}.{{ domain }}/log"' always;

  # favicon.ico
  location = /favicon.ico {
      log_not_found off;
  }

  # robots.txt
  location = /robots.txt {
      log_not_found off;
  }

  # gzip
  gzip            on;
  gzip_vary       on;
  gzip_proxied    any;
  gzip_comp_level 6;
  gzip_types      text/plain text/css text/xml application/json application/javascript application/rss+xml application/atom+xml image/svg+xml;

{% set _auth_enabled = nginx_site_args.auth | default('none') == 'required' %}
{% if _auth_enabled %}
  # Authelia forward-auth: every browser hit to this site is subrequested
  # against Authelia's /api/authz/auth-request endpoint. 200 -> allow; 401
  # -> error_page 401 below redirects to the portal with returnUrl. The
  # /internal/authelia location is marked `internal` so external requests
  # can't bypass the auth by hitting it directly. Authelia upstream URL
  # is host-parameterized so non-lab hosts (pug, bunk) can point at lab's
  # Authelia over wireguard when they need forward-auth.
  location /internal/authelia {
    internal;
{% if nginx_site_args.upstream_authorization is defined %}
    # Machine clients (no Authelia session cookie, presenting their own
    # Authorization header) skip the Authelia round-trip: return 204
    # straight away, so auth_request admits the parent. The `location /`
    # block then leaves the client's header untouched (the
    # `proxy_set_header Authorization` below initialises from
    # $http_authorization so the original token passes through). The
    # match is computed in the $authelia_bypass map in nginx.conf.j2
    # because nginx's `if` can't compose two conditions. Implies trust
    # in any presented Authorization header from a cookieless client
    # -- only safe when the upstream itself rejects bad tokens
    # (InfluxDB does).
    if ($authelia_bypass) {
      return 204;
    }
{% endif %}
{% if nginx_site_args.bypass_query_param is defined %}
    # URL-param bypass for clients that can't send Authorization headers
    # (compta's Mac app, homepage_alerts cross-host poller). Compare the
    # extracted token (from the parent's $request_uri via the $req_auth_token
    # map in nginx.conf.j2) against the vaulted value; on match return 204
    # (a 2xx -> auth_request lets the parent through) without consulting
    # Authelia. Why not `if ($arg_auth_token = ...)`: $arg_X inside an
    # auth_request subrequest refers to the subrequest's own (empty) query,
    # not the parent's -- so that comparison never matches. The token
    # itself is redacted from the access log via $request_safe.
    if ($req_auth_token = "{{ nginx_site_args.bypass_query_param.value }}") {
      return 204;
    }
{% endif %}
    proxy_pass {{ authelia_internal_url }};
    # Bound the auth subrequest so a transient gap on the path to Authelia
    # (notably fox reaching lab's Authelia over wg0) fails fast instead of
    # stalling on nginx's 60s default -- a sub-second blip otherwise becomes a
    # 60s hang and then a 500. Authelia normally answers in ~100ms, so a few
    # seconds is ample headroom.
    proxy_connect_timeout 3s;
    proxy_send_timeout    5s;
    proxy_read_timeout    5s;
    proxy_pass_request_body off;
    proxy_set_header Content-Length          "";
    proxy_set_header X-Original-Method       $request_method;
    proxy_set_header X-Original-URL          $scheme://$http_host$request_uri;
    proxy_set_header X-Forwarded-For         $remote_addr;
    proxy_set_header X-Forwarded-Method      $request_method;
    proxy_set_header X-Forwarded-Proto       $scheme;
    proxy_set_header X-Forwarded-Host        $http_host;
    proxy_set_header X-Forwarded-Uri         $request_uri;
  }

  # Authelia returns 401 with a redirect target in the body; nginx's
  # auth_request maps that to a plain 401 to the client. error_page
  # rewrites the 401 into a 302 to the portal with returnUrl + method
  # preserved, so users land on the login page and bounce back here
  # after a successful auth.
  error_page 401 =302 https://auth.{{ authelia_cookie_domain }}/?rd=$scheme://$http_host$request_uri&rm=$request_method;

{% endif %}
  location / {
{% if _auth_enabled %}
    auth_request /internal/authelia;
    # Capture Authelia's Remote-* response headers from the auth_request
    # subrequest as nginx variables, then forward them to the upstream
    # below. Upstreams that trust the proxy (e.g. *arr v4 with
    # AuthenticationMethod=External) read X-Forwarded-User and skip their
    # own local login. Authelia sends Remote-User on every authenticated
    # 200; the bypass_query_param shortcut returns 204 with no Remote-*,
    # so $authelia_user is empty there — incompatible with upstreams
    # that require X-Forwarded-User. Don't combine the two on the same
    # site.
    auth_request_set $authelia_user   $upstream_http_remote_user;
    auth_request_set $authelia_groups $upstream_http_remote_groups;
    auth_request_set $authelia_name   $upstream_http_remote_name;
    auth_request_set $authelia_email  $upstream_http_remote_email;
{% endif %}
{% if nginx_site_args.bypass_query_param is defined %}
    # Strip the bypass token from $args before proxy_pass so the
    # upstream app never sees it (token must not land in compta's own
    # logs or echo back in error messages). nginx's proxy_pass forwards
    # $is_args$args when the upstream URL has no own query string, so
    # rewriting $args here removes the param from the forwarded URL.
    # Two rewrites cover (1) param-first and (2) param-not-first:
    if ($args ~ "^{{ nginx_site_args.bypass_query_param.name }}=[^&]*&?(.*)$") {
      set $args $1;
    }
    if ($args ~ "^(.*)&{{ nginx_site_args.bypass_query_param.name }}=[^&]*(.*)$") {
      set $args "$1$2";
    }
{% endif %}
{% if nginx_site_args.proxy_pass is defined %}
    proxy_pass         {{ nginx_site_args.proxy_pass }};

    proxy_http_version 1.1;
    proxy_cache_bypass $http_upgrade;

    # Proxy SSL
    proxy_ssl_server_name on;

    # Proxy headers
    proxy_set_header Host              $host;
    proxy_set_header Upgrade           $http_upgrade;
    proxy_set_header Connection        $connection_upgrade;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header Forwarded         $proxy_add_forwarded;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host  $host;
    proxy_set_header X-Forwarded-Port  $server_port;
{% if _auth_enabled %}
    proxy_set_header X-Forwarded-User   $authelia_user;
    proxy_set_header X-Forwarded-Groups $authelia_groups;
    proxy_set_header X-Forwarded-Name   $authelia_name;
    proxy_set_header X-Forwarded-Email  $authelia_email;
{% endif %}
{% if nginx_site_args.upstream_authorization is defined %}
    # Per-user upstream Authorization injection. The caller passes a
    # dict {authelia_user: header_value}; each entry becomes an
    # `if ($authelia_user = "...") { set $upstream_auth "..."; }`. We
    # use the `if + set` pattern (one of the "evil if" exceptions
    # documented by nginx) rather than an http-scope `map` because
    # `$authelia_user` is created by auth_request_set inside this
    # location and isn't visible to map directives at http scope
    # (nginx -t fails with "unknown variable" at parse time).
    #
    # Initialize from $http_authorization (client's own header) so the
    # bypass-on-Authorization machine-client path passes through
    # unmodified -- proxy_set_header with empty value strips the
    # client's header (it doesn't fall back to nginx's default
    # forward), so an unconditional `set $upstream_auth ""` would
    # silently 401 every Telegraf/HA/Grafana write. Mapped Authelia
    # users still get their assigned token (the if-set below overrides
    # $http_authorization), and unmapped Authelia users with no
    # Authorization land at the upstream's native sign-in.
    set $upstream_auth $http_authorization;
    {% for user, header in nginx_site_args.upstream_authorization.items() %}
    if ($authelia_user = "{{ user }}") { set $upstream_auth "{{ header }}"; }
    {% endfor %}
    proxy_set_header Authorization      $upstream_auth;
{% endif %}

    # Proxy timeouts
    proxy_connect_timeout {{ nginx_site_args.proxy_connect_timeout | default('60s') }};
    proxy_send_timeout    {{ nginx_site_args.proxy_send_timeout | default('60s') }};
    proxy_read_timeout    {{ nginx_site_args.proxy_read_timeout | default('60s') }};
{% if nginx_site_args.proxy_buffering is defined %}
    proxy_buffering {{ nginx_site_args.proxy_buffering }};
{% endif %}
{% if nginx_site_args.proxy_request_buffering is defined %}
    proxy_request_buffering {{ nginx_site_args.proxy_request_buffering }};
{% endif %}
{% if nginx_site_args.client_max_body_size is defined %}
    client_max_body_size {{ nginx_site_args.client_max_body_size }};
{% endif %}
{% endif %}
{% if nginx_site_args.location_conf is defined %}

    {{ nginx_site_args.location_conf | trim | indent(4) }}
{% endif %}
  }
{% if nginx_site_args.server_conf is defined %}

  {{ nginx_site_args.server_conf | trim | indent(2) }}
{% endif %}
}
{% if not (nginx_site_args.enable_http | default(false)) %}

server {
    listen      80;
{% if nginx_ipv6 | default(false) %}
    listen      [::]:80;
{% endif %}
    server_name {{ nginx_site_args.subdomain }}.{{ inventory_hostname }}.{{ domain }} {{ nginx_site_args.subdomain }}.{{ domain}};

    return 301 https://$host$request_uri;
}
{% endif %}
