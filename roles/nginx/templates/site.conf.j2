{# HTTP/2: `http2 on;` (set in nginx.conf.j2's http{}) on nginx >= 1.25.1, the
   legacy `listen ... http2` parameter on jammy/1.18 and noble/1.24. Mirrors
   the blacklist gate there so both move together. #}
{% set _http2_listen = ' http2' if ansible_distribution_release in ['jammy', 'noble'] else '' %}
server {
  listen              443 ssl{{ _http2_listen }};
{% if nginx_ipv6 %}
  listen              [::]:443 ssl{{ _http2_listen }};
{% endif %}
{% if _nginx_site_enable_http %}
  # Cleartext :80 in this same server block (no http->https redirect). The
  # security headers below are emitted here too: HSTS over :80 is a no-op
  # browsers ignore per RFC 6797, the rest are harmless. Only for upstreams
  # that need plaintext -- asserted incompatible with auth/bypass, whose
  # secrets would otherwise travel unencrypted.
  listen              80;
{% if nginx_ipv6 %}
  listen              [::]:80;
{% endif %}
{% endif %}

  server_name         {{ nginx_site_args.subdomain }}.{{ inventory_hostname }}.{{ domain }} {{ nginx_site_args.subdomain }}.{{ domain}};

  # Security headers. Captured once into `security_headers` and emitted both
  # here at server scope (covering the favicon/robots locations, the Authelia
  # 401->302 redirect, and error responses, all via the `always` flag) and
  # re-emitted inside `location /` when a location_conf is present: nginx
  # inherits add_header only into levels that define none of their own, so a
  # location_conf adding e.g. Access-Control-Allow-Origin would otherwise
  # strip every security header from the proxied path.
  #
  # Referrer-Policy is no-referrer on bypass_query_param sites (the URL carries
  # the vaulted auth_token; $request_safe redacts only our own access log, so
  # the token must never leak via a Referer to third-party assets), same-origin
  # elsewhere.
{% set security_headers %}
  add_header X-XSS-Protection          "1; mode=block" always;
  add_header X-Content-Type-Options    "nosniff" always;
{% if nginx_site_args.bypass_query_param is defined %}
  add_header Referrer-Policy           "no-referrer" always;
{% else %}
  add_header Referrer-Policy           "same-origin" always;
{% endif %}
{% if not (nginx_site_args.csp_passthrough | default(false)) %}
  add_header Content-Security-Policy   "{% if nginx_site_args.csp_additional is defined %}{{ nginx_site_args.csp_additional }}; {% endif %}default-src {% if nginx_site_args.csp_default_src is defined %}{{ nginx_site_args.csp_default_src }} {% endif %}{{ nginx_csp_default }}; frame-ancestors {% if nginx_site_args.csp_frame_ancestors is defined %}{{ nginx_site_args.csp_frame_ancestors }}{% else %}'self'{% endif %};" always;
{% endif %}
{# interest-cohort (FLoC) was abandoned in 2022 and no browser still parses it;
   browsing-topics opts out of its live Topics-API successor instead. #}
  add_header Permissions-Policy        "browsing-topics=()" always;
{# max-age 63072000 (2y) per the TLSRef v6.0 / Mozilla Intermediate profile,
   matching the cipher block in nginx.conf.j2; no preload (deliberate). #}
  add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
{% endset %}
{{ security_headers }}

  # favicon.ico
  location = /favicon.ico {
      log_not_found off;
  }

  # robots.txt
  location = /robots.txt {
      log_not_found off;
  }

{% set _auth_enabled = _nginx_site_auth == 'required' %}
{% if _auth_enabled %}
  # Authelia forward-auth: every browser hit to this site is subrequested
  # against Authelia's /api/authz/auth-request endpoint. 200 -> allow; 401
  # -> error_page routes to @authelia_unauth below (navigations redirect to the
  # portal with returnUrl; XHR/fetch get a bare 401). The
  # /internal/authelia location is marked `internal` so external requests
  # can't bypass the auth by hitting it directly. Authelia upstream URL
  # is host-parameterized so non-lab hosts (pug, bunk) can point at lab's
  # Authelia over wireguard when they need forward-auth. (The location name is
  # a local convention predating upstream's /internal/authelia/authz; it's
  # internal-only, so the exact path is immaterial -- don't "fix" it.)
  location /internal/authelia {
    internal;
{% if _nginx_site_upstream_auth %}
    # Machine clients (no Authelia session cookie, presenting their own
    # Authorization header) skip the Authelia round-trip: return 204
    # straight away, so auth_request admits the parent. The 204 carries no
    # Remote-User, so $authelia_user is empty in `location /` and the
    # upstream-auth map's `default $http_authorization` forwards the
    # client's own token unchanged. The match is computed in the
    # $authelia_bypass map in nginx.conf.j2 because nginx's `if` can't
    # compose two conditions. Implies trust in any presented Authorization
    # header from a cookieless client -- only safe when the upstream itself
    # rejects bad tokens (InfluxDB does).
    if ($authelia_bypass) {
      return 204;
    }
{% endif %}
{% if nginx_site_args.bypass_query_param is defined %}
    # URL-param bypass for clients that can't send Authorization headers
    # (the netdata/homepage cross-host poller). Compare the
    # extracted token (from the parent's $request_uri via the $req_auth_token
    # map in nginx.conf.j2) against the vaulted value; on match return 204
    # (a 2xx -> auth_request lets the parent through) without consulting
    # Authelia. Why not `if ($arg_auth_token = ...)`: $arg_X inside an
    # auth_request subrequest refers to the subrequest's own (empty) query,
    # not the parent's -- so that comparison never matches. The param name
    # is fixed to `auth_token` (the $req_auth_token/$request_safe maps in
    # nginx.conf.j2 hardcode it). The token is redacted from OUR access log
    # via $request_safe, but that redaction does NOT cover error_log: on any
    # upstream error (e.g. a 502 from a stalled upstream) nginx logs the full
    # request line -- token and all -- to error_log, which goes to journald. So
    # the journal IS token-bearing for bypass sites; treat it like the other
    # secret-logging units. Redaction also can't reach a Referer to a third
    # party -- the no-referrer Referrer-Policy above covers that.
    if ($req_auth_token = "{{ nginx_site_args.bypass_query_param.value }}") {
      return 204;
    }
{% endif %}
    proxy_pass {{ authelia_internal_url }};
    # HTTP/1.1 to the auth endpoint (matches `location /`): the default 1.0
    # disables chunked transfer and keepalive on the subrequest fired for every
    # authenticated request.
    proxy_http_version 1.1;
    # Bound the auth subrequest so a transient gap on the path to Authelia
    # (notably fox reaching lab's Authelia over wg0) fails fast instead of
    # stalling on nginx's 60s default -- a sub-second blip otherwise becomes a
    # 60s hang and then a 500. Authelia normally answers in ~100ms, so a few
    # seconds is ample headroom.
    proxy_connect_timeout 3s;
    proxy_send_timeout    5s;
    proxy_read_timeout    5s;
    # Buffer sizing from Authelia's canonical authelia-location.conf: its 401
    # response carries the portal-redirect Location plus the Remote-* identity
    # headers, which can overflow nginx's default 4k/8k header buffer on a
    # subrequest and surface as an intermittent "upstream sent too big header"
    # 502 on the auth leg.
    proxy_buffer_size       32k;
    proxy_buffers           4 32k;
    client_body_buffer_size 128k;
    proxy_pass_request_body off;
    proxy_set_header Content-Length          "";
    # Clear any client-supplied Connection header off the internal subrequest
    # (matches Authelia's canonical snippet).
    proxy_set_header Connection              "";
    proxy_set_header X-Original-Method       $request_method;
    proxy_set_header X-Original-URL          $scheme://$host$request_uri;
    proxy_set_header X-Forwarded-For         $remote_addr;
    proxy_set_header X-Forwarded-Method      $request_method;
    proxy_set_header X-Forwarded-Proto       $scheme;
    proxy_set_header X-Forwarded-Host        $host;
    proxy_set_header X-Forwarded-Uri         $request_uri;
  }

{% endif %}
  location / {
{% if _auth_enabled %}
    auth_request /internal/authelia;
    # Capture Authelia's Remote-* response headers from the auth_request
    # subrequest as nginx variables, then forward them to the upstream
    # below. Upstreams that trust the proxy (e.g. *arr v4 with
    # AuthenticationMethod=External) read X-Forwarded-User and skip their
    # own local login. Authelia sends Remote-User on every authenticated
    # 200; the bypass_query_param shortcut returns 204 with no Remote-*,
    # so $authelia_user is empty there — incompatible with upstreams
    # that require X-Forwarded-User. Don't combine the two on the same
    # site.
    auth_request_set $authelia_user   $upstream_http_remote_user;
    auth_request_set $authelia_groups $upstream_http_remote_groups;
    auth_request_set $authelia_name   $upstream_http_remote_name;
    auth_request_set $authelia_email  $upstream_http_remote_email;
    # Authelia returns 401 with the portal-redirect target (returnUrl + method
    # already baked in) in its `Location` response header; capture it so
    # @authelia_unauth can rewrite the auth_request 401 into a 302 there. This is
    # Authelia's modern integration -- nginx no longer hardcodes the portal host,
    # so an Authelia cookie-domain / multi-domain change needs no edit here.
    auth_request_set $redirection_url $upstream_http_location;
    # Route the auth_request's own 401 to @authelia_unauth (below), which
    # redirects browser navigations to the portal but returns a bare 401 to
    # XHR/fetch -- an SPA can't follow a cross-origin portal redirect and would
    # loop. An UPSTREAM 401 is unaffected: proxy_intercept_errors stays at its
    # default `off`, so it passes straight to the client and never hits error_page.
    error_page 401 = @authelia_unauth;
{% endif %}
{% if nginx_site_args.bypass_query_param is defined %}
    # The $args strip below and the $request_safe log-redaction each assume a
    # single, well-formed auth_token. Reject the two malformed shapes that would
    # otherwise smuggle the token past the strip and forward it raw to the
    # upstream: a duplicated param, and a literal "?" inside the query string (a
    # second "?" in the URI). $req_auth_token's [?&] extractor matches a
    # ?-prefixed token and fires the 204 bypass, but the &-anchored strip below
    # does not catch it. Both shapes are abnormal for the API clients that use
    # bypass (the netdata/homepage poller), which only ever send one "?auth_token=".
    if ($request_uri ~ "auth_token=.*[?&]auth_token=") {
      return 400;
    }
    if ($args ~ "[?]") {
      return 400;
    }
    # Strip the bypass token from $args before proxy_pass so the
    # upstream app never sees it (token must not land in the upstream's own
    # logs or echo back in error messages). nginx's proxy_pass forwards
    # $is_args$args when the upstream URL has no own query string, so
    # rewriting $args here removes the param from the forwarded URL.
    # Two rewrites cover (1) param-first and (2) param-not-first:
    if ($args ~ "^auth_token=[^&]*&?(.*)$") {
      set $args $1;
    }
    if ($args ~ "^(.*)&auth_token=[^&]*(.*)$") {
      set $args "$1$2";
    }
{% endif %}
{% if nginx_site_args.proxy_pass is defined %}
    proxy_pass         {{ nginx_site_args.proxy_pass }};

    proxy_http_version 1.1;
    proxy_cache_bypass $http_upgrade;

    # Proxy SSL. proxy_ssl_server_name forwards SNI to the upstream; the
    # upstream cert is deliberately NOT verified (no proxy_ssl_verify) -- the
    # HTTPS upstreams are LAN devices (UDM, Eaton, marantz) carrying self-signed
    # certs, reached over the trusted home LAN. An on-path attacker on that VLAN
    # could MITM the leg; that's out of scope for the home threat model.
    proxy_ssl_server_name on;

    # Detect a silently-dropped upstream (a power-cycled LAN device — Eaton,
    # marantz) via TCP keepalives, rather than hanging on a half-open socket
    # until proxy_read_timeout.
    proxy_socket_keepalive on;

    # Canonical forwarded headers -- one source, shared with any
    # server_conf/location_conf location via the same include.
    include /etc/nginx/snippets/proxy_params.conf;
{% if _auth_enabled %}
    # Forward the captured Authelia identity to the upstream under both naming
    # conventions: Authelia's own canonical authrequest snippet uses Remote-*,
    # while the *arr suite (AuthenticationMethod=External) reads X-Forwarded-User.
    # Emitting both lets an upstream wired per either convention pick it up.
    proxy_set_header X-Forwarded-User   $authelia_user;
    proxy_set_header X-Forwarded-Groups $authelia_groups;
    proxy_set_header X-Forwarded-Name   $authelia_name;
    proxy_set_header X-Forwarded-Email  $authelia_email;
    proxy_set_header Remote-User        $authelia_user;
    proxy_set_header Remote-Groups      $authelia_groups;
    proxy_set_header Remote-Name        $authelia_name;
    proxy_set_header Remote-Email       $authelia_email;
{% endif %}
{% if _nginx_site_upstream_auth %}
    # Per-user upstream Authorization. The caller passes a dict
    # {authelia_user: header_value}; it is rendered into an http-scope `map`
    # keyed on $authelia_user, in conf.d/upstream_auth_<sub>.conf, dropped by
    # the helper alongside this vhost (a map can't live in server{}). The map
    # variable is evaluated HERE in the content phase, after auth_request has
    # populated $authelia_user -- unlike the old rewrite-phase `if/set`, which
    # ran before auth and so never matched. The map's `default
    # $http_authorization` forwards a cookieless machine client's own token
    # unchanged (its 204 bypass leaves $authelia_user empty); a mapped browser
    # user gets their assigned token, overriding any stale header the SPA
    # replayed. See upstream_auth_map.conf.j2 / tasks/site.yml.
    proxy_set_header Authorization      $nginx_upstream_auth_{{ nginx_site_args.subdomain | replace('-', '_') }};
{% endif %}

    # Proxy timeouts
    proxy_connect_timeout 60s;
    proxy_send_timeout    {{ nginx_site_args.proxy_send_timeout | default('60s') }};
    proxy_read_timeout    {{ nginx_site_args.proxy_read_timeout | default('60s') }};
{% if nginx_site_args.proxy_buffering is defined %}
    proxy_buffering {{ nginx_site_args.proxy_buffering }};
{% endif %}
{% if nginx_site_args.proxy_request_buffering is defined %}
    proxy_request_buffering {{ nginx_site_args.proxy_request_buffering }};
{% endif %}
{% if nginx_site_args.client_max_body_size is defined %}
    client_max_body_size {{ nginx_site_args.client_max_body_size }};
{% endif %}
{% if nginx_site_args.client_body_buffer_size is defined %}
    client_body_buffer_size {{ nginx_site_args.client_body_buffer_size }};
{% endif %}
{% endif %}
{% if nginx_site_args.location_conf is defined %}
    # Re-establish the server-scope security headers at this location level:
    # the location_conf below may add its own add_header, which would
    # otherwise drop them all here (see the security_headers note above).
{{ security_headers }}

    {{ nginx_site_args.location_conf | trim | indent(4) }}
{% endif %}
  }
{% if _auth_enabled %}

  # Unauthenticated forward-auth handler. error_page in `location /` routes the
  # auth_request's own 401 here. Redirect to the Authelia portal only for
  # top-level navigations; return a bare 401 for XHR/fetch
  # (Sec-Fetch-Mode cors/same-origin/no-cors), which cannot follow a cross-origin
  # HTML portal and would otherwise loop an SPA polling an authed endpoint
  # without a session (the InfluxDB-UI redirect loop). $authelia_unauth_redirect
  # is computed from Sec-Fetch-Mode in nginx.conf.j2 (maps live at http scope);
  # $redirection_url is the captured portal target. `if` with only `return` is
  # the documented-safe use; the server-scope security headers (always) still
  # apply to both responses since this location declares no add_header.
  location @authelia_unauth {
    if ($authelia_unauth_redirect) {
      return 302 $redirection_url;
    }
    return 401;
  }
{% endif %}
{% if nginx_site_args.server_conf is defined %}

  {{ nginx_site_args.server_conf | trim | indent(2) }}
{% endif %}
}
{% if not _nginx_site_enable_http %}

server {
    listen      80;
{% if nginx_ipv6 %}
    listen      [::]:80;
{% endif %}
    server_name {{ nginx_site_args.subdomain }}.{{ inventory_hostname }}.{{ domain }} {{ nginx_site_args.subdomain }}.{{ domain}};

{% if nginx_site_args.bypass_query_param is defined %}
    # Drop the query on the cleartext :80 leg: it can carry the vaulted
    # auth_token, which must not be reflected in a plaintext redirect Location.
    # Bypass clients target https directly, so they never hit this redirect.
    return 308 https://$host$uri;
{% else %}
    return 308 https://$host$request_uri;
{% endif %}
}
{% endif %}
