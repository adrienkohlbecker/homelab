# Example configuration file, it's safe to copy this as the default config file without any modification.

# You don't have to copy this file to your instance,
# just run `./gitea-runner generate-config > config.yaml` to generate a config file.

log:
  # The level of logging, can be trace, debug, info, warn, error, fatal
  level: info

runner:
  # Where to store the registration result.
  file: /mnt/services/gitea_runner/.runner
  # Execute how many tasks concurrently at the same time.
  capacity: 4
  # Extra environment variables to run jobs.
  envs: {}
  # Extra environment variables to run jobs from a file.
  # It will be ignored if it's empty or the file doesn't exist.
  env_file: /mnt/services/gitea_runner/.env
  # The timeout for a job to be finished.
  # Please note that the Gitea instance also has a timeout (3h by default) for the job.
  # So the job could be stopped by the Gitea instance if it's timeout is shorter than this.
  timeout: 1h
  # How long to wait for in-flight jobs to finish on SIGTERM before
  # cancelling them. Composes with gitea_runner.service.j2's
  # TimeoutStopSec=120: systemd gives the daemon 120s total, the daemon
  # waits 110s for jobs, 10s headroom for cleanup. Without this set
  # (upstream default 0s), SIGTERM cancels jobs immediately and the
  # 120s on the systemd side is pure padding.
  shutdown_timeout: 110s
  # Whether skip verifying the TLS certificate of the Gitea instance.
  insecure: false
  # The timeout for fetching the job from the Gitea instance.
  fetch_timeout: 5s
  # The interval for fetching the job from the Gitea instance.
  fetch_interval: 2s
  # The labels of a runner are used to determine which jobs the runner can run, and how to run them.
  # Like: "macos-arm64:host" or "ubuntu-latest:docker://gitea/runner-images:ubuntu-latest"
  # Find more images provided by Gitea at https://gitea.com/gitea/runner-images .
  # Setting labels here (non-empty) overrides whatever is persisted in
  # .runner at daemon start; the daemon writes them back to .runner and
  # calls the gitea-side Declare RPC, so editing this list + restarting
  # the service propagates without re-registration.
  labels:
{% for lbl in gitea_runner_labels %}
    - "{{ lbl }}"
{% endfor %}

cache:
  # Enable cache server to use actions/cache.
  enabled: true
  # The directory to store the cache data.
  # If it's empty, the cache data will be stored in $HOME/.cache/actcache.
  dir: /mnt/scratch/gitea_runner/cache
  # The host of the cache server.
  # It's not for the address to listen, but the address to connect from job containers.
  # So 0.0.0.0 is a bad choice, leave it empty to detect automatically.
  host: ""
  # The port of the cache server. Pinned via service_ports so the
  # restart-spawned cache server reuses the same port; upstream's
  # default of 0 (random) strands in-flight jobs that cached against
  # the previous port.
  port: {{ service_ports.gitea_runner_cache }}
  # The external cache server URL. Valid only when enable is true.
  # If it's specified, gitea-runner will use this URL as the ACTIONS_CACHE_URL rather than start a server by itself.
  # The URL should generally end with "/".
  external_server: ""

container:
  # Specifies the network to which the container will connect.
  # Could be host, bridge or the name of a custom network.
  # If it's empty, gitea-runner will create a network automatically.
  network: ""
  # Whether to use privileged mode or not when launching task containers (privileged mode is required for Docker-in-Docker).
  privileged: false
  # And other options to be used when the container is started (eg, --add-host=my.gitea.url:host-gateway).
  # --add-host lets workflows reach the gitea instance by its public hostname
  # from inside the container; without it the container would have to talk to
  # the rootless podman bridge gateway address instead.
  options: --add-host=gitea.{{ inventory_hostname }}.{{ domain }}:host-gateway
  # The parent directory of a job's working directory.
  # NOTE: There is no need to add the first '/' of the path as gitea-runner will add it automatically.
  # If the path starts with '/', the '/' will be trimmed.
  # For example, if the parent directory is /path/to/my/dir, workdir_parent should be path/to/my/dir
  # If it's empty, /workspace will be used.
  workdir_parent:
  # Volumes (including bind mounts) can be mounted to containers. Glob syntax is supported, see https://github.com/gobwas/glob
  # Empty list = no host bind mounts allowed. Add globs here if a workflow
  # needs to mount a host path.
  valid_volumes: []
  # overrides the docker client host with the specified one.
  # If it's empty, gitea-runner will find an available docker host automatically.
  # If it's "-", gitea-runner will find an available docker host automatically, but the docker host won't be mounted to the job containers and service containers.
  # If it's not empty or "-", the specified docker host will be used. An error will be returned if it doesn't work.
  docker_host: unix:///run/user/{{ gitea_runner_user.uid }}/podman/podman.sock
  # Pull docker image(s) even if already present. Pairs with the moving
  # `:latest` tag in the default gitea_runner_labels (defaults/main.yml):
  # without force_pull, a fresh upstream image bump (e.g. CVE patch in
  # gitea/runner-images:ubuntu-latest) doesn't propagate to jobs until
  # podman's prune timer evicts the cached copy.
  force_pull: true
  # Rebuild docker image(s) even if already present
  force_rebuild: false
  # Fail the daemon start loud if the rootless podman socket isn't
  # serving within docker_timeout. Catches "socket file exists but
  # podman isn't yet accepting connections" -- a real edge case during
  # user-manager startup that the unit's ExecStartPre wait loop
  # (gitea_runner.service.j2) doesn't cover because it checks file
  # presence, not connection readiness.
  require_docker: true
  docker_timeout: 30s

host:
  # The parent directory of a job's working directory.
  # If it's empty, $HOME/.cache/act/ will be used.
  workdir_parent: /mnt/scratch/gitea_runner/workdir

metrics:
  # Prometheus endpoint at http://<addr>/metrics (plus /healthz at the
  # same addr). Loopback-only -- no auth on the endpoint -- scraped by
  # netdata's go.d prometheus collector (wire-up in roles/netdata is a
  # follow-up). 9101 matches the upstream default for googleable
  # troubleshooting.
  enabled: true
  addr: "127.0.0.1:{{ service_ports.gitea_runner_metrics }}"
