# See /usr/share/postfix/main.cf.dist for a commented, more complete version


# Debian specific:  Specifying a file name will cause the first
# line of that file to be used as the name.  The Debian default
# is /etc/mailname.
#myorigin = /etc/mailname

biff = no

# appending .domain is the MUA's job.
append_dot_mydomain = no

# Uncomment the next line to generate "delayed mail" warnings
#delay_warning_time = 4h

readme_directory = no

# Pin the compatibility level so a postfix major upgrade keeps the parameter
# defaults this config was written against rather than silently shifting them.
# See http://www.postfix.org/COMPATIBILITY_README.html.
compatibility_level = 3.6



# TLS parameters
smtp_tls_CApath=/etc/ssl/certs
smtp_tls_session_cache_database = btree:${data_directory}/smtp_scache

smtpd_relay_restrictions = permit_mynetworks permit_sasl_authenticated reject_unauth_destination
mydomain = {{ domain }}
# Qualify bare local senders (cron/smartd/fail2ban `root`) straight to $mydomain
# rather than the default $myhostname, so a system alert is `root@$mydomain` in one
# step -- the smtp_generic_maps @$mydomain rule then rewrites it to the per-host
# sender identity. $mydomain is in mydestination, so the matching `root` *recipient*
# still resolves locally through /etc/aliases. Postfix's recommended setting for a
# domain spanning multiple hosts. masquerade_domains below stays as the safety net
# that folds any FQDN-subdomain straggler (e.g. root@$myhostname) back to $mydomain.
myorigin = $mydomain
masquerade_domains = {{ email_domain }} {{ domain }}
alias_maps = hash:/etc/aliases
alias_database = hash:/etc/aliases
# Not a pure null client (which sets `mydestination =` empty): local delivery is
# kept so system mail to root/operator resolves through /etc/aliases, then leaves
# again to root_email via the relay. $mydomain here also captures bounces to the
# masqueraded `root@$mydomain` sender locally instead of relaying them back out.
# See http://www.postfix.org/STANDARD_CONFIGURATION_README.html (null client).
mydestination = $myhostname, $mydomain, localhost.$mydomain, localhost
relayhost = [{{ smtp_host }}]:{{ smtp_port }}
mynetworks = 127.0.0.0/8 [::ffff:127.0.0.0]/104 [::1]/128
mailbox_size_limit = 0
recipient_delimiter = +
# Send-only relay: bind smtpd to loopback so no external SMTP listener exists on
# any interface (alias->relay submission flows through the local pickup path,
# not smtpd). IPv6 is disabled at the kernel and Mailgun publishes no AAAA, so
# pin inet_protocols to ipv4 -- `all` only adds dead AAAA lookups and a startup
# warning on every host.
inet_interfaces = loopback-only
inet_protocols = ipv4
disable_vrfy_command = yes

smtp_sasl_auth_enable = yes
# texthash: reads the flat sasl_passwd at process start, so no postmap(1) step
# or .db artifact -- the role restarts postfix on credential change anyway.
smtp_sasl_password_maps = texthash:/etc/postfix/sasl_passwd
# noplaintext refuses the SASL credential over a non-TLS link: if a host ever
# overrides smtp_port to 25 (dropping TLS, see smtp_tls_security_level below),
# the relay fails closed rather than leaking the fleet credential in clear.
smtp_sasl_security_options = noanonymous, noplaintext
smtp_sasl_tls_security_options = noanonymous
# `secure` verifies the relay's certificate against the nexthop name (Mailgun
# presents a publicly-trusted cert) rather than accepting any cert as plain
# `encrypt` would -- defeats an active MITM harvesting the fleet-wide credential.
smtp_tls_security_level = {{ 'secure' if (smtp_use_ssl | bool or smtp_use_tls | bool) else 'none' }}
smtp_tls_secure_cert_match = nexthop
smtp_tls_mandatory_protocols = >=TLSv1.2
# Raise the cipher floor above the `medium` default: Mailgun supports HIGH-grade
# ciphers, so the link carrying the fleet-wide SASL credential negotiates only
# those. Applies at the mandatory (`secure`) level set above; inert at `none`.
smtp_tls_mandatory_ciphers = high
smtp_tls_loglevel = 1
smtp_tls_wrappermode = {{ 'yes' if smtp_use_ssl | bool else 'no' }}
# Rewrite the outbound sender to a per-host identity at the Mailgun-authorized
# {{ email_domain }} (the domain the service roles send from) -- the lookup is
# read at process start (texthash), so no postmap step. See generic.j2.
smtp_generic_maps = texthash:/etc/postfix/generic
header_size_limit = 4096000
# Raise the per-message cap to 20 MB (default 10 MB) so a large smartd/journal
# digest or a fail2ban report with an attachment relays instead of bouncing;
# stays under Mailgun's 25 MB accept limit.
message_size_limit = 20480000

# Keep `bounce` so a relay rejection (a lost cron/smartd/fail2ban alert) is
# itself surfaced to the operator; drop the verbose protocol/policy/data
# SMTP-transcript classes.
notify_classes = resource, software, bounce
