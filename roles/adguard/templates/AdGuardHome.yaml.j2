http:
  pprof:
    port: 6060
    enabled: false
  doh:
    routes:
      - GET /dns-query
      - POST /dns-query
      - GET /dns-query/{ClientID}
      - POST /dns-query/{ClientID}
    insecure_enabled: false
  address: 0.0.0.0:3000
  session_ttl: 30d
{#
  No app-level users: the admin UI/API is only published on the host
  loopback and fronted by the Authelia-gated nginx vhost (auth: required
  in tasks/main.yml), which is the sole LAN ingress. Host-local processes
  and co-located containers can reach the API unauthenticated -- accepted
  for this home environment.
#}
users: []
auth_attempts: 5
block_auth_min: 15
http_proxy: ""
language: ""
theme: auto
dns:
  bind_hosts:
    - 0.0.0.0
  port: 53
  anonymize_client_ip: false
{#
  Per-client (/32) request budget. The upstream default of 20 rps is too
  tight for a busy household client; 300 keeps one misbehaving LAN/IoT
  device from monopolizing the resolver without throttling real use.
#}
  ratelimit: 300
  ratelimit_subnet_len_ipv4: 32
  ratelimit_subnet_len_ipv6: 64
  ratelimit_whitelist: []
  refuse_any: true
  upstream_dns:
{#
  Primary resolver: Cloudflare DoH keeps household DNS encrypted over normal
  HTTPS/443 and avoids EDNS Client Subnet, favoring privacy over occasionally
  sharper CDN geo-steering.
#}
    - https://cloudflare-dns.com/dns-query
  upstream_dns_file: ""
  bootstrap_dns:
{#
  Bootstrap must be plain DNS; it resolves DoH hostnames before encrypted
  upstreams are reachable. Keep using the shared bootstrap escape hatch.
#}
{% for resolver in bootstrap_dns_resolver %}
    - {{ resolver ~ ':53' }}
{% endfor %}
  fallback_dns:
{#
  Fallback resolver: Google DoH is a broad, reliable secondary when Cloudflare
  is unavailable. ECS stays disabled below for privacy.
#}
    - https://dns.google/dns-query
  upstream_mode: load_balance
  fastest_timeout: 1s
  allowed_clients: []
  disallowed_clients: []
  blocked_hosts: []
{#
  X-Forwarded-For is honored only from nginx's path into the container:
  the loopback publish DNATs onto the default podman network, so requests
  arrive sourced from that network's gateway. Trust exactly that address,
  not the whole bridge range -- any co-located container could otherwise
  forge its client identity.
#}
  trusted_proxies:
    - 127.0.0.0/8
    - ::1/128
    - {{ podman_default_network | ansible.utils.ipaddr('1') | ansible.utils.ipaddr('address') }}/32
  cache_enabled: true
  cache_size: 4194304
  cache_ttl_min: 0
  cache_ttl_max: 0
{#
  Serve-stale: during a WAN or DoH-upstream outage, answer cached names
  with expired data (TTL 30s) while refreshing in the background, instead
  of going dark for the whole household. Entries older than 12h are
  evicted rather than served.
#}
  cache_optimistic: true
  cache_optimistic_answer_ttl: 30s
  cache_optimistic_max_age: 12h
  bogus_nxdomain: []
  aaaa_disabled: false
  enable_dnssec: true
  edns_client_subnet:
    custom_ip: ""
    enabled: false
    use_custom: false
  max_goroutines: 300
  handle_ddr: true
  ipset: []
  ipset_file: ""
  bootstrap_prefer_ipv6: false
  upstream_timeout: 10s
  private_networks: []
  use_private_ptr_resolvers: true
  local_ptr_upstreams:
    - {{ external_ips.udm ~ ':53' }}
  use_dns64: false
  dns64_prefixes: []
  serve_http3: false
{#
  Both DoH upstreams speak HTTP/3; QUIC's faster reconnects shave tail
  latency after idle periods. Falls back to HTTP/2 if UDP/443 is blocked.
#}
  use_http3_upstreams: true
  serve_plain_dns: true
  hostsfile_enabled: false
  pending_requests:
    enabled: true
tls:
  enabled: false
  server_name: ""
  force_https: false
  port_https: 443
  port_dns_over_tls: 853
  port_dns_over_quic: 853
  port_dnscrypt: 0
  dnscrypt_config_file: ""
  certificate_chain: ""
  private_key: ""
  certificate_path: ""
  private_key_path: ""
  strict_sni_check: false
{#
  Query log disabled entirely: it is browsing-history-equivalent data for
  the whole household, and /mnt/services/adguard/work rides ZFS snapshots
  plus off-host replication, where snapshot retention would keep it far
  beyond any in-app interval. Aggregate statistics below stay on for the
  dashboard.
#}
querylog:
  dir_path: ""
  ignored: []
  interval: 30d
  size_memory: 1000
  enabled: false
  ignored_enabled: false
  file_enabled: false
statistics:
  dir_path: ""
{#
  The keepalived healthcheck digs adguard.home every second per host;
  without this the synthetic probes drown the top-domains statistics.
#}
  ignored:
    - adguard.home
  interval: 10d
  enabled: true
  ignored_enabled: true
filters:
{% for url in adguard_adlists %}
  - enabled: true
    url: {{ url }}
    name: blocklist_{{ loop.index }}
    id: {{ loop.index }}
{% endfor %}
whitelist_filters:
{% for url in adguard_whitelists %}
  - enabled: true
    url: {{ url }}
    name: allowlist_{{ loop.index }}
    id: {{ 1000 + loop.index }}
{% endfor %}
{#
  Parity with the retired dnscrypt-proxy block_unqualified /
  block_undelegated toggles: single-label names and undelegated LAN
  suffixes can never resolve publicly, so answer them locally (0.0.0.0
  under blocking_mode default) instead of leaking internal hostnames and
  typos to the DoH upstreams. `home` is deliberately not blocked --
  adguard.home (the healthcheck rewrite above) lives under it; the
  single-label regex never matches it since it carries a dot.
#}
{# The regex rule is deliberately unquoted: AdGuard rewrites this file on
   startup and serializes it as a plain scalar -- a quoted rendering here
   would re-template (and restart) on every converge. #}
user_rules:
  - /^[^.]+$/
  - '||lan^'
  - '||local^'
  - '||internal^'
  - '||test^'
  - '||home.arpa^'
dhcp:
  enabled: false
  interface_name: ""
  local_domain_name: lan
  dhcpv4:
    gateway_ip: ""
    subnet_mask: ""
    range_start: ""
    range_end: ""
    lease_duration: 86400
    icmp_timeout_msec: 1000
    options: []
  dhcpv6:
    range_start: ""
    lease_duration: 86400
    ra_slaac_only: false
    ra_allow_slaac: false
filtering:
  blocking_ipv4: ""
  blocking_ipv6: ""
  blocked_services:
    schedule:
      time_zone: {{ system_timezone }}
    ids: []
  protection_disabled_until: null
  safe_search:
    enabled: false
    bing: true
    duckduckgo: true
    ecosia: true
    google: true
    pixabay: true
    yandex: true
    youtube: true
  blocking_mode: default
  parental_block_host: family-block.dns.adguard.com
  safebrowsing_block_host: standard-block.dns.adguard.com
  rewrites:
    - domain: adguard.home
      answer: 127.0.0.1
      enabled: true
    - domain: pug.{{ domain }}
      answer: {{ external_ips.pug }}
      enabled: true
    - domain: '*.pug.{{ domain }}'
      answer: {{ external_ips.pug }}
      enabled: true
    - domain: lab.{{ domain }}
      answer: {{ external_ips.lab }}
      enabled: true
    - domain: '*.lab.{{ domain }}'
      answer: {{ external_ips.lab }}
      enabled: true
    - domain: box.{{ domain }}
      answer: {{ external_ips.box }}
      enabled: true
    - domain: '*.box.{{ domain }}'
      answer: {{ external_ips.box }}
      enabled: true
    - domain: auth.{{ domain }}
      answer: {{ external_ips.lab }}
      enabled: true
  safe_fs_patterns: []
  safebrowsing_cache_size: 1048576
  safesearch_cache_size: 1048576
  parental_cache_size: 1048576
  cache_time: 30
  filters_update_interval: 24
  blocked_response_ttl: 10
  filtering_enabled: true
  rewrites_enabled: true
  parental_enabled: false
  safebrowsing_enabled: false
  protection_enabled: true
clients:
  runtime_sources:
    whois: true
    arp: true
    rdns: true
    dhcp: true
    hosts: true
  persistent: []
log:
  enabled: true
  file: ""
  max_backups: 0
  max_size: 100
  max_age: 3
  compress: false
  local_time: false
  verbose: false
os:
  group: ""
  user: ""
  rlimit_nofile: 0
schema_version: 34
