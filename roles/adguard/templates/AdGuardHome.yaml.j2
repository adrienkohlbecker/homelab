http:
  pprof:
    port: 6060
    enabled: false
  doh:
    routes:
      - GET /dns-query
      - POST /dns-query
      - GET /dns-query/{ClientID}
      - POST /dns-query/{ClientID}
    insecure_enabled: false
  address: 0.0.0.0:3000
  session_ttl: 30d
{#
  No app-level users: the admin UI/API is only published on the host
  loopback and fronted by the Authelia-gated nginx vhost (auth: required
  in tasks/main.yml), which is the sole LAN ingress. Host-local processes
  and every container on the default podman bridge can reach the API
  unauthenticated -- and it controls upstreams/rewrites, so a compromised
  co-located container could hijack household DNS. Accepted for this home
  environment, the same trade as the cross-bridge DNAT gap documented in
  roles/firewall. The obvious hardenings do not work here: binding
  127.0.0.1 breaks the loopback publish (the DNAT targets the container
  IP, verified on the harness), and netavark does not isolate podman
  networks under our nftables setup even with isolate=true. Platform
  isolation fix tracked in notes/SOMEDAY.md.
#}
users: []
auth_attempts: 5
block_auth_min: 15
http_proxy: ""
language: ""
theme: auto
dns:
  bind_hosts:
    - 0.0.0.0
  port: 53
  anonymize_client_ip: false
{#
  Per-client (/32) request budget. The upstream default of 20 rps is too
  tight for a busy household client; 300 keeps one misbehaving LAN/IoT
  device from monopolizing the resolver without throttling real use.
#}
  ratelimit: 300
  ratelimit_subnet_len_ipv4: 32
  ratelimit_subnet_len_ipv6: 64
  ratelimit_whitelist: []
  refuse_any: true
  upstream_dns:
{#
  Primary resolver: Cloudflare DoH keeps household DNS encrypted over normal
  HTTPS/443 and avoids EDNS Client Subnet, favoring privacy over occasionally
  sharper CDN geo-steering.
#}
    - https://cloudflare-dns.com/dns-query
  upstream_dns_file: ""
  bootstrap_dns:
{#
  Bootstrap must be plain DNS; it resolves DoH hostnames before encrypted
  upstreams are reachable. Keep using the shared bootstrap escape hatch.
#}
{% for resolver in bootstrap_dns_resolver %}
    - {{ resolver ~ ':53' }}
{% endfor %}
  fallback_dns:
{#
  Fallback resolver: Google DoH is a broad, reliable secondary when Cloudflare
  is unavailable. ECS stays disabled below for privacy.
#}
    - https://dns.google/dns-query
  upstream_mode: load_balance
  fastest_timeout: 1s
  allowed_clients: []
  disallowed_clients: []
  blocked_hosts: []
{#
  X-Forwarded-For is honored only from nginx's path into the container:
  the loopback publish DNATs onto the default podman network, so requests
  arrive sourced from that network's gateway. Trust exactly that address,
  not the whole bridge range -- any co-located container could otherwise
  forge its client identity.
#}
  trusted_proxies:
    - 127.0.0.0/8
    - ::1/128
    - {{ podman_default_network | ansible.utils.ipaddr('1') | ansible.utils.ipaddr('address') }}/32
  cache_enabled: true
  cache_size: 4194304
  cache_ttl_min: 0
  cache_ttl_max: 0
{#
  Serve-stale: during a WAN or DoH-upstream outage, answer cached names
  with expired data (TTL 30s) while refreshing in the background, instead
  of going dark for the whole household. Entries older than 12h are
  evicted rather than served.
#}
  cache_optimistic: true
  cache_optimistic_answer_ttl: 30s
  cache_optimistic_max_age: 12h
  bogus_nxdomain: []
  aaaa_disabled: false
  enable_dnssec: true
  edns_client_subnet:
    custom_ip: ""
    enabled: false
    use_custom: false
  max_goroutines: 300
  handle_ddr: true
  ipset: []
  ipset_file: ""
  bootstrap_prefer_ipv6: false
  upstream_timeout: 10s
  private_networks: []
  use_private_ptr_resolvers: true
  local_ptr_upstreams:
    - {{ external_ips.udm ~ ':53' }}
  use_dns64: false
  dns64_prefixes: []
  serve_http3: false
{#
  Both DoH upstreams speak HTTP/3; QUIC's faster reconnects shave tail
  latency after idle periods. Falls back to HTTP/2 if UDP/443 is blocked.
#}
  use_http3_upstreams: true
  serve_plain_dns: true
  hostsfile_enabled: false
  pending_requests:
    enabled: true
{#
  DoT for household clients: Android Private DNS auto-upgrades
  opportunistically to the VIP, DDR (handle_ddr above) advertises the
  endpoint to Windows 11 / Apple clients, and strict-mode clients pin
  dns.<domain> -- the server_name doubles as the DDR SVCB target and
  the SNI clients validate. The name rides the per-host cert through
  certbot_extra_sans on both DNS peers and resolves to the VIP via the
  rewrite below.
#}
tls:
  enabled: true
  server_name: dns.{{ domain }}
  force_https: false
{#
  port_https 0 keeps the in-app HTTPS/DoH server off: nginx owns 443 on
  these hosts, and a non-zero port would make DDR advertise a DoH
  endpoint nothing publishes. Same reason port_dns_over_quic is 0 --
  only DoT 853/tcp is published on the VIP, and DDR must not advertise
  more than that. In practice DDR answers empty either way: AdGuard
  omits DoT records unless the cert carries IP SANs (AGH#4927, per the
  DDR verified-discovery rules), which a public CA can never issue for
  an RFC1918 VIP. Encrypted discovery rides Android Private DNS and
  DHCP DNR instead; handle_ddr stays on as it self-activates should
  the cert or protocol set ever allow it.
#}
  port_https: 0
  port_dns_over_tls: 853
  port_dns_over_quic: 0
  port_dnscrypt: 0
  dnscrypt_config_file: ""
  certificate_chain: ""
  private_key: ""
  certificate_path: /opt/adguardhome/conf/tls/fullchain.pem
  private_key_path: /opt/adguardhome/conf/tls/privkey.pem
  strict_sni_check: false
{#
  Query log disabled entirely: it is browsing-history-equivalent data for
  the whole household, and /mnt/services/adguard/work rides ZFS snapshots
  plus off-host replication, where snapshot retention would keep it far
  beyond any in-app interval. Aggregate statistics below stay on for the
  dashboard.
#}
querylog:
  dir_path: ""
  ignored: []
  interval: 30d
  size_memory: 1000
  enabled: false
  ignored_enabled: false
  file_enabled: false
statistics:
  dir_path: ""
{#
  The keepalived healthcheck digs adguard.home every second per host;
  without this the synthetic probes drown the top-domains statistics.
  pi.hole is the same class of noise: only operator probes ever ask it.
#}
  ignored:
    - adguard.home
    - pi.hole
  interval: 10d
  enabled: true
  ignored_enabled: true
{# An empty list must render `[]`, not a bare key (YAML null): AdGuard's
   startup rewrite serializes empty lists as `[]`, and any mismatch with
   that rendering re-templates -- and restarts DNS -- on every converge. #}
{% if adguard_adlists %}
filters:
{% for url in adguard_adlists %}
  - enabled: true
    url: {{ url }}
    name: blocklist_{{ loop.index }}
    id: {{ loop.index }}
{% endfor %}
{% else %}
filters: []
{% endif %}
{% if adguard_whitelists %}
whitelist_filters:
{% for url in adguard_whitelists %}
  - enabled: true
    url: {{ url }}
    name: allowlist_{{ loop.index }}
    id: {{ 1000 + loop.index }}
{% endfor %}
{% else %}
whitelist_filters: []
{% endif %}
{# Entries starting with ! are adblock-style comments: data to AdGuard,
   shown in the Custom filtering rules UI, and preserved by its startup
   rewrite (which strips YAML comments -- hence Jinja comments elsewhere
   in this file). Serialization parity with that rewrite, or the file
   re-templates and restarts DNS on every converge: the regex must stay
   a plain scalar, while entries starting with ! or | must be
   single-quoted, matching how yaml.v3 writes them back. #}
user_rules:
  - '! Answered NXDOMAIN locally (the RFC 6762 expectation for .local): these'
  - '! names can never resolve publicly, so internal hostnames and typos must'
  - '! not leak to the DoH upstreams. dnsrewrite answers count as rewrites in'
  - '! statistics, not blocks. Parity with the retired dnscrypt-proxy'
  - '! block_unqualified / block_undelegated toggles.'
  - '! Single-label names. Never matches adguard.home or pi.hole (they carry a'
  - '! dot) nor IPv6 literals (the colon exclusion): AdGuard checks HTTPS-record'
  - '! ipv6hints as hostnames, and a dot-only guard would swallow every HTTPS'
  - '! answer carrying one, silently blocking type-65 for half the internet.'
  - /^[^.:]+$/$dnsrewrite=NXDOMAIN
  - '! Undelegated LAN suffixes. `home` and `hole` stay unblocked -- the'
  - '! adguard.home and pi.hole rewrites live under them.'
  - '||lan^$dnsrewrite=NXDOMAIN'
  - '||local^$dnsrewrite=NXDOMAIN'
  - '||internal^$dnsrewrite=NXDOMAIN'
  - '||test^$dnsrewrite=NXDOMAIN'
  - '||home.arpa^$dnsrewrite=NXDOMAIN'
dhcp:
  enabled: false
  interface_name: ""
  local_domain_name: lan
  dhcpv4:
    gateway_ip: ""
    subnet_mask: ""
    range_start: ""
    range_end: ""
    lease_duration: 86400
    icmp_timeout_msec: 1000
    options: []
  dhcpv6:
    range_start: ""
    lease_duration: 86400
    ra_slaac_only: false
    ra_allow_slaac: false
filtering:
  blocking_ipv4: ""
  blocking_ipv6: ""
  blocked_services:
    schedule:
      time_zone: {{ system_timezone }}
    ids: []
  protection_disabled_until: null
  safe_search:
    enabled: false
    bing: true
    duckduckgo: true
    ecosia: true
    google: true
    pixabay: true
    yandex: true
    youtube: true
  blocking_mode: default
  parental_block_host: family-block.dns.adguard.com
  safebrowsing_block_host: standard-block.dns.adguard.com
  rewrites:
    - domain: adguard.home
      answer: 127.0.0.1
      enabled: true
{#
  pihole-era compatibility name: anything still asking pi.hole (operator
  muscle memory, leftover dashboards) gets the same loopback answer.
  Ignored in statistics above alongside adguard.home.
#}
    - domain: pi.hole
      answer: 127.0.0.1
      enabled: true
    - domain: pug.{{ domain }}
      answer: {{ external_ips.pug }}
      enabled: true
    - domain: '*.pug.{{ domain }}'
      answer: {{ external_ips.pug }}
      enabled: true
    - domain: lab.{{ domain }}
      answer: {{ external_ips.lab }}
      enabled: true
    - domain: '*.lab.{{ domain }}'
      answer: {{ external_ips.lab }}
      enabled: true
    - domain: box.{{ domain }}
      answer: {{ external_ips.box }}
      enabled: true
    - domain: '*.box.{{ domain }}'
      answer: {{ external_ips.box }}
      enabled: true
    - domain: auth.{{ domain }}
      answer: {{ external_ips.lab }}
      enabled: true
    - domain: dns.{{ domain }}
      answer: {{ dns_keepalived_ip }}
      enabled: true
  safe_fs_patterns: []
  safebrowsing_cache_size: 1048576
  safesearch_cache_size: 1048576
  parental_cache_size: 1048576
  cache_time: 30
  filters_update_interval: 24
  blocked_response_ttl: 10
  filtering_enabled: true
  rewrites_enabled: true
  parental_enabled: false
  safebrowsing_enabled: false
  protection_enabled: true
clients:
  runtime_sources:
{#
  WHOIS only labels public client IPs over cleartext TCP/43 -- every
  client here is RFC1918, so it is dead weight with an external-egress
  footprint. rDNS stays on: private PTRs resolve through
  local_ptr_upstreams (the UDM), so dashboard names come from DHCP
  without leaving the LAN.
#}
    whois: false
    arp: true
    rdns: true
    dhcp: true
    hosts: true
{#
  Serialization parity with AdGuard's startup rewrite: field order
  mirrors the clientObject struct (internal/home/clients.go), entries
  are listed sorted by name (AdGuard writes them back via
  Storage.RangeByName), and uids are pinned -- AdGuard would otherwise
  generate a random UUIDv7 on first load and the file would re-template
  (and restart DNS) on the next converge.
#}
  persistent:
{#
  Scheduled distraction blocking for the operator phone (static lease in
  data/network_topology.yml). The schedule is inverted from intuition: it
  lists the PAUSE windows when the services are allowed, and blocking
  applies outside them (filtering/blocked.go gates on !Contains). So
  "blocked 22:45-07:00 except Friday and Saturday nights" renders as
  allow 07:00-22:45 weekdays, through midnight on Friday, all of
  Saturday, and from midnight on Sunday. Durations must match
  timeutil.Duration rendering exactly (0s / 7h / 22h45m, and 24h
  serializes as 1d). use_global_blocked_services false is load-bearing:
  true would make AdGuard ignore this list entirely.
#}
    - safe_search:
        enabled: false
        bing: true
        duckduckgo: true
        ecosia: true
        google: true
        pixabay: true
        yandex: true
        youtube: true
      blocked_services:
