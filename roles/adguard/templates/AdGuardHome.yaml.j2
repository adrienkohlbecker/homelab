http:
  pprof:
    port: 6060
    enabled: false
  doh:
    routes:
      - GET /dns-query
      - POST /dns-query
      - GET /dns-query/{ClientID}
      - POST /dns-query/{ClientID}
    insecure_enabled: false
  address: 0.0.0.0:3000
  session_ttl: 30d
users: []
auth_attempts: 5
block_auth_min: 15
http_proxy: ""
language: ""
theme: auto
dns:
  bind_hosts:
    - 0.0.0.0
  port: 53
  anonymize_client_ip: false
  ratelimit: 10000
  ratelimit_subnet_len_ipv4: 32
  ratelimit_subnet_len_ipv6: 64
  ratelimit_whitelist: []
  refuse_any: true
  upstream_dns:
{#
  Primary resolver: Cloudflare DoH keeps household DNS encrypted over normal
  HTTPS/443 and avoids EDNS Client Subnet, favoring privacy over occasionally
  sharper CDN geo-steering.
#}
    - https://cloudflare-dns.com/dns-query
  upstream_dns_file: ""
  bootstrap_dns:
{#
  Bootstrap must be plain DNS; it resolves DoH hostnames before encrypted
  upstreams are reachable. Keep using the shared bootstrap escape hatch.
#}
{% for resolver in bootstrap_dns_resolver %}
    - {{ resolver ~ ':53' }}
{% endfor %}
  fallback_dns:
{#
  Fallback resolver: Google DoH is a broad, reliable secondary when Cloudflare
  is unavailable. ECS stays disabled below for privacy.
#}
    - https://dns.google/dns-query
  upstream_mode: load_balance
  fastest_timeout: 1s
  allowed_clients: []
  disallowed_clients: []
  blocked_hosts: []
  trusted_proxies:
    - 127.0.0.0/8
    - ::1/128
    - {{ podman_bridge_pool }}
  cache_enabled: true
  cache_size: 4194304
  cache_ttl_min: 0
  cache_ttl_max: 0
  cache_optimistic: false
  cache_optimistic_answer_ttl: 30s
  cache_optimistic_max_age: 12h
  bogus_nxdomain: []
  aaaa_disabled: false
  enable_dnssec: true
  edns_client_subnet:
    custom_ip: ""
    enabled: false
    use_custom: false
  max_goroutines: 300
  handle_ddr: true
  ipset: []
  ipset_file: ""
  bootstrap_prefer_ipv6: false
  upstream_timeout: 10s
  private_networks: []
  use_private_ptr_resolvers: true
  local_ptr_upstreams:
    - {{ external_ips.udm ~ ':53' }}
  use_dns64: false
  dns64_prefixes: []
  serve_http3: false
  use_http3_upstreams: false
  serve_plain_dns: true
  hostsfile_enabled: false
  pending_requests:
    enabled: true
tls:
  enabled: false
  server_name: ""
  force_https: false
  port_https: 443
  port_dns_over_tls: 853
  port_dns_over_quic: 853
  port_dnscrypt: 0
  dnscrypt_config_file: ""
  certificate_chain: ""
  private_key: ""
  certificate_path: ""
  private_key_path: ""
  strict_sni_check: false
querylog:
  dir_path: ""
  ignored: []
  interval: 30d
  size_memory: 1000
  enabled: true
  ignored_enabled: false
  file_enabled: true
statistics:
  dir_path: ""
  ignored: []
  interval: 10d
  enabled: true
  ignored_enabled: false
filters:
{% for url in pihole_adlists %}
  - enabled: true
    url: {{ url }}
    name: blocklist_{{ loop.index }}
    id: {{ loop.index }}
{% endfor %}
whitelist_filters:
{% for url in pihole_whitelists %}
  - enabled: true
    url: {{ url }}
    name: allowlist_{{ loop.index }}
    id: {{ 1000 + loop.index }}
{% endfor %}
user_rules: []
dhcp:
  enabled: false
  interface_name: ""
  local_domain_name: lan
  dhcpv4:
    gateway_ip: ""
    subnet_mask: ""
    range_start: ""
    range_end: ""
    lease_duration: 86400
    icmp_timeout_msec: 1000
    options: []
  dhcpv6:
    range_start: ""
    lease_duration: 86400
    ra_slaac_only: false
    ra_allow_slaac: false
filtering:
  blocking_ipv4: ""
  blocking_ipv6: ""
  blocked_services:
    schedule:
      time_zone: {{ system_timezone }}
    ids: []
  protection_disabled_until: null
  safe_search:
    enabled: false
    bing: true
    duckduckgo: true
    ecosia: true
    google: true
    pixabay: true
    yandex: true
    youtube: true
  blocking_mode: default
  parental_block_host: family-block.dns.adguard.com
  safebrowsing_block_host: standard-block.dns.adguard.com
  rewrites:
    - domain: adguard.home
      answer: 127.0.0.1
      enabled: true
    - domain: pug.{{ domain }}
      answer: {{ external_ips.pug }}
      enabled: true
    - domain: '*.pug.{{ domain }}'
      answer: {{ external_ips.pug }}
      enabled: true
    - domain: lab.{{ domain }}
      answer: {{ external_ips.lab }}
      enabled: true
    - domain: '*.lab.{{ domain }}'
      answer: {{ external_ips.lab }}
      enabled: true
    - domain: box.{{ domain }}
      answer: {{ external_ips.box }}
      enabled: true
    - domain: '*.box.{{ domain }}'
      answer: {{ external_ips.box }}
      enabled: true
    - domain: auth.{{ domain }}
      answer: {{ external_ips.lab }}
      enabled: true
  safe_fs_patterns: []
  safebrowsing_cache_size: 1048576
  safesearch_cache_size: 1048576
  parental_cache_size: 1048576
  cache_time: 30
  filters_update_interval: 24
  blocked_response_ttl: 10
  filtering_enabled: true
  rewrites_enabled: true
  parental_enabled: false
  safebrowsing_enabled: false
  protection_enabled: true
clients:
  runtime_sources:
    whois: true
    arp: true
    rdns: true
    dhcp: true
    hosts: true
  persistent: []
log:
  enabled: true
  file: ""
  max_backups: 0
  max_size: 100
  max_age: 3
  compress: false
  local_time: false
  verbose: false
os:
  group: ""
  user: ""
  rlimit_nofile: 0
schema_version: 34
