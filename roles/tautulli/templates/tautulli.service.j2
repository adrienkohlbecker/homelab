#jinja2: lstrip_blocks: True
# tautulli.service #######################################################################
[Unit]
Description=tautulli
After=network-online.target
Wants=network-online.target
StartLimitInterval=600
StartLimitBurst=3
{% if zfs_root %}
{% if zfs_has_services_mount %}
After=zfs_mount_mnt_services.service
Requires=zfs_mount_mnt_services.service
After=zfs_mount_mnt_services_sqlite.service
Requires=zfs_mount_mnt_services_sqlite.service
{% endif %}
After=zfs_autosnapshot.target
PartOf=zfs_autosnapshot.target
{% endif %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutSec=120
# Exceed the container's --stop-timeout (120s) so a slow graceful shutdown --
# during which Tautulli writes config.ini back -- finishes before systemd's
# stop deadline SIGKILLs it and skips the writeback.
TimeoutStopSec=180
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --name tautulli \
    --log-driver journald \
    --log-opt tag="tautulli" \
    --security-opt=no-new-privileges \
    --volume /mnt/services/tautulli:/config \
    --volume /mnt/services/sqlite/tautulli:/mnt/services/sqlite/tautulli \
    --env PUID={{ tautulli_user.uid }} \
    --env PGID={{ media_group.gid }} \
    --env TZ={{ system_timezone }} \
    {# UMASK=027: /config backups bundle config.ini (api_key/pms_token/  #}
    {# jwt_secret); 027 keeps them group-unreadable (image default 022   #}
    {# is group-readable by mode). Tautulli isn't in the media file      #}
    {# pipeline, so no cross-service group-write is sacrificed.          #}
    --env UMASK=027 \
    --network media \
    --publish 127.0.0.1:{{ service_ports.tautulli }}:8181/tcp \
    --health-cmd '["curl","--head","--location","--fail","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://localhost:8181/status"]' \
    --health-startup-cmd '["curl","--head","--location","--fail","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://localhost:8181/status"]' \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "100s" \
    --stop-timeout 120 \
    docker.io/linuxserver/tautulli:2.14.2
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
{% if zfs_root %}
WantedBy=zfs_autosnapshot.target
{% endif %}
