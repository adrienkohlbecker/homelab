#jinja2: lstrip_blocks: True
# socket_proxy.service ################################################################
# Read-only Docker-API proxy in front of the rootful podman socket. netdata's
# go.d docker collector reads container metrics through this (tcp loopback)
# instead of joining the podman-socket group, so a netdata compromise can't
# reach the container-create API. POST is denied by default (read-only); only
# the GET sections the collector needs are enabled (CONTAINERS/IMAGES/INFO;
# VERSION/PING are on by default; EVENTS is explicitly disabled). LOG_LEVEL is
# raised to warning so HAProxy stops logging every proxied request -- netdata's
# docker collector and homepage poll this socket every few seconds (~21 MB/day
# of journald access-log noise otherwise); warning still surfaces real
# proxy/backend errors. The proxy
# itself necessarily holds
# the socket access -- it is the deliberate isolation boundary, a tiny audited
# HAProxy rather than the full netdata daemon. No --user: the bind-mounted
# podman socket is root-owned (0660) and the proxy needs read access.
[Unit]
Description=socket_proxy
After=network-online.target
Wants=network-online.target
After=podman.socket
Requires=podman.socket
StartLimitIntervalSec=600
StartLimitBurst=3

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Delegate=yes
Restart=always
TimeoutSec=120
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --name socket_proxy \
    --init \
    --security-opt=no-new-privileges \
    --network socket_proxy \
    --log-driver journald \
    --log-opt tag="socket_proxy" \
    --volume /run/podman/podman.sock:/var/run/docker.sock:ro \
    --env CONTAINERS=1 \
    --env IMAGES=1 \
    --env INFO=1 \
    --env EVENTS=0 \
    --env POST=0 \
    --env EXEC=0 \
    --env DISABLE_IPV6=1 \
    --env LOG_LEVEL=warning \
    --publish 127.0.0.1:{{ service_ports.socket_proxy }}:2375/tcp \
    --health-cmd '["sh","-c","wget -q -O /dev/null http://127.0.0.1:2375/version"]' \
    --health-startup-cmd '["sh","-c","wget -q -O /dev/null http://127.0.0.1:2375/version"]' \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "30s" \
    --stop-timeout 30 \
    {{ socket_proxy_image }}
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
