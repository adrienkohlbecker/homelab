#jinja2: trim_blocks: False
# {{ ansible_managed }} -- source: host_vars/<host>.yml:fancontrol_settings
# Chip names below (nct6798, drivetemp, etc.) resolve to live
# /sys/class/hwmon/hwmonN at every service start via
# /usr/local/sbin/fancontrol_remap (ExecStartPre). The daemon-input
# file is /etc/fancontrol; this is the template.
{% for f in fancontrol_settings.fans %}
# {{ f.pwm }} -> {{ f.name }}
{%- endfor %}
INTERVAL={{ fancontrol_settings.interval | default(10) }}
FCTEMPS={% for f in fancontrol_settings.fans %}{{ f.pwm }}={{ f.temp }}{% if not loop.last %} {% endif %}{% endfor %}
FCFANS={% for f in fancontrol_settings.fans %}{{ f.pwm }}={{ f.fan }}{% if not loop.last %} {% endif %}{% endfor %}
MINTEMP={% for f in fancontrol_settings.fans %}{{ f.pwm }}={{ f.mintemp }}{% if not loop.last %} {% endif %}{% endfor %}
MAXTEMP={% for f in fancontrol_settings.fans %}{{ f.pwm }}={{ f.maxtemp }}{% if not loop.last %} {% endif %}{% endfor %}
MINSTART={% for f in fancontrol_settings.fans %}{{ f.pwm }}={{ f.minstart }}{% if not loop.last %} {% endif %}{% endfor %}
MINSTOP={% for f in fancontrol_settings.fans %}{{ f.pwm }}={{ f.minstop }}{% if not loop.last %} {% endif %}{% endfor %}
MINPWM={% for f in fancontrol_settings.fans %}{{ f.pwm }}={{ f.minpwm }}{% if not loop.last %} {% endif %}{% endfor %}
{% if fancontrol_settings.fans | selectattr('average', 'defined') | list | length > 0 %}
AVERAGE={% for f in fancontrol_settings.fans %}{{ f.pwm }}={{ f.average | default(1) }}{% if not loop.last %} {% endif %}{% endfor %}
{% endif %}
