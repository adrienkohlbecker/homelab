#!/usr/bin/env python3
# Render /etc/fancontrol from /etc/fancontrol.template against the live
# /sys/class/hwmon. The template uses stable chip names (nct6798,
# drivetemp) as keys; we substitute them to current hwmonN and emit
# DEVPATH/DEVNAME header lines so the fancontrol daemon -- which knows
# only hwmonN -- can consume it.
#
# Why: kernel renumbers hwmon entries across reboots based on module
# load order, and DEVPATH for sata-attached chips also shifts with
# topology changes. Doing the resolution at every service start
# (ExecStartPre) keeps /etc/fancontrol in sync with reality.
# fancontrol's own FixupDeviceFiles is meant to handle drift via
# DEVPATH lookup but is unreliable when DEVPATH itself is stale.
#
# Modes:
#   fancontrol_remap                  read /etc/fancontrol.template,
#                                     write /etc/fancontrol
#   fancontrol_remap --check PATH     parse PATH as a template and assert
#                                     every chip resolves under
#                                     /sys/class/hwmon (used by ansible
#                                     template validate)

import argparse
import re
import sys
from pathlib import Path

TEMPLATE = Path("/etc/fancontrol.template")
OUTPUT = Path("/etc/fancontrol")
HWMON_ROOT = Path("/sys/class/hwmon")

# Chip names are identifiers (letters/digits/underscore) and always
# precede `/<feature>` in template tokens like nct6798/pwm1. The
# leading word-boundary keeps us off arbitrary substrings.
CHIP_TOKEN_RE = re.compile(r"\b([A-Za-z][A-Za-z0-9_]*)/[a-z0-9_]+")


def fail(msg: str) -> None:
    print(f"fancontrol_remap: {msg}", file=sys.stderr)
    sys.exit(1)


def strip_sys(target: str) -> str:
    # Two known DEVPATH layouts: legacy hwmon-classpath chips (nct6798,
    # drivetemp) live at /sys/.../device/hwmon/hwmonN with an
    # intermediate /hwmon/ dir; subsystem-native chips (nvme) live at
    # /sys/.../device/hwmonN directly. The optional (?:/hwmon)? strips
    # either. If neither matches, refuse to write back an unstripped
    # path so the daemon doesn't load a misrouted DEVPATH.
    stripped = re.sub(r"^/sys/(.*?)(?:/hwmon)?/hwmon\d+$", r"\1", target)
    if stripped.startswith("/sys/"):
        fail(f"devpath {target!r} did not match expected layout")
    return stripped


def discover() -> tuple[dict[str, str], dict[str, str]]:
    name_to_hwmon: dict[str, str] = {}
    hwmon_to_devpath: dict[str, str] = {}
    for entry in HWMON_ROOT.iterdir():
        try:
            name = (entry / "name").read_text().strip()
        except OSError:
            continue
        name_to_hwmon[name] = entry.name
        hwmon_to_devpath[entry.name] = strip_sys(str(entry.resolve()))
    return name_to_hwmon, hwmon_to_devpath


def referenced_chips(template_text: str) -> list[str]:
    # Skip comment lines so a `# nct6798/pwm1 -> CPU_FAN` comment using
    # a chip name that's NOT also referenced by a config line doesn't
    # trip the "chip missing" error.
    chips: list[str] = []
    for line in template_text.splitlines():
        if line.lstrip().startswith("#"):
            continue
        for chip in CHIP_TOKEN_RE.findall(line):
            if chip not in chips:
                chips.append(chip)
    return chips


def render(template_text: str) -> str:
    name_to_hwmon, hwmon_to_devpath = discover()
    chips = referenced_chips(template_text)
    missing = [c for c in chips if c not in name_to_hwmon]
    if missing:
        fail(
            f"chips referenced in template but absent from {HWMON_ROOT}: "
            + ", ".join(missing)
        )

    used_hwmons = sorted({name_to_hwmon[c] for c in chips})
    devpath_line = "DEVPATH=" + " ".join(
        f"{hw}={hwmon_to_devpath[hw]}" for hw in used_hwmons
    )
    devname_line = "DEVNAME=" + " ".join(
        f"{name_to_hwmon[c]}={c}" for c in sorted(chips, key=lambda c: name_to_hwmon[c])
    )

    # Substitute chip name -> hwmonN only on non-comment lines. Sort
    # longest-first so a chip "foo_bar" doesn't get partially clobbered
    # by a substitution for "foo" (\b would protect against this, but
    # the explicit ordering is cheaper to reason about).
    out_lines: list[str] = []
    inserted_header = False
    for line in template_text.splitlines():
        if line.startswith("INTERVAL=") and not inserted_header:
            out_lines.append(line)
            out_lines.append(devpath_line)
            out_lines.append(devname_line)
            inserted_header = True
            continue
        if line.lstrip().startswith("#") or not line.strip():
            out_lines.append(line)
            continue
        rewritten = line
        for chip in sorted(chips, key=len, reverse=True):
            rewritten = re.sub(
                rf"\b{re.escape(chip)}\b", name_to_hwmon[chip], rewritten
            )
        out_lines.append(rewritten)

    if not inserted_header:
        fail("template missing required INTERVAL= line")

    return "\n".join(out_lines) + "\n"


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument(
        "--check",
        metavar="PATH",
        help="parse PATH as a template and validate against /sys/class/hwmon",
    )
    args = ap.parse_args()

    if args.check:
        render(Path(args.check).read_text())
        return 0

    if not TEMPLATE.exists():
        return 0
    output = render(TEMPLATE.read_text())
    if not OUTPUT.exists() or OUTPUT.read_text() != output:
        OUTPUT.write_text(output)
        print(f"fancontrol_remap: rewrote {OUTPUT}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
