# {{ ansible_managed }}
# Adds ExecReload to the upstream fluent-bit.service. Paired with
# Hot_Reload On in fluent-bit.conf, conf and lua filter changes apply
# without dropping in-flight records (a restart would empty the
# in-memory backlog despite storage.backlog.flush_on_shutdown=on).
#
# Type=notify + WatchdogSec was attempted as a sd_notify-based
# readiness gate, but fluent-bit 5.0.5 doesn't emit READY=1 on init
# (the binary doesn't appear to honour NOTIFY_SOCKET in our packaged
# build), and the unit timed out after 90s on start. /api/v1/health
# probed from _verify is the practical alternative.
[Service]
ExecReload=/bin/kill -s HUP $MAINPID
