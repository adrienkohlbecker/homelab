# {{ ansible_managed }}
#
# Ships journald + nginx logs to HyperDX over OTLP HTTP. On hosts that
# colocate HyperDX (lab) we hit its OTLP receiver on loopback; everything
# else ships TLS through the hyperdx.lab.{{ domain }} nginx subdomain.
# Auth: a static ingestion token templated in below; rotate by bumping
# hyperdx_ingestion_api_key in the vault and re-running the play.

[SERVICE]
    Flush             5
    Log_Level         warn
    Daemon            off
    Parsers_File      parsers.conf
    # HTTP_Server exposes /api/v1/metrics/prometheus on the loopback for
    # netdata's prometheus collector. The output_dropped_records_total
    # counter increases when fluent-bit exhausts retries against an
    # ingestion endpoint and drops records -- silent log loss otherwise.
    # 127.0.0.1 only, no exposure beyond the host.
    HTTP_Server       on
    HTTP_Listen       127.0.0.1
    HTTP_Port         {{ service_ports.fluentbit }}
    # SIGHUP reparses the config without dropping in-flight records;
    # the systemd unit's ExecReload (installed via the role's
    # override.conf drop-in) sends SIGHUP, and the role's systemd_unit
    # reload: trigger fires on conf/lua changes.
    Hot_Reload        on
    storage.path      /var/lib/fluent-bit/storage/
    storage.sync      normal
    storage.checksum  off
    storage.metrics   on
    storage.backlog.mem_limit  5M
    # Drain in-memory + on-disk backlog before exit so role-triggered
    # restarts (conf / lua changes) don't drop records mid-flight.
    storage.backlog.flush_on_shutdown  on
    # Each [INPUT] below caps its own filesystem backlog at 20M via
    # storage.total_limit_size. Pairs with pause_on_chunks_overlimit so
    # a single misbehaving stream can't fill /var/lib/fluent-bit/storage/
    # and starve the others. Disk budget under back-pressure:
    # 4 inputs * 20M + 50M OTLP output queue = ~130M worst case.

# Everything that logs via systemd journal (which on modern Ubuntu is
# nearly every service — including apt/dpkg/unattended-upgrades that
# the legacy vector role had to tail individually).
#
# Read_From_Tail is a first-install knob: when fluent-bit starts with
# no cursor in journal.db, `on` skips the existing journal (could be
# weeks of retained records on a long-running host); `off` would replay
# everything from disk. Once the cursor exists, the flag is moot —
# fluent-bit resumes from the stored cursor regardless. We keep it on
# rather than gating on journal.db existence: a dynamic value would
# render different conf bytes pre- vs post-first-install and break the
# harness's second-apply idempotence check. The behavioural side-effect
# is that a manual `rm /var/lib/fluent-bit/journal.db` recovery also
# skips to tail; in practice that matches what an operator deleting
# the cursor wants (resume live shipping, not replay days of stale
# journal).
[INPUT]
    Name              systemd
    Tag               svc.*
    Path              /var/log/journal
    DB                /var/lib/fluent-bit/journal.db
    Read_From_Tail    on
    Strip_Underscores on
    storage.type      filesystem
    storage.total_limit_size  20M
    storage.pause_on_chunks_overlimit  on

# Browser-emitted CSP violation reports. nginx on csplogger.<host>.<domain>
# proxies POST /log here; the public endpoint stays public-by-design (CSP
# reports are fire-and-forget cross-origin POSTs that can't carry auth)
# while the OO / HyperDX ingest tokens stay server-side. Returns 204 to
# keep browser report queues happy.
[INPUT]
    Name              http
    Tag               csp.{{ inventory_hostname }}
    Listen            127.0.0.1
    Port              {{ service_ports.csp_ingest }}
    Successful_response_code  204
    # csplogger's nginx caps client_max_body_size at 32k, so anything
    # larger never reaches us. Matching here is defence-in-depth: if the
    # nginx cap is ever raised, the http input still rejects bodies
    # past this size (returns 413). The two tail inputs below still
    # use 256k because they read whole logrotated files at startup.
    Buffer_Max_Size   32k
    storage.type      filesystem
    storage.total_limit_size  20M
    storage.pause_on_chunks_overlimit  on

# nginx access/error logs don't go through journald by default.
# Rotate_Wait holds the pre-rotation inode open for 30s after a
# detected rotation. Ubuntu's /etc/logrotate.d/nginx uses rename+USR1
# (not copytruncate), so the inode changes; 30s vs the upstream
# default 5s buys headroom for high-volume access logs to flush
# their tail-input buffers before fluent-bit closes the old fd.
[INPUT]
    Name              tail
    Tag               nginx.access
    Path              /var/log/nginx/access.log
    DB                /var/lib/fluent-bit/nginx-access.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.total_limit_size  20M
    storage.pause_on_chunks_overlimit  on

[INPUT]
    Name              tail
    Tag               nginx.error
    Path              /var/log/nginx/error.log
    DB                /var/lib/fluent-bit/nginx-error.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.total_limit_size  20M
    storage.pause_on_chunks_overlimit  on

# Join python / go / java / ruby tracebacks into a single record per
# stack so HyperDX doesn't scatter the frames across 10+ rows. Records
# arrive pre-partitioned by systemd unit (the input's Tag svc.* wildcard
# expands _SYSTEMD_UNIT per record), so the multiline buffer can't
# cross-contaminate between concurrent log streams. flush_ms is the
# worst-case added latency for non-continuation lines (default 4s ->
# 1s; tracebacks are emitted contiguously, no need to wait long).
#
# Known quirk of fluent-bit's python parser: the trailing exception
# line ("ValueError: bad input") is emitted *both* as the tail of the
# joined record and as a standalone record. The dup is harmless — it
# just inflates count slightly and provides a redundant searchable copy
# of the error type.
[FILTER]
    Name              multiline
    Match             svc.*
    multiline.parser  python,go,java,ruby
    multiline.key_content  MESSAGE
    buffer            on
    flush_ms          1000
    emitter_name      multiline_emitter
    emitter_storage.type  filesystem

# CSP reports arrive as raw JSON. flatten_csp.lua normalises the two
# wire formats (legacy report-uri + modern Reporting API) into a uniform
# csp_* attribute set so HyperDX queries can filter on
# LogAttributes['csp_blocked_uri'] etc. directly, instead of running
# JSONExtract over a nested csp-report blob. It also synthesises a
# scannable `log` body (CSP <directive> blocked <uri> on <document>) and
# stamps SYSLOG_IDENTIFIER=csplogger on every record -- including
# unparseable POSTs -- so the UI filter pattern documented at the bottom
# of this file (LogAttributes.SYSLOG_IDENTIFIER) reaches them too.
[FILTER]
    Name              lua
    Match             csp.*
    script            /etc/fluent-bit/flatten_csp.lua
    call              flatten_csp

# Two record-shaping passes that apply to every record:
# (a) Stamp inventory_hostname as `host` so cross-stream queries in
#     HyperDX can filter by host without parsing the tag. systemd input
#     also sets HOSTNAME from the journal, but tails don't -- this
#     normalises both. Set (not Add): the CSP HTTP input lets an
#     attacker put `{"host":"lab", ...}` at the top of the POST body,
#     which would otherwise land as a record key; Add's insert-if-
#     absent semantics would refuse to overwrite, Set always wins.
# (b) Rename journald's MESSAGE -> `log` so HyperDX's OTLP output
#     reads it as LogRecord.Body (the opentelemetry output expects
#     `log` by convention). Rename not Copy: HyperDX is the only
#     consumer, no need to keep MESSAGE around. The Rename is a no-op
#     on tail records (no MESSAGE key) so nginx tails' existing `log`
#     field is untouched.
[FILTER]
    Name              modify
    Match             *
    Set               host {{ inventory_hostname }}
    Rename            MESSAGE log

# nginx access logs never carry semantically-meaningful level keywords
# -- every token in the body is an HTTP transaction field. The only
# "alert"/"warning"/"error" substrings are random URL path segments,
# which HyperDX's collector transform processor's body-regex would
# happily upgrade to FATAL/WARN/ERROR (it uses \b not non-word borders
# on both sides). Stamp info up-front to keep that body-regex
# inference from firing on URL noise, and to skip the 120-char
# keyword scan in level_from_message.lua for high-volume access logs.
# The lua filter sees record["severity_text"] and lifts it into the
# OTLP metadata stream (which is what the OTLP output reads).
[FILTER]
    Name              modify
    Match             nginx.access
    Condition         Key_does_not_exist severity_text
    Set               severity_text info
    Set               severity_number 9

# podman's journald log driver labels every stderr line as PRIORITY=3
# (err) regardless of content, so postgres / celery / linuxserver INFO
# chatter swamps `journalctl -p warning`. Parse the message text for
# a level keyword and write severity_text/severity_number into the
# OTLP metadata stream that HyperDX reads. See the script for the
# matching rules and the default-info fallback that prevents
# HyperDX's body-regex inference from firing on records with no real
# level marker.
[FILTER]
    Name              lua
    Match             *
    script            /etc/fluent-bit/level_from_message.lua
    call              set_priority

# Restructure the now-finalised flat record into the OTLP-native shape
# the opentelemetry output below expects (record["otlp"]["attributes"]
# -> LogAttributes, record["resource"]["attributes"] -> Resource
# including service.name for the ClickHouse ServiceName column). Runs
# last so it captures every flat key the upstream filters set. See
# files/otlp_shape.lua for the per-tag service.name derivation.
[FILTER]
    Name              lua
    Match             *
    script            /etc/fluent-bit/otlp_shape.lua
    call              shape_otlp

# Co-located on lab → hit the OTel receiver on loopback. Off-host (pug
# etc.) → TLS through hyperdx.lab.{{ domain }} (nginx subdomain proxies
# /v1/logs to loopback 4318 on lab; see roles/hyperdx).
#
# The bundled OTel collector enforces a per-team auth token on the OTLP
# receiver (opampController in the api wires bearertokenauth/hyperdx
# when at least one team exists in MongoDB, and the hyperdx role
# bootstraps that team with team.apiKey = hyperdx_ingestion_api_key).
# The extension is configured with `scheme: ''`, so the header value
# is the raw token -- NOT "Bearer <token>". Sending the Bearer prefix
# gets a 401 "provided authorization does not match expected scheme".
#
# Record shape: the three lua filters write the event-metadata stream
# (5-arg callback) under metadata.otlp.{severity_text, severity_number,
# attributes, resource}; fluent-bit's opentelemetry output reads that
# namespace via logs_metadata_key=otlp and maps each sub-key onto the
# corresponding LogRecord field (Resource includes service.name, which
# populates the ClickHouse ServiceName column the ClickHouse exporter
# pulls from). record["log"] still feeds LogRecord.Body by convention.
[OUTPUT]
    Name              opentelemetry
    Match             *
{% if fluentbit_otlp_local %}
    Host              127.0.0.1
    Port              {{ service_ports.hyperdx_otlp_http }}
{% else %}
    Host              hyperdx.lab.{{ domain }}
    Port              443
    tls               on
    tls.verify        on
    tls.verify_hostname  on
{% endif %}
    compress          zstd
    workers           1
    logs_uri          /v1/logs
    header            Authorization {{ hyperdx_ingestion_api_key }}
    log_response_payload  false
    logs_metadata_key  otlp
    # Retry_Limit false = no per-chunk retry cap. The backlog is bounded
    # by storage.total_limit_size below (50M on disk), not by retry
    # count: a HyperDX outage longer than ~2min would otherwise discard
    # chunks despite the disk reservation being there to absorb them.
    Retry_Limit       false
    storage.total_limit_size  50M
