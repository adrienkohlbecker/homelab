# {{ ansible_managed }}
#
# Ships journald + nginx logs to HyperDX over OTLP HTTP. On hosts that
# colocate HyperDX (lab) we hit its OTLP receiver on loopback; everything
# else ships TLS through the hyperdx.lab.{{ domain }} nginx subdomain.
# Auth: a static ingestion token templated in below; rotate by bumping
# hyperdx_ingestion_api_key in the vault and re-running the play.

[SERVICE]
    Flush             5
    Log_Level         warn
    Daemon            off
    Parsers_File      parsers.conf
    # HTTP_Server exposes /api/v1/metrics/prometheus on the loopback for
    # netdata's prometheus collector. The output_dropped_records_total
    # counter increases when fluent-bit exhausts retries against an
    # ingestion endpoint and drops records -- silent log loss otherwise.
    # 127.0.0.1 only, no exposure beyond the host.
    HTTP_Server       on
    HTTP_Listen       127.0.0.1
    HTTP_Port         {{ service_ports.fluentbit }}
    # SIGHUP reparses the config without dropping in-flight records;
    # the systemd unit's ExecReload (installed via the role's
    # override.conf drop-in) sends SIGHUP, and the role's systemd_unit
    # reload: trigger fires on conf/lua changes.
    Hot_Reload        on
    storage.path      /var/lib/fluent-bit/storage/
    storage.sync      normal
    storage.checksum  off
    storage.metrics   on
    storage.backlog.mem_limit  5M
    # Drain in-memory + on-disk backlog before exit so role-triggered
    # restarts (conf / lua changes) don't drop records mid-flight.
    storage.backlog.flush_on_shutdown  on

# Everything that logs via systemd journal (which on modern Ubuntu is
# nearly every service — including apt/dpkg/unattended-upgrades that
# the legacy vector role had to tail individually).
#
# Read_From_Tail is a first-install knob: when fluent-bit starts with
# no cursor in journal.db, `on` skips the existing journal (could be
# weeks of retained records on a long-running host); `off` would replay
# everything from disk. Once the cursor exists, the flag is moot —
# fluent-bit resumes from the stored cursor regardless. We keep it on
# rather than gating on journal.db existence: a dynamic value would
# render different conf bytes pre- vs post-first-install and break the
# harness's second-apply idempotence check. The behavioural side-effect
# is that a manual `rm /var/lib/fluent-bit/journal.db` recovery also
# skips to tail; in practice that matches what an operator deleting
# the cursor wants (resume live shipping, not replay days of stale
# journal).
[INPUT]
    Name              systemd
    Tag               svc.*
    Path              /var/log/journal
    DB                /var/lib/fluent-bit/journal.db
    Read_From_Tail    on
    Strip_Underscores on
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

# nginx access/error logs don't go through journald by default.
# Rotate_Wait holds the pre-rotation inode open for 30s after a
# detected rotation. Ubuntu's /etc/logrotate.d/nginx uses rename+USR1
# (not copytruncate), so the inode changes; 30s vs the upstream
# default 5s buys headroom for high-volume access logs to flush
# their tail-input buffers before fluent-bit closes the old fd.
[INPUT]
    Name              tail
    Tag               nginx.access
    Path              /var/log/nginx/access.log
    DB                /var/lib/fluent-bit/nginx-access.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

[INPUT]
    Name              tail
    Tag               nginx.error
    Path              /var/log/nginx/error.log
    DB                /var/lib/fluent-bit/nginx-error.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

# File-backed service logs that can't be routed to journald in their
# own config (or where the volume/UI dependency makes that the wrong
# call): pihole's FTL.log is parsed by the admin web UI's
# diagnosis view and can't be redirected without breaking it; pihole's
# lighttpd access + gravity-update logs live inside the container
# with no exposed override knob, so we tail what the container writes
# to the bind-mounted host dir; clickhouse-server inside hyperdx is
# tailed from the host so a wedged hyperdx doesn't take its own
# self-observability down; the host package-management subsystem
# (apt / dpkg / unattended-upgrades / alternatives / ubuntu-pro-client)
# has no journald routing knob at all; auditd's audit.log is the sole
# audit-record channel after roles/journald disabled the parallel
# kernel-netlink subscription (closes the prior 80/20 dual-write).
#
# Companion log paths we *don't* tail but keep on disk for local
# troubleshooting (operator ssh + grep, never shipped to HyperDX):
#  - /var/log/libvirt/qemu/<vm>.log  -- per-VM qemu stdio / serial
#    console; guest-specific noise, debugged per-VM not globally.
#  - /var/log/zfs_autobackup/*.log   -- rsync --log-file with per-file
#    change records; useful for "why didn't file X land on bunk" but
#    too verbose / too NAS-specific for the central log stream.
#  - /var/log/pihole/pihole.log      -- raw per-query DNS log
#    (~16 MB/day on lab); privacy-sensitive and FTL.log already
#    summarises the operational signal.
#
# Migrated to journald in their own role, so the systemd input above
# already covers them: fail2ban (logtarget=SYSTEMD-JOURNAL in
# fail2ban.local), jellyfin (Serilog File sink disabled via
# /config/logging.json override; Console sink still streams to
# container stdout -> journald), and samba (logging = systemd).
#
# Read_from_Head=off prevents replay of rotated leftovers when
# fluent-bit first sees them.
# Rotate_Wait=30 holds the pre-rotation inode open after a detected
# rotation so the tail buffer flushes -- matches the nginx tails'
# choice for the same reason. service.name lands at the tag
# (lowercased) via otlp_shape's else branch.

# pihole's FTL daemon (the actual DNS resolver + API) writes FTL.log
# directly inside the container at /var/log/pihole/FTL.log, which is
# bind-mounted to the host of the same path. Distinct from the pihole
# container's stdout-to-journald (which carries the lighttpd/s6
# startup chatter, not the FTL runtime trace). Not routed to journald
# because the pihole admin web UI's "Tools -> Pi-hole diagnosis" view
# parses this file directly; redirecting would break the UI.
[INPUT]
    Name              tail
    Tag               pihole_ftl
    Path              /var/log/pihole/FTL.log
    DB                /var/lib/fluent-bit/pihole_ftl.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

# pihole's admin lighttpd access log. Not routed to journald because
# the pihole container ships its own lighttpd config with no exposed
# accesslog.filename knob, and bind-mounting an override is invasive
# for ~100 bytes/day. The pihole DNS query log (pihole.log) is
# deliberately not tailed -- ~16 MB/day on lab, per-query DNS traces
# with no operational value beyond what FTL.log already summarises,
# and privacy-sensitive.
[INPUT]
    Name              tail
    Tag               pihole_webserver
    Path              /var/log/pihole/webserver.log
    DB                /var/lib/fluent-bit/pihole_webserver.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

# pihole's gravity-update cron output. Carries the blocklist refresh
# trace (sources fetched, entries added/skipped, errors); useful to
# spot the day a blocklist starts 404'ing and the gravity dataset
# silently shrinks. Cron writes ANSI escape codes (cursor moves,
# bracket characters) into the file -- fluent-bit ships them as-is,
# HyperDX renders them readable enough.
[INPUT]
    Name              tail
    Tag               pihole_gravity
    Path              /var/log/pihole/pihole_updateGravity.log
    DB                /var/lib/fluent-bit/pihole_gravity.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

# clickhouse-server inside the hyperdx container, bind-mounted to
# /mnt/services/hyperdx/clickhouse_logs/. Tailed from the host so a
# wedged hyperdx doesn't take its own self-observability down with
# it (the standard channel for clickhouse errors is hyperdx ingesting
# its own telemetry -- which requires the clickhouse-server it's
# trying to report on to be alive).
#
# Path narrowed to clickhouse-server.err.log -- the panic / fatal
# stream. clickhouse-server.log carries per-query INFO chatter; with
# fluent-bit shipping every line to HyperDX and HyperDX writing to
# clickhouse, that path creates a tight write-amplification feedback
# loop (every shipped line generates new lines). The .err file
# logs only at warning+; the on-disk .log keeps the verbose trace
# for `ssh + less` when the operator needs it.
[INPUT]
    Name              tail
    Tag               clickhouse_server
    Path              /mnt/services/hyperdx/clickhouse_logs/clickhouse-server.err.log
    DB                /var/lib/fluent-bit/clickhouse_server.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

# auditd's authoritative file. The systemd-journald-audit.socket is
# disabled by roles/journald (Audit=no in journald.conf), so this
# tail is the sole channel for audit records reaching HyperDX --
# closes the ~20% file-only gap (USER_CMD / CRED_REFR / USER_START
# from sudo, etc.) the old dual-write left visible.
[INPUT]
    Name              tail
    Tag               audit
    Path              /var/log/audit/audit.log
    DB                /var/lib/fluent-bit/audit.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

# Host package-management subsystem -- apt, dpkg, unattended-upgrades,
# update-alternatives, plus ubuntu-pro-client (which hooks into apt for
# esm-cache refresh). None of these have a built-in journald routing
# knob (the systemd-unit-level invocations already land in journald,
# but the verbose per-package / per-transaction trace lives only in
# these files). One tail with multiple paths keeps them all in a
# single `host_packages` bucket; Path_Key filepath stamps the source
# file on each record so HyperDX can filter by which file the line
# came from. *.log shape excludes the .log.1 / .log.gz rotated history
# (Read_from_Head=off would skip replay anyway).
#
# certbot's /var/log/letsencrypt/letsencrypt.log is *not* in this
# bucket: certbot writes about cert renewals (not package
# transactions), and the certbot.timer systemd unit already lands
# the operational signal -- renewal success/failure, next-due
# timestamp -- in journald. The on-disk file adds DEBUG-level Python
# trace (suppressed on stdout) that's only useful for the rare
# renewal-debug session and is faster to ssh+less than to query.
[INPUT]
    Name              tail
    Tag               host_packages
    Path              /var/log/apt/*.log,/var/log/dpkg.log,/var/log/unattended-upgrades/*.log,/var/log/alternatives.log,/var/log/ubuntu-advantage.log,/var/log/ubuntu-advantage-apt-hook.log
    DB                /var/lib/fluent-bit/host_packages.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

{% if fluentbit_udm_input %}
# UniFi SIEM syslog: the UDM + APs + switches forward device and
# system logs as RFC 3164 UDP syslog. Bound to this host's management
# IP so only the local LAN can reach it (firewall scopes to the mgmt
# VLAN). Uses a `udp` input + custom parser instead of the `syslog`
# input because UniFi's ident field contains commas and plus signs
# (e.g. "e063da...,UAP-nanoHD-6.7.41+15623") that the stock
# syslog-rfc3164 parser's `[a-zA-Z0-9_\/\.\-]*` rejects.
[INPUT]
    Name              udp
    Tag               unifi
    Listen            {{ ansible_ssh_host }}
    Port              {{ service_ports.udm_syslog }}
    Format            none
    Chunk_Size        32k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on
{% endif %}

# keepalived emits "Printing VRRP as json for process(N) on signal" at
# LOG_INFO every time netdata's prometheus collector scrapes it (default
# ~30s -> ~3k records/day/host of pure scrape chatter). Hardcoded in
# keepalived with no upstream toggle; drop here so it doesn't reach
# HyperDX. The line still lands in journald and /var/log/syslog --
# `journalctl -u keepalived` is the source of truth if you ever need to
# confirm the collector is alive.
[FILTER]
    Name              grep
    Match             svc.*
    Exclude           MESSAGE ^Printing VRRP as json for process

# Drop journal noise from journald-input streams. Each pattern was
# identified from a 24h HyperDX sweep on pug; the count comments are
# the daily volume that motivated the exclude. journalctl on the host
# is still the source of truth for any of these.
#
#  - ansible module invocation echoes (~8k/day on pug during apply
#    windows): every module call logs at LOG_INFO/LOG_ERR with the full
#    parameter dict; appears under mitogen-shaped SYSLOG_IDENTIFIER for
#    mitogen-strategy applies, also under sudo/sshd when sudo wraps the
#    module. Match on the body shape ("ansible-<module> Invoked with")
#    rather than identifier so the otlp_shape.lua mitogen-collapse
#    _verify (which uses a body that doesn't start with "ansible-")
#    keeps passing. `journalctl _COMM=python3` still has them.
#  - cron's per-invocation PAM open/close (~350/day): sysstat (sa1)
#    fires every minute, cron.hourly fires once an hour; the actual
#    CMD line still flows.
#  - kernel: ephemeral podman bridge churn (~140/day): podman healthchecks
#    spawn transient containers that add/remove veth pairs.
#  - kernel: keepalived gratuitous-ARP martians for the pihole VIP
#    (10.123.1.224, ~120/day). Macvlan bridge mode delivers the broadcast
#    to both eth0 and mac_mgmt; mac_mgmt's /28 doesn't cover .224, so the per-iface
#    rp_filter check logs it. Loosening rp_filter site-wide is the bigger
#    hammer (CLAUDE.md "Someday"); meanwhile silence the specific pattern.
#    The "ll header: 00000000:" hex dump is the kernel's follow-up line.
#  - audit/apparmor: ubuntu_pro_esm_cache's apt method probing
#    /etc/gnutls/config (which doesn't exist) -- known harmless DENY,
#    apt method handles ENOENT gracefully.
#  - networkd-dispatcher / networkctl racing with ephemeral podman veths
#    (the iface is gone by the time `networkctl status` fires).
#  - nut 2.7.4 (jammy) double-forks for privilege drop; the child PID
#    lands in /run/nut/upsmon.pid, so systemd warns "Supervising process
#    N which is not our child" at every start. Cosmetic; upstream fix
#    is nut 2.8.x's Type=notify support (not worth backporting).
[FILTER]
    Name              grep
    Match             svc.*
    Exclude           MESSAGE ^ansible-[A-Za-z0-9._]+ Invoked with
    Exclude           MESSAGE ^pam_unix\(cron:session\)
    Exclude           MESSAGE ^podman0: port
    Exclude           MESSAGE ^veth[0-9]+( |@|: )
    Exclude           MESSAGE ^IPv4: martian source 10\.123\.1\.224
    Exclude           MESSAGE ^ll header: 00000000:
    Exclude           MESSAGE name="/etc/gnutls/config"
    Exclude           MESSAGE Failed to get interface "(veth|podman)
    Exclude           MESSAGE Unknown index .* seen, reloading interface list
    Exclude           MESSAGE which is not our child

# audit-tail noise filter. SERVICE_START / SERVICE_STOP for podman
# healthcheck transient .service units (sha256 unit names cycling
# continuously, ~110k/day on lab) are dropped here. The full record
# remains in /var/log/audit/audit.log on the host -- `sudo ausearch
# -m SERVICE_START` or `grep SERVICE_START /var/log/audit/audit.log`
# is the source of truth if ever needed.
[FILTER]
    Name              grep
    Match             audit
    Exclude           log ^type=SERVICE_(START|STOP) msg=audit\([0-9.]+:[0-9]+\): pid=1 uid=0 auid=4294967295 ses=4294967295 subj=unconfined msg='unit=[a-f0-9]{64}

# Per-service scoped excludes. Logical_Op=and means the record is dropped
# only when *all* Exclude rules match -- i.e. the message pattern AND the
# originating systemd unit. Without the SYSTEMD_UNIT gate, the message
# pattern could match unrelated services that happen to log a similar
# line.
#
# speedtest container's apache HEAD / healthcheck (~3k/day on lab):
# internal podman healthcheck hits `/` every 30s, apache logs the access
# at stdout=PRIORITY=6.
[FILTER]
    Name              grep
    Match             svc.*
    Logical_Op        and
    Exclude           SYSTEMD_UNIT ^speedtest\.service$
    Exclude           MESSAGE "HEAD / HTTP/1\.1" 200 [0-9]+ "-" "curl/

# profilarr task-system + git-status info chatter (~2k/day on lab): the
# image has no log-level env, the lines fire every ~60s as the task
# scheduler sweeps. The three patterns cover Repository Sync,
# remote-status updates, and "0 incoming changes" no-op runs.
[FILTER]
    Name              grep
    Match             svc.*
    Logical_Op        and
    Exclude           SYSTEMD_UNIT ^profilarr\.service$
    Exclude           MESSAGE (Task Repository Sync \(ID: 1\) status changed to:|Updating remote status for branch:|Processing 0 incoming changes)

# homepage_alerts (roles/homepage/files/alerts_generate.py) polls
# /api/v1/alarms?active + /api/v1/alarm_log every 30s on each host to
# render the homepage dashboard. That's ~5k access-log lines/day per
# host with no diagnostic value (the response codes already show up
# in netdata's own metrics). UA "homepage-alerts/1" pins the match to
# our own caller.
[FILTER]
    Name              grep
    Match             nginx.access
    Exclude           log "homepage-alerts/1"

# Join python / go / java / ruby tracebacks into a single record per
# stack so HyperDX doesn't scatter the frames across 10+ rows. Records
# arrive pre-partitioned by systemd unit (the input's Tag svc.* wildcard
# expands _SYSTEMD_UNIT per record), so the multiline buffer can't
# cross-contaminate between concurrent log streams. flush_ms is the
# worst-case added latency for non-continuation lines (default 4s ->
# 1s; tracebacks are emitted contiguously, no need to wait long).
#
# Known quirk of fluent-bit's python parser: the trailing exception
# line ("ValueError: bad input") is emitted *both* as the tail of the
# joined record and as a standalone record. The dup is harmless — it
# just inflates count slightly and provides a redundant searchable copy
# of the error type.
[FILTER]
    Name              multiline
    Match             svc.*
    multiline.parser  python,go,java,ruby
    multiline.key_content  MESSAGE
    buffer            on
    flush_ms          1000
    emitter_name      multiline_emitter
    emitter_storage.type  filesystem

{% if fluentbit_udm_input %}
# Parse raw UniFi syslog into structured fields. The udp input delivers
# the whole RFC 3164 line as `log`; parse_unifi.lua handles all three
# wire shapes (gateway daemon syslog, AP/switch device syslog, and CEF
# events), sets `log` to the human-readable body, stamps severity from
# the syslog PRI, and leaves the extracted fields on the record for
# otlp_shape.lua to lift into LogAttributes. A Lua filter rather than a
# `parser` filter because CEF can't be expressed as a fixed regex: its
# extension is a variable set of space-separated key=value pairs whose
# values themselves contain spaces. See the script header for the
# deliberate choice to keep the ingestion timestamp (the syslog stamp
# has no year/timezone and would land records in the future).
[FILTER]
    Name              lua
    Match             unifi
    script            /etc/fluent-bit/parse_unifi.lua
    call              parse_unifi
{% endif %}

# Two record-shaping passes that apply to every record:
# (a) Stamp inventory_hostname as `host` so cross-stream queries in
#     HyperDX can filter by host without parsing the tag. systemd input
#     also sets HOSTNAME from the journal, but tails don't -- this
#     normalises both. Set (not Add): defence-in-depth so an attacker
#     can't spoof `{"host":"lab", ...}` via any ingest path; Add's
#     insert-if-absent semantics would refuse to overwrite, Set always
#     wins.
# (b) Rename journald's MESSAGE -> `log` so HyperDX's OTLP output
#     reads it as LogRecord.Body (the opentelemetry output expects
#     `log` by convention). Rename not Copy: HyperDX is the only
#     consumer, no need to keep MESSAGE around. The Rename is a no-op
#     on tail records (no MESSAGE key) so nginx tails' existing `log`
#     field is untouched.
[FILTER]
    Name              modify
    Match             *
    Set               host {{ inventory_hostname }}
    Rename            MESSAGE log

# nginx access logs never carry semantically-meaningful level keywords
# -- every token in the body is an HTTP transaction field. The only
# "alert"/"warning"/"error" substrings are random URL path segments,
# which HyperDX's collector transform processor's body-regex would
# happily upgrade to FATAL/WARN/ERROR (it uses \b not non-word borders
# on both sides). Stamp info up-front to keep that body-regex
# inference from firing on URL noise, and to skip the 120-char
# keyword scan in level_from_message.lua for high-volume access logs.
# The lua filter sees record["severity_text"] and lifts it into the
# OTLP metadata stream (which is what the OTLP output reads).
[FILTER]
    Name              modify
    Match             nginx.access
    Condition         Key_does_not_exist severity_text
    Set               severity_text info
    Set               severity_number 9

# podman's journald log driver labels every stderr line as PRIORITY=3
# (err) regardless of content, so postgres / celery / linuxserver INFO
# chatter swamps `journalctl -p warning`. Parse the message text for
# a level keyword and write severity_text/severity_number into the
# OTLP metadata stream that HyperDX reads. See the script for the
# matching rules and the default-info fallback that prevents
# HyperDX's body-regex inference from firing on records with no real
# level marker.
[FILTER]
    Name              lua
    Match             *
    script            /etc/fluent-bit/level_from_message.lua
    call              set_priority

# Restructure the now-finalised flat record into the OTLP-native shape
# the opentelemetry output below expects (record["otlp"]["attributes"]
# -> LogAttributes, record["resource"]["attributes"] -> Resource
# including service.name for the ClickHouse ServiceName column). Runs
# last so it captures every flat key the upstream filters set. See
# files/otlp_shape.lua for the per-tag service.name derivation.
[FILTER]
    Name              lua
    Match             *
    script            /etc/fluent-bit/otlp_shape.lua
    call              shape_otlp

# Co-located on lab → hit the OTel receiver on loopback. Off-host (pug
# etc.) → TLS through hyperdx.lab.{{ domain }} (nginx subdomain proxies
# /v1/logs to loopback 4318 on lab; see roles/hyperdx).
#
# The bundled OTel collector enforces a per-team auth token on the OTLP
# receiver (opampController in the api wires bearertokenauth/hyperdx
# when at least one team exists in MongoDB, and the hyperdx role
# bootstraps that team with team.apiKey = hyperdx_ingestion_api_key).
# The extension is configured with `scheme: ''`, so the header value
# is the raw token -- NOT "Bearer <token>". Sending the Bearer prefix
# gets a 401 "provided authorization does not match expected scheme".
#
# Record shape: split between two streams because fluent-bit's OTLP
# output wires record accessors asymmetrically.
#
# (a) LogRecord fields with $otlp[...] accessors (severity_text,
#     severity_number, attributes, trace/span IDs, timestamps) come
#     from the event-metadata stream. The three lua filters (5-arg
#     callback) write metadata.otlp.{severity_text, severity_number,
#     attributes}; logs_metadata_key=otlp selects the namespace.
#
# (b) ResourceLogs.resource has NO $otlp['resource'] accessor. The
#     output reads Resource via the hardcoded $resource['attributes']
#     RA applied to each record's BODY in "standalone context" mode
#     (logs.c's standalone branch jumps to the same set_resource_
#     attributes call the group-start branch uses). otlp_shape.lua
#     writes record["resource"]={attributes=...} to the body, and
#     logs_resource_metadata_key=resource pins it. (commit f59a9e99
#     tried to route Resource through metadata.otlp.resource alongside
#     the others and emitted records with empty ServiceName for two
#     days; this is the revert of just that part.)
#
# record["log"] still feeds LogRecord.Body by convention.
[OUTPUT]
    Name              opentelemetry
    Match             *
{% if fluentbit_otlp_local %}
    Host              127.0.0.1
    Port              {{ service_ports.hyperdx_otlp_http }}
{% else %}
    Host              hyperdx.lab.{{ domain }}
    Port              443
    tls               on
    tls.verify        on
    tls.verify_hostname  on
{% endif %}
    compress          zstd
    workers           1
    logs_uri          /v1/logs
    header            Authorization {{ hyperdx_ingestion_api_key }}
    log_response_payload  false
    logs_metadata_key  otlp
    logs_resource_metadata_key  resource
    # Retry_Limit false = no per-chunk retry cap. The backlog is bounded
    # by storage.total_limit_size below (50M on disk), not by retry
    # count: a HyperDX outage longer than ~2min would otherwise discard
    # chunks despite the disk reservation being there to absorb them.
    Retry_Limit       false
    storage.total_limit_size  50M
