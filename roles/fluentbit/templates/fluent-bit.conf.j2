# {{ ansible_managed }}
#
# Normalizes host logs into one JSON Lines stream for lnav. systemd captures
# stdout to /var/log/fluent-bit/lnav.jsonl; stderr stays in journald so Fluent
# Bit diagnostics never pollute the JSONL store.

[SERVICE]
    Flush             5
    Log_Level         warn
    Daemon            off
    Parsers_File      parsers.conf
    # Absolute paths (not relative like the stock parsers.conf above): the
    # role validates this config with `fluent-bit --dry-run` against a temp
    # copy, so a relative Parsers_File would resolve against the temp dir and
    # fail to load. The role deploys these parser files before this validate.
    Parsers_File      /etc/fluent-bit/parsers_nginx.conf
    # HTTP_Server exposes /api/v1/metrics/prometheus on the loopback for
    # netdata's prometheus collector. The output_dropped_records_total
    # counter increases when fluent-bit exhausts retries against an
    # ingestion endpoint and drops records -- silent log loss otherwise.
    # 127.0.0.1 only, no exposure beyond the host.
    HTTP_Server       on
    HTTP_Listen       127.0.0.1
    HTTP_Port         {{ service_ports.fluentbit }}
    # SIGHUP reparses the config without dropping in-flight records;
    # the systemd unit's ExecReload (installed via the role's
    # override.conf drop-in) sends SIGHUP, and the role's systemd_unit
    # reload: trigger fires on conf/lua changes.
    Hot_Reload        on
    storage.path      /var/lib/fluent-bit/storage/
    storage.sync      normal
    storage.checksum  off
    storage.metrics   on
    storage.backlog.mem_limit  5M
    # Drain in-memory + on-disk backlog before exit so role-triggered
    # restarts (conf / lua changes) don't drop records mid-flight.
    storage.backlog.flush_on_shutdown  on

# Everything that logs via systemd journal (which on modern Ubuntu is
# nearly every service — including apt/dpkg/unattended-upgrades that
# the legacy vector role had to tail individually).
#
# Read_From_Tail is a first-install knob: when fluent-bit starts with
# no cursor in journal.db, `on` skips the existing journal (could be
# weeks of retained records on a long-running host); `off` would replay
# everything from disk. Once the cursor exists, the flag is moot —
# fluent-bit resumes from the stored cursor regardless. We keep it on
# rather than gating on journal.db existence: a dynamic value would
# render different conf bytes pre- vs post-first-install and break the
# harness's second-apply idempotence check. The behavioural side-effect
# is that a manual `rm /var/lib/fluent-bit/journal.db` recovery also
# skips to tail; in practice that matches what an operator deleting
# the cursor wants (resume live shipping, not replay days of stale
# journal).
[INPUT]
    Name              systemd
    Tag               svc.*
    # No Path: libsystemd opens the default journal, which follows journald's
    # Storage= -- /run/log/journal when volatile (the box/minimal test
    # fixtures), /var/log/journal when persistent (prod). Pinning either path
    # makes fluent-bit fail to initialise on hosts using the other.
    DB                /var/lib/fluent-bit/journal.db
    Read_From_Tail    on
    Strip_Underscores on
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

# nginx access/error logs don't go through journald by default.
# Rotate_Wait holds the pre-rotation inode open for 30s after a
# detected rotation. Ubuntu's /etc/logrotate.d/nginx uses rename+USR1
# (not copytruncate), so the inode changes; 30s vs the upstream
# default 5s buys headroom for high-volume access logs to flush
# their tail-input buffers before fluent-bit closes the old fd.
[INPUT]
    Name              tail
    Tag               nginx.access
    Path              /var/log/nginx/access.log
    DB                /var/lib/fluent-bit/nginx-access.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

[INPUT]
    Name              tail
    Tag               nginx.error
    Path              /var/log/nginx/error.log
    DB                /var/lib/fluent-bit/nginx-error.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

# File-backed service logs that can't be routed to journald in their
# own config: the host package-management subsystem (apt / dpkg /
# unattended-upgrades / alternatives / ubuntu-pro-client) has no
# journald routing knob at all; auditd's audit.log is the sole
# audit-record channel after roles/journald disabled the parallel
# kernel-netlink subscription.
#
# Companion log paths we *don't* tail but keep on disk for local
# troubleshooting (operator ssh + grep, not part of the lnav aggregate):
#  - /var/log/libvirt/qemu/<vm>.log  -- per-VM qemu stdio / serial
#    console; guest-specific noise, debugged per-VM not globally.
#  - /var/log/zfs_autobackup/*.log   -- rsync --log-file with per-file
#    change records; useful for "why didn't file X land on bunk" but
#    too verbose / too NAS-specific for the operator triage stream.
#
# Migrated to journald in their own role, so the systemd input above
# already covers them: fail2ban (logtarget=SYSTEMD-JOURNAL in
# fail2ban.local), jellyfin (Serilog File sink disabled via
# /config/logging.json override; Console sink still streams to
# container stdout -> journald), and samba (logging = systemd).
#
# Read_from_Head=off prevents replay of rotated leftovers when
# fluent-bit first sees them.
# Rotate_Wait=30 holds the pre-rotation inode open after a detected
# rotation so the tail buffer flushes -- matches the nginx tails'
# choice for the same reason. service lands at the tag (lowercased) via
# lnav_shape's fallback branch.

# auditd's authoritative file. The systemd-journald-audit.socket is
# disabled by roles/journald (Audit=no in journald.conf), so this
# tail is the sole channel for audit records reaching the lnav aggregate.
[INPUT]
    Name              tail
    Tag               audit
    Path              /var/log/audit/audit.log
    DB                /var/lib/fluent-bit/audit.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on

# Host package-management subsystem -- apt, dpkg, unattended-upgrades,
# update-alternatives, plus ubuntu-pro-client (which hooks into apt for
# esm-cache refresh). None of these have a built-in journald routing
# knob (the systemd-unit-level invocations already land in journald,
# but the verbose per-package / per-transaction trace lives only in
# these files). One tail with multiple paths keeps them all in a
# single `host_packages` bucket; Path_Key filepath stamps the source
# file on each record so lnav can filter by which file the line came from.
# *.log shape excludes the .log.1 / .log.gz rotated history
# (Read_from_Head=off would skip replay anyway).
#
# certbot's /var/log/letsencrypt/letsencrypt.log is *not* in this
# bucket: certbot writes about cert renewals (not package
# transactions), and the certbot.timer systemd unit already lands
# the operational signal -- renewal success/failure, next-due
# timestamp -- in journald. The on-disk file adds DEBUG-level Python
# trace (suppressed on stdout) that's only useful for the rare
# renewal-debug session and is faster to ssh+less than to query.
[INPUT]
    Name              tail
    Tag               host_packages
    Path              /var/log/apt/*.log,/var/log/dpkg.log,/var/log/unattended-upgrades/*.log,/var/log/alternatives.log,/var/log/ubuntu-advantage.log,/var/log/ubuntu-advantage-apt-hook.log
    DB                /var/lib/fluent-bit/host_packages.db
    db.locking        on
    Path_Key          filepath
    Read_from_Head    off
    Skip_Long_Lines   on
    Skip_Empty_Lines  on
    Rotate_Wait       30
    Buffer_Max_Size   256k
    storage.type      filesystem
    storage.pause_on_chunks_overlimit  on


# keepalived emits "Printing VRRP as json for process(N) on signal" at
# LOG_INFO every time netdata's prometheus collector scrapes it (default
# ~30s -> ~3k records/day/host of pure scrape chatter). Hardcoded in
# keepalived with no upstream toggle; drop here so it doesn't reach
# the lnav aggregate. The line still lands in journald and /var/log/syslog --
# `journalctl -u keepalived` is the source of truth if you ever need to
# confirm the collector is alive.
[FILTER]
    Name              grep
    Match             svc.*
    Exclude           MESSAGE ^Printing VRRP as json for process

# Drop journal noise from journald-input streams. Each pattern was
# identified from a 24h log sweep on pug; the count comments are
# the daily volume that motivated the exclude. journalctl on the host
# is still the source of truth for any of these.
#
#  - ansible module invocation echoes (~8k/day on pug during apply
#    windows): every module call logs at LOG_INFO/LOG_ERR with the full
#    parameter dict; appears under mitogen-shaped SYSLOG_IDENTIFIER for
#    mitogen-strategy applies, also under sudo/sshd when sudo wraps the
#    module. Match on the body shape ("ansible-<module> Invoked with")
#    rather than identifier so the lnav_shape.lua mitogen-collapse
#    _verify (which uses a body that doesn't start with "ansible-")
#    keeps passing. `journalctl _COMM=python3` still has them.
#  - cron's per-invocation PAM open/close (~350/day): sysstat (sa1)
#    fires every minute, cron.hourly fires once an hour; the actual
#    CMD line still flows.
#  - kernel: ephemeral podman bridge churn (~140/day): podman healthchecks
#    spawn transient containers that add/remove veth pairs.
#  - audit/apparmor: ubuntu_pro_esm_cache's apt method probing
#    /etc/gnutls/config (which doesn't exist) -- known harmless DENY,
#    apt method handles ENOENT gracefully.
#  - networkd-dispatcher / networkctl racing with ephemeral podman veths
#    (the iface is gone by the time `networkctl status` fires).
#  - nut 2.7.4 (jammy) double-forks for privilege drop; the child PID
#    lands in /run/nut/upsmon.pid, so systemd warns "Supervising process
#    N which is not our child" at every start. Cosmetic; upstream fix
#    is nut 2.8.x's Type=notify support (not worth backporting).
#  - systemd "marked world-inaccessible" warning for the netplan-generated
#    netplan-ovs-cleanup.service (~285/day): a 0600 unit under /run that
#    systemd reads on every daemon-reload. Stock netplan, no effect, no knob.
[FILTER]
    Name              grep
    Match             svc.*
    Exclude           MESSAGE ^ansible-[A-Za-z0-9._]+ Invoked with
    Exclude           MESSAGE ^pam_unix\(cron:session\)
    Exclude           MESSAGE ^podman0: port
    Exclude           MESSAGE ^veth[0-9]+( |@|: )
    Exclude           MESSAGE name="/etc/gnutls/config"
    Exclude           MESSAGE Failed to get interface "(veth|podman)
    Exclude           MESSAGE Unknown index .* seen, reloading interface list
    Exclude           MESSAGE which is not our child
    Exclude           MESSAGE ^Configuration file /run/systemd/system/netplan-ovs-cleanup\.service is marked world-inaccessible

# podman emits a `container health_status` event to the journal every time a
# container's healthcheck runs (~30s) and embeds the container's entire image
# label set in each one (avg ~900 B). On a host running ~30 containers that is
# ~60 MB/day of steady "health_status=healthy" events with no signal -- the
# healthy/unhealthy state already shows on the container's systemd unit and in
# netdata. Drop the steady healthy events; transitions (health_status=starting
# / unhealthy) still flow so a flapping container stays visible. journalctl on
# the host still has the full events.
[FILTER]
    Name              grep
    Match             svc.*
    Exclude           MESSAGE container health_status .*health_status=healthy

# audit-tail noise filter. SERVICE_START / SERVICE_STOP for podman
# healthcheck transient .service units (sha256 unit names cycling
# continuously, ~110k/day on lab) are dropped here. The full record
# remains in /var/log/audit/audit.log on the host -- `sudo ausearch
# -m SERVICE_START` or `grep SERVICE_START /var/log/audit/audit.log`
# is the source of truth if ever needed.
[FILTER]
    Name              grep
    Match             audit
    Exclude           log ^type=SERVICE_(START|STOP) msg=audit\([0-9.]+:[0-9]+\): pid=1 uid=0 auid=4294967295 ses=4294967295 subj=unconfined msg='unit=[a-f0-9]{64}

# Per-service scoped excludes. Logical_Op=and means the record is dropped
# only when *all* Exclude rules match -- i.e. the message pattern AND the
# originating systemd unit. Without the SYSTEMD_UNIT gate, the message
# pattern could match unrelated services that happen to log a similar
# line.
#
# speedtest container's apache curl healthcheck (~5k/day on lab):
# internal podman healthcheck hits `/` every 30s, apache logs the access
# at stdout=PRIORITY=6. The probe uses both HEAD (older) and GET (current).
[FILTER]
    Name              grep
    Match             svc.*
    Logical_Op        and
    Exclude           SYSTEMD_UNIT ^speedtest\.service$
    Exclude           MESSAGE "(HEAD|GET) / HTTP/1\.1" 200 [0-9]+ "-" "curl/

# profilarr task-system + apscheduler chatter (~5k/day on lab): the image
# has no log-level env, the lines fire every ~60s as the task scheduler
# sweeps. Covers the git-status Repository Sync / remote-status / "0 incoming
# changes" no-op runs, plus the apscheduler DEBUG poll ("Looking for jobs to
# run", "Next wakeup is due") and its INFO job-run / task_system bookkeeping.
[FILTER]
    Name              grep
    Match             svc.*
    Logical_Op        and
    Exclude           SYSTEMD_UNIT ^profilarr\.service$
    Exclude           MESSAGE (Task Repository Sync \(ID: 1\) status changed to:|Updating remote status for branch:|Processing 0 incoming changes|apscheduler\.scheduler - DEBUG - (Looking for jobs to run|Next wakeup is due)|apscheduler\.executors\.default - INFO - (Running job|Job )|task_system - INFO - (Starting task: Repository Sync|Task Repository Sync completed successfully))

# netdata internal-churn lines with no operator action, dropped together (all
# netdata.service-scoped, so unrelated services logging a similar line still
# flow). journalctl -u netdata stays the source of truth:
#  - health-DB `Failed to prepare statement SQL_SELECT_HEALTH_LOG` tight loop
#    (~7k/day on lab) and the metadata-DB `Failed to execute 'DROP TABLE ...'
#    (database table is locked)` retries (~2.5k/day on lab).
#  - the LISTENER ACL check that can't reverse-resolve 'localhost' (not in DNS),
#    ~8.6k/day/host -- the single largest netdata noise source.
[FILTER]
    Name              grep
    Match             svc.*
    Logical_Op        and
    Exclude           SYSTEMD_UNIT ^netdata\.service$
    Exclude           MESSAGE (^Failed to prepare statement SQL_SELECT_HEALTH_LOG|^Failed to execute 'DROP TABLE|^LISTENER: Cannot validate 'localhost')

# netdata's debugfs.plugin mirrors each hwmon `inN_alarm` bit and logs a line
# whenever it flips (`voltage sensor '...' transitioned from state ... (kernel
# driver generated)`). The Super-I/O voltage rails (nct6798 in6 on lab) ship
# uncalibrated chip-default min/max limits the real reading straddles, so the
# bit flaps every few minutes (~870/day on lab) -- a known false positive, not a
# real electrical fault. It raises no netdata health alarm (confirmed: 0 active,
# 0 alert transitions) and sends no notification, so it is pure log noise.
# Scoped to `voltage sensor` only: temperature/fan sensor transitions (the ones
# worth seeing) start with a different prefix and still flow.
[FILTER]
    Name              grep
    Match             svc.*
    Logical_Op        and
    Exclude           SYSTEMD_UNIT ^netdata\.service$
    Exclude           MESSAGE ^voltage sensor '[^']+' transitioned from state

# Same debugfs.plugin mechanism for temperatures: the nct6798 Super-I/O temp
# inputs (e.g. temp7_PECI_Agent_0 on pug) carry the same uncalibrated
# chip-default limits as its voltage rails, so the alarm bit flaps clear<->alarm
# every few minutes (~26/day on pug) -- a known false positive, no health alarm,
# no notification. Scoped to the `temperature_nct6798-` sensor name prefix so the
# real ones still flow: drivetemp (drive temps) and coretemp/k10temp (CPU) use
# kernel-provided thresholds, name differently, and DO raise health alarms.
[FILTER]
    Name              grep
    Match             svc.*
    Logical_Op        and
    Exclude           SYSTEMD_UNIT ^netdata\.service$
    Exclude           MESSAGE ^temperature sensor 'temperature_nct6798-isa-

# homepage_alerts.service is a ~24s timer; systemd emits Starting/Finished
# plus the unit's own "Deactivated successfully" on every run (~5k each/day on
# lab). The panel-generation success/failure is visible in the unit state and
# the script's own output -- the lifecycle lines carry no signal. Matched on the
# message text, not a SYSTEMD_UNIT gate: the Starting/Finished lines are logged
# by pid1 (init.scope), not under the unit, so a unit gate would miss them.
# This drops only the lifecycle chatter, NOT the script's own fetch errors
# (a genuine signal -- a poll failing against a peer).
[FILTER]
    Name              grep
    Match             svc.*
    Exclude           MESSAGE ^(Starting|Finished) Generate homepage alerts panel static files
    Exclude           MESSAGE ^homepage_alerts\.service: Deactivated successfully

# tailscaled retries disco pings to peers that have no current endpoint -- a
# mobile peer (phone) that is offline -- logging `disco: failed to send ping
# ... sendto: destination address required` plus `derp-N does not know about
# peer ..., removing route` (~6k/day on lab while a phone is away). Normal,
# recurring, unactionable churn; `tailscale status` is the source of truth for
# peer reachability. The `netcheck: UDP is blocked` path diagnostic is left to
# flow.
[FILTER]
    Name              grep
    Match             svc.*
    Logical_Op        and
    Exclude           SYSTEMD_UNIT ^tailscaled\.service$
    Exclude           MESSAGE (disco: failed to send ping .* sendto: destination address required|derp-[0-9]+ does not know about peer .* removing route)

# hd-idle (the C 1.05 build on jammy/noble) runs in the foreground under -d so
# systemd can track the real process (see roles/hd_idle/files/hd-idle-override.conf);
# -d also prints `probing sdX: reads: N, writes: N` for every disk on every
# poll (~9k/day on lab). The spin-up/down state changes -- the only signal --
# are logged without the `probing` prefix, so drop just the per-poll probes.
[FILTER]
    Name              grep
    Match             svc.*
    Logical_Op        and
    Exclude           SYSTEMD_UNIT ^hd-idle\.service$
    Exclude           MESSAGE ^probing sd[a-z]+: reads:

# homepage_alerts (roles/homepage/files/alerts_generate.py) polls
# /api/v1/alarms?active + /api/v1/alarm_log every 30s on each host to
# render the homepage dashboard. That's ~5k access-log lines/day per
# host with no diagnostic value (the response codes already show up
# in netdata's own metrics). UA "homepage-alerts/1" pins the match to
# our own caller.
#
# Home Assistant streams telemetry to InfluxDB via POST /api/v2/write
# (~40k access-log lines/day on lab, the single largest access-log source).
# Successful telemetry writes carry no operator signal; write failures surface
# in HA and influxdb's own logs and in the nginx.error tail. Drop the write
# POSTs regardless of status.
[FILTER]
    Name              grep
    Match             nginx.access
    Exclude           log "homepage-alerts/1"
    Exclude           log "POST /api/v2/write\?

# Parse the nginx access line into structured HTTP fields (see
# parsers_nginx.conf). Runs after the homepage-alerts drop so we never parse
# lines we are about to discard. Preserve_Key keeps the raw line under `log`
# so lnav_shape still uses the full request as the message body; the parsed
# keys land flat on the record and lnav_shape sweeps them into the JSONL
# `fields` object. Reserve_Data keeps filepath and the other tail metadata.
# A non-matching line (malformed beyond the graceful idiom) is left untouched
# and flows through as a plain message.
[FILTER]
    Name              parser
    Match             nginx.access
    Key_Name          log
    Parser            nginx_access_custom
    Reserve_Data      On
    Preserve_Key      On

# Join python / go / java / ruby tracebacks into a single record per
# stack so lnav doesn't scatter the frames across 10+ rows. Records
# arrive pre-partitioned by systemd unit (the input's Tag svc.* wildcard
# expands _SYSTEMD_UNIT per record), so the multiline buffer can't
# cross-contaminate between concurrent log streams. flush_ms is the
# worst-case added latency for non-continuation lines (default 4s ->
# 1s; tracebacks are emitted contiguously, no need to wait long).
#
# Known quirk of fluent-bit's python parser: the trailing exception
# line ("ValueError: bad input") is emitted *both* as the tail of the
# joined record and as a standalone record. The dup is harmless — it
# just inflates count slightly and provides a redundant searchable copy
# of the error type.
[FILTER]
    Name              multiline
    Match             svc.*
    multiline.parser  python,go,java,ruby
    multiline.key_content  MESSAGE
    buffer            on
    flush_ms          1000
    emitter_name      multiline_emitter
    emitter_storage.type  filesystem

# Two record-shaping passes that apply to every record:
# (a) Stamp inventory_hostname as `host` so cross-stream queries in
#     lnav can filter by host without parsing the tag. systemd input
#     also sets HOSTNAME from the journal, but tails don't -- this
#     normalises both. Set (not Add): defence-in-depth so an attacker
#     can't spoof `{"host":"lab", ...}` via any ingest path; Add's
#     insert-if-absent semantics would refuse to overwrite, Set always
#     wins.
# (b) Rename journald's MESSAGE -> `log` so the later Lua filters have
#     one message key for both journald and tail inputs. Rename not Copy:
#     lnav_shape preserves the original metadata under `fields`.
[FILTER]
    Name              modify
    Match             *
    Set               host {{ inventory_hostname }}
    Rename            MESSAGE log

# Strip ANSI escape sequences (colour/SGR codes, cursor moves) from the
# message. seerr (jellyseerr) wraps its level token in colour codes and
# ships the raw bytes to journald. Besides the visual noise, the colour
# bytes hug the level word
# (\x1b[34mdebug\x1b[39m) and break level_from_message's word-boundary keyword
# scan -- a colourised debug/warn would misclassify as info -- so this runs
# before that filter.
[FILTER]
    Name              lua
    Match             *
    script            /etc/fluent-bit/strip_ansi.lua
    call              strip_ansi

# nginx access logs never carry semantically-meaningful level keywords
# -- every token in the body is an HTTP transaction field. The only
# "alert"/"warning"/"error" substrings are random URL path segments,
# which could otherwise become false warning/error matches. Stamp info
# up-front and skip the 120-char keyword scan in level_from_message.lua
# for high-volume access logs. The lua filter sees record["severity_text"]
# and carries it into the _level field for lnav_shape.
[FILTER]
    Name              modify
    Match             nginx.access
    Condition         Key_does_not_exist severity_text
    Set               severity_text info

# podman's journald log driver labels every stderr line as PRIORITY=3
# (err) regardless of content, so postgres / celery / linuxserver INFO
# chatter swamps `journalctl -p warning`. Parse the message text for
# a level keyword and write the text level into the record's _level field,
# which lnav_shape promotes into the JSONL record body.
[FILTER]
    Name              lua
    Match             *
    script            /etc/fluent-bit/level_from_message.lua
    call              set_priority

# Restructure the now-finalised flat record into the lnav JSONL shape. Runs
# last so it captures every flat key the upstream filters set. See
# files/lnav_shape.lua for the per-tag service derivation.
[FILTER]
    Name              lua
    Match             *
    script            /etc/fluent-bit/lnav_shape.lua
    call              shape_lnav

[OUTPUT]
    Name              stdout
    Match             *
    Format            json_lines
    json_date_key     time
    json_date_format  iso8601
    Workers           1
