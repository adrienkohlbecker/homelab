# {{ ansible_managed }}
#
# Ships journald + nginx logs to OpenObserve on lab. One stream per
# host ({{ inventory_hostname }}); the openobserve UI groups streams
# per-org, so per-host streams keep filtering clean without pre-tagging
# every record. Auth: HTTP Basic with the root account; rotate by
# bumping openobserve_root_password in the vault and re-running the
# play (the new password is templated into this file).

[SERVICE]
    Flush             5
    Log_Level         warn
    Daemon            off
    Parsers_File      parsers.conf
    HTTP_Server       off
    storage.path      /var/lib/fluent-bit/storage/
    storage.sync      normal
    storage.checksum  off
    storage.backlog.mem_limit  5M

# Everything that logs via systemd journal (which on modern Ubuntu is
# nearly every service — including apt/dpkg/unattended-upgrades that
# the legacy vector role had to tail individually).
[INPUT]
    Name              systemd
    Tag               journal.*
    Path              /var/log/journal
    DB                /var/lib/fluent-bit/journal.db
    Read_From_Tail    on
    Strip_Underscores on

# Browser-emitted CSP violation reports. nginx on csplogger.<host>.<domain>
# proxies POST /log here; the public endpoint stays public-by-design (CSP
# reports are fire-and-forget cross-origin POSTs that can't carry auth)
# while the OO / HyperDX ingest tokens stay server-side. Returns 204 to
# keep browser report queues happy.
[INPUT]
    Name              http
    Tag               csp.{{ inventory_hostname }}
    Listen            127.0.0.1
    Port              {{ service_ports.csp_ingest }}
    Successful_response_code  204

# nginx access/error logs don't go through journald by default.
[INPUT]
    Name              tail
    Tag               nginx.access
    Path              /var/log/nginx/access.log
    DB                /var/lib/fluent-bit/nginx-access.db
    Path_Key          filepath
    Refresh_Interval  5
    Skip_Long_Lines   on

[INPUT]
    Name              tail
    Tag               nginx.error
    Path              /var/log/nginx/error.log
    DB                /var/lib/fluent-bit/nginx-error.db
    Path_Key          filepath
    Refresh_Interval  5
    Skip_Long_Lines   on

# Partition journal records by service before the multiline filter
# runs. The multiline filter buffers per-tag, so without retagging, a
# paperless INFO line arriving mid-flush inside a homeassistant python
# traceback would get appended to it. Records without SYSLOG_IDENTIFIER
# (rare) keep the original journal.* tag and pass through unchanged.
[FILTER]
    Name              rewrite_tag
    Match             journal.*
    Rule              $SYSLOG_IDENTIFIER ^(.+)$ svc.$1 false
    Emitter_Name      re_emit_svc

# Join python / go / java / ruby tracebacks into a single record per
# stack so OpenObserve doesn't scatter the frames across 10+ rows.
# Per-service tag partitioning above is what keeps the buffer from
# cross-contaminating between concurrent log streams. flush_ms is the
# worst-case added latency for non-continuation lines (default 4s ->
# 1s; tracebacks are emitted contiguously, no need to wait long).
#
# Known quirk of fluent-bit's python parser: the trailing exception
# line ("ValueError: bad input") is emitted *both* as the tail of the
# joined record and as a standalone record. The dup is harmless — it
# just inflates count slightly and provides a redundant searchable copy
# of the error type.
[FILTER]
    Name              multiline
    Match             svc.*
    multiline.parser  python,go,java,ruby
    multiline.key_content  MESSAGE
    buffer            on
    flush_ms          1000

# CSP reports arrive as raw JSON. flatten-csp.lua normalises the two
# wire formats (legacy report-uri + modern Reporting API) into a uniform
# csp_* attribute set so HyperDX queries can filter on
# LogAttributes['csp_blocked_uri'] etc. directly, instead of running
# JSONExtract over a nested csp-report blob. It also synthesises a
# scannable `log` body (CSP <directive> blocked <uri> on <document>) and
# stamps SYSLOG_IDENTIFIER=csplogger on every record -- including
# unparseable POSTs -- so the UI filter pattern documented at the bottom
# of this file (LogAttributes.SYSLOG_IDENTIFIER) reaches them too.
[FILTER]
    Name              lua
    Match             csp.*
    script            /etc/fluent-bit/flatten-csp.lua
    call              flatten_csp

# Tag every record with the inventory hostname so cross-stream queries
# in OpenObserve can still filter by host without parsing the stream
# name. systemd input also sets HOSTNAME from the journal, but tails
# don't — this normalises both.
[FILTER]
    Name              modify
    Match             *
    Add               host {{ inventory_hostname }}

# Mirror journald's MESSAGE into `log` so the parallel HyperDX OTLP
# output below picks it up as the LogRecord Body (fluent-bit's
# opentelemetry output uses `log` by convention). Copy not Rename:
# the OpenObserve HTTP output still references MESSAGE as the canonical
# body field, so both pipelines need their respective key intact. The
# modify Copy is a no-op when MESSAGE doesn't exist (nginx tails),
# leaving their existing `log` field untouched.
[FILTER]
    Name              modify
    Match             *
    Copy              MESSAGE log

# podman's journald log driver labels every stderr line as PRIORITY=3
# (err) regardless of content, so postgres / celery / linuxserver INFO
# chatter swamps `journalctl -p warning`. Parse the message text for a
# level token and overwrite PRIORITY. See the script for the matching
# rules. Non-matching records (kernel, systemd, anything without a
# recognisable level keyword in the first 120 chars) pass through with
# the journald-supplied PRIORITY intact.
[FILTER]
    Name              lua
    Match             *
    script            /etc/fluent-bit/level-from-message.lua
    call              set_priority

# Restructure the now-finalised flat record into the OTLP-native shape
# the opentelemetry output below expects (record["otlp"]["attributes"]
# -> LogAttributes, record["resource"]["attributes"] -> Resource
# including service.name for the ClickHouse ServiceName column). Runs
# last so it captures every flat key the upstream filters set. See
# files/otlp-shape.lua for the per-tag service.name derivation.
[FILTER]
    Name              lua
    Match             *
    script            /etc/fluent-bit/otlp-shape.lua
    call              shape_otlp

[OUTPUT]
    Name              http
    Match             *
{% if inventory_hostname in ['box', 'lab'] %}
    # openobserve is co-located: skip nginx + public DNS + TLS and hit
    # its published loopback port directly. Decouples fluent-bit's
    # bootstrap from pihole/dnscrypt readiness (the upstream's
    # getaddrinfo race during the 02:20 podman cycle stops being a
    # thing) and removes the cert/handshake from the per-flush path.
    Host              127.0.0.1
    Port              {{ service_ports.openobserve }}
{% else %}
    Host              openobserve.lab.{{ domain }}
    Port              443
    tls               on
    tls.verify        on
{% endif %}
    URI               /api/default/{{ inventory_hostname }}/_json
    Format            json
    Json_date_key     _timestamp
    Json_date_format  iso8601
    http_User         {{ root_email }}
    http_Passwd       {{ openobserve_root_password }}
    Retry_Limit       False
    storage.total_limit_size  50M

{% if inventory_hostname in ['box', 'lab'] %}
# Parallel-ship to HyperDX over OTLP HTTP for the evaluation window (see
# CLAUDE.md "Someday" -- pick a winner between OO and HyperDX and drop
# the loser). HyperDX is co-located on the same hosts where it's
# installed (lab roles in site.yml), so target loopback directly.
#
# The bundled OTel collector enforces a per-team auth token on the OTLP
# receiver (opampController in the api wires bearertokenauth/hyperdx
# when at least one team exists in MongoDB, and the hyperdx role
# bootstraps that team with team.apiKey = hyperdx_ingestion_api_key).
# The extension is configured with `scheme: ''`, so the header value
# is the raw token -- NOT "Bearer <token>". Sending the Bearer prefix
# gets a 401 "provided authorization does not match expected scheme".
#
# Record shape: fluent-bit's opentelemetry output only promotes specific
# "metadata" record keys to LogRecord fields (log -> Body, plus the
# configured logs_metadata_key sub-map for attributes / severity /
# trace / span and logs_resource_metadata_key sub-map for Resource).
# Top-level keys outside the recognised set are silently dropped on
# serialization -- which is why earlier records reached HyperDX with
# empty LogAttributes and a blank ServiceName column. The shape-otlp
# lua filter (Match *, runs last) restructures the flat record into
# record["otlp"]["attributes"] (-> LogAttributes) and
# record["resource"]["attributes"] (-> ResourceAttributes including
# service.name, which populates the ServiceName column ClickHouse
# exporter pulls from Resource).
[OUTPUT]
    Name              opentelemetry
    Match             *
    Host              127.0.0.1
    Port              {{ service_ports.hyperdx_otlp_http }}
    logs_uri          /v1/logs
    header            Authorization {{ hyperdx_ingestion_api_key }}
    log_response_payload  false
    # Resource is the only OTLP field fluent-bit's opentelemetry output
    # can populate from a record body key. The default for
    # logs_resource_metadata_key is a body-level lookup ("resource"), so
    # otlp-shape.lua's record["resource"]["attributes"] map flows
    # through to LogRecord.Resource and the ClickHouse exporter
    # populates the ServiceName column. The other metadata-key options
    # (logs_attributes_metadata_key, logs_severity_*_metadata_key) all
    # default to fluent-bit's separate event-metadata stream which lua
    # filters can't populate from the standard callback signature;
    # overriding them to body keys doesn't help -- the output ignores
    # any value that isn't sourced from the event-metadata stream.
    # Instead we encode LogRecord attributes and severity into Body as
    # "warn: <prose> {<json>}" and let HyperDX's collector transform
    # processor extract them on receive. See flatten-csp.lua for the
    # body construction.
    logs_resource_metadata_key         resource
    Retry_Limit       False
    storage.total_limit_size  50M
{% endif %}
