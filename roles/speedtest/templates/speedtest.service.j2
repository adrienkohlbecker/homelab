# speedtest.service #######################################################################
[Unit]
Description=speedtest
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=600
StartLimitBurst=3

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutSec=120
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --name speedtest \
    --log-driver journald \
    --log-opt tag="speedtest" \
    --network speedtest \
    --security-opt=no-new-privileges \
    --user 0:0 \
    {{ speedtest_user | podman_idmap_args | join(" ") }} \
    --env MODE=standalone \
    --env WEBPORT={{ service_ports.speedtest }} \
    --env DISABLE_IPINFO=true \
    --publish 127.0.0.1:{{ service_ports.speedtest }}:{{ service_ports.speedtest }}/tcp \
    --health-cmd         {{ ('http://localhost:' ~ service_ports.speedtest ~ '/') | podman_health_curl }} \
    --health-startup-cmd {{ ('http://localhost:' ~ service_ports.speedtest ~ '/') | podman_health_curl }} \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "100s" \
    --stop-timeout 10 \
    {{ speedtest_image }}
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
