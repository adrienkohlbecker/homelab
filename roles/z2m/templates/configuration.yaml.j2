# Indicates the configuration version (used by configuration migrations)
version: 5

# Home Assistant integration (MQTT discovery)
homeassistant:
  enabled: true

# Strip tilt_* from every cover's discovery payload. The Schneider S520567
# Roller shutter converter advertises tilt support but the hardware has no
# tilt, so every state update triggers a HA "no attribute 'tilt'" template
# warning. Safe globally only because all covers currently routed through
# z2m here are S520567s; move to per-device overrides in devices.yaml if a
# real venetian/tilt-capable cover is ever added.
device_options:
  homeassistant:
    cover:
      tilt_status_topic: null
      tilt_status_template: null
      tilt_command_topic: null

# Enable the frontend, runs on port 8080 by default
frontend:
  enabled: true
  port: 8081
  url: https://z2m.{{ inventory_hostname }}.{{ domain }}

# MQTT settings
mqtt:
  # MQTT base topic for zigbee2mqtt MQTT messages
  base_topic: zigbee2mqtt
  # MQTT server URL
  server: 'mqtt://mosquitto:1883'
  # MQTT server authentication, uncomment if required:
  user: '!secret.yaml mqtt_user'
  password: '!secret.yaml mqtt_password'

# Serial settings, only required when Zigbee2MQTT fails to start with:
#   USB adapter discovery error (No valid USB adapter found).
#   Specify valid 'adapter' and 'port' in your configuration.
# serial:
#   # Location of the adapter
#   # USB adapters - use format "port: /dev/serial/by-id/XXX"
#   # Ethernet adapters - use format "port: tcp://192.168.1.12:6638"
#   port: /dev/serial/by-id/usb-Texas_Instruments_TI_CC2531_USB_CDC___0X00124B0018ED3DDF-if00
#   # Adapter type, allowed values: `zstack`, `ember`, `deconz`, `zigate` or `zboss`
#   adapter: zstack
serial:
  port: tcp://{{ external_ips.tubeszb }}:6638
  adapter: zstack

# Periodically check whether devices are online/offline
availability:
  enabled: true

# Advanced settings
advanced:
  # channel: 11
  network_key: '!secret.yaml network_key'
  pan_id: 40336
  ext_pan_id:
    - 92
    - 37
    - 125
    - 47
    - 127
    - 57
    - 250
    - 171
  last_seen: ISO_8601

devices: devices.yaml
groups: groups.yaml

blocklist:
  - '0x00178801091c4186'
  - '0x00178801091c419d'
  - '0x00178801091c4186'
  - '0x00178801091c419d'
