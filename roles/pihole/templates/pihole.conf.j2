# vim:ft=yaml
# netdata 2.x go.d/pihole module: talks to the pi-hole v6 REST API
# (/api/auth + /api/stats/summary) and authenticates with the plaintext
# web password, which it exchanges for a session. Job name `local` matches
# the `go.d:collector:pihole:local` entry in host_vars.
jobs:
  - name: local
    url: http://127.0.0.1:{{ service_ports.pihole }}
    password: {{ pihole_password | to_json }}
    autodetection_retry: 60
