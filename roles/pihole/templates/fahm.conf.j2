address=/pug.fahm.fr/{{ external_ips.pug }}
address=/lab.fahm.fr/{{ external_ips.lab }}
address=/box.fahm.fr/{{ external_ips.box }}
# Authelia portal: public Cloudflare has `auth.fahm.fr` CNAME
# `lab.fahm.fr` → public IP. For LAN clients we shortcut to lab's
# internal IP directly so traffic doesn't hairpin through WAN /
# wireguard. dnsmasq's `address=/...` matches the name + every
# subdomain, but auth lives at the apex (not under .lab.) so it
# needs its own line.
address=/auth.fahm.fr/{{ external_ips.lab }}
