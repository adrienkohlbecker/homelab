#!/bin/bash
set -euo pipefail

# Holds a systemd shutdown:block inhibitor lock while no pihole keepalived
# peer can answer DNS. Prevents rebooting the last DNS server via any path
# (manual, ansible, unattended-upgrades). Override with `systemctl reboot
# --force`.
#
# Reactive: watches keepalived journal for state transitions (BACKUP =
# peer is MASTER = safe, instant unlock; MASTER/FAULT/STOP = probe peer).
# Falls back to a periodic DNS probe every 30s when the journal is idle.
#
# Probes `pi.hole` (pihole-local, no external dependency) — if FTL answers
# at all (even NXDOMAIN), rc=0 = service alive; timeout/refused = rc!=0.

PEER_IPS=(
{% for peer in pihole_keepalived_peers | reject('eq', inventory_hostname) | sort %}
  {{ external_ips[peer] }}
{% endfor %}
)

LOCK_PID=

take_lock() {
  if [ -z "$LOCK_PID" ]; then
    systemd-inhibit \
      --what=shutdown \
      --mode=block \
      --who="pihole_reboot_guard" \
      --why="No healthy pihole peer — this host is the last DNS server" \
      sleep infinity &
    LOCK_PID=$!
  fi
}

release_lock() {
  if [ -n "${LOCK_PID:-}" ]; then
    kill "$LOCK_PID" 2>/dev/null || true
    wait "$LOCK_PID" 2>/dev/null || true
    LOCK_PID=
  fi
}

check_peers() {
  for ip in "${PEER_IPS[@]}"; do
    if dig +timeout=3 +tries=1 "@${ip}" pi.hole >/dev/null 2>&1; then
      return 0
    fi
  done
  return 1
}

update_lock() {
  if check_peers; then
    release_lock
  else
    take_lock
  fi
}

trap 'release_lock; exit 0' SIGTERM SIGINT

update_lock

while true; do
  # Read keepalived state transitions reactively. BACKUP = peer is MASTER
  # and healthy (instant unlock). MASTER/FAULT/STOP = peer may be down
  # (probe to confirm). `read -t 30` fires a periodic fallback probe when
  # the journal is idle. If journalctl exits (journal rotation, unit
  # absent), the inner loop ends and the outer loop restarts it.
  while IFS= read -r -t 30 line; do
    case "$line" in
      *BACKUP*)
        release_lock
        ;;
      *MASTER*|*FAULT*|*STOP*)
        update_lock
        ;;
    esac
  done < <(journalctl -t pihole-keepalived -f --since=now -o cat 2>/dev/null || true)

  update_lock
done
