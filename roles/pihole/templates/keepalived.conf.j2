vrrp_script pihole_healthcheck {
  script    /usr/local/bin/pihole_healthcheck
  interval  1
  timeout   5
  rise      1
  fall      2
  user      root
  # Start the script in FAILED state so keepalived enters FAULT on every
  # restart and only transitions out once the healthcheck passes once --
  # a deterministic gate on pihole's actual health rather than a wallclock
  # startup delay.
  init_fail
}

vrrp_instance pihole {
  state     BACKUP
  interface eth0

  # Create a dedicated macvlan child `vrrp.{{ pihole_keepalived_vrid }}` on
  # eth0 with the VRRP standard MAC 00:00:5e:00:01:{{ '%02x' % pihole_keepalived_vrid }} and
  # carry the VIP on it. Without use_vmac the VIP rides eth0's primary MAC
  # and the periodic GARP below (which announces VIP→hostMAC) trips UniFi's
  # last-write-wins client tracker — the host's UniFi client entry flips
  # from its primary IP to the pihole VIP. A dedicated vmac splits that
  # into two distinct UniFi clients (host + VIP) and keeps both stable.
  use_vmac
  # Source outbound traffic on eth0, not the vmac. Two reasons: the firewall
  # scopes the VRRP-accept rule to iifname $WAN_IFACE (= eth0; see
  # roles/firewall/templates/nftables.conf.j2), so peer adverts must continue
  # to ingress on eth0; and pihole's reply traffic for the VIP keeps its
  # existing L2 path instead of acquiring the vmac as egress iface.
  vmac_xmit_base

  unicast_src_ip {{ external_ips[inventory_hostname] }}
  unicast_peer {
    {% for name in pihole_keepalived_peers | select("ne", inventory_hostname) | sort %}
    {{ external_ips[name] }}
    {% endfor %}
  }

  virtual_router_id {{ pihole_keepalived_vrid }}
  priority          {{ pihole_keepalived_priority }}
  advert_int        1

  # Delay a recovered higher-priority node from reclaiming the VIP for
  # 60s, so a flapping FTL doesn't yank the VIP back (re-churning the GARP
  # / UniFi MAC update) the instant its healthcheck rises again. Plain
  # preempt (no nopreempt) is kept so the MASTER does eventually reclaim.
  preempt_delay     60

  virtual_ipaddress {
    {{ pihole_keepalived_ip }}/32
  }

  # Periodic gratuitous ARP so any LAN cache that picks up a wrong MAC
  # for the VIP self-heals within ~1 minute. With use_vmac above, GARPs
  # advertise VIP→vmac-MAC (00:00:5e:00:01:{{ '%02x' % pihole_keepalived_vrid }}), so a stale cache
  # pointing at the previous MASTER's vmac (or — pre-vmac-rollout — at
  # the host's eth0 MAC) gets refreshed within the refresh window.
  garp_master_repeat 3
  garp_master_refresh 60

  track_script {
    pihole_healthcheck
  }

  notify_master "/usr/bin/logger -t pihole-keepalived MASTER"
  notify_backup "/usr/bin/logger -t pihole-keepalived BACKUP"
  notify_fault  "/usr/bin/logger -t pihole-keepalived FAULT"
  # The state-transition hooks above don't fire when keepalived itself is
  # stopped (SIGTERM during the throttled rolling restart), so notify_stop
  # leaves a breadcrumb in the journal at exactly that planned VIP handoff.
  notify_stop   "/usr/bin/logger -t pihole-keepalived STOP"
}
