#jinja2: lstrip_blocks: True
# transmission.service #######################################################################
[Unit]
Description=transmission
After=network-online.target
Wants=network-online.target
StartLimitInterval=600
StartLimitBurst=3
{% if zfs_root %}
{% if zfs_has_services_mount %}
After=zfs_mount_mnt_services.service
Requires=zfs_mount_mnt_services.service
{% endif %}
{% if zfs_has_scratch_mount %}
After=zfs_mount_mnt_scratch.service
Requires=zfs_mount_mnt_scratch.service
{% endif %}
{% if zfs_has_media_mount %}
After=zfs_mount_mnt_media.service
Requires=zfs_mount_mnt_media.service
{% endif %}
After=zfs_autosnapshot.target
PartOf=zfs_autosnapshot.target
{% endif %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutSec=120
TimeoutStopSec=150
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --name transmission \
    --security-opt=no-new-privileges \
    --log-driver journald \
    --log-opt tag="transmission" \
    --env PUID={{ transmission_user.uid }} \
    --env PGID={{ media_group.gid }} \
    --env UMASK=002 \
    --env TZ={{ system_timezone }} \
    --env USER=transmission \
    --env HOST_WHITELIST={{ transmission_host_whitelist }} \
    --secret=transmission_rpc_password,type=mount,target=pass \
    --env FILE__PASS=/run/secrets/pass \
    --volume /mnt/services/transmission:/config \
    --volume /mnt/media/Torrents:/downloads/complete \
    --volume /mnt/scratch/transmission:/downloads/incomplete \
    --network media \
    --publish 127.0.0.1:{{ service_ports.transmission }}:9091/tcp \
    --publish 0.0.0.0:{{ service_ports.transmission_bt }}:51413/tcp \
    --publish 0.0.0.0:{{ service_ports.transmission_bt }}:51413/udp \
{# Liveness only -- a credential-free probe so it needs neither the rpc secret
   nor the host-whitelist. RPC auth is enforced for real clients (the *arr leg,
   asserted in _verify); here a bare GET to the RPC endpoint draws transmission's
   409 CSRF response, which precedes auth, and curl without -f exits 0 on any
   HTTP reply (only a refused/closed port is non-zero). 127.0.0.1 is always
   allowed regardless of rpc-host-whitelist. #}
    --health-cmd         '["curl","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://127.0.0.1:9091/transmission/rpc"]' \
    --health-startup-cmd '["curl","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://127.0.0.1:9091/transmission/rpc"]' \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "100s" \
    --stop-timeout 120 \
    docker.io/linuxserver/transmission:4.1.1
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
{% if zfs_root %}
WantedBy=zfs_autosnapshot.target
{% endif %}
