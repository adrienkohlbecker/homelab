*filter
# Allow all outgoing, but drop incoming and forwarding packets by default
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# Custom chains
:FWD_DROP - [0:0]

##################################################
#                   INPUT RULES                  #
##################################################

# Established/related and loopback are accepted unconditionally; INVALID
# is dropped. After these three lines, every remaining packet is NEW —
# so no rule below needs an explicit `--ctstate NEW` qualifier.
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A INPUT -i lo -j ACCEPT
-A INPUT -m conntrack --ctstate INVALID -j DROP

# TCP NEW must have SYN. Conntrack's loose mode (default) classifies
# mid-stream non-SYN packets as NEW rather than INVALID, so without
# this an attacker could probe TCP services with crafted ACKs.
# Flipping the sysctl `nf_conntrack_tcp_loose=0` would catch them via
# INVALID DROP — but doing so live disconnects in-flight SSH on the
# first apply because the sysctl change classifies pre-existing
# untracked packets as INVALID. Keep the explicit rule.
-A INPUT -p tcp ! --syn -j DROP

# UDP traffic rules
-A INPUT -p udp --dport 1900  -j ACCEPT                                     -m comment --comment "Allow UPnP broadcast"
-A INPUT -p udp --dport 5053  -j ACCEPT                                     -m comment --comment "Allow dnscrypt-proxy"
-A INPUT -p udp --dport 5333  -j ACCEPT                                     -m comment --comment "Allow aardvark-dns (post-DNAT from gateway:53)"
-A INPUT -p udp --dport 5353  -j ACCEPT                                     -m comment --comment "Allow mDNS"
-A INPUT -p udp --dport 6667  -j ACCEPT                                     -m comment --comment "Allow Tuya discovery"
-A INPUT -p udp --dport 51820 -j ACCEPT                                     -m comment --comment "Allow Wireguard"
-A INPUT -p udp --dport 60000 -j ACCEPT                                     -m comment --comment "Allow Mosh"

# be explicit with rejection of known traffic so they are documented and don't appear in logs
-A INPUT -p udp --dport 67    -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny DHCP"
-A INPUT -p udp --dport 137   -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny NetBIOS"
-A INPUT -p udp --dport 138   -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny NetBIOS"
-A INPUT -p udp --dport 139   -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny NetBIOS"
-A INPUT -p udp --dport 5351  -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny NAT-PMP"
-A INPUT -p udp --dport 10001 -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny Unifi device discovery broadcast"
-A INPUT -p udp --dport 17500 -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny Dropbox LanSync"
-A INPUT -p udp --dport 57621 -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny Spotify P2P"

# TCP traffic rules
-A INPUT -p tcp --dport 22    -j ACCEPT                                     -m comment --comment "Allow SSH"
-A INPUT -p tcp --dport 80    -j ACCEPT                                     -m comment --comment "Allow HTTP"
-A INPUT -p tcp --dport 443   -j ACCEPT                                     -m comment --comment "Allow HTTPS"
-A INPUT -p tcp --dport 445   -j ACCEPT                                     -m comment --comment "Allow Samba"
-A INPUT -p tcp --dport 3493  -j ACCEPT                                     -m comment --comment "Allow nut"

# ICMP — ping et al. ESTABLISHED/RELATED handles replies; this is for new incoming.
-A INPUT -p icmp -j ACCEPT

# Other protocols
-A INPUT -p 112 -j ACCEPT -m comment --comment "Allow keepalived (VRRP)"
-A INPUT -p 51  -j ACCEPT -m comment --comment "Allow keepalived (auth_type AH)"

# Reject anything that's fallen through to this point
## Try to be protocol-specific w/ rejection message
-A INPUT -m limit --limit 5/min --limit-burst 10 -j LOG --log-prefix "[iptables] INPUT:REJECT: "
-A INPUT -p udp -j REJECT --reject-with icmp-port-unreachable
-A INPUT -p tcp -j REJECT --reject-with tcp-reset
-A INPUT -j REJECT --reject-with icmp-proto-unreachable

##################################################
#                   FORWARD RULES                #
##################################################

# Boilerplate policy
-A FWD_DROP -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A FWD_DROP -m conntrack --ctstate INVALID -j DROP

-A FWD_DROP -i wg0 -o eth0 -j ACCEPT -m comment --comment "Allow forwarding traffic to external hosts coming in through wireguard"

-A FWD_DROP -i podman0 -o eth0 -j ACCEPT -m comment --comment "Allow container egress through eth0"

# Per-container new-inbound allows. Netavark's NETAVARK_FORWARD chain
# only accepts RELATED/ESTABLISHED into the container subnet plus
# egress from it; it does NOT auto-allow new inbound to published
# ports — the operator owns those rules. Each line below pairs a
# host-published service with the ingress interface(s) that should
# reach it (eth0 for LAN, wg0 for VPN). Deleting any line breaks
# reachability for that service even if `--publish` is set.
-A FWD_DROP -i eth0 -o podman0 -p tcp --dport 32400 -j ACCEPT -m comment --comment "Allow plex through eth0"
-A FWD_DROP -i wg0 -o podman0 -p tcp --dport 32400 -j ACCEPT -m comment --comment "Allow plex through wireguard"

-A FWD_DROP -i eth0 -o podman0 -p tcp --dport 53 -j ACCEPT -m comment --comment "Allow pihole tcp through eth0"
-A FWD_DROP -i wg0 -o podman0 -p tcp --dport 53 -j ACCEPT -m comment --comment "Allow pihole tcp through wireguard"
-A FWD_DROP -i eth0 -o podman0 -p udp --dport 53 -j ACCEPT -m comment --comment "Allow pihole udp through eth0"
-A FWD_DROP -i wg0 -o podman0 -p udp --dport 53 -j ACCEPT -m comment --comment "Allow pihole udp through wireguard"

-A FWD_DROP -i eth0 -o podman0 -p tcp --dport 51413 -j ACCEPT -m comment --comment "Allow transmission tcp through eth0"
-A FWD_DROP -i eth0 -o podman0 -p udp --dport 51413 -j ACCEPT -m comment --comment "Allow transmission udp through eth0"

-A FWD_DROP -i eth0 -o podman0 -p tcp --dport 1400 -j ACCEPT -m comment --comment "Allow sonos app control for homeassistant tcp through eth0"
-A FWD_DROP -i eth0 -o podman0 -p udp --dport 3722 -j ACCEPT -m comment --comment "Allow apple tv for homeassistant udp through eth0"

-A FWD_DROP -m limit --limit 5/min --limit-burst 10 -j LOG --log-prefix "[iptables] FORWARD:REJECT: "
-A FWD_DROP -j DROP
-A FORWARD -j FWD_DROP

##################################################
#                       END                      #
##################################################

COMMIT

*nat
:POSTROUTING ACCEPT [0:0]
-A POSTROUTING -o eth0 -j MASQUERADE -m comment --comment "Ensure forwarded packets have our IP as source and keep track of where to send the replies"
COMMIT
