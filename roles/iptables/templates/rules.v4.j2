*filter
# Allow all outgoing, but drop incoming and forwarding packets by default
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

##################################################
#                   INPUT RULES                  #
##################################################

# Established/related and loopback are accepted unconditionally; INVALID
# is dropped. After these three lines, every remaining packet is NEW —
# so no rule below needs an explicit `--ctstate NEW` qualifier.
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A INPUT -i lo -j ACCEPT
-A INPUT -m conntrack --ctstate INVALID -j DROP

# TCP NEW must have SYN. Conntrack's loose mode (default) classifies
# mid-stream non-SYN packets as NEW rather than INVALID, so without
# this an attacker could probe TCP services with crafted ACKs.
# Flipping the sysctl `nf_conntrack_tcp_loose=0` would catch them via
# INVALID DROP — but doing so live disconnects in-flight SSH on the
# first apply because the sysctl change classifies pre-existing
# untracked packets as INVALID. Keep the explicit rule.
-A INPUT -p tcp ! --syn -j DROP

# UDP traffic rules. Source-scope what doesn't need WAN reach:
# 5053/5333 are container DNS (consumers live on podman0); 5353
# mDNS is link-local on the home LAN so it's scoped there (multicast
# can't traverse the wireguard tunnel anyway).
-A INPUT -s {{ podman_default_network }} -p udp --dport 5053 -j ACCEPT      -m comment --comment "Allow dnscrypt-proxy (containers)"
-A INPUT -s {{ podman_default_network }} -p udp --dport 5333 -j ACCEPT      -m comment --comment "Allow aardvark-dns (post-DNAT from gateway:53)"
-A INPUT -s {{ site_subnets.home }} -p udp --dport 5353 -j ACCEPT           -m comment --comment "Allow mDNS (home LAN)"
-A INPUT -p udp --dport 51820 -j ACCEPT                                     -m comment --comment "Allow Wireguard"
-A INPUT -p udp --dport 60000:61000 -j ACCEPT                               -m comment --comment "Allow Mosh"

# be explicit with rejection of known traffic so they are documented and don't appear in logs
-A INPUT -p udp --dport 67    -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny DHCP"
-A INPUT -p udp --dport 137   -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny NetBIOS"
-A INPUT -p udp --dport 138   -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny NetBIOS"
-A INPUT -p udp --dport 139   -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny NetBIOS"
-A INPUT -p udp --dport 5351  -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny NAT-PMP"
-A INPUT -p udp --dport 10001 -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny Unifi device discovery broadcast"
-A INPUT -p udp --dport 17500 -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny Dropbox LanSync"
-A INPUT -p udp --dport 57621 -j REJECT --reject-with icmp-port-unreachable -m comment --comment "Deny Spotify P2P"

# TCP traffic rules. SSH/HTTP/HTTPS are wide-open (admin + public
# services). Samba and nut are admin services scoped to home LAN +
# wireguard — two rules each because iptables -s takes a single CIDR;
# remote sites (brumath, bonniers) and any future bridge/VLAN are
# excluded by omission.
-A INPUT -p tcp --dport 22    -j ACCEPT                                     -m comment --comment "Allow SSH"
-A INPUT -p tcp --dport 80    -j ACCEPT                                     -m comment --comment "Allow HTTP"
-A INPUT -p tcp --dport 443   -j ACCEPT                                     -m comment --comment "Allow HTTPS"
-A INPUT -s {{ site_subnets.home }} -p tcp --dport 445 -j ACCEPT            -m comment --comment "Allow Samba (home LAN)"
-A INPUT -s {{ wireguard_subnet }} -p tcp --dport 445 -j ACCEPT             -m comment --comment "Allow Samba (wireguard)"
-A INPUT -s {{ site_subnets.home }} -p tcp --dport 3493 -j ACCEPT           -m comment --comment "Allow nut (home LAN)"
-A INPUT -s {{ wireguard_subnet }} -p tcp --dport 3493 -j ACCEPT            -m comment --comment "Allow nut (wireguard)"

# ICMP — only echo-request (ping), rate-limited. Other ICMP types
# (destination unreachable, time exceeded, etc.) come back as
# RELATED via conntrack so the ESTABLISHED,RELATED rule above
# accepts them. Narrowing here keeps redirects and similar attack
# vectors out. The rate limit (10/sec sustained, 20 burst) caps
# echo-reply amplification under flood; overflow drops silently
# rather than falling through to the catch-all REJECT, which would
# emit icmp-proto-unreachable and reflect bandwidth back at the
# spoofed source.
-A INPUT -p icmp --icmp-type echo-request -m limit --limit 10/sec --limit-burst 20 -j ACCEPT
-A INPUT -p icmp --icmp-type echo-request -j DROP

# Other protocols
-A INPUT -p 112 -j ACCEPT -m comment --comment "Allow keepalived (VRRP)"

# Reject anything that's fallen through to this point
## Try to be protocol-specific w/ rejection message
-A INPUT -m limit --limit 5/min --limit-burst 10 -j LOG --log-prefix "[iptables] INPUT:REJECT: "
-A INPUT -p udp -j REJECT --reject-with icmp-port-unreachable
-A INPUT -p tcp -j REJECT --reject-with tcp-reset
-A INPUT -j REJECT --reject-with icmp-proto-unreachable

##################################################
#                   FORWARD RULES                #
##################################################

# Interface naming below: `wg0` is the literal iface name set by
# the wireguard role (roles/wireguard/tasks/main.yml's `iface: wg0`)
# and `podman0` is netavark's default bridge name for the default
# `podman` network. Both are hardcoded conventions; neither varies
# across hosts in this inventory. The WAN-side iface (eth0 on prod
# via netplan set-name, enpXsY on the test VM) is templated via
# ansible_default_ipv4.interface because it does vary.

# Boilerplate policy
-A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A FORWARD -m conntrack --ctstate INVALID -j DROP
# Mirror of the INPUT ! --syn drop — see that rule for the conntrack
# tcp_loose rationale. Without this a spoofed ACK arriving on wg0 can
# match the wg0→podman0 DNAT-state allow below in NEW state.
-A FORWARD -p tcp ! --syn -j DROP

# Egress paths from internal interfaces to WAN — wireguard clients
# reaching the internet, and containers on podman0 doing the same.
# POSTROUTING below MASQUERADEs them so the reply-route is correct.
-A FORWARD -i wg0 -o {{ ansible_default_ipv4.interface }} -j ACCEPT -m comment --comment "Allow forwarding traffic to external hosts coming in through wireguard"
-A FORWARD -i podman0 -o {{ ansible_default_ipv4.interface }} -j ACCEPT -m comment --comment "Allow container egress through {{ ansible_default_ipv4.interface }}"

# Reach published containers via netavark's DNAT. Netavark's
# NETAVARK_FORWARD chain only accepts RELATED/ESTABLISHED + egress
# *from* the container subnet — new inbound is the operator's
# responsibility. We accept any packet whose ingress is {{ ansible_default_ipv4.interface }} or wg0
# and that conntrack tagged as DNAT (i.e. netavark rewrote it for a
# `--publish 0.0.0.0:` port). New containers self-expose without
# rule edits; the {{ ansible_default_ipv4.interface }}/wg0 scoping prevents reachability from any
# future interface (guest VLAN, mgmt net) that we haven't trusted.
-A FORWARD -i {{ ansible_default_ipv4.interface }} -o podman0 -d {{ podman_default_network }} -m conntrack --ctstate DNAT -j ACCEPT -m comment --comment "Reach published containers via LAN"
-A FORWARD -i wg0  -o podman0 -d {{ podman_default_network }} -m conntrack --ctstate DNAT -j ACCEPT -m comment --comment "Reach published containers via wireguard"

-A FORWARD -m limit --limit 5/min --limit-burst 10 -j LOG --log-prefix "[iptables] FORWARD:REJECT: "
-A FORWARD -j DROP

##################################################
#                       END                      #
##################################################

COMMIT

*nat
:POSTROUTING ACCEPT [0:0]
# Source-scoped so we never silently NAT traffic from a future
# interface (guest VLAN, mgmt net, an extra macvlan) we hadn't
# considered. Host's own egress matches home_subnet but MASQUERADE
# is a no-op when the source IP already equals the egress IP.
-A POSTROUTING -s {{ podman_default_network }} -o {{ ansible_default_ipv4.interface }} -j MASQUERADE -m comment --comment "NAT container egress"
-A POSTROUTING -s {{ home_subnet }} -o {{ ansible_default_ipv4.interface }} -j MASQUERADE -m comment --comment "NAT routed traffic from wireguard / LAN"
COMMIT
