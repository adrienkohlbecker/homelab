# {{ ansible_managed }}
# Receives syslog UDP from the UDM and writes to /var/log/unifi/unifi.log.
# Uses a dedicated ruleset so this port's traffic doesn't mix with the
# default ruleset or trigger other drop-ins.

# module(load=) is idempotent -- safe if another drop-in already loaded imudp.
module(load="imudp")
input(
  type="imudp"
  address="{{ udm_syslog_listen_address }}"
  port="{{ service_ports.udm_syslog | int }}"
  ruleset="unifi_syslog"
{% if udm_syslog_rate_limit_interval | int > 0 %}
  rateLimit.interval="{{ udm_syslog_rate_limit_interval | int }}"
  rateLimit.burst="{{ udm_syslog_rate_limit_burst | int }}"
{% endif %}
)

ruleset(name="unifi_syslog") {
{% set udm_syslog_effective_allowed_sources = udm_syslog_allowed_sources + ([ansible_default_ipv4.address] if qemu_test | default(false) else []) %}
  if not ({% for source in udm_syslog_effective_allowed_sources %}$fromhost-ip == "{{ source }}"{% if not loop.last %} or {% endif %}{% endfor %}) then {
    stop
  }
  action(
    type="omfile"
    file="/var/log/unifi/unifi.log"
    fileOwner="syslog"
    fileGroup="adm"
    fileCreateMode="0640"
  )
  stop
}
