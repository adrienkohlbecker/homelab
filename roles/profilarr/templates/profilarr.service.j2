#jinja2: lstrip_blocks: True
# profilarr.service #######################################################################
[Unit]
Description=profilarr
After=network-online.target
Wants=network-online.target
StartLimitInterval=600
StartLimitBurst=3
{% if zfs_root %}
{% if zfs_has_services_mount %}
After=zfs_mount_mnt_services.service
Requires=zfs_mount_mnt_services.service
After=zfs_mount_mnt_services_sqlite.service
Requires=zfs_mount_mnt_services_sqlite.service
{% endif %}
After=zfs_autosnapshot.target
PartOf=zfs_autosnapshot.target
{% endif %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutSec=120
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
# Image: santiagosayshey/profilarr:v1.1.3 is the original author's final Python
#   build. ghcr.io/dictionarry-hub/profilarr is a breaking v2 rewrite (DB moves
#   to /config/data, ORIGIN env required) -- a migration, not a tag bump; the
#   sqlite_dataset symlink wiring assumes the v1 /config-root profilarr.db.
# --init: gunicorn runs as PID 1 under gosu in this image; reap its zombies.
# --health-cmd via python urllib (not curl): python:3.9-slim ships no curl/wget,
#   so tier-3 urllib is the only in-container probe available.
# --env UMASK=027: profilarr.db holds every synced *arr instance's API key; 027
#   keeps it owner-only (image default 022 is world-readable by mode). profilarr
#   owns a dedicated group, so no group-write is sacrificed.
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --name profilarr \
    --security-opt=no-new-privileges \
    --init \
    --log-driver journald \
    --log-opt tag="profilarr" \
    --env PUID={{ profilarr_user.uid }} \
    --env PGID={{ profilarr_user.group }} \
    --env TZ={{ system_timezone }} \
    --env UMASK=027 \
    --volume /mnt/services/profilarr:/config \
    --volume /mnt/services/sqlite/profilarr:/mnt/services/sqlite/profilarr \
    --network media \
    --publish 127.0.0.1:{{ service_ports.profilarr }}:6868/tcp \
    --health-cmd         '["python","-c","import urllib.request as u, sys; u.urlopen(sys.argv[1], timeout=1)","http://localhost:6868/ping"]' \
    --health-startup-cmd '["python","-c","import urllib.request as u, sys; u.urlopen(sys.argv[1], timeout=1)","http://localhost:6868/ping"]' \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "100s" \
    --stop-timeout 120 \
    docker.io/santiagosayshey/profilarr:v1.1.3
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
{% if zfs_root %}
WantedBy=zfs_autosnapshot.target
{% endif %}
