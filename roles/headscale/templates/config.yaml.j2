#jinja2: lstrip_blocks: True
# Managed by Ansible (roles/headscale). Schema: headscale v0.26.x.
# server_url follows the repo's <service>.<host>.<domain> convention so the
# same template renders headscale.box.fahm.fr under the test harness and
# headscale.fox.fahm.fr in prod. nginx terminates TLS and reverse-proxies to
# the loopback listener, so headscale itself runs plain HTTP (tls_* empty).
# The tailscale role's _setup overrides headscale_server_url to the plain-http
# loopback listener so a real Tailscale client can register against this box
# under the harness without trusting the snakeoil TLS cert (whose CN/SAN don't
# match headscale.box.fahm.fr). Prod leaves the default https vhost URL.
server_url: {{ headscale_server_url | default('https://headscale.' ~ inventory_hostname ~ '.' ~ domain) }}
listen_addr: 0.0.0.0:8080
metrics_listen_addr: 0.0.0.0:9090
grpc_listen_addr: 127.0.0.1:50443
grpc_allow_insecure: false

# CLI talks to the running `serve` over this socket (used by _verify and by
# the tailscale role's preauthkey mint). Kept inside the writable state dir so
# the tier-1 non-root container user can create it (default /var/run isn't
# writable without root).
unix_socket: /var/lib/headscale/headscale.sock
unix_socket_permission: "0770"

noise:
  private_key_path: /var/lib/headscale/noise_private.key

prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

# Embedded DERP: STUN (udp/3478, published to the internet) does NAT-traversal
# assistance; the relay itself rides server_url over nginx/443. urls/paths are
# empty so the tailnet relays only through our own DERP (no third-party relay);
# relayed traffic is WireGuard-encrypted end-to-end regardless. Direct
# connections are preferred and are what carry traffic in the common case.
derp:
  server:
    enabled: true
    region_id: 999
    region_code: "fox"
    region_name: "Headscale Embedded DERP (fox)"
    # [::] (not 0.0.0.0) so STUN serves IPv6 clients too -- fox is a dual-stack
    # relay and the container sits on a dual-stack podman network. The :: socket
    # is dual-stack (accepts v4-mapped too), so the single listener covers both.
    stun_listen_addr: "[::]:3478"
    private_key_path: /var/lib/headscale/derp_server_private.key
    automatically_add_embedded_derp_region: true
    # Pin the public addresses the embedded DERP advertises (host_vars/fox.yml,
    # the terraform-reserved primary IPs). headscale's auto-detection would
    # otherwise see the container's podman bridge/ULA address behind nginx + the
    # DNAT bridge, degrading NAT traversal for roaming clients. Unset on the
    # IPv4-only box harness (no host_var), so the keys are simply omitted there.
{% if headscale_derp_ipv4 is defined %}
    ipv4: "{{ headscale_derp_ipv4 }}"
{% endif %}
{% if headscale_derp_ipv6 is defined %}
    ipv6: "{{ headscale_derp_ipv6 }}"
{% endif %}
  urls: []
  paths: []
  auto_update_enabled: false
  update_frequency: 24h

# Don't phone home for update checks.
disable_check_updates: true
ephemeral_node_inactivity_timeout: 30m

# Pinned off (the upstream default), deliberately. Randomizing the WireGuard
# source port helps hole-punching on some NAT types but hurts it on others, so
# it's a per-deployment field-test knob (verify with `tailscale netcheck` from a
# roaming cellular client), not a blind on. Left explicit so flipping it is a
# conscious decision rather than an accidental default.
randomize_client_port: false

database:
  type: sqlite
  sqlite:
    path: /var/lib/headscale/db.sqlite
    # Pin WAL on explicitly. It's the upstream default today, but the whole
    # reason db.sqlite lives on the dedicated 4K-recordsize sqlite dataset
    # (roles/sqlite_dataset) is so its WAL/SHM siblings land there too -- an
    # upstream default-flip to rollback-journal would silently undo that. State
    # the assumption the storage layout depends on.
    write_ahead_log: true

# TLS is terminated by nginx (roles/nginx site). Leave headscale's own TLS off.
tls_letsencrypt_hostname: ""
tls_cert_path: ""
tls_key_path: ""

log:
  format: text
  level: info

policy:
  mode: file
  path: /etc/headscale/acl.hujson

# MagicDNS resolves tailnet names under base_domain (must differ from the
# server_url FQDN). All other queries forward to pihole over the mesh (pihole's
# keepalived VIP is inside 10.123.0.0/21, reachable via the lab/pug subnet
# routers), so roaming clients keep pihole adblock + split-horizon resolution
# of *.fahm.fr to internal IPs. roles/pihole is unchanged.
dns:
  magic_dns: true
  base_domain: ts.{{ domain }}
  nameservers:
    global:
      - {{ external_ips.pihole }}
    split: {}
  search_domains: []
  extra_records: []

{% if headscale_oidc_enabled | default(false) %}
# User-device enrollment via Authelia OIDC. Headless hosts (lab/pug/bunk) use
# pre-auth keys instead and never hit this. Disabled under the test harness
# (headscale validates the issuer at boot via OIDC discovery, which the box VM
# can't reach).
oidc:
  issuer: "{{ headscale_oidc_issuer }}"
  client_id: "{{ headscale_oidc_client_id }}"
  client_secret_path: "/run/secrets/oidc_client_secret"
  scope: ["openid", "profile", "email"]
  # Fail closed at boot (the upstream default, pinned explicitly): refuse to
  # start until OIDC discovery against the issuer succeeds. With the unit's
  # After=wg-quick@wg0 + wide StartLimit window, this guarantees that whenever
  # headscale is `active` the family Apple-device login flow actually works -- a
  # started-but-OIDC-broken control plane would be a silent WAF regression. Flip
  # to false only to keep serving pre-auth (lab/pug) clients through an Authelia
  # outage, at the cost of OIDC possibly staying broken until a restart.
  only_start_if_oidc_is_available: true
  # Re-auth cadence for OIDC-enrolled user devices (pre-auth-key hosts are
  # unaffected). 180d is the upstream default, pinned so the household re-login
  # interval is a deliberate dial -- lengthen if family re-logins get annoying.
  expiry: 180d
{% if headscale_oidc_allowed_domains | default([]) | length > 0 %}
  allowed_domains:
{% for d in headscale_oidc_allowed_domains %}
    - {{ d }}
{% endfor %}
{% endif %}
{% endif %}
