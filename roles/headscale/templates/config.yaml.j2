#jinja2: lstrip_blocks: True
# Managed by Ansible (roles/headscale). Schema: headscale v0.26.x.
# server_url is the public control-plane + DERP FQDN clients enroll against. The
# default follows the repo's <service>.<host>.<domain> convention, which the test
# harness renders (headscale.box.fahm.fr). Prod (fox) overrides it via
# headscale_server_url to the apex-level headscale.fahm.fr -- a flat public name
# decoupled from fox.fahm.fr (now the host's Tailscale IP) so an un-enrolled
# client can still reach the control plane to join (see host_vars/fox.yml +
# terraform/dns_fahm_fr.tf). nginx terminates TLS and reverse-proxies to the
# loopback listener, so headscale itself runs plain HTTP (tls_* empty). The
# tailscale role's _setup overrides headscale_server_url again to the plain-http
# loopback listener so a real Tailscale client can register under the harness
# without trusting the snakeoil TLS cert (whose CN/SAN don't match the vhost).
server_url: {{ headscale_server_url | default('https://headscale.' ~ inventory_hostname ~ '.' ~ domain) }}
listen_addr: 0.0.0.0:8080
metrics_listen_addr: 0.0.0.0:9090
grpc_listen_addr: 127.0.0.1:50443
grpc_allow_insecure: false

# CLI talks to the running `serve` over this socket (used by _verify and by
# the tailscale role's preauthkey mint). Kept inside the writable state dir so
# the tier-1 non-root container user can create it (default /var/run isn't
# writable without root). 0700 (owner-only): the only callers are the
# headscale-uid serve process and `podman exec` as that same uid (_verify, the
# tailscale role's mint), so the group bit the upstream example sets buys
# nothing here -- it just widens who could drive the admin gRPC socket.
unix_socket: /var/lib/headscale/headscale.sock
unix_socket_permission: "0700"

noise:
  private_key_path: /var/lib/headscale/noise_private.key

prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

# Embedded DERP: STUN (udp/3478, published to the internet) does NAT-traversal
# assistance; the relay itself rides server_url over nginx/443. urls/paths are
# empty so the tailnet relays only through our own DERP (no third-party relay);
# relayed traffic is WireGuard-encrypted end-to-end regardless. Direct
# connections are preferred and are what carry traffic in the common case.
derp:
  server:
    enabled: true
    region_id: 999
    region_code: "fox"
    region_name: "Headscale Embedded DERP (fox)"
    # [::] (not 0.0.0.0) so STUN serves IPv6 clients too -- fox is a dual-stack
    # relay and the container sits on a dual-stack podman network. The :: socket
    # is dual-stack (accepts v4-mapped too), so the single listener covers both.
    stun_listen_addr: "[::]:3478"
    private_key_path: /var/lib/headscale/derp_server_private.key
    automatically_add_embedded_derp_region: true
    # Pin the public addresses the embedded DERP advertises (host_vars/fox.yml,
    # the terraform-reserved primary IPs). headscale's auto-detection would
    # otherwise see the container's podman bridge/ULA address behind nginx + the
    # DNAT bridge, degrading NAT traversal for roaming clients. Unset on the
    # IPv4-only box harness (no host_var), so the keys are simply omitted there.
{% if headscale_derp_ipv4 is defined %}
    ipv4: "{{ headscale_derp_ipv4 }}"
{% endif %}
{% if headscale_derp_ipv6 is defined %}
    ipv6: "{{ headscale_derp_ipv6 }}"
{% endif %}
  urls: []
  paths: []
  auto_update_enabled: false
  update_frequency: 24h

# Don't phone home for update checks.
disable_check_updates: true
ephemeral_node_inactivity_timeout: 30m

# A per-deployment NAT-traversal tuning knob, surfaced deliberately. Randomizing
# the WireGuard source port helps hole-punching on some NAT types but hurts it on
# others, so it's a field-test dial (verify with `tailscale netcheck` from a
# roaming cellular client), not a blind on. Kept explicit so flipping it is a
# conscious decision.
randomize_client_port: false

database:
  type: sqlite
  sqlite:
    path: /var/lib/headscale/db.sqlite
    # WAL is load-bearing here, not a default-pin: db.sqlite lives on the
    # dedicated 4K-recordsize sqlite dataset (roles/sqlite_dataset) precisely so
    # its WAL/SHM siblings land there too. headscale defaults this on, but the
    # storage layout *depends* on it -- a default-flip to rollback-journal would
    # silently break that -- so state it.
    write_ahead_log: true

# TLS is terminated by nginx (roles/nginx site). Leave headscale's own TLS off.
tls_letsencrypt_hostname: ""
tls_cert_path: ""
tls_key_path: ""

log:
  format: text
  level: info

policy:
  mode: file
  path: /etc/headscale/acl.hujson

# MagicDNS resolves tailnet names under base_domain (must differ from the
# server_url FQDN). All other queries forward to adguard over the mesh. The
# lab/pug Tailscale nodes advertise the 10.123.0.0/18 physical partition,
# deliberately less specific than the 10.123.0.0/21 classless static route
# pushed on the Trusted VLAN, so Trusted clients prefer the local gateway while
# roaming clients keep adguard and the physical sites reachable.
dns:
  magic_dns: true
  # Send ALL queries from roaming devices to adguard, not just tailnet/MagicDNS
  # names. Without this, a device on foreign WiFi resolves via that network's DNS
  # and loses adblock + split-horizon *.fahm.fr. The cost is that the advertised
  # route must be accepted by the client; otherwise DNS is unreachable until the
  # client opts out with `tailscale set --accept-dns=false` (a per-device escape
  # hatch this server setting can't override). Headless hosts already run
  # --accept-dns=false, so only roaming user-devices are affected.
  override_local_dns: true
  base_domain: ts.{{ domain }}
  nameservers:
    global:
      - {{ external_ips.dns }}
    split: {}
  search_domains: []
{% if headscale_derp_ipv4 is defined %}
  # Pin the control-plane FQDN into MagicDNS so a roaming device can still resolve
  # it when the DNS-VIP chain (the global nameserver above) is unreachable. With
  # override_local_dns on, all queries go to the VIP, so without this a DNS
  # outage leaves a client unable to re-resolve headscale to recover. Points at
  # fox's public IPs (the same addresses headscale.fahm.fr resolves to). fox-only:
  # gated on the DERP IPs, unset under the box harness where server_url is a
  # loopback URL.
  extra_records:
    - name: "headscale.{{ domain }}"
      type: "A"
      value: "{{ headscale_derp_ipv4 }}"
{% if headscale_derp_ipv6 is defined %}
    - name: "headscale.{{ domain }}"
      type: "AAAA"
      value: "{{ headscale_derp_ipv6 }}"
{% endif %}
{% else %}
  extra_records: []
{% endif %}

{% if headscale_oidc_enabled %}
# User-device enrollment via Authelia OIDC. Headless hosts (lab/pug/bunk) use
# pre-auth keys instead and never hit this. Disabled under the test harness
# (headscale validates the issuer at boot via OIDC discovery, which the box VM
# can't reach).
oidc:
  issuer: "{{ headscale_oidc_issuer }}"
  client_id: "{{ headscale_oidc_client_id }}"
  client_secret_path: "/run/secrets/oidc_client_secret"
  scope: ["openid", "profile", "email"]
  # Keep the control plane available when Authelia is down. Existing nodes and
  # pre-auth-key registration must not depend on the lab-hosted OIDC issuer; only
  # interactive user-device enrollment is degraded until discovery succeeds.
  only_start_if_oidc_is_available: false
  # PKCE hardens the public auth-code flow against authorization-code
  # interception (headscale's default method is S256). Enabling it is the
  # deliberate non-default here; Authelia accepts a PKCE challenge from clients
  # that send one, so this needs no Authelia-side client change. Exercised under
  # the harness by the mockoidc OIDC boot test (_setup.yml + _verify.yml).
  pkce:
    enabled: true
  # No allowed_domains/allowed_groups gate: device enrollment is open to any
  # identity Authelia authenticates. Deliberate -- this is a single-household
  # tailnet and the ACL is permissive by design (acl.hujson.j2), so a
  # domain/group filter here would add no real isolation until the ACL is
  # tightened. Revisit (allowed_groups + the "groups" scope) alongside that.
{% endif %}
