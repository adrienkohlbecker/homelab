# {{ ansible_managed }}
# zram swap: the primary, high-priority swap device. Routine cold-page
# eviction compresses into RAM here; the disk/zvol swap (negative default
# priority) is reached only under genuine exhaustion. See
# notes/swap_strategy.md.
[zram0]
# Size = min(ram, max-zram-size). jammy's 0.3.2 sizes via zram-fraction +
# max-zram-size (the zram-size expression is 1.x-only); both keys work on
# 1.x too. fraction 1.0 means "up to all of RAM", capped at the MB below
# -- so a small box gets ~RAM, a big box the cap. The cap also stops a
# worst-case incompressible fill (stored ~1:1) from consuming more RAM
# than the box has.
zram-fraction = 1.0
max-zram-size = {{ (swap_zram.size | human_to_bytes) // 1048576 }}
compression-algorithm = {{ swap_zram.algorithm | default('zstd') }}
swap-priority = {{ swap_zram.priority | default(100) }}
