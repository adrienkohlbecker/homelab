#!/bin/bash
# Bootstrap the first hyperdx team.
#
# HyperDX's all-in-one image leaves the OTLP receiver UNWIRED until at
# least one team exists in MongoDB (opampController only adds
# `otlp/hyperdx` to pipelines when apiKeys.length > 0). Without this,
# port 4318 never binds and fluent-bit's OTLP output sees Connection
# refused. The `INGESTION_API_KEY` env documented for this purpose is
# dead code in the all-in-one-noauth image variant -- config.js checks
# `HYPERDX_IMAGE === 'all-in-one-auth'` but entry.base.sh always sets
# `all-in-one-noauth` when IS_LOCAL_APP_MODE is not the dangerous-mode
# sentinel.
#
# Idempotence: both ops below are naturally idempotent --
#   - /api/register/password returns 409 (teamAlreadyExists) on re-apply
#   - updateOne with $set is a no-op when state already matches
# Safe to invoke ad-hoc on every apply or for operator-side rotation.
#
# Conceptually one-time: team + apiKey + opamp wiring persist in mongo,
# so out-of-band hyperdx restarts don't need a re-run. The ansible
# caller fires this only on first install (sentinel missing) or when
# this script's content has changed (the caller wipes the sentinel
# before the `creates:`-gated run). For mongo data loss (snapshot
# restore, accident), the operator manually re-runs:
#   sudo /usr/local/bin/hyperdx_bootstrap.sh
#
# Lives at /usr/local/bin/hyperdx_bootstrap.sh, mode 0700 root, with the
# vault secrets baked in via Jinja. The eventual P2 migration to
# podman_secret will replace the baked-in secrets with in-container
# /run/secrets/ reads via `podman exec hyperdx cat ...`.
set -euo pipefail

UI_PORT={{ service_ports.hyperdx }}
ADMIN_EMAIL='{{ root_email }}'
ADMIN_PASSWORD='{{ hyperdx_admin_password }}'
API_KEY='{{ hyperdx_ingestion_api_key }}'

# Wait for the api (~2min budget). Redundant on first ansible apply (the
# Enable hyperdx service task already waited for Type=notify healthy)
# but needed for ad-hoc runs after a container restart. --retry +
# --retry-connrefused + --retry-all-errors covers ECONNREFUSED, 5xx,
# and transient curl errors with backoff; --show-error surfaces the
# final upstream error to stderr if the budget is exhausted.
curl --silent --show-error --fail --max-time 5 \
  --retry 60 --retry-delay 2 --retry-connrefused --retry-all-errors \
  --output /dev/null \
  "http://localhost:${UI_PORT}/api/health"

# Register first admin. 200 (created) and 409 (team exists) are both
# the desired terminal state; anything else is a real failure. Body
# built via jq so embedded quotes / backslashes / dollar signs in the
# password JSON-escape correctly. Body piped via stdin (--data-binary
# @-) so the password never lands in curl's argv (visible to any host
# user via /proc/<pid>/cmdline). Response body captured via --write-out
# so an unexpected status surfaces the API's error message to stderr.
body=$(jq -n --arg email "$ADMIN_EMAIL" --arg pw "$ADMIN_PASSWORD" \
  '{email: $email, password: $pw, confirmPassword: $pw}')
response=$(curl --silent --output - --write-out 'HTTPSTATUS:%{http_code}' \
  --max-time 10 \
  --request POST \
  --header 'Content-Type: application/json' \
  --data-binary @- \
  "http://localhost:${UI_PORT}/api/register/password" <<<"$body")
status="${response##*HTTPSTATUS:}"
body_text="${response%HTTPSTATUS:*}"
case "$status" in
  200|409) ;;
  *) echo "register/password returned status $status: ${body_text:0:200}" >&2; exit 1 ;;
esac

# Pin the target team for the apiKey/auth-enforced update: refuse if
# Mongo has more than one team (UI-side creation of a second tenant).
# The empty-filter updateOne would silently mutate whichever team Mongo
# orders first; fail loud and surface the ambiguity to the operator.
team_count=$(podman exec -i hyperdx mongo --quiet hyperdx <<<'db.teams.countDocuments({})')
if [[ "$team_count" != "1" ]]; then
  echo "bootstrap expected exactly one team in Mongo, found '$team_count'; refusing to apply apiKey blindly" >&2
  exit 1
fi

# Force the team's apiKey to the vault value AND pin
# collectorAuthenticationEnforced=true (defends against a future upstream
# default flip that would silently disable auth on prod re-applies).
# API_KEY JSON-escaped via `jq -n --arg` so a future key containing `"`,
# `\`, `$` doesn't break the JS literal or mutate an unintended field.
# `--arg` over `jq -Rs . <<<"$key"` because the herestring appends a
# trailing newline that ends up as a literal "\n" inside the stored
# apiKey, silently breaking bearertokenauth (mongo holds "key\n", header
# sends "key", receiver returns 401).
escaped_key=$(jq -n --arg k "$API_KEY" '$k')
result=$(podman exec -i hyperdx mongo --quiet hyperdx <<EOF
JSON.stringify(db.teams.updateOne({}, {\$set: {apiKey: ${escaped_key}, collectorAuthenticationEnforced: true}}))
EOF
)
if ! echo "$result" | grep -q '"matchedCount":1'; then
  echo "team apiKey update did not match a team: $result" >&2
  exit 1
fi

# Sentinel for the ansible `creates:` gate. Touched only after the
# state-forcing ops above succeed, so a partially-failed bootstrap
# (e.g. Mongo unreachable mid-script) doesn't claim done.
mkdir -p /var/lib/hyperdx
touch /var/lib/hyperdx/.bootstrapped
