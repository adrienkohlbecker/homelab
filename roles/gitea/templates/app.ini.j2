APP_NAME = Gitea
RUN_USER = git
WORK_PATH = /mnt/services/gitea
RUN_MODE = prod

[database]
DB_TYPE = sqlite3
NAME = gitea
PATH = /mnt/services/sqlite/gitea/gitea.db
SQLITE_JOURNAL_MODE = WAL
# gitea default is 500ms; under concurrent web + cron + LFS load (the
# cleanup_actions cron in particular) writers race on the WAL lock and
# 500ms is short enough to surface as user-visible 500s.
SQLITE_TIMEOUT = 10000
LOG_SQL = false

[repository]
ROOT = /mnt/services/gitea/data/gitea-repositories

[server]
SSH_DOMAIN = gitea.{{ inventory_hostname }}.{{ domain }}
DOMAIN = gitea.{{ inventory_hostname }}.{{ domain }}
HTTP_ADDR = 127.0.0.1
HTTP_PORT = {{ service_ports.gitea }}
ROOT_URL = https://gitea.{{ inventory_hostname }}.{{ domain }}/
APP_DATA_PATH = /mnt/services/gitea/data
DISABLE_SSH = false
SSH_PORT = 22
# Host sshd serves git@; gitea rewrites ~git/.ssh/authorized_keys with
# command="..." prefixes. SSH clones break (and a bash shell may be
# exposed) if sshd moves off :22 or any key loses the prefix. Pin
# SSH_USER explicitly so a future gitea release flipping its default
# (it has historically tracked RUN_USER) doesn't silently rewrite every
# clone URL we hand out.
SSH_USER = git
LFS_START_SERVER = true
LFS_JWT_SECRET = {{ gitea_lfs_jwt_secret }}
OFFLINE_MODE = true
# DISABLE_REGISTRATION = true (below) means /explore is the only anon
# landing page that ever shows public-repo lists; redirecting straight
# to /user/login matches the closed-registration posture.
LANDING_PAGE = login
# Router logs are debug-only signal; nginx access logs are upstream.
DISABLE_ROUTER_LOG = true

[lfs]
PATH = /mnt/services/gitea/data/lfs

[mailer]
ENABLED = true
SMTP_ADDR = {{ smtp_host }}
SMTP_PORT = {{ smtp_port }}
FROM = {{ gitea_smtp_user }}
USER = {{ gitea_smtp_user }}
PASSWD = {{ gitea_smtp_password }}

# Only deviations from upstream gitea defaults: closed registration
# behind email-confirm + captcha, mail notifications on, time tracking
# off. Every other [service] key is left at the gitea-shipped default.
[service]
REGISTER_EMAIL_CONFIRM = true
ENABLE_NOTIFY_MAIL = true
DISABLE_REGISTRATION = true
ENABLE_CAPTCHA = true
DEFAULT_ENABLE_TIMETRACKING = false

[cron.update_checker]
ENABLED = false

[session]
PROVIDER = file
# ROOT_URL is https, so cookies must carry Secure. SameSite=lax defangs
# CSRF on state-changing GETs without breaking inbound oauth callbacks.
COOKIE_SECURE = true
SAME_SITE = lax

[log]
MODE = console
LEVEL = info

[repository.pull-request]
DEFAULT_MERGE_STYLE = merge

[repository.signing]
DEFAULT_TRUST_MODEL = collaborator

[security]
INSTALL_LOCK = true
INTERNAL_TOKEN = {{ gitea_internal_token }}
PASSWORD_HASH_ALGO = pbkdf2_hi
# Independent of [session] COOKIE_SECURE -- gitea has separate cookies
# for the user session and the CSRF/security token; both must be Secure
# now that ROOT_URL is https.
COOKIE_SECURE = true
MIN_PASSWORD_LENGTH = 12

# gitea generates JWT_SECRET on first start if it's missing and writes
# it back to app.ini, which then makes the role non-idempotent (template
# diff -> restart -> repeat). Pin it from vault to break the cycle.
# Used as the signing key when gitea acts as an OAuth2 provider for
# third-party apps (gitea's own API uses INTERNAL_TOKEN instead).
[oauth2]
JWT_SECRET = {{ gitea_jwt_secret }}

[actions]
ENABLED = true

[cron.cleanup_actions]
ENABLED = true
OLDER_THAN = 8760h
