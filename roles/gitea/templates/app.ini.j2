APP_NAME = Gitea
RUN_USER = git
WORK_PATH = /mnt/services/gitea
RUN_MODE = prod

[database]
DB_TYPE = sqlite3
HOST = 127.0.0.1:3306
NAME = gitea
USER = gitea
PASSWD =
SCHEMA =
SSL_MODE = disable
PATH = /mnt/services/sqlite/gitea/gitea.db
SQLITE_JOURNAL_MODE = WAL
LOG_SQL = false

[repository]
ROOT = /mnt/services/gitea/data/gitea-repositories

[server]
SSH_DOMAIN = gitea.{{ inventory_hostname }}.{{ domain }}
DOMAIN = gitea.{{ inventory_hostname }}.{{ domain }}
HTTP_PORT = 3000
ROOT_URL = https://gitea.{{ inventory_hostname }}.{{ domain }}/
APP_DATA_PATH = /mnt/services/gitea/data
DISABLE_SSH = false
SSH_PORT = 22
LFS_START_SERVER = true
LFS_JWT_SECRET = {{ gitea_lfs_jwt_secret }}
OFFLINE_MODE = true

[lfs]
PATH = /mnt/services/gitea/data/lfs

[mailer]
ENABLED = true
SMTP_ADDR = {{ smtp_host }}
SMTP_PORT = {{ smtp_port }}
FROM = {{ gitea_smtp_user }}
USER = {{ gitea_smtp_user }}
PASSWD = {{ gitea_smtp_password }}

[service]
REGISTER_EMAIL_CONFIRM = true
ENABLE_NOTIFY_MAIL = true
DISABLE_REGISTRATION = false
ALLOW_ONLY_EXTERNAL_REGISTRATION = false
ENABLE_CAPTCHA = true
REQUIRE_SIGNIN_VIEW = false
DEFAULT_KEEP_EMAIL_PRIVATE = false
DEFAULT_ALLOW_CREATE_ORGANIZATION = true
DEFAULT_ENABLE_TIMETRACKING = false
NO_REPLY_ADDRESS = noreply.localhost

[openid]
ENABLE_OPENID_SIGNIN = false
ENABLE_OPENID_SIGNUP = false

[cron.update_checker]
ENABLED = false

[session]
PROVIDER = file

[log]
MODE = console
LEVEL = info
ROOT_PATH = /var/log/gitea

[repository.pull-request]
DEFAULT_MERGE_STYLE = merge

[repository.signing]
DEFAULT_TRUST_MODEL = committer

[security]
INSTALL_LOCK = true
INTERNAL_TOKEN = {{ gitea_internal_token }}
PASSWORD_HASH_ALGO = pbkdf2

[oauth2]
JWT_SECRET = {{ gitea_jwt_secret }}

# Disabled until the gitea-actions / act_runner 0.6.1 state-machine bug
# is resolved. Symptom: a job whose `if:` resolves to false (job-level
# or matrix-cell-level) is reported back as Failure (status=4) rather
# than Skipped (status=6); downstream `needs:` consumers then sit in
# Blocked (status=7) forever while the jobEmitter retries them every
# ~9s, generating a write storm that drives push latency to 30s+. The
# test.yml workflow's static-superset matrix triggers this on every
# push (~100 cells with a per-cell `if:` filter). Flip back to true
# once test.yml is restructured or the upstream bug is fixed.
[actions]
ENABLED = false
