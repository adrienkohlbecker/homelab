APP_NAME = Gitea
RUN_USER = git
WORK_PATH = /mnt/services/gitea
RUN_MODE = prod

[database]
DB_TYPE = sqlite3
NAME = gitea
PATH = /mnt/services/sqlite/gitea/gitea.db
SQLITE_JOURNAL_MODE = WAL
# gitea default is 500ms; under concurrent web + cron + LFS load (the
# cleanup_actions cron in particular) writers race on the WAL lock and
# 500ms is short enough to surface as user-visible 500s.
SQLITE_TIMEOUT = 10000
LOG_SQL = false

[repository]
ROOT = /mnt/services/gitea/data/gitea-repositories

[server]
SSH_DOMAIN = gitea.{{ inventory_hostname }}.{{ domain }}
DOMAIN = gitea.{{ inventory_hostname }}.{{ domain }}
HTTP_ADDR = 127.0.0.1
HTTP_PORT = {{ service_ports.gitea }}
ROOT_URL = https://gitea.{{ inventory_hostname }}.{{ domain }}/
APP_DATA_PATH = /mnt/services/gitea/data
DISABLE_SSH = false
SSH_PORT = 22
# Host sshd serves git@; gitea rewrites ~git/.ssh/authorized_keys with
# command="..." prefixes. SSH clones break (and a bash shell may be
# exposed) if sshd moves off :22 or any key loses the prefix. Pin
# SSH_USER explicitly so a future gitea release flipping its default
# (it has historically tracked RUN_USER) doesn't silently rewrite every
# clone URL we hand out.
SSH_USER = git
# Back up ~git/.ssh/authorized_keys before each rewrite. Gitea rebuilds
# the file from the DB on every key add/remove; a bad rewrite (missing
# command= prefix) silently exposes a bash shell at git@. The backup
# gives an on-disk diff target after the fact.
SSH_AUTHORIZED_KEYS_BACKUP = true
LFS_START_SERVER = true
LFS_JWT_SECRET = {{ gitea_lfs_jwt_secret }}
# Disables external avatar/CDN fetches and the periodic update check.
OFFLINE_MODE = true
# REQUIRE_SIGNIN_VIEW = true (below) gates every view behind a session, so
# there is no anonymous landing page; this just points the pre-auth redirect
# at /user/login to match the SSO-only, closed-registration posture.
LANDING_PAGE = login
# Router logs are debug-only signal; nginx access logs are upstream.
DISABLE_ROUTER_LOG = true

[lfs]
PATH = /mnt/services/gitea/data/lfs

[mailer]
ENABLED = true
PROTOCOL = {{ 'smtps' if smtp_use_ssl | bool else ('smtp+starttls' if smtp_use_tls | bool else 'smtp') }}
SMTP_ADDR = {{ smtp_host }}
SMTP_PORT = {{ smtp_port }}
FROM = {{ gitea_smtp_from }}
USER = {{ gitea_smtp_user }}
PASSWD = {{ gitea_smtp_password }}

# Only deviations from upstream gitea defaults: closed registration
# behind email-confirm + captcha, require sign-in to view anything, mail
# notifications on, time tracking off. Every other [service] key is left at
# the gitea-shipped default.
[service]
REGISTER_EMAIL_CONFIRM = true
ENABLE_NOTIFY_MAIL = true
DISABLE_REGISTRATION = true
ENABLE_CAPTCHA = true
DEFAULT_ENABLE_TIMETRACKING = false
# Require a session for every view -- no anonymous repo browsing, even of
# the otherwise-public /explore listing. API requests with a token in the
# Authorization header still authenticate normally.
REQUIRE_SIGNIN_VIEW = true
# Hide the local username/password web form -- login is SSO-only via the
# Authelia OIDC button (admin rights flow through --admin-group=admins).
# ENABLE_BASIC_AUTHENTICATION stays at its default (true) so git-over-HTTPS
# and API tokens still work. Break-glass if Authelia is down: `gitea admin`
# CLI on the host (e.g. `gitea admin user create ... --admin`).
ENABLE_PASSWORD_SIGNIN_FORM = false

[cron.update_checker]
ENABLED = false

[session]
PROVIDER = file
# ROOT_URL is https, so cookies must carry Secure. SameSite=lax defangs
# CSRF on state-changing GETs without breaking inbound oauth callbacks.
COOKIE_SECURE = true
SAME_SITE = lax

[log]
MODE = console
LEVEL = info

[repository.pull-request]
DEFAULT_MERGE_STYLE = merge

[repository.signing]
DEFAULT_TRUST_MODEL = collaborator

[security]
INSTALL_LOCK = true
INTERNAL_TOKEN = {{ gitea_internal_token }}
PASSWORD_HASH_ALGO = pbkdf2_hi
# Independent of [session] COOKIE_SECURE -- gitea has separate cookies
# for the user session and the CSRF/security token; both must be Secure
# now that ROOT_URL is https.
COOKIE_SECURE = true
MIN_PASSWORD_LENGTH = 12
# Same idempotence trap as [oauth2] JWT_SECRET below: gitea generates
# SECRET_KEY on first start if unset and writes it back to app.ini.
# SECRET_KEY also encrypts 2FA secrets and OAuth client secrets, so a
# regenerated key silently invalidates every stored token. Pin from
# vault to break the cycle.
SECRET_KEY = {{ gitea_secret_key }}
# Reject API tokens passed as ?token=... URL params -- they land in
# nginx access logs and browser history. Upstream notes this will
# become the default in a future release.
DISABLE_QUERY_AUTH_TOKEN = true
# Server-side git hooks let any repo-admin run arbitrary code as the
# git user, including reading app.ini secrets and modifying the DB.
# We don't use them; closing the door reduces blast radius from a
# compromised account or future role-grant mistake.
DISABLE_GIT_HOOKS = true

# gitea generates JWT_SECRET on first start if it's missing and writes
# it back to app.ini, which then makes the role non-idempotent (template
# diff -> restart -> repeat). Pin it from vault to break the cycle.
# Used as the signing key when gitea acts as an OAuth2 provider for
# third-party apps (gitea's own API uses INTERNAL_TOKEN instead).
[oauth2]
JWT_SECRET = {{ gitea_jwt_secret }}

# No registered runner in the fleet (the gitea_runner role was retired).
# Disabled so a pushed .gitea/workflows/ job is rejected at the UI instead of
# queueing pending forever against a non-existent executor. Re-enable this
# alongside a new runner.
[actions]
ENABLED = false

# Left on as a fail-safe janitor: [actions] is disabled so nothing new is
# produced, but this still ages out any residual action logs left in the DB
# from when the runner was active (and keeps cleaning if Actions is re-enabled).
[cron.cleanup_actions]
ENABLED = true
OLDER_THAN = 8760h

# Reject weak keys at registration time -- gitea-side enforcement is
# independent of host sshd's KexAlgorithms/Ciphers. -1 = disallowed.
[ssh.minimum_key_sizes]
ED25519 = 256
RSA = 3071
ECDSA = -1
DSA = -1

# Suppress version disclosure in the page footer (visible on the anon
# login page, which is the only page anon visitors see given closed
# registration + LANDING_PAGE = login).
[other]
SHOW_FOOTER_VERSION = false
