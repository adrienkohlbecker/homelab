# Drop-in installed by roles/github_runner on user@{{ github_runner_user.uid }}.service.
# Pulls zfs mount/autosnap deps up to the user manager so every user
# unit running under it (= every github_runner@<inst>.service via the
# templated github_runner@.service in user scope) waits transitively.
# Cross-scope After=/Requires=/PartOf= can't be expressed inside the
# user-scope unit directly -- systemd silently ignores them across
# manager boundaries -- so the ordering lives here on the system unit
# that birthed the user manager.
[Unit]
{% if zfs_has_scratch_mount %}
After=zfs_mount_mnt_scratch.service
Requires=zfs_mount_mnt_scratch.service
{% endif %}
After=zfs_autosnapshot.target
PartOf=zfs_autosnapshot.target
