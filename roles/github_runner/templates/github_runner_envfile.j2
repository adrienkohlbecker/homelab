# Per-instance environment for github_runner@{{ runner_instance.repo }}_{{ runner_instance.suffix }}.service.
# Consumed by the runner container via podman's --env-file. Static for
# the instance's lifetime; changes (relabel, repo rename) propagate via
# the systemd_unit helper's restart trigger in _register.yml.
#
# REPO_OWNER / REPO_NAME are split (not REPO_URL) because the entrypoint
# uses them in the path of GitHub's generate-jitconfig API endpoint
# directly. GITHUB_PAT_FILE points at the secret-mount target inside
# the container; the host-level github_runner_pat podman secret is
# bound there by the unit's --secret type=mount,target= line.
REPO_OWNER={{ github_runner_owner }}
REPO_NAME={{ runner_instance.repo }}
RUNNER_NAME={{ inventory_hostname }}_{{ runner_instance.repo }}_{{ runner_instance.suffix }}
RUNNER_LABELS={{ runner_instance.labels }}
GITHUB_PAT_FILE=/run/secrets/github_pat
