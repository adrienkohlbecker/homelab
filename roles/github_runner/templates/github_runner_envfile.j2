# Per-instance environment for github_runner@{{ runner_instance.repo }}_{{ runner_instance.suffix }}.service.
# Consumed only by github_runner_jit_mint (the ExecStartPre script on
# the host), which sources this file via `. /etc/default/github_runner@<inst>`
# to get REPO_OWNER / REPO_NAME / RUNNER_NAME / RUNNER_LABELS /
# RUNNER_WORK_FOLDER / RUNNER_GROUP_ID, then POSTs them as the
# JIT-config request. The runner container does NOT see these vars
# (the unit dropped --env-file): they'd be visible to sibling DooD
# containers via `docker inspect`, and the entrypoint doesn't read
# them anyway (the JIT blob carries the authoritative values).
# Static for the instance's lifetime; changes (relabel, repo rename,
# owner move, group change) propagate via the systemd_unit helper's
# restart trigger in _register.yml.
REPO_OWNER={{ runner_instance.owner }}
REPO_NAME={{ runner_instance.repo }}
RUNNER_NAME={{ inventory_hostname }}_{{ runner_instance.repo }}_{{ runner_instance.suffix }}
RUNNER_LABELS={{ runner_instance.labels }}
RUNNER_WORK_FOLDER=/mnt/scratch/github_runner/workdir_{{ runner_instance.repo }}_{{ runner_instance.suffix }}
# group 1 is the only group on personal-account repos and the org's
# reserved "Default" group on org repos -- so the default is "lands
# wherever the implicit GitHub default is", which is right for both
# our current use cases. Override per-instance for custom org groups.
RUNNER_GROUP_ID={{ runner_instance.runner_group_id | default(1) }}
