#!/bin/bash
set -euo pipefail
# Re-bootstrap keepalived after a UniFi OS firmware update.
# Firmware replaces the SquashFS root, wiping /usr/ — the keepalived apt
# package disappears. Systemd units in /etc/systemd/system/ (overlay upper
# dir) usually survive but may not after a major firmware update — re-deploy
# symlinks unconditionally.

DATADIR=/data/keepalived

# -- keepalived ----------------------------------------------------------
# Wrapped in a subshell so a dpkg/apt failure does not abort the rest of
# the recovery (sysctl, iptables, service start).
if ! command -v keepalived &>/dev/null; then
  (
    if ls "$DATADIR"/cache/keepalived_*.deb &>/dev/null; then
      latest="$(ls -v "$DATADIR"/cache/keepalived_*.deb | tail -1)"
      dpkg -i "$latest" || { apt-get update -qq && apt-get install -y -qq keepalived; }
    else
      apt-get update -qq
      apt-get install -y -qq keepalived
      mkdir -p "$DATADIR/cache"
      cp /var/cache/apt/archives/keepalived_*.deb "$DATADIR/cache/" 2>/dev/null || true
    fi
  ) || logger -t on-boot-keepalived "WARNING: keepalived install failed, continuing with infra setup"
fi

# -- symlinks from persistent storage ------------------------------------
ln -sfn "$DATADIR/keepalived.conf" /etc/keepalived/keepalived.conf
mkdir -p /etc/keepalived/conf.d
ln -sfn "$DATADIR/pihole.conf"     /etc/keepalived/conf.d/pihole.conf
ln -sfn "$DATADIR/healthcheck.sh"  /usr/local/bin/pihole_healthcheck

# -- heartbeat timer (firmware-update detection via healthchecks.io) ------
ln -sfn "$DATADIR/udm_keepalived_heartbeat.service" /etc/systemd/system/udm_keepalived_heartbeat.service
ln -sfn "$DATADIR/udm_keepalived_heartbeat.timer"   /etc/systemd/system/udm_keepalived_heartbeat.timer
systemctl daemon-reload

# -- sysctl ---------------------------------------------------------------
sysctl -w net.ipv4.ip_nonlocal_bind=1

# -- iptables VRRP accept ------------------------------------------------
# One rule per peer source IP -- only the real peers may deliver adverts.
for src in {{ pihole_keepalived_peers | select("ne", inventory_hostname) | map("extract", external_ips) | sort | join(" ") }}; do
  if ! iptables -w 5 -C INPUT -i {{ udm_dns_failover_interface }} -s "$src" -p 112 -m comment --comment "keepalived VRRP" -j ACCEPT 2>/dev/null; then
    iptables -w 5 -A INPUT -i {{ udm_dns_failover_interface }} -s "$src" -p 112 -m comment --comment "keepalived VRRP" -j ACCEPT
  fi
done

# -- validate and start ---------------------------------------------------
if command -v keepalived &>/dev/null && keepalived -t -f /etc/keepalived/keepalived.conf &>/dev/null; then
  systemctl enable --now keepalived.service
else
  logger -t on-boot-keepalived "WARNING: keepalived config validation failed, skipping start"
fi
systemctl enable --now udm_keepalived_heartbeat.timer
