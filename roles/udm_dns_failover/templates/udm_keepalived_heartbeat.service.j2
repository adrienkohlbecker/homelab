[Unit]
Description=Heartbeat ping for UDM keepalived VRRP peer

[Service]
Type=oneshot
# Push status=up only when keepalived is up AND the loopback healthcheck
# passes (the UDM can actually serve DNS); otherwise push status=down.
# This catches both a dead keepalived (firmware-wiped /usr) and a
# keepalived wedged in FAULT (its dnsmasq down) -- `systemctl is-active`
# alone reports the FAULT case as healthy, yet such a peer can't take the
# VIP. Either way an explicit status=down beat surfaces the fault sooner
# than waiting out the Kuma silence window like an offline UDM (the down
# beat still passes through the monitor's retry count before it alerts).
# --retry-all-errors so a resolver-not-up-yet blip just after boot retries
# like a 5xx would; --retry-max-time bounds the 2 retries inside -m 10/attempt.
ExecStart=/bin/bash -c 'if systemctl is-active --quiet keepalived.service && /usr/local/bin/dnsmasq_healthcheck; then url="{{ udm_dns_failover_heartbeat_url }}?status=up"; else url="{{ udm_dns_failover_heartbeat_url }}?status=down"; fi; exec curl -fsS -m 10 --retry 2 --retry-delay 5 --retry-connrefused --retry-all-errors --retry-max-time 30 -o /dev/null "$url"'
