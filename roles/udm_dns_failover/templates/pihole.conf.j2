vrrp_script pihole_healthcheck {
  script    /usr/local/bin/pihole_healthcheck
  interval  1
  timeout   5
  rise      1
  fall      2
  # The base conf defaults vrrp_script blocks to script_user nobody; declare
  # it explicitly per the multi-tenant contract. The loopback DNS healthcheck
  # needs no privilege (unlike pihole's container-port probe on lab/pug, which
  # declares user root).
  user      nobody
  # Start in FAILED state so keepalived enters FAULT on every restart and only
  # leaves once the healthcheck passes once -- a deterministic gate on the
  # UDM's own dnsmasq health rather than a wallclock startup delay.
  init_fail
}

# The instance name `pihole` (and the pihole-* identifiers throughout) is
# deliberately shared with the lab/pug peers, not a copy-paste leftover:
# this is the same VRRP group as roles/pihole, so the vrid/advert_int/VIP
# here MUST stay equal to roles/pihole/templates/keepalived.conf.j2. Only
# priority, use_vmac, and interface legitimately differ per peer.
vrrp_instance pihole {
  state     BACKUP
  interface {{ udm_dns_failover_interface }}

  # use_vmac OMITTED — kernel 4.19.152-ui-alpine has no macvlan module.
  # GARP announces VIP → br0 physical MAC instead of the VRRP standard MAC.
  # Acceptable: the UDM only claims the VIP in a catastrophic dual-failure
  # scenario where the UniFi client-tracker cosmetic flipping is a non-issue.

  # No `authentication` block: VRRPv2 auth is plaintext (worthless against
  # anyone who can sniff the segment), so it isn't the control here. The real
  # takeover protection is the per-peer iptables source-scoping (only the
  # listed peers may deliver proto-112 adverts) plus check_unicast_src below,
  # which validates each advert's source against unicast_peer.
  check_unicast_src

  unicast_src_ip {{ external_ips[inventory_hostname] }}
  unicast_peer {
    {% for name in pihole_keepalived_peers | select("ne", inventory_hostname) | sort %}
    {{ external_ips[name] }}
    {% endfor %}
  }

  virtual_router_id {{ pihole_keepalived_vrid }}
  priority          {{ pihole_keepalived_priority }}
  advert_int        1

  # Delay a recovered higher-priority peer (lab/pug) from reclaiming the VIP
  # for 60s so a flapping peer doesn't yank DNS back and forth. Plain preempt
  # (no nopreempt) is kept so a recovered peer does eventually reclaim and the
  # UDM falls back to BACKUP.
  preempt_delay     60

  # No explicit track_interface: keepalived already tracks the instance's own
  # `interface` (above) for link state, so re-listing it is redundant --
  # keepalived ignores it ("since own interface") and that warning makes
  # `keepalived -t` exit non-zero, failing the validate gate. (pihole's
  # fragment lists it because its use_vmac moves the instance onto a vmac
  # child, leaving the physical a *different* interface worth tracking; this
  # role omits use_vmac, so there is nothing extra to track.)

  virtual_ipaddress {
    {{ pihole_keepalived_ip }}/32
  }

  # Periodic gratuitous ARP so any LAN cache holding a stale MAC for the VIP
  # self-heals within ~1 minute. Without use_vmac (above) these advertise the
  # VIP at br0's physical MAC.
  garp_master_repeat 3
  garp_master_refresh 60

  track_script {
    pihole_healthcheck
  }

  notify "/usr/bin/logger -t pihole-keepalived"
}
