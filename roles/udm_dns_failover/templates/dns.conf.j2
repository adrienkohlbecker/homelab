vrrp_script dnsmasq_healthcheck {
  script    /usr/local/bin/dnsmasq_healthcheck
  interval  1
  timeout   5
  rise      1
  fall      2
  # The UDM's keepalived 2.2.7 + enable_script_security rejects `user nobody`
  # on the /data symlink chain (keepalived -t SIGTERMs with rc -15). root is
  # fine — the healthcheck is a loopback dig that needs no privilege escalation.
  user      root
  # Start in FAILED state so keepalived enters FAULT on every restart and only
  # leaves once the healthcheck passes once -- a deterministic gate on the
  # UDM's own dnsmasq health rather than a wallclock startup delay.
  init_fail
}

# The instance name matches roles/adguard's (`dns`) for uniform journal
# greps, though VRRP interop is keyed on vrid/advert_int/VIP, not names.
# Same VRRP group as roles/adguard, so the vrid/advert_int/VIP here MUST
# stay equal to roles/adguard/templates/keepalived.conf.j2. Only priority,
# use_vmac, and interface legitimately differ per peer. The healthcheck
# identifiers carry the dnsmasq_ prefix: they probe the UDM's own dnsmasq,
# this node's last-resort resolver.
vrrp_instance dns {
  state     BACKUP
  interface {{ udm_dns_failover_interface }}

  # use_vmac OMITTED — kernel 4.19.152-ui-alpine has no macvlan module.
  # GARP announces VIP → br0 physical MAC instead of the VRRP standard MAC.
  # Acceptable: the UDM only claims the VIP in a catastrophic dual-failure
  # scenario where the UniFi client-tracker cosmetic flipping is a non-issue.

  # No `authentication` block: VRRPv2 auth is plaintext (worthless against
  # anyone who can sniff the segment), so it isn't the control here. The real
  # takeover protection is the per-peer iptables source-scoping (only the
  # listed peers may deliver proto-112 adverts) plus check_unicast_src below,
  # which validates each advert's source against unicast_peer.
  check_unicast_src

  unicast_src_ip {{ external_ips[inventory_hostname] }}
  unicast_peer {
    {% for name in dns_keepalived_peers | select("ne", inventory_hostname) | sort %}
    {{ external_ips[name] }}
    {% endfor %}
  }

  virtual_router_id {{ dns_keepalived_vrid }}
  priority          {{ dns_keepalived_priority }}
  advert_int        1

  # Delay a recovered higher-priority peer (lab/pug adguard) from reclaiming
  # the VIP for 60s so a flapping peer doesn't yank DNS back and forth. Plain
  # preempt (no nopreempt) is kept so a recovered peer does eventually reclaim
  # and the UDM falls back to BACKUP.
  preempt_delay     60

  # No explicit track_interface: keepalived already tracks the instance's own
  # `interface` (above) for link state, so re-listing it is redundant --
  # keepalived ignores it ("since own interface") and that warning makes
  # `keepalived -t` exit non-zero, failing the validate gate. (The lab/pug
  # fragment omits it for the same reason -- see the track_interface note in
  # roles/adguard/templates/keepalived.conf.j2.)

  virtual_ipaddress {
    {{ network.virtual_ips.dns }}/32
  }

  # Periodic gratuitous ARP so any LAN cache holding a stale MAC for the VIP
  # self-heals within ~1 minute. Without use_vmac (above) these advertise the
  # VIP at br0's physical MAC.
  garp_master_repeat 3
  garp_master_refresh 60

  track_script {
    dnsmasq_healthcheck
  }

  # notify omitted: keepalived 2.2.7 + enable_script_security on the UDM
  # SIGTERMs keepalived -t (rc -15) when any notify script is present.
  # Transition logging is non-critical for this last-resort peer.
}
