#jinja2: lstrip_blocks: True
# sabnzbd.service #######################################################################
[Unit]
Description=sabnzbd
After=network-online.target
Wants=network-online.target
StartLimitInterval=600
StartLimitBurst=3
{% if zfs_root %}
{% if zfs_has_services_mount %}
After=zfs_mount_mnt_services.service
Requires=zfs_mount_mnt_services.service
After=zfs_mount_mnt_services_sqlite.service
Requires=zfs_mount_mnt_services_sqlite.service
{% endif %}
{% if zfs_has_scratch_mount %}
After=zfs_mount_mnt_scratch.service
Requires=zfs_mount_mnt_scratch.service
{% endif %}
{% if zfs_has_media_mount %}
After=zfs_mount_mnt_media.service
Requires=zfs_mount_mnt_media.service
{% endif %}
After=zfs_autosnapshot.target
PartOf=zfs_autosnapshot.target
{% endif %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutSec=120
# Exceed the container's `--stop-timeout 120` so systemd doesn't SIGKILL the
# cgroup at the moment podman's graceful-stop window closes -- that race would
# truncate SABnzbd's flush of history1.db onto the 4K sqlite dataset.
TimeoutStopSec=150
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --name sabnzbd \
    --security-opt=no-new-privileges \
    --log-driver journald \
    --log-opt tag="sabnzbd" \
    --env PUID={{ sabnzbd_user.uid }} \
    --env PGID={{ media_group.gid }} \
    --env UMASK=002 \
    --env TZ={{ system_timezone }} \
    --env DOCKER_MODS=linuxserver/mods:universal-package-install \
    --env INSTALL_PACKAGES=ffmpeg \
    --volume /mnt/services/sabnzbd:/config \
    --volume /mnt/services/sqlite/sabnzbd:/mnt/services/sqlite/sabnzbd \
    --volume /mnt/services/sabnzbd/autoProcessMedia.cfg:/opt/nzbToMedia/autoProcessMedia.cfg \
    --volume /mnt/media/Other:/media/Other \
    --volume /mnt/scratch:/scratch \
    --volume /opt/nzbToMedia:/opt/nzbToMedia \
    --network media \
    --publish 127.0.0.1:{{ service_ports.sabnzbd }}:8080/tcp \
    --health-cmd         '["curl","--head","--location","--fail","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://localhost:8080/api?mode=version"]' \
    --health-startup-cmd '["curl","--head","--location","--fail","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://localhost:8080/api?mode=version"]' \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "100s" \
    --stop-timeout 120 \
    docker.io/linuxserver/sabnzbd:5.0.0
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
{% if zfs_root %}
WantedBy=zfs_autosnapshot.target
{% endif %}
