127.0.0.1 localhost
{# Short name only — the FQDN intentionally lives in DNS (pihole), not #}
{# /etc/hosts. Reason: podman's base_hosts_file copies the host's #}
{# /etc/hosts into containers, so a `127.0.1.1 lab.fahm.fr` entry inside #}
{# pihole's container would make dnsmasq answer 127.0.1.1 for lab.fahm.fr #}
{# (hosts-file lookup wins over `address=/lab.fahm.fr/...`). Public DNS #}
{# CNAMEs every *.lab.fahm.fr subdomain to lab.fahm.fr, so the override #}
{# silently breaks every LAN-side lookup for subdomains as well. #}
{# `hostname --fqdn` falls through to DNS via NSS `files dns`. #}
127.0.1.1 {{ inventory_hostname }}

# The following line is desirable for IPv6 capable hosts
::1 localhost ip6-localhost ip6-loopback
{% if etc_hosts_entries | default({}) %}

# Static name → IP overrides from group_vars or host_vars `etc_hosts_entries`.
# Empty in most production host vars because regular DNS handles lab-internal
# names. Set per host only when that host needs a private route public DNS
# cannot express, and set in group_vars/test.yml so test boxes resolve
# lab-internal hostnames to LAN IPs reachable from inside qemu user-mode
# networking. The same map drives roles/pihole's container --add-host flags.
{% for host, ip in etc_hosts_entries.items() %}
{{ ip }} {{ host }}
{% endfor %}
{% endif %}
