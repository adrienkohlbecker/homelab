#jinja2: lstrip_blocks: True
# wolweb.service #######################################################################
[Unit]
Description=wolweb
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=600
StartLimitBurst=3
{% if zfs_root %}
{% if zfs_has_services_mount %}
After=zfs_mount_mnt_services.service
Requires=zfs_mount_mnt_services.service
{% endif %}
{% endif %}
# Deliberately NOT PartOf=zfs_autosnapshot.target. The nightly snapshot
# quiesces stateful services, but wolweb has no writable state -- its mounts
# are config.json + devices.json, both :ro. Quiescing buys nothing.

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutSec=120
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
{# --network host: a WoL magic packet is an L2 broadcast that must reach   #}
{# the target NIC's segment (the management VLAN). A NAT bridge cannot     #}
{# emit it and a published port would not help; host netns is what lets    #}
{# wolweb broadcast on the host's own NIC and bind the `interface` named   #}
{# in devices.json. (A mac_mgmt macvlan is the only non-host alternative   #}
{# and is materially more complex -- see host_vars mac_mgmt block.)        #}
{# --cap-drop=ALL is safe: sending a UDP datagram needs no capability.     #}
{# --unsetenv WOLWEB*: the image bakes WOLWEBPORT/WOLWEBVDIR env defaults  #}
{# which cleanenv overlays ON TOP of config.json; clearing them keeps the  #}
{# mounted config.json authoritative (esp. vdir=/ and host=127.0.0.1).     #}
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --init \
    --name wolweb \
    --log-driver journald \
    --log-opt tag="wolweb" \
    --volume /mnt/services/wolweb/config.json:/wolweb/config.json:ro \
    --volume /mnt/services/wolweb/devices.json:/wolweb/devices.json:ro \
    --user {{ wolweb_user.uid }}:{{ wolweb_user.group }}  \
    --security-opt=no-new-privileges \
    --cap-drop=ALL \
    --unsetenv WOLWEBPORT \
    --unsetenv WOLWEBVDIR \
    --unsetenv WOLWEBHOST \
    --unsetenv WOLWEBBCASTIP \
    --unsetenv WOLWEBREADONLY \
    --network host \
    --health-cmd '["curl","--fail","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://localhost:{{ service_ports.wolweb }}/health"]' \
    --health-startup-cmd '["curl","--fail","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://localhost:{{ service_ports.wolweb }}/health"]' \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "100s" \
    --stop-timeout 120 \
    ghcr.io/sameerdhoot/wolweb:alpine@sha256:4dacd33d9d1d747efa4018a7fcf07c62e3a4afd348c0ef45ca31fe4ecd51c36a
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
