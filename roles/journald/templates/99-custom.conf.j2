[Journal]
Storage={{ journald_storage }}
{# Compress=no only when the journal lands on a ZFS dataset that already
   compresses it; otherwise (tmpfs for Storage=volatile, ext4 for non-ZFS
   hosts) journald's per-object XZ is the only compression in the stack. #}
Compress={{ (journald_storage == 'persistent' and zfs_root) | ternary('no', 'yes') }}
ForwardToSyslog=no
ReadKMsg=yes
# Audit records flow through fluent-bit's tail of /var/log/audit/audit.log
# (the auditd authoritative stream, 100% coverage). Letting journald
# subscribe to the kernel audit netlink in parallel would put ~80% of
# records into both streams -- the 80/20 split surfaces in HyperDX as
# duplicate facets. systemd-journald-audit.socket is disabled below
# so the netlink fd stays unclaimed.
Audit=no
