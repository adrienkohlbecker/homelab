# fan2go config for lab. Two shared sensors (nct6798 temp2, drivetemp
# max) drive two curves; four fans reference them.
#
# Rotational disks are pulled from group_vars/all.yml:rotational_disks_by_id
# (computed at apply time from ansible_devices) and aggregated via a
# max-function curve so HDD-driven fans track the hottest spinner. Not
# the simpler "platform: drivetemp" form: it binds to the first drivetemp
# libsensors enumerates, often a cool SSD (sde/sdf/sdg run 28-39°C), so
# the curve evaluates below mintemp=40 and the fans pin at 0. SSDs
# deliberately excluded; we don't want fan speed reacting to them.

dbPath: /var/lib/fan2go/fan2go.db

# fan2go-tui (interactive, ssh-in-and-run) talks to the daemon over
# this loopback HTTP API. Port pinned from
# group_vars/all.yml:service_ports.fan2go_api; the matching tui side
# lives in roles/fan2go/templates/fan2go-tui.yaml.j2.
api:
  enabled: true
  host: 127.0.0.1
  port: {{ service_ports.fan2go_api }}

fans:
  - id: cpu_fan
    hwmon:
      platform: nct6798
      rpmChannel: 2
      pwmChannel: 2
    curve: cpu_curve
    startPwm: 58
    minPwm: 28

  - id: cha_fan1_exhaust
    hwmon:
      platform: nct6798
      rpmChannel: 1
      pwmChannel: 1
    curve: cpu_curve
    startPwm: 46
    minPwm: 16

  - id: cha_fan3_intake
    hwmon:
      platform: nct6798
      rpmChannel: 4
      pwmChannel: 4
    curve: hdd_curve
    startPwm: 46
    minPwm: 16

  - id: cha_fan2_intake
    hwmon:
      platform: nct6798
      rpmChannel: 3
      pwmChannel: 3
    curve: hdd_curve
    startPwm: 46
    minPwm: 16

sensors:
  - id: nct6798_temp2
    hwmon:
      platform: nct6798
      index: 2
{% for disk in rotational_disks_by_id %}
  - id: hdd_{{ loop.index }}_temp
    disk:
      device: /dev/disk/by-id/{{ disk }}
{% endfor %}

curves:
  # CPUTIN ramps from idle (~43°C) to max-spinout (~65°C). Ceiling
  # widened from 60 to 65 since Pkg-temp tops out around 70°C under
  # bursty load and CPUTIN trails Pkg by several degrees -- the
  # previous max=60 had the CPU fans pinned at 100% during normal
  # spikes.
  - id: cpu_curve
    linear:
      sensor: nct6798_temp2
      min: 30
      max: 65
{% for disk in rotational_disks_by_id %}
  # min=38: ramp starts ~1°C before the hottest WD10TB's steady-state
  # (46°C) so the curve actually pulls heat back down. max=48: full
  # PWM at 48°C; well below the 65°C WD Red Plus continuous rating
  # but close enough to keep longevity in the sweet spot.
  - id: hdd_{{ loop.index }}_curve
    linear:
      sensor: hdd_{{ loop.index }}_temp
      min: 38
      max: 48
{% endfor %}

  - id: hdd_curve
    function:
      type: maximum
      curves:
{% for disk in rotational_disks_by_id %}
        - hdd_{{ loop.index }}_curve
{% endfor %}
