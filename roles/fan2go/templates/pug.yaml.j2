# fan2go config for pug. CHA_FAN_2 follows CPU package temp via
# coretemp; CHA_FAN_1 follows the hotter of pug's rotational HDDs
# (high startPwm=120 because that fan stalls below it).
#
# CHA_FAN_2 used to follow nct6798/temp1 (SYSTIN) in the fancontrol-era
# config, but SYSTIN reads ~51°C idle on this box (probably positioned
# near a heat source, not at the intake) and would have pinned the fan
# at high PWM nonstop on fan2go. coretemp's Package id 0 is a more
# honest "is the CPU actually warm?" signal.
#
# Rotational disks are pulled from group_vars/all.yml:rotational_disks_by_id
# (computed at apply time from ansible_devices) and aggregated via a
# max-function curve. Same rationale as lab.yaml.j2 -- "platform: drivetemp"
# binds to whichever drivetemp libsensors enumerates first.

dbPath: /var/lib/fan2go/fan2go.db

# fan2go-tui (interactive, ssh-in-and-run) talks to the daemon over
# this loopback HTTP API. Port pinned from
# group_vars/all.yml:service_ports.fan2go_api; the matching tui side
# lives in roles/fan2go/templates/fan2go-tui.yaml.j2.
api:
  enabled: true
  host: 127.0.0.1
  port: {{ service_ports.fan2go_api }}

fans:
  - id: cha_fan_2
    hwmon:
      platform: nct6798
      rpmChannel: 3
      pwmChannel: 3
    curve: cpu_curve
    startPwm: 40
    minPwm: 10

  - id: cha_fan_1_hdd
    hwmon:
      platform: nct6798
      rpmChannel: 2
      pwmChannel: 2
    curve: hdd_curve
    startPwm: 120
    minPwm: 90

sensors:
  # coretemp index 1 is "Package id 0" -- the CPU package envelope
  # temp, derived from per-core DTS readings. Idles ~54°C on pug
  # and ramps with actual CPU load.
  - id: cpu_package_temp
    hwmon:
      platform: coretemp
      index: 1
{% for disk in rotational_disks_by_id %}
  - id: hdd_{{ loop.index }}_temp
    disk:
      device: /dev/disk/by-id/{{ disk }}
{% endfor %}

curves:
  # Idle Package id 0 ~54°C; under sustained load it'll climb toward
  # 75-80°C. min=50 keeps the fan near minPwm at idle; max=80 gives
  # full speed before any thermal-throttle territory.
  - id: cpu_curve
    linear:
      sensor: cpu_package_temp
      min: 50
      max: 80
{% for disk in rotational_disks_by_id %}
  # min=38, max=48: matches lab.yaml.j2's HDD curve. Ramp starts just
  # before WD10TB steady-state; full PWM at 48°C keeps spinners in
  # the longevity sweet spot well clear of the 65°C continuous rating.
  - id: hdd_{{ loop.index }}_curve
    linear:
      sensor: hdd_{{ loop.index }}_temp
      min: 38
      max: 48
{% endfor %}

  - id: hdd_curve
    function:
      type: maximum
      curves:
{% for disk in rotational_disks_by_id %}
        - hdd_{{ loop.index }}_curve
{% endfor %}
