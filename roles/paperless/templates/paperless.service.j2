#jinja2: lstrip_blocks: True
# paperless.service #######################################################################
[Unit]
Description=paperless
After=network-online.target
Wants=network-online.target
StartLimitInterval=600
StartLimitBurst=3
{% if zfs_root %}
{% if zfs_has_services_mount %}
After=zfs_mount_mnt_services.service
Requires=zfs_mount_mnt_services.service
After=zfs_mount_mnt_services_sqlite.service
Requires=zfs_mount_mnt_services_sqlite.service
{% endif %}
After=zfs_autosnapshot.target
PartOf=zfs_autosnapshot.target
{% endif %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutSec=240
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --name paperless \
    --log-driver journald \
    --log-opt tag="paperless" \
    --volume /mnt/services/paperless/data:/usr/src/paperless/data \
    --volume /mnt/services/sqlite/paperless:/mnt/services/sqlite/paperless \
    --volume /mnt/services/paperless/media:/usr/src/paperless/media \
    --volume /mnt/services/paperless/consume:/usr/src/paperless/consume \
    --volume /mnt/services/paperless/export:/usr/src/paperless/export \
    --network redis \
    --publish 127.0.0.1:8001:8000/tcp \
    --env USERMAP_UID={{ paperless_user.uid }} \
    --env USERMAP_GID={{ paperless_user.group }} \
    --env PAPERLESS_REDIS="redis://redis.dns.podman:6379/1" \
    --env PAPERLESS_OCR_LANGUAGES="eng fra nld" \
    --env PAPERLESS_OCR_LANGUAGE=fra \
    --env PAPERLESS_URL=https://paperless.{{ inventory_hostname }}.{{ domain }} \
    --env PAPERLESS_APPS=allauth.socialaccount.providers.openid_connect \
    --env PAPERLESS_ACCOUNT_DEFAULT_HTTP_PROTOCOL=https \
    --env PAPERLESS_ACCOUNT_EMAIL_VERIFICATION=none \
    --env PAPERLESS_SOCIAL_AUTO_SIGNUP=true \
    --env PAPERLESS_REDIRECT_LOGIN_TO_SSO=true \
    --env PAPERLESS_SOCIALACCOUNT_PROVIDERS_FILE=/run/secrets/socialaccount_providers.json \
    --secret=paperless_secret_key,type=env,target=PAPERLESS_SECRET_KEY \
    --secret=paperless_socialaccount_providers,type=mount,target=socialaccount_providers.json \
    --health-cmd         '["curl","--head","--location","--fail","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://localhost:8000/"]' \
    --health-startup-cmd '["curl","--head","--location","--fail","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://localhost:8000/"]' \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "100s" \
    --stop-timeout 120 \
    ghcr.io/paperless-ngx/paperless-ngx:2.20.15
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
{% if zfs_root %}
WantedBy=zfs_autosnapshot.target
{% endif %}
