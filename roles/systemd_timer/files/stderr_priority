#!/bin/bash
# Run a command with its stderr re-tagged as priority `err` for the
# journal. systemd's SyslogLevelPrefix= (default true) parses <N>
# kernel-style prefixes on captured output and applies the priority,
# so prefixing every stderr line with <3> turns
# `journalctl -u <unit> -p err` into a clean failure-only view.
# No second journal stream (unlike systemd-cat), so no duplicates.
#
# Implementation notes: bare `2> >(sed ...)` + `wait` looks correct
# but loses lines under Type=oneshot — bash's `wait` (no args)
# doesn't reliably track process-substitution PIDs as jobs, so the
# wrapper exits before sed flushes, systemd closes the stderr pipe,
# and SIGPIPE drops the in-flight line. Using `exec 2> >(...)` lets
# us capture the PID via `$!` and `wait "$pid"` explicitly; closing
# fd 2 first feeds sed EOF so it returns instead of hanging.
set -u
[ "$#" -ge 1 ] || {
  echo "Usage: ${0##*/} CMD [ARGS...]" >&2
  exit 64
}
exec 2> >(sed -u 's/^/<3>/' >&2)
sed_pid=$!
"$@"
rc=$?
exec 2>&-
wait "$sed_pid" 2>/dev/null || true
exit "$rc"
