[Unit]
Description={{ systemd_timer_args.description | default(systemd_timer_args.name) }}

[Service]
Type=oneshot
# stderr lines land in the journal at priority err; see /usr/local/bin/stderr_priority.
ExecStart=/usr/local/bin/stderr_priority {{ systemd_timer_args.exec_start }}
SyslogIdentifier={{ systemd_timer_args.name }}
# RuntimeMaxSec= has no effect under Type=oneshot; TimeoutStartSec= is the right knob.
TimeoutStartSec={{ systemd_timer_args.timeout_start_sec | default('1h') }}
TimeoutStopSec={{ systemd_timer_args.timeout_stop_sec | default('30s') }}
{% if systemd_timer_args.run_as is defined %}
User={{ systemd_timer_args.run_as }}
Group={{ systemd_timer_args.run_as_group | default(systemd_timer_args.run_as) }}
{% endif %}
{% if systemd_timer_args.environment is defined %}
{% for k, v in (systemd_timer_args.environment | dictsort) %}
Environment="{{ k }}={{ v | string | replace('\\', '\\\\') | replace('"', '\\"') }}"
{% endfor %}
{% endif %}
{% if systemd_timer_args.additional_service_directives is defined %}
{% for line in systemd_timer_args.additional_service_directives %}
{{ line }}
{% endfor %}
{% endif %}
