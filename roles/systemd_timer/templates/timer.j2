[Unit]
Description={{ systemd_timer_args.description | default(systemd_timer_args.name) }} timer

[Timer]
OnCalendar={{ systemd_timer_args.on_calendar }}
# Persistent=true catches up missed fires across reboots, but also fires
# immediately on first enable (no existing stamp). Set persistent: false
# to suppress that immediate catch-up fire on fresh installs.
Persistent={{ 'true' if systemd_timer_args.persistent | default(true) else 'false' }}
{% if systemd_timer_args.randomized_delay_sec is defined %}
RandomizedDelaySec={{ systemd_timer_args.randomized_delay_sec }}
{% if systemd_timer_args.fixed_random_delay | default(false) %}
FixedRandomDelay=yes
{% endif %}
{% endif %}
{% if systemd_timer_args.accuracy_sec is defined %}
AccuracySec={{ systemd_timer_args.accuracy_sec }}
{% endif %}
{% if systemd_timer_args.on_active_sec is defined %}
OnActiveSec={{ systemd_timer_args.on_active_sec }}
{% endif %}

[Install]
WantedBy=timers.target
