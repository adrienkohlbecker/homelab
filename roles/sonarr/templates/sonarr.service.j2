#jinja2: lstrip_blocks: True
# sonarr.service #######################################################################
[Unit]
Description=sonarr
After=network-online.target
Wants=network-online.target
StartLimitInterval=600
StartLimitBurst=3
{% if zfs_root %}
{% if zfs_has_services_mount %}
After=zfs_mount_mnt_services.service
Requires=zfs_mount_mnt_services.service
After=zfs_mount_mnt_services_sqlite.service
Requires=zfs_mount_mnt_services_sqlite.service
{% endif %}
{% if zfs_has_scratch_mount %}
After=zfs_mount_mnt_scratch.service
Requires=zfs_mount_mnt_scratch.service
{% endif %}
{% if zfs_has_media_mount %}
After=zfs_mount_mnt_media.service
Requires=zfs_mount_mnt_media.service
{% endif %}
After=zfs_autosnapshot.target
PartOf=zfs_autosnapshot.target
{% endif %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutStartSec=120
# Exceed the container's --stop-timeout (120s) so a slow graceful shutdown --
# during which sonarr writes config.xml back -- finishes before systemd's stop
# deadline SIGKILLs it and skips the writeback.
TimeoutStopSec=180
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --detach \
    --replace \
    --rm \
    --name sonarr \
    --security-opt=no-new-privileges \
    --log-driver journald \
    --log-opt tag="sonarr" \
    --env PUID={{ sonarr_user.uid }} \
    --env PGID={{ media_group.gid }} \
    --env UMASK=002 \
    --env TZ={{ system_timezone }} \
    --volume /mnt/services/sonarr:/config \
    --volume /mnt/services/sqlite/sonarr:/mnt/services/sqlite/sonarr \
    --volume /mnt/media:/media \
    --volume /mnt/scratch/sonarr:/scratch/sonarr \
    --network media \
    --publish 127.0.0.1:{{ service_ports.sonarr }}:8989/tcp \
    --health-cmd         '["curl","--location","--fail","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://localhost:8989/ping"]' \
    --health-startup-cmd '["curl","--location","--fail","--silent","--show-error","--connect-timeout","1","--max-time","5","-o","/dev/null","http://localhost:8989/ping"]' \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --stop-timeout 120 \
    {{ sonarr_image }}
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
{% if zfs_root %}
WantedBy=zfs_autosnapshot.target
{% endif %}
