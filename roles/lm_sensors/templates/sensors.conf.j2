# vim:ft=yaml
# netdata go.d sensors collector. The collector auto-discovers every hwmon
# chip, so the bare job below is all that's needed to graph them. Charts are
# named after the chip/feature (e.g. coretemp-isa-0000 -> temp2), which is
# cryptic; set `lm_sensors_relabel` in host_vars to give specific sensors a
# friendly label (chip identifiers and feature names differ per host -- run
# `sensors` to list them). It's an optional companion to `lm_sensors_modules`;
# empty means no relabeling. Shape:
#   lm_sensors_relabel:
#     - chip: coretemp-isa-*      # chip pattern (glob)
#       sensors:
#         - name: temp1           # feature name as `sensors` reports it
#           label: CPU Package
{% set relabel = lm_sensors_relabel %}
jobs:
  - name: sensors
    autodetection_retry: 60
{% if relabel | length > 0 %}
    relabel:
{% for entry in relabel %}
      - chip: {{ entry.chip | to_json }}
        sensors:
{% for sensor in entry.sensors %}
          - name: {{ sensor.name | to_json }}
            label: {{ sensor.label | to_json }}
{% endfor %}
{% endfor %}
{% endif %}
