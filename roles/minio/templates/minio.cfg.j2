# vim:ft=properties

# Set the hosts and volumes MinIO uses at startup
# The command uses MinIO expansion notation {x...y} to denote a
# sequential series.
#
# The following example covers four MinIO hosts
# with 4 drives each at the specified hostname and drive locations.
# The command includes the port that each MinIO server listens on
# (default 9000)

MINIO_VOLUMES="/mnt/minio"

# Set all MinIO server options
#
# The following explicitly sets the MinIO Console listen address to
# port 9001 on all network interfaces. The default behavior is dynamic
# port selection.

MINIO_OPTS="--address 127.0.0.1:9199 --console-address 127.0.0.1:9001"

# Set the root username. This user has unrestricted permissions to
# perform S3 and administrative API operations on any resource in the
# deployment.
#
# Defer to your organizations requirements for superadmin user name.

MINIO_ROOT_USER={{ minio_root_user }}

# Set the root password
#
# Use a long, random, unique string that meets your organizations
# requirements for passwords.

MINIO_ROOT_PASSWORD={{ minio_root_password }}

# Set to the URL of the load balancer for the MinIO deployment
# This value *must* match across all MinIO servers. If you do
# not have a load balancer, set this value to to any *one* of the
# MinIO hosts in the deployment as a temporary measure.
MINIO_SERVER_URL=https://minio-api.{{ inventory_hostname }}.{{ domain }}
MINIO_BROWSER_REDIRECT_URL=https://minio.{{ inventory_hostname }}.{{ domain }}

# don't require auth on metrics endpoint
MINIO_PROMETHEUS_AUTH_TYPE=public

# Display metrics in the console
MINIO_PROMETHEUS_URL=http://localhost:9090

# OIDC provider (Authelia). MINIO_ROOT_USER above stays the
# emergency break-glass login; day-to-day console access is via
# OIDC. MinIO doesn't probe the discovery URL at startup -- it
# fetches it lazily on first login -- so an unreachable Authelia
# only breaks new logins, not the daemon itself.
#
# CLAIM_NAME=groups maps Authelia's per-user groups list onto
# MinIO's policy-attachment lookup: a token with groups: ["admins"]
# attaches the IAM policy named "admins" (created out-of-band via
# `mc admin policy create` against an Authelia group name -- see
# notes/authelia_rollout.md). consoleAdmin is the built-in admin
# policy; map the Authelia "admins" group to it for operators.
MINIO_IDENTITY_OPENID_CONFIG_URL=https://auth.{{ authelia_cookie_domain }}/.well-known/openid-configuration
MINIO_IDENTITY_OPENID_CLIENT_ID=minio
MINIO_IDENTITY_OPENID_CLIENT_SECRET={{ minio_oidc_client_secret }}
MINIO_IDENTITY_OPENID_SCOPES=openid,profile,email,groups
MINIO_IDENTITY_OPENID_CLAIM_NAME=groups
MINIO_IDENTITY_OPENID_DISPLAY_NAME=Authelia
MINIO_IDENTITY_OPENID_REDIRECT_URI=https://minio.{{ inventory_hostname }}.{{ domain }}/oauth_callback
