{#
  Schedule policy: fixed-time batch jobs (full scans, refreshes, cache cleanup)
  are pinned to <= 00:30 local so they finish well before the 02:00 UTC
  zfs_autosnapshot backup -- even at the winter (CET, +1h) offset, where 00:30
  local = 23:30 UTC. This keeps the nightly backup from interrupting them and
  lets the snapshot capture their completed output. Times are local
  (--env TZ=Europe/Paris). Continuous poll loops (*/N) are exempt -- they retry
  and the quiesce stops/resumes them cleanly. See notes/scheduled_jobs_audit.md.
#}
 "jobs": {
  "plex-recently-added-scan": {
   "schedule": "0 */5 * * * *"
  },
  "plex-full-scan": {
   "schedule": "0 0 0 * * *"
  },
  "plex-watchlist-sync": {
   "schedule": "0 */3 * * * *"
  },
  "plex-refresh-token": {
   "schedule": "0 30 23 * * *"
  },
  "radarr-scan": {
   "schedule": "0 10 0 * * *"
  },
  "sonarr-scan": {
   "schedule": "0 20 0 * * *"
  },
  "availability-sync": {
   "schedule": "0 30 0 * * *"
  },
  "download-sync": {
   "schedule": "0 * * * * *"
  },
  "download-sync-reset": {
   "schedule": "0 0 1 * * *"
  },
  "jellyfin-recently-added-scan": {
   "schedule": "0 */5 * * * *"
  },
  "jellyfin-full-scan": {
   "schedule": "0 5 0 * * *"
  },
  "image-cache-cleanup": {
   "schedule": "0 45 23 * * *"
  },
  "process-blocklisted-tags": {
   "schedule": "0 30 1 */7 * *"
  }
 },
 "network": {
  "csrfProtection": true,
  "forceIpv4First": false,
  "trustProxy": true,
  "proxy": {
   "enabled": false,
   "hostname": "",
   "port": 8080,
   "useSsl": false,
   "user": "",
   "password": "",
   "bypassFilter": "",
   "bypassLocalAddresses": true
  },
  "dnsCache": {
   "enabled": false,
   "forceMinTtl": 0,
   "forceMaxTtl": -1
  },
  "apiRequestTimeout": 10000
 },
{#
  migrations[] is seerr's applied-settings-migration ledger. The migrator runs
  every file in server/lib/settings/migrations/* on each boot, but each
  migration self-gates: it returns early if its own name is already in this
  array, otherwise it transforms settings and pushes its name. So the ledger
  -- not the migrator -- is what makes a migration a no-op. We render the full
  post-migration canonical shape already, so an empty ledger on a brand-new
  host lets the ledger-gated migrations (0007 arr-tags, 0008 blacklist->
  blocklist) run once against our already-canonical data -- a no-op transform
  that only appends their names -- and seerr writes the populated ledger back
  on first boot. Slurp-preserve takes over from there: once booted seerr owns
  the array and appends whatever new migration an upgrade ships, and the
  daemon's value wins. Seeding [] (rather than tracking the current migration
  tail) costs one extra first-boot writeback+restart but drops the per-image-
  bump chore of re-auditing which migrations are ledger-gated. 0001-0006 gate
  on the presence of old keys, so they self-skip against canonical data anyway.
#}
{% set _migrations = seerr_settings_json | json_query('migrations') | default([], true) %}
{% if _migrations %}
 "migrations": [
{% for _m in _migrations %}
  {{ _m | to_json }}{% if not loop.last %},{% endif %}

{% endfor %}
 ]
{% else %}
 "migrations": []
{% endif %}
}
