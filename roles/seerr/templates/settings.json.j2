{#
  Byte-exact template: the rendered bytes must equal what seerr persists via
  JSON.stringify(_, null, 1), or every converge diff-churns and restarts seerr
  (enforced by the _verify byte-for-byte shape-match). Whitespace is therefore
  load-bearing -- this leans on ansible's default trim_blocks (which strips the
  newline after each block/comment tag) and main.yml strips the single trailing
  newline JSON.stringify omits. Don't add a jinja whitespace-control header or
  hand-reflow the loops without re-running the _verify shape-match assert.
#}
{
 "clientId": "{{ seerr_client_id }}",
 "sessionSecret": "{{ seerr_session_secret }}",
 "vapidPrivate": "{{ seerr_vapid_private }}",
 "vapidPublic": "{{ seerr_vapid_public }}",
 "main": {
  "apiKey": "{{ seerr_api_key }}",
  "applicationTitle": "Seerr",
  "applicationUrl": "https://seerr.{{ inventory_hostname }}.{{ domain }}",
  "cacheImages": true,
  "defaultPermissions": 32,
  "defaultQuotas": {
   "movie": {},
   "tv": {}
  },
  "hideAvailable": false,
  "hideBlocklisted": false,
  "localLogin": true,
  "mediaServerLogin": true,
  "newPlexLogin": false,
  "discoverRegion": "US",
  "streamingRegion": "US",
  "originalLanguage": "",
  "blocklistRegion": "",
  "blocklistLanguage": "",
  "blocklistedTags": "",
  "blocklistedTagsLimit": 50,
{# mediaServerType enum: PLEX=1, JELLYFIN=2, EMBY=3, NOT_CONFIGURED=4. The 4
   default is "unconfigured", routing a fresh install's UI to /setup (see the
   public.initialized block below); slurp preserves the wizard's choice after. #}
  "mediaServerType": {{ (seerr_settings_json | json_query('main.mediaServerType') | default(4, true)) }},
  "partialRequestsEnabled": true,
  "enableSpecialEpisodes": false,
  "locale": "en",
  "youtubeUrl": ""
 },
{#
  plex.libraries[] is daemon-owned once Plex is connected: seerr discovers and
  rewrites the set (ids/names/types) and bumps each lastScan on every plex scan.
  Seed the operator's three curated libraries (pre-enabled) for a fresh install,
  then slurp-preserve so a library add/rename/disable/rescan in Plex doesn't
  diff-churn and restart seerr on the next converge. Mirrors jellyfin.libraries
  below; the per-key emit order (id/name/enabled/type/lastScan) matches seerr's
  own JSON.stringify writeback so the rendered bytes stay stable.
#}
{% set _plex_libs = seerr_settings_json | json_query('plex.libraries') | default([
  {'id': '10', 'name': 'Live Music', 'enabled': true, 'type': 'movie', 'lastScan': 0},
  {'id': '1', 'name': 'Movies', 'enabled': true, 'type': 'movie', 'lastScan': 0},
  {'id': '2', 'name': 'TV Shows', 'enabled': true, 'type': 'show', 'lastScan': 0}
], true) %}
 "plex": {
  "name": "DockerPlex",
  "ip": "plex.dns.podman",
  "port": 32400,
  "useSsl": false,
  "libraries": [
{% for _lib in _plex_libs %}
   {
    "id": {{ _lib.id | to_json }},
    "name": {{ _lib.name | to_json }},
    "enabled": {{ _lib.enabled | string | lower }},
    "type": {{ _lib.type | to_json }},
    "lastScan": {{ _lib.lastScan | default(0, true) }}
   }{% if not loop.last %},{% endif %}

{% endfor %}
  ],
  "webAppUrl": "https://plex.{{ inventory_hostname }}.{{ domain }}/web/index.html",
  "machineId": "{{ plex_machine_id }}"
 },
{#
  jellyfin is the SSO source. The bootstrap path (server/routes/auth.ts):
  the setup wizard's JellyfinSetup form POSTs serverType + username +
  password + hostname/port/useSsl/urlBase to /api/v1/auth/jellyfin; if
  userRepository.count() === 0, seerr authenticates against jellyfin,
  mints an API token labelled "Seerr" off the operator's admin session,
  and writes name/ip/port/useSsl/urlBase/serverId/apiKey/libraries[] to
  settings.json. CRITICAL: pre-bootstrap, settings.jellyfin.ip MUST be
  empty -- auth.ts errors with "Jellyfin hostname already configured"
  (HTTP 500, unmapped by UI so it surfaces as "Something went wrong")
  if settings.jellyfin.ip is non-empty AND the form sends hostname,
  which the setup form always does. So ip/port/useSsl/urlBase all
  slurp-preserve from disk and start empty; the operator fills them in
  during /setup. Post-bootstrap, the slurp picks the daemon-written
  values up and re-renders them, keeping ansible idempotent.
  externalHostname stays operator-config (used for outbound notification
  links; not gated by the auth route). Empty libraries[] renders
  single-line per seerr's JSON.stringify(_, 1) shape; once populated,
  the manual loop below matches the daemon's multi-line shape so
  ansible diffs stay quiet.
#}
{% set _jelly_libs = seerr_settings_json | json_query('jellyfin.libraries') %}
 "jellyfin": {
  "name": {{ (seerr_settings_json | json_query('jellyfin.name') or '') | to_json }},
  "ip": {{ (seerr_settings_json | json_query('jellyfin.ip') or '') | to_json }},
  "port": {{ seerr_settings_json | json_query('jellyfin.port') | default(8096, true) }},
  "useSsl": {{ (seerr_settings_json | json_query('jellyfin.useSsl') | default(false, true)) | string | lower }},
  "urlBase": {{ (seerr_settings_json | json_query('jellyfin.urlBase') or '') | to_json }},
  "externalHostname": "https://jellyfin.{{ inventory_hostname }}.{{ domain }}",
  "jellyfinForgotPasswordUrl": "",
{% if _jelly_libs %}
  "libraries": [
{% for _lib in _jelly_libs %}
   {
    "id": {{ _lib.id | to_json }},
    "name": {{ _lib.name | to_json }},
    "enabled": {{ _lib.enabled | string | lower }},
    "type": {{ _lib.type | to_json }}{% if _lib.lastScan is defined %},
    "lastScan": {{ _lib.lastScan }}{% endif %}

   }{% if not loop.last %},{% endif %}

{% endfor %}
  ],
{% else %}
  "libraries": [],
{% endif %}
  "serverId": {{ (seerr_settings_json | json_query('jellyfin.serverId') or '') | to_json }},
  "apiKey": {{ (seerr_settings_json | json_query('jellyfin.apiKey') or '') | to_json }}
 },
 "tautulli": {
