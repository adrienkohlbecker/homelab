{#
  jellyfin is the SSO source. The bootstrap path (server/routes/auth.ts):
  on first sign-in via the Jellyfin form, when userRepository.count() === 0,
  seerr mints a Jellyfin API token labelled "Seerr" using the operator's
  Jellyfin admin session and writes it back to settings.jellyfin.apiKey,
  along with name/serverId/libraries[]. Slurp+json_query preserves those
  daemon-written fields across re-templates; ip/port/useSsl/urlBase/
  externalHostname/jellyfinForgotPasswordUrl are operator-config we own.
  Empty libraries[] renders single-line per seerr's JSON.stringify(_, 1)
  shape; once populated, the manual loop below matches the daemon's
  multi-line shape so ansible diffs stay quiet.
#}
{% set _jelly_libs = seerr_settings_json | json_query('jellyfin.libraries') %}
 "jellyfin": {
  "name": "{{ seerr_settings_json | json_query('jellyfin.name') or '' }}",
  "ip": "jellyfin.dns.podman",
  "port": 8096,
  "useSsl": false,
  "urlBase": "",
  "externalHostname": "https://jellyfin.{{ inventory_hostname }}.{{ domain }}",
  "jellyfinForgotPasswordUrl": "",
{% if _jelly_libs %}
  "libraries": [
{% for _lib in _jelly_libs %}
   {
    "id": "{{ _lib.id }}",
    "name": "{{ _lib.name }}",
    "enabled": {{ _lib.enabled | string | lower }},
    "type": "{{ _lib.type }}",
    "lastScan": {{ _lib.lastScan | default(0) }}
   }{% if not loop.last %},{% endif %}

{% endfor %}
  ],
{% else %}
  "libraries": [],
{% endif %}
  "serverId": "{{ seerr_settings_json | json_query('jellyfin.serverId') or '' }}",
  "apiKey": "{{ seerr_settings_json | json_query('jellyfin.apiKey') or '' }}"
 },
 "tautulli": {
  "hostname": "tautulli.dns.podman",
  "port": 8181,
  "useSsl": false,
  "apiKey": "{{ tautulli_api_key }}",
  "externalUrl": "https://tautulli.{{ inventory_hostname }}.{{ domain }}"
 },
 "metadataSettings": {
  "tv": "tmdb",
  "anime": "tmdb"
 },
 "radarr": [
  {
   "name": "radarr",
   "hostname": "radarr.dns.podman",
   "port": 7878,
   "apiKey": "{{ radarr_api_key }}",
   "useSsl": false,
   "activeProfileId": 12,
   "activeProfileName": "2160p Quality",
   "activeDirectory": "/media/Movies",
   "is4k": false,
   "minimumAvailability": "released",
   "tags": [],
   "isDefault": true,
   "externalUrl": "https://radarr.{{ inventory_hostname }}.{{ domain }}",
   "syncEnabled": true,
   "preventSearch": false,
   "tagRequests": false,
   "id": 0
  }
 ],
 "sonarr": [
  {
   "name": "sonarr",
   "hostname": "sonarr.dns.podman",
   "port": 8989,
   "apiKey": "{{ sonarr_api_key }}",
   "useSsl": false,
   "activeProfileId": 12,
   "activeLanguageProfileId": 1,
   "activeProfileName": "2160p Quality",
   "activeDirectory": "/media/TV",
   "activeAnimeProfileId": 12,
   "activeAnimeLanguageProfileId": 1,
   "activeAnimeProfileName": "2160p Quality",
   "activeAnimeDirectory": "/media/TV",
   "tags": [],
   "animeTags": [],
   "is4k": false,
   "isDefault": true,
   "enableSeasonFolders": false,
   "externalUrl": "https://sonarr.{{ inventory_hostname }}.{{ domain }}",
   "syncEnabled": true,
   "preventSearch": false,
   "tagRequests": false,
   "id": 0
  }
 ],
{#
  public.initialized + main.mediaServerType are written by the setup
  wizard's POST /api/v1/settings/initialize and the Jellyfin auth bootstrap
  branch (server/routes/auth.ts). Default both to "unconfigured" on first
  install so the UI routes the operator to /setup (which sends serverType
  in the auth POST) instead of /login (which doesn't and would trip the
  ApiErrorCode.NoAdminUser throw at auth.ts:328). After the wizard
  completes, seerr writes initialized: true + mediaServerType: 2
  (JELLYFIN) to disk; slurp preserves both on every subsequent converge.
#}
 "public": {
  "initialized": {{ (seerr_settings_json | json_query('public.initialized') | default(false, true)) | string | lower }}
 },
