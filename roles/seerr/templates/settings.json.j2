   "tags": [],
   "animeTags": [],
   "is4k": false,
   "isDefault": true,
   "enableSeasonFolders": false,
   "externalUrl": "https://sonarr.{{ inventory_hostname }}.{{ domain }}",
   "syncEnabled": true,
   "preventSearch": false,
