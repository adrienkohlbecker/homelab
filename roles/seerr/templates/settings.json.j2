{#
  migrations[] is seerr's applied-migration bookkeeping -- it appends an entry
  as each migration runs, so a hardcoded list would diff-churn (and restart
  seerr every converge) the moment an upgrade ships a new one. Slurp-preserve
  it instead; the default below is only the fresh-install seed before seerr has
  written its own, after which the slurp picks up whatever the daemon recorded.
#}
{% set _migrations = seerr_settings_json | json_query('migrations') | default(['0007_migrate_arr_tags', '0008_migrate_blacklist_to_blocklist'], true) %}
 "migrations": [
{% for _m in _migrations %}
  {{ _m | to_json }}{% if not loop.last %},{% endif %}

{% endfor %}
 ]
}
