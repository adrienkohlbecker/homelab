#jinja2: lstrip_blocks: True
# seerr.service ###########################################################################
[Unit]
Description=seerr
After=network-online.target
Wants=network-online.target
StartLimitInterval=600
StartLimitBurst=3
{% if zfs_root %}
{% if zfs_has_services_mount %}
After=zfs_mount_mnt_services.service
Requires=zfs_mount_mnt_services.service
After=zfs_mount_mnt_services_sqlite.service
Requires=zfs_mount_mnt_services_sqlite.service
{% endif %}
After=zfs_autosnapshot.target
PartOf=zfs_autosnapshot.target
{% endif %}

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
Delegate=yes
TimeoutSec=120
RestartSec=5
Type=notify
NotifyAccess=all
SyslogIdentifier=%N

ExecStartPre=/bin/rm -f %t/%n.ctr-id
# `USER node:node` is baked into the v3 image, so the entrypoint runs as
# in-container uid/gid 1000 from the start (no privilege drop). The +1000
# uidmap routes that to host `seerr`; +0 is reserved for a hypothetical
# in-container root step that this image never performs (kept for symmetry
# with the canonical pattern in CLAUDE.md "Container User Namespacing").
ExecStart=/usr/bin/podman run \
    --cidfile=%t/%n.ctr-id \
    --cgroups=split \
    --sdnotify=healthy \
    --init \
    --detach \
    --replace \
    --rm \
    --name seerr \
    --log-driver journald \
    --log-opt tag="seerr" \
    --user 1000:1000 \
    --uidmap=0:0:65536 \
    --uidmap=+1000:{{ seerr_user.uid }}:1 \
    --gidmap=0:0:65536 \
    --gidmap=+1000:{{ seerr_user.group }}:1 \
    --env TZ={{ system_timezone }} \
    --volume /mnt/services/seerr:/app/config \
    --volume /mnt/services/sqlite/seerr:/app/config/db \
    --network media \
    --publish 127.0.0.1:{{ service_ports.seerr }}:5055/tcp \
    --health-cmd         '["wget","-q","-T","5","-O","/dev/null","http://localhost:5055/api/v1/status"]' \
    --health-startup-cmd '["wget","-q","-T","5","-O","/dev/null","http://localhost:5055/api/v1/status"]' \
    --health-startup-interval "1s" \
    --health-startup-timeout "5s" \
    --health-start-period "100s" \
    --stop-timeout 120 \
    ghcr.io/seerr-team/seerr:v3.2.0
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm --force --ignore --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
{% if zfs_root %}
WantedBy=zfs_autosnapshot.target
{% endif %}
