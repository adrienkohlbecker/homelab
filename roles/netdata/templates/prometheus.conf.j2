# vim:ft=yaml
jobs:
  # fluent-bit's HTTP_Server exposes a prometheus endpoint with
  # output_dropped_records_total + output_retried_records_total. Dropped
  # records mean fluent-bit gave up after exhausting retries against
  # OpenObserve/HyperDX -- silent log loss otherwise.
  - name: fluentbit
    url: http://127.0.0.1:{{ service_ports.fluentbit }}/api/v1/metrics/prometheus
    autodetection_retry: 60

{% if minio_enabled %}

  - name: minio
    url: http://127.0.0.1:{{ service_ports.minio_api }}/minio/v2/metrics/cluster
    autodetection_retry: 60
{% endif %}

{% if 'go.d:collector:prometheus:kuma' in (netdata_collectors | default([])) %}

  # kuma runs only on lab (site.yml). Gated on its presence in this host's
  # netdata_collectors -- the same source of truth that drives the presence
  # alert -- so the scrape job exists exactly where the liveness signal does,
  # instead of idling (and logging connection-refused every 60s) elsewhere.
  # No auth on /metrics once the role has seeded disableAuth (server/auth.js
  # apiAuth next()s the basic-auth gate when disableAuth is set); this is a
  # loopback scrape that bypasses the Authelia-fronted nginx vhost. The seed
  # is skipped until kuma has a user, so on a fresh host this collector idles
  # on a 401 until the operator runs the setup wizard and a converge seeds it.
  - name: kuma
    url: http://127.0.0.1:{{ service_ports.kuma }}/metrics
    autodetection_retry: 60
{% endif %}
{% if 'go.d:collector:prometheus:headscale' in (netdata_collectors | default([])) %}

  # headscale runs only on fox (site.yml). Gated on netdata_collectors
  # membership so the scrape job lives only where headscale does; the presence
  # alert doubles as a liveness signal -- if the control server or its metrics
  # endpoint dies, the collector goes missing. Loopback scrape of the
  # unauthenticated metrics_listen_addr.
  - name: headscale
    url: http://127.0.0.1:{{ service_ports.headscale_metrics }}/metrics
    autodetection_retry: 60
{% endif %}
{% if 'go.d:collector:prometheus:gitlab_runner' in (netdata_collectors | default([])) %}

  # gitlab_runner runs on the host orchestrating the AWS test cells (fox).
  # Loopback scrape of the unauthenticated metrics listener (config.toml
  # listen_address). Gated on netdata_collectors membership rather than the
  # prod-wide gitlab_runner_enabled flag (which would render this on every prod
  # host); the presence alert doubles as a liveness signal where it runs.
  - name: gitlab_runner
    url: http://127.0.0.1:{{ service_ports.gitlab_runner }}/metrics
    autodetection_retry: 60
{% endif %}
