# vim:ft=yaml
jobs:
  # fluent-bit's HTTP_Server exposes a prometheus endpoint with
  # output_dropped_records_total + output_retried_records_total. Dropped
  # records mean fluent-bit gave up after exhausting retries against
  # OpenObserve/HyperDX -- silent log loss otherwise.
  - name: fluentbit
    url: http://127.0.0.1:2020/api/v1/metrics/prometheus
    autodetection_retry: 60

{% if prometheus_enabled|default(false) %}

  - name: prometheus
    url: http://127.0.0.1:9090/metrics
    autodetection_retry: 60
{% endif %}
{% if minio_enabled|default(false) %}

  - name: minio
    url: http://127.0.0.1:9199/minio/v2/metrics/cluster
    autodetection_retry: 60
{% endif %}

  # Tries on every host; the role only applies on hosts in site.yml's
  # gitea_runner mapping (currently lab), elsewhere autodetection_retry
  # quietly idles. Listed in lab.yml's netdata_collectors so the
  # presence alert catches a scrape job that goes missing there.
  - name: gitea_runner
    url: http://127.0.0.1:{{ service_ports.gitea_runner_metrics }}/metrics
    autodetection_retry: 60

  # The exporter applies to all:!bunk (site.yml); try on every host and
  # let autodetection_retry idle on hosts where the unit isn't up.
  # Listed in {lab,pug}.yml's netdata_collectors so the presence alert
  # catches a scrape job that goes missing. The `_local` suffix matches
  # the chart context the keepalived_alerts.conf alert binds to
  # (prometheus.keepalived_exporter_local.keepalived_vrrp_become_master).
  - name: keepalived_exporter_local
    url: http://127.0.0.1:{{ service_ports.keepalived_exporter }}/metrics
    autodetection_retry: 60

  # kuma runs only on lab (site.yml); try on every host and let
  # autodetection_retry idle elsewhere. Listed in lab.yml's
  # netdata_collectors so the presence alert doubles as a kuma liveness
  # signal -- if kuma dies or /metrics breaks, the collector goes missing.
  # No auth on /metrics because the role seeds disableAuth (server/auth.js
  # apiAuth next()s the basic-auth gate when disableAuth is set); this is a
  # loopback scrape that bypasses the Authelia-fronted nginx vhost.
  - name: kuma
    url: http://127.0.0.1:{{ service_ports.kuma }}/metrics
    autodetection_retry: 60

  # headscale runs only on fox (site.yml); try on every host and let
  # autodetection_retry idle elsewhere. Listed in fox.yml's netdata_collectors
  # so the presence alert doubles as a headscale liveness signal -- if the
  # control server dies or its metrics endpoint breaks, the collector goes
  # missing. Loopback scrape of the unauthenticated metrics_listen_addr.
  - name: headscale
    url: http://127.0.0.1:{{ service_ports.headscale_metrics }}/metrics
    autodetection_retry: 60
