# vim:ft=yaml
jobs:
  - name: journald
    url: http://127.0.0.1:{{ service_ports.journald_exporter }}/metrics
    username: metrics
    # Same vault var (journald_exporter_key) is also written to
    # /etc/journald-exporter/keys/netdata by roles/journald_exporter.
    # The daemon side hot-reloads on inotify; this scrape config
    # does not -- netdata reads it only at start/restart. A vault
    # rotation requires re-applying BOTH roles (or `--tags
    # journald_exporter,netdata`) to avoid a 401 window.
    password: {{ journald_exporter_key }}
    max_time_series: 10000 # there is many series per individual systemd service, including temporary ones. Let's see if this is enough
    autodetection_retry: 60

  # fluent-bit's HTTP_Server exposes a prometheus endpoint with
  # output_dropped_records_total + output_retried_records_total. Dropped
  # records mean fluent-bit gave up after exhausting retries against
  # OpenObserve/HyperDX -- silent log loss otherwise.
  - name: fluentbit
    url: http://127.0.0.1:2020/api/v1/metrics/prometheus
    autodetection_retry: 60

{% if prometheus_enabled|default(false) %}

  - name: prometheus
    url: http://127.0.0.1:9090/metrics
    autodetection_retry: 60
{% endif %}
{% if minio_enabled|default(false) %}

  - name: minio
    url: http://127.0.0.1:9199/minio/v2/metrics/cluster
    autodetection_retry: 60
{% endif %}

  # Tries on every host; the role only applies on hosts in site.yml's
  # gitea_runner mapping (currently lab), elsewhere autodetection_retry
  # quietly idles. Listed in lab.yml's netdata_collectors so the
  # presence alert catches a scrape job that goes missing there.
  - name: gitea_runner
    url: http://127.0.0.1:{{ service_ports.gitea_runner_metrics }}/metrics
    autodetection_retry: 60
