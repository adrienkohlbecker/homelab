# Managed by ansible (roles/netdata/templates/netdata.conf.j2).
#
# Only the load-bearing overrides live here. netdata overlays this file on its
# compiled-in defaults, so every option not listed keeps its auto-tuned value
# -- this is deliberately NOT a wholesale copy of netdata.conf. The package's
# stock netdata.conf is dpkg-diverted aside (see configure.yml), so this is the
# only netdata.conf the daemon reads.
#
# Keys are non-indented `key = value` so the configparser validate parses cleanly.

[web]
bind to = 127.0.0.1
# netdata's bind is loopback-only, so every peer is 127.0.0.1 (nginx proxies from
# localhost -- see "Configure nginx" in main.yml). Pin `... by dns = no` on every
# ACL so netdata never reverse-resolves a peer. Its default DNS decision is
# `heuristic`, which runs a reverse+forward (FCrDNS) lookup on any access list
# that isn't purely IP/subnet. The load-bearing pair is management/netdata.conf
# below: their `none` pattern matches no IP, so on every connection netdata falls
# through to the DNS check, reverse-resolves 127.0.0.1 to `localhost` (via
# /etc/hosts), and -- localhost having no DNS record -- logs `LISTENER: Cannot
# validate 'localhost' as ip of 'localhost', not listed in DNS` (~16k/day on fox,
# one per poll). The `*` lists short-circuit on the IP match before any lookup,
# but carry `by dns = no` too for uniformity.
#
# management/netdata.conf stay `none`: the nginx vhost fronts netdata with an
# Authelia bypass keyed on a shared cross-host poll token, so a token-bearer must
# not be able to reach the management API (silence alarms) or dump the full config
# (netdata.conf). Nothing legitimate fetches them through the proxy -- the
# operator reads them on-host.
allow management from = none
allow management by dns = no
allow netdata.conf from = none
allow netdata.conf by dns = no
allow connections from = *
allow connections by dns = no
allow dashboard from = *
allow dashboard by dns = no
allow badges from = *
allow badges by dns = no

# v2 moved access logging out of [global] into [logs]; `[global] access log` is
# silently ignored, re-enabling the file. Accesses are logged by nginx.
[logs]
access = none

[db]
update every = 5
# Drop tier 2 (1h resolution / 2-year retention). Tier 0 + tier 1 still give 14
# days at 5s + 90 days at 1m, which covers any chart you'd actually look at on a
# homelab. Saves ~100-150 MiB of per-metric overhead in the main netdata process.
storage tiers = 2

# ML anomaly detection trains a model per metric. Memory cost grows with metric
# count and the alerts aren't actionable here.
[ml]
enabled = no

# ebpf.plugin loads syscall/process eBPF programs and runs as its own ~300 MiB
# process. Useful for syscall-level forensics, dead weight if nobody looks at it.
#
# scripts.d.plugin auto-watches /etc/netdata/scripts.d for scripted collectors;
# we use charts.d (not scripts.d), so the dir never exists and the plugin logs
# `start watching '/etc/netdata/scripts.d': no such file or directory` on a
# loop (~3k/day on lab). Disable it -- charts.d.plugin is unaffected.
#
# tc.plugin reads Linux tc qdisc/class stats and shells out to tc-qos-helper.sh,
# which only produces useful charts when FireQOS labelled the classes. We run no
# FireQOS/tc QoS, so the helper logs `Cannot find file tc-qos-helper.conf` and
# `FireQOS is not installed` on a loop (~130/day on pug) and collects nothing.
[plugins]
ebpf = no
scripts.d = no
tc = no

[registry]
enabled = yes
registry to announce = https://netdata.{{ inventory_hostname }}.{{ domain }}
