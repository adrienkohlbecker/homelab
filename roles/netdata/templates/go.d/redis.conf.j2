# vim:ft=yaml
jobs:
  # netdata runs on the host; redis publishes 127.0.0.1:{{ service_ports.redis }}.
  # `password` is a separate key (not embedded in the address URI) so a vault
  # password with URI metacharacters needs no escaping. The job name must stay
  # `local` -- lab.yml's netdata_collectors presence alert binds to
  # go.d:collector:redis:local.
  - name: local
    address: 'redis://@127.0.0.1:{{ service_ports.redis }}'
    password: '{{ redis_password }}'
