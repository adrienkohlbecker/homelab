#!/bin/bash
set -euo pipefail

# Prefer the Fluent Bit JSONL store when it exists. Unit and line-count queries
# still use journalctl directly, because lnav file mode has no -u equivalent.
# Bare -n is passed through to lnav as non-interactive mode; -n <count> selects
# the journalctl line-count fallback.

case "${1:-}" in
-V | --version | -h | --help)
	exec /usr/local/bin/lnav "$@"
	;;
esac

since="1 hour ago"
since_explicit=false
until=""
lines=""
units=()
lnav_args=()

while [[ $# -gt 0 ]]; do
	case "$1" in
	-S | --since)
		if [[ $# -lt 2 ]]; then
			echo "lnav-journal: $1 requires a value" >&2
			exit 2
		fi
		since="$2"
		since_explicit=true
		lnav_args+=("$1" "$2")
		shift 2
		;;
	--since=*)
		since="${1#--since=}"
		since_explicit=true
		lnav_args+=("$1")
		shift
		;;
	-n | --lines)
		if [[ $# -ge 2 && "$2" != -* ]]; then
			lines="$2"
			shift 2
		else
			lnav_args+=("$1")
			shift
		fi
		;;
	--lines=*)
		lines="${1#--lines=}"
		shift
		;;
	-U | --until)
		if [[ $# -lt 2 ]]; then
			echo "lnav-journal: $1 requires a value" >&2
			exit 2
		fi
		until="$2"
		lnav_args+=("$1" "$2")
		shift 2
		;;
	--until=*)
		until="${1#--until=}"
		lnav_args+=("$1")
		shift
		;;
	-u | --unit)
		if [[ $# -lt 2 ]]; then
			echo "lnav-journal: $1 requires a value" >&2
			exit 2
		fi
		units+=("$2")
		shift 2
		;;
	--unit=*)
		units+=("${1#--unit=}")
		shift
		;;
	*)
		lnav_args+=("$1")
		shift
		;;
	esac
done

shopt -s nullglob
fluentbit_candidates=(
	/var/log/fluent-bit/lnav.jsonl
	/var/log/fluent-bit/lnav.jsonl.[0-9]
	/var/log/fluent-bit/lnav.jsonl.[0-9].gz
	/var/log/fluent-bit/lnav.jsonl.[0-9][0-9]
	/var/log/fluent-bit/lnav.jsonl.[0-9][0-9].gz
)
fluentbit_logs=()
for log_path in "${fluentbit_candidates[@]}"; do
	if [[ -f "$log_path" && -r "$log_path" ]]; then
		fluentbit_logs+=("$log_path")
	fi
done

# :goto 100% lands on the newest record at startup (lnav otherwise opens at the
# top, i.e. the oldest line in the store); being at the bottom, lnav then
# auto-follows records appended live by Fluent Bit. Placed before the
# passthrough args so an explicit user position still wins.
if [[ ${#fluentbit_logs[@]} -gt 0 && ${#units[@]} -eq 0 && -z "$lines" ]]; then
	exec /usr/local/bin/lnav -c ':goto 100%' "${lnav_args[@]}" "${fluentbit_logs[@]}"
fi

journalctl_args=(--no-pager --quiet -o json)
if [[ -n "$lines" ]]; then
	journalctl_args+=(-n "$lines")
elif [[ "$since_explicit" == false && ${#units[@]} -gt 0 ]]; then
	journalctl_args+=(-n 10000)
else
	journalctl_args+=(--since "$since")
fi
if [[ -n "$until" ]]; then
	journalctl_args+=(--until "$until")
else
	journalctl_args+=(--follow)
fi
for unit in "${units[@]}"; do
	journalctl_args+=(-u "$unit")
done

tmpfile=$(mktemp /tmp/lnav-journal-XXXXXX.json)

lnav_format_args=()
if [[ ${#units[@]} -gt 0 ]]; then
	tmpfmt=$(mktemp -d /tmp/lnav-fmt-XXXXXX)
	mkdir -p "$tmpfmt/formats"
	cat >"$tmpfmt/formats/journald_no_unit.json" <<'ENDFMT'
{
  "$schema": "https://lnav.org/schemas/format-v1.schema.json",
  "journald_json_log": {
    "line-format": [
      { "field": "__REALTIME_TIMESTAMP", "timestamp-format": "%Y-%m-%d %H:%M:%S" },
      " ",
      { "field": "SYSLOG_IDENTIFIER", "max-width": 15 },
      "[",
      { "field": "_PID" },
      "] ",
      { "field": "__level__", "text-transform": "uppercase" },
      " ",
      { "field": "MESSAGE" }
    ]
  }
}
ENDFMT
	lnav_format_args=(-I "$tmpfmt")
	trap 'rm -rf "$tmpfmt" "$tmpfile"' EXIT
else
	trap 'rm -f "$tmpfile"' EXIT
fi

journalctl "${journalctl_args[@]}" >"$tmpfile" &
jctl_pid=$!

_wait=0
until [[ -s "$tmpfile" ]] || ! kill -0 "$jctl_pid" 2>/dev/null || (( _wait >= 40 )); do
	sleep 0.05
	(( _wait++ )) || true
done

# No :filter-out args: noise filtering is owned by the Fluent Bit stage
# (roles/fluentbit), which strips these patterns before they reach the
# lnav.jsonl store the primary path reads. This journalctl-fallback path (-u
# unit / -n line-count queries) reads the raw journal, so it intentionally
# shows unfiltered lines -- acceptable since those are targeted queries where
# the noise is in-scope, and journalctl on the host is the source of truth.
set +e
/usr/local/bin/lnav \
	"${lnav_format_args[@]}" \
	-c ':goto 100%' \
	"${lnav_args[@]}" \
	"$tmpfile"
lnav_exit=$?
set -e

kill "$jctl_pid" 2>/dev/null || true
wait "$jctl_pid" 2>/dev/null || true
exit "$lnav_exit"
