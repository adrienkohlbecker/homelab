{% set own_peer = wireguard_peers|selectattr("name", "eq", own_peer_name)|first -%}
[Interface]
# PublicKey = {{ own_peer.public_key }}
PrivateKey = {{ own_peer.private_key }}
Address = {{ own_peer.address }}/32
{# wg-quick auto-discovers MTU from the endpoint route minus 80 bytes
   (1500 ethernet -> 1420). That breaks for mobile peers on PPPoE
   uplinks (capped at 1492 -> 1412 effective WG), cellular 4G/5G
   (often 1300-1400), or VPN-stacked links: tunnel comes up, small
   packets succeed, large packets stall silently. 1280 is the IPv6
   minimum MTU -- universally fragmentation-safe. Server-side keeps
   auto-discovery (stable uplinks). -#}
{% if not own_peer.is_server %}
MTU = 1280
{% endif %}
ListenPort = {{ listen_port | default('51820') }}
{% if 'post_up' in own_peer %}
PostUp = {{ own_peer.post_up }}
{% endif %}
{% if 'post_down' in own_peer %}
PostDown = {{ own_peer.post_down }}
{% endif %}
{% if not own_peer.is_server %}
DNS = {{ external_ips.pihole }}
{% endif %}

{# Host /32 only. wg0 is a break-glass backbone reaching peer *hosts*, not a
   subnet router or exit: cross-site subnet access (home 0/21, bonniers 57/24)
   and full-tunnel egress are the tailscale mesh's job now. Routing a peer's
   declared subnet here is what let a public peer (fox) inherit the bonniers
   /24, so AllowedIPs is deliberately pinned to the peer's own /32 -- no
   per-peer allowed_ips, no all-traffic variant. #}
{% for peer in wireguard_peers if (peer.is_server or own_peer.is_server) and (peer.public_key != own_peer.public_key) %}
{% set tuple = [own_peer.name, peer.name]|sort %}
[Peer]
# Name = {{ peer.name }}
PublicKey = {{ peer.public_key }}
AllowedIPs = {{ peer.address }}/32
{# PSK derived from the vaulted seed, never stored on disk: both ends sort
   the pair name so they compute the same key. See filter_plugins/wireguard_psk.py. #}
PresharedKey = {{ tuple | join('-') | wireguard_psk(wireguard_psk_seed) }}
{% if 'endpoint' in peer %}
{% if own_peer.is_server and peer.is_server and peer.site_subnet == own_peer.site_subnet %}
Endpoint = {{ peer.endpoint.local }}
{% else %}
{% set host = peer.endpoint.remote | split(':') | first %}
{% set port = peer.endpoint.remote | split(':') | last %}
{% if own_peer.is_server %}
{% set host = lookup('community.general.dig', host) %}
{% endif %}
Endpoint = {{ host }}:{{ port }}
{% endif %}
{% endif %}
{# Peer-pair keepalive: emit PersistentKeepalive only when own_peer is
   listed in peer.keepalive_from. Per-pair (rather than per-peer) so
   battery-sensitive mobile peers don't get a forced 25s heartbeat
   they don't need. Currently used to make lab/pug's view of bunk's
   handshake_ago stay fresh enough for the netdata
   wireguard_peer_handshake_stale alarm to be meaningful -- without
   it, bunk's handshake only refreshes during nightly zfs sends and
   the alarm fires all day. #}
{% if own_peer.name in peer.get('keepalive_from', []) %}
PersistentKeepalive = 25
{% endif %}

{% endfor %}
