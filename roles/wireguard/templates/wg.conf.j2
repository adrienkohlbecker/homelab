{% set own_peer = wireguard_peers | one_by_attr("name", own_peer_name) -%}
[Interface]
# PublicKey = {{ own_peer.public_key }}
PrivateKey = {{ own_peer.private_key }}
Address = {{ own_peer.address }}/32
{# wg-quick auto-discovers MTU from the endpoint route minus 80 bytes
   (1500 ethernet -> 1420). That breaks for mobile peers on PPPoE
   uplinks (capped at 1492 -> 1412 effective WG), cellular 4G/5G
   (often 1300-1400), or VPN-stacked links: tunnel comes up, small
   packets succeed, large packets stall silently. 1280 is the IPv6
   minimum MTU -- universally fragmentation-safe. Server-side keeps
   auto-discovery (stable uplinks). -#}
{% if not own_peer.is_server %}
MTU = 1280
{% endif %}
{# Table = auto is wg-quick's default; pinned to document that wg-quick owns
   route installation -- the full-restart-on-change strategy (wg.yml) and the
   _verify kernel-route guard both depend on it, not on `wg syncconf`. #}
Table = auto
ListenPort = {{ listen_port | default('51820') }}
{# No DNS line: wg0 is a split-tunnel break-glass backbone (peer /32s only),
   so DNS = the adguard VIP would point the device at a resolver outside AllowedIPs
   (unreachable over the tunnel) and would hijack the device's system DNS the
   moment the tunnel comes up -- exactly when you might bring wg up to bypass
   adguard. Break-glass clients keep their own resolver. #}

{# Host /32s only. wg0 is a break-glass backbone reaching peer *hosts*, not a
   subnet router or exit (cross-site subnet access and full-tunnel egress are
   the tailscale mesh's job now). Each peer gets its own wg /32; a peer in a
   *different site* than this host also gets that peer's physical /32, so an
   off-site host (fox) can reach a home host's service at the IP its public DNS
   resolves to over the backbone. Still only host /32s -- routing a peer's
   declared *subnet* is what let fox inherit the bonniers /24, so that stays
   out. Same-site peers reach each other on the LAN; roaming clients (no site,
   own_host == {}) keep the pure wg-/32 split tunnel. #}
{% set own_host = network.hosts.get(own_peer_name, {}) %}
{% for peer in wireguard_peers if (peer.is_server or own_peer.is_server) and (peer.name != own_peer_name) %}
{% set tuple = [own_peer.name, peer.name]|sort %}
{% set peer_host = network.hosts.get(peer.name, {}) %}
[Peer]
# Name = {{ peer.name }}
PublicKey = {{ peer.public_key }}
{% if peer_host.physical is defined and own_host.site is defined and peer_host.site != own_host.site %}
AllowedIPs = {{ peer.address }}/32, {{ peer_host.physical }}/32
{% else %}
AllowedIPs = {{ peer.address }}/32
{% endif %}
{# PSK derived from the vaulted seed, never stored on disk: both ends sort
   the pair name so they compute the same key. See filter_plugins/wireguard_psk.py. #}
PresharedKey = {{ tuple | join('-') | wireguard_psk(wireguard_psk_seed) }}
{% if 'endpoint' in peer %}
{% if own_peer.is_server and peer.is_server and own_host.site is defined and peer_host.site is defined and peer_host.site == own_host.site and peer.endpoint.local is defined %}
Endpoint = {{ peer.endpoint.local }}
{% else %}
{# Remote endpoints are bare IP:port literals (the off-site/home public IPs live
   in the vault, not in DNS), so wg-quick never resolves a name at bring-up and
   there's no template-time dig. A bracketed IPv6 literal would pass through fine. #}
Endpoint = {{ peer.endpoint.remote }}
{% endif %}
{% endif %}
{# Peer-pair keepalive: emit PersistentKeepalive only when own_peer is
   listed in peer.keepalive_from. Per-pair (rather than per-peer) so
   battery-sensitive mobile peers don't get a forced 25s heartbeat
   they don't need. Currently used to make lab/pug's view of bunk's
   handshake_ago stay fresh enough for the netdata
   wireguard_peer_handshake_stale alarm to be meaningful -- without
   it, bunk's handshake only refreshes during nightly zfs sends and
   the alarm fires all day. #}
{% if own_peer.name in peer.get('keepalive_from', []) %}
PersistentKeepalive = 25
{% endif %}

{% endfor %}
