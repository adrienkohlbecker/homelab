# vim:ft=properties
# defaults file for hd-idle

## Debian specific defaults for hd-idle
# In order to make init.d script and systemd service consistent, hd-idle
# defaults file supports only one option - HD_IDLE_OPTS.

# Don't start hd-idle by default. By specifying "-h" in HD_IDLE_OPTS,
# hd-idle daemon will print usage and successfully exit both for systemd
# and systemv scripts
# properly update HD_IDLE_OPTS in order to start hd-idle

#HD_IDLE_OPTS="-h"

# Newer hd-idle (>= resolute / 26.04, Go rewrite) exits immediately
# only if START_HD_IDLE=false; older releases (jammy/noble, C 1.05)
# ignore the variable entirely. Setting it =true is a no-op on both,
# kept as a defensive sentinel that matches the upstream env-file
# Debian ships starting with the Go rewrite.
START_HD_IDLE=true

# hd-idle command line options
# Options are:
#  -a <name>               Set device name of disks for subsequent idle-time
#                          parameters (-i). This parameter is optional in the
#                          sense that there's a default entry for all disks
#                          which are not named otherwise by using this
#                          parameter. This can also be a symlink
#                          (e.g. /dev/disk/by-uuid/...)
#  -i <idle_time>          Idle time in seconds.
#  -s <policy>             Symlink resolution policy. 1 = re-resolve missing
#                          /dev/disk/by-id/ symlinks at runtime, so disks
#                          powered up after the daemon started get tracked
#                          (USB hotplug, late-arriving SAS expanders). The
#                          0 default silently never tracks them.
#                          Only emitted on releases newer than jammy/noble;
#                          older hd-idle packages predate the flag.
#
# Options not exactly useful here:
#  -l <logfile>            Name of logfile. We omit this so hd-idle writes
#                          to stderr → systemd-journald (query with
#                          `journalctl -u hd-idle`); upstream warns the
#                          option may itself wake the disk that holds the
#                          logfile, which is also why we don't use it.
#  -t <disk>               Spin-down the specified disk immediately and exit.
#  -d                      Debug mode. This will prevent hd-idle from
#                          becoming a daemon and print debugging info to
#                          stdout/stderr
#  -h                      Print usage information.
#
# Filter chain:
#   name prefix    excludes md/dm/loop/sr/ram/zd kernel pseudo block
#                  devices, which can report rotational=1 but have
#                  nothing to spin (observed on box's mdadm-EFI/swap).
#                  ansible_devices' `virtual` field looks like it
#                  should discriminate this, but on modern kernels
#                  /sys/block/<x> is always a symlink and ansible's
#                  detection logic (linux.py:733-748) sets virtual=1
#                  for every disk — unusable as a real-vs-pseudo
#                  filter, so we fall back to the name prefix.
#   rotational=1   skip SSDs / NVMe (spindown is harmful + nonsensical).
#   removable=0    skip USB-attached HDDs — they tend to be backup
#                  targets where mid-write spindown is harmful.
#   links.ids      skip drives udev didn't surface a /dev/disk/by-id/
#                  link for (no stable identifier to bind hd-idle to).
HD_IDLE_OPTS="-i 0{% if ansible_distribution_release not in ['jammy', 'noble'] %} -s 1{% endif %}{% for name, dev in ansible_devices.items() if not name.startswith(('md', 'dm-', 'loop', 'sr', 'ram', 'zd')) and dev.rotational == '1' and dev.removable == '0' and dev.links.ids %} -a /dev/disk/by-id/{{ dev.links.ids | sort | first }} -i 1200{% endfor %}"
