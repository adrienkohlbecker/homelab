# Empty listen_addresses to use systemd socket activation. The bind address is
# set by templates/override_socket.conf.j2, NOT here -- editing this line won't
# move the listening port.
listen_addresses = []
# Both Paris-local DNSCrypt resolvers, distinct operators (DNSCry.pt and dct).
# Both anonymizable via [anonymized_dns] below. DoH-only stamps (e.g. fdn) can't
# be relayed in 2.0.45 -- ODoH is 2.0.46+ -- so we pick DNSCrypt-protocol stamps
# to keep both upstreams anonymized. Scaleway-fr (Frank Denis) is intentionally
# excluded here so we can use anon-scaleway* relays without collapsing the
# resolver and relay to a single operator.
server_names = ['dnscry.pt-paris-ipv4', 'dct-fr']

# Fresh DNSCrypt key per query: resolver can't link our queries together.
dnscrypt_ephemeral_keys = true

# Disable internal cache: pihole's FTL is the cache layer just downstream, so
# this would be a duplicate. More importantly, cache hits in dnscrypt-proxy
# collapse to the last-used (server, relay) pair for the TTL, undoing the
# load-balancer's anonymization-set diversity. Let pihole cache; let every
# uncached query through here get a fresh balancer roll.
cache = false

# Random across the two pinned servers per query. The default 'p2' (pick the
# faster of two) degenerates to "always pin one" once the two operators' real
# latencies diverge by a few ms -- which defeats the dual-operator setup and
# breaks _verify.yml's per-server relay-traversal assertion that depends on
# both pinned servers seeing traffic.
lb_strategy = 'random'

# Bare hostnames + non-delegated TLDs (the wpad / .local / typo-domain class
# from containers and systemd-resolved fallback) can never be answered by a
# public resolver. Synthesize the empty replies locally instead of routing
# them through a relay+resolver round-trip.
#
# block_ipv6 is deliberately OFF: its synthetic unsigned responses fail
# pihole's DNSSEC validation (SERVFAIL), and musl-static binaries (uv, rust
# CLIs) treat the AAAA SERVFAIL as fatal rather than falling back to A
# records. The extra relay round-trip for AAAA is negligible.
block_ipv6 = false
block_unqualified = true
block_undelegated = true

# Resolver-list refresh (download.dnscrypt.info, every 72h per [sources])
# needs DNS for the URL host. Without ignore_system_dns, dnscrypt asks
# getaddrinfo, which on these hosts walks /etc/resolv.conf -> pihole ->
# dnscrypt: circular. Force the bootstrap resolver instead. Steady-state
# lookups use IP-keyed stamps from the cached list and don't hit this path.
# fallback_resolver (singular) was renamed bootstrap_resolvers (plural list)
# in dnscrypt-proxy 2.1.x. Ubuntu ships 2.0.45 through both jammy (22.04) and
# noble (24.04), and 2.1.x only from resolute (26.04) on -- so gate on the
# major version >= 26, NOT the codename (noble renders like jammy here, not
# like resolute). Passing the wrong key is fatal: dnscrypt-proxy -check
# rejects an unknown key outright, failing the template validate. Same >= 26
# threshold roles/apt_source uses for its deb822 fork.
# Future hardening: hardcode download.dnscrypt.info's A record in /etc/hosts
# to remove the cleartext UDP/53 bootstrap query entirely.
{% if ansible_distribution_major_version | int < 26 %}
fallback_resolver = '9.9.9.11:53'
{% else %}
bootstrap_resolvers = ['9.9.9.11:53', '8.8.8.8:53']
{% endif %}
ignore_system_dns = true

[sources]
  [sources.'public-resolvers']
  url = 'https://download.dnscrypt.info/resolvers-list/v2/public-resolvers.md'
  cache_file = '/var/cache/dnscrypt-proxy/public-resolvers.md'
  minisign_key = 'RWQf6LRCGA9i53mlYecO4IzT51TGPpvWucNSCh1CBM0QTaLn73Y7GFO3'
  refresh_delay = 72
  prefix = ''

  # v3 is the first revision that ships relays.md as a separate file; v2
  # public-resolvers.md above continues to work for resolver stamps. Same
  # minisign key signs both lists.
  [sources.'relays']
  url = 'https://download.dnscrypt.info/resolvers-list/v3/relays.md'
  cache_file = '/var/cache/dnscrypt-proxy/relays.md'
  minisign_key = 'RWQf6LRCGA9i53mlYecO4IzT51TGPpvWucNSCh1CBM0QTaLn73Y7GFO3'
  refresh_delay = 72
  prefix = ''

# Relay encrypted DNSCrypt queries through a third party so the resolver sees
# the relay's IP and the relay sees only ciphertext. Four distinct relay
# operators (Cryptostorm, Frank Denis/Scaleway, plan9-dns, ACSACSAR) so the
# load-balancer's anonymization set never collapses to a single legal entity --
# if one operator is coerced or breached, queries are still anonymized via the
# others. None match either of our resolvers (DNSCry.pt, dct), so no single
# party sees both our IP and our queries. server_name='*' applies the via
# list to every server in server_names.
[anonymized_dns]
routes = [
  { server_name = '*', via = [
    'anon-cs-fr', 'anon-scaleway', 'anon-scaleway2',
    'anon-plan9-dns-fr', 'anon-acsacsar-ams',
  ] },
]
