# {{ ansible_managed }}
[Unit]
Description=homepage_alerts
Wants=network-online.target
After=network-online.target

StartLimitInterval=300
StartLimitBurst=3

[Service]
Restart=always
TimeoutSec=30
RestartSec=5
Type=exec
SyslogIdentifier=%N

User=homepage
Group=homepage

# Polled netdata endpoints, formatted as `<label>=<query-url>[=<click-url>]`.
# Whichever host this is running on gets queried via loopback to skip nginx
# + TLS, with the public FQDN as the click-through target; the other host
# uses the FQDN for both since it has to traverse the network anyway.
Environment=NETDATA_HOSTS=lab={% if inventory_hostname == 'lab' %}http://localhost:19999={% endif %}https://netdata.lab.{{ domain }},pug={% if inventory_hostname == 'pug' %}http://localhost:19999={% endif %}https://netdata.pug.{{ domain }}
Environment=LISTEN_PORT={{ service_ports.homepage_alerts }}

ExecStart=/usr/bin/python3 /opt/homepage_alerts/alerts_server.py

# Tighten the namespace since this process only needs network + the script
# under /opt. Useful at zero cost — the script is short and well-bounded.
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
NoNewPrivileges=yes

[Install]
WantedBy=default.target
