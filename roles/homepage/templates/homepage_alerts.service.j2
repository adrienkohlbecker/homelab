# {{ ansible_managed }}
[Unit]
Description=homepage_alerts
Wants=network-online.target
After=network-online.target

StartLimitInterval=300
StartLimitBurst=3

[Service]
Restart=always
TimeoutSec=30
RestartSec=5
Type=exec
SyslogIdentifier=%N

User=homepage
Group=homepage

# Polled netdata endpoints, formatted as `<label>=<query-url>[=<click-url>]`.
# Lab is queried via loopback to skip nginx + TLS but click-through targets
# the public vhost so the alarm rows are reachable from a browser; pug is
# remote so the same FQDN doubles as both.
Environment=NETDATA_HOSTS={{ inventory_hostname }}=http://localhost:19999=https://netdata.{{ inventory_hostname }}.{{ domain }},pug=https://netdata.pug.{{ domain }}
Environment=LISTEN_PORT={{ service_ports.homepage_alerts }}

ExecStart=/usr/bin/python3 /opt/homepage_alerts/alerts_server.py

# Tighten the namespace since this process only needs network + the script
# under /opt. Useful at zero cost — the script is short and well-bounded.
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
NoNewPrivileges=yes

[Install]
WantedBy=default.target
