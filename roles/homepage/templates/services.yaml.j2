# {{ ansible_managed }}
# Top section: per-host netdata health. Each count tile shows the active
# warnings + criticals; the alerts iframe below renders the alarm names
# pulled by the homepage_alerts sidecar so the dashboard answers both "is
# anything on fire?" and "what specifically?" without round-tripping into
# netdata's UI.
- Health:
    - Lab:
        href: https://netdata.{{ inventory_hostname }}.{{ domain }}/
        description: System metrics for lab
        widget:
          type: netdata
          url: https://netdata.{{ inventory_hostname }}.{{ domain }}
    - Pug:
        href: https://netdata.pug.{{ domain }}/
        description: System metrics for pug
        widget:
          type: netdata
          url: https://netdata.pug.{{ domain }}

- Active alerts:
    - Active alerts:
        widget:
          type: iframe
          src: https://homepage-alerts.{{ inventory_hostname }}.{{ domain }}/
          classes: h-96 w-full
          referrerPolicy: same-origin
          allowScrolling: 'yes'
