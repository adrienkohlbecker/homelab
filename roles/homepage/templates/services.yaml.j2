# {{ ansible_managed }}
# Active alarm titles pulled by the homepage_alerts sidecar across each host.
# Replaces the built-in netdata count widget (warnings/criticals only) since
# the iframe already shows the underlying alarm names.
- Active alerts:
    - Active alerts:
        widget:
          type: iframe
          src: https://homepage-alerts.{{ inventory_hostname }}.{{ domain }}/
          classes: h-96 w-full
          referrerPolicy: same-origin
          allowScrolling: 'yes'
