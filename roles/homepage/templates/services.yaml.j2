# {{ ansible_managed }}
# Active alarm titles pulled by the homepage_alerts sidecar across each host.
# Same origin (mounted at /alerts/ on the homepage vhost) so the page can
# resize its own iframe to fit content.
- Active alerts:
    - Active alerts:
        widget:
          type: iframe
          src: /alerts/
          classes: w-full h-32
          referrerPolicy: same-origin
          allowScrolling: 'no'
