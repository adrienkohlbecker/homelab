# {{ ansible_managed }}
# Active alarm titles pulled by the homepage_alerts sidecar across each host.
# Same origin (mounted at /alerts/ on the homepage vhost) so the page can
# resize its own iframe to fit content.
#
# Gethomepage-native alternative if the iframe approach ever becomes a
# problem: re-add JSON output to alerts_generate.py (a sibling _atomic_write
# of api_alerts.json + an exact-match nginx location), replace `type: iframe`
# with `type: customapi` pointing at /alerts/api/alerts, and use `mappings:`
# to render per-host counts inline.
# See https://gethomepage.dev/widgets/services/customapi/.
- Active alerts:
    - Active alerts:
        widget:
          type: iframe
          src: /alerts/
          classes: w-full h-32
          referrerPolicy: same-origin
          allowScrolling: 'no'
          # 30s in ms; matches homepage_alerts.timer's OnCalendar=*:*:0/30
          # cadence. Browser-side conditional GETs (If-Modified-Since) 304 on
          # unchanged content so the every-30s fetch stays cheap.
          refreshInterval: 30000
