# {{ ansible_managed }}
title: Homepage
headerStyle: clean
theme: dark
color: slate
layout:
  Active alerts:
    style: row
    columns: 1
    header: false
# _self: homepage-wide bookmark clicks open in the current tab. The /alerts/ iframe
# overrides this to target="_blank" per-row in alerts_server.py:render_html — _self
# inside that iframe would replace the iframe, not the page.
target: _self
hideVersion: true
disableCollapse: true
