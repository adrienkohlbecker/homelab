# {{ ansible_managed }}
# Edit homepage_bookmarks in vars/main.yml — this file just iterates that dict.
# selfh.st icons resolve via the `sh-<icon>.png` prefix; omit icon: to fall
# back to the 2-letter abbr (used for services selfh.st doesn't ship).
{% for section, items in homepage_bookmarks.items() %}
{% if not loop.first %}

{% endif %}
- {{ section }}:
{% for item in items %}
    - {{ item.name }}:
        - abbr: {{ item.abbr }}
{% if item.icon is defined %}
          icon: sh-{{ item.icon }}.png
{% endif %}
{% if item.is_root is defined and item.is_root %}
          href: https://{{ item.sub }}.{{ domain }}{{ item.path | default('/') }}
{% else %}
          href: https://{{ item.sub }}.{{ item.host | default(inventory_hostname) }}.{{ domain }}{{ item.path | default('/') }}
{% endif %}
{% endfor %}
{% endfor %}
