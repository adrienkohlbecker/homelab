# root's outbound SSH client config, read by the zfs_autobackup backup scripts:
# onsite zfs-autobackup (via --ssh-config) and the offsite rsync to ak@bunk.
# ControlMaster is load-bearing -- zfs-autobackup opens many short ssh connections
# per run and multiplexes them over one master. See roles/ssh_root/tasks/main.yml.
Host *
    BatchMode yes
    ControlPath ~/.ssh/.controlmaster-%C
    ControlMaster auto
    ControlPersist 300
    ForwardAgent no
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
    PreferredAuthentications publickey
    ServerAliveCountMax 2
    ServerAliveInterval 30
    ConnectTimeout 10
