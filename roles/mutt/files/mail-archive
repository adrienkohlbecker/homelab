#!/bin/bash
set -euo pipefail

# Read-only browser for the getmail Gmail "All Mail" archive Maildir.
# -R opens neomutt read-only so browsing never mutates the irreplaceable
# archive; -n skips host-level defaults; -F points at the curated,
# ansible-managed config.
exec neomutt -n -R -F /opt/mutt/muttrc "$@"
