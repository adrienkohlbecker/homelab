# {{ ansible_managed }}
# Read-only viewer for the getmail Gmail "All Mail" archive: a single flat
# Maildir at /mnt/services/getmail (operator-owned 0700). Launch via the
# `mail-archive` wrapper, which adds -R so browsing never mutates the
# irreplaceable archive. See notes/archive/getmail_webmail_design.md.

set mbox_type = Maildir
# Browse through the read-only bind mount, not the source Maildir: the bind is
# mounted ro (mnt-services-mutt-archive.mount), so even a forgotten -R or a
# fat-fingered write physically cannot reach the archive. getmail still writes
# the real /mnt/services/getmail directly.
set folder    = /mnt/services/mutt/archive
set spoolfile = /mnt/services/mutt/archive
# Read-only viewer: no sent/draft folders to write to.
set record    = ""
set postponed = ""

# Header cache so reopening the multi-year archive doesn't re-parse every
# message. On the services dataset (operator-owned), never in $HOME. (No
# message_cachedir: the body cache only serves IMAP/POP — for a local Maildir
# the bodies are already on disk, so it would never populate.)
set header_cache     = /mnt/services/mutt/headers

# Belt-and-suspenders with the wrapper's -R: never move read mail out of the
# spool, never flag messages "old", no delete/trash.
set read_only     = yes
set move          = no
set mark_old      = no
set maildir_trash = no
unset confirm_append

# Browsing ergonomics for one big flat archive.
set sort         = reverse-date-received
set date_format  = "%Y-%m-%d %H:%M"
# %D renders the received date via $date_format in local time. (The strftime
# brace specifier is avoided here because its literal braces collide with
# Jinja's statement delimiter when this file is templated.)
set index_format = "%4C %Z %D %-25.25F %s"
set pager_index_lines = 12
set pager_context     = 3
set pager_stop        = yes
set tilde
set mail_check_stats

# Archived mail predates consistent charset labelling; a message lacking a
# charset= parameter would otherwise decode as US-ASCII and mojibake (accented
# names, latin1 bodies). Fall back through the common legacy encodings.
set assumed_charset = "utf-8:windows-1252:iso-8859-1"

# Render HTML mail inline (archived Gmail is heavily HTML) via w3m through the
# mailcap installed alongside this config.
set mailcap_path = /opt/mutt/mailcap
auto-view text/html
alternative-order text/plain text/enriched text/html
