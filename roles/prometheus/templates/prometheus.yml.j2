global:
  # Disambiguate series if both box and lab are ever scraped together.
  external_labels:
    host: '{{ inventory_hostname }}'

# Alerting/recording rules are deliberately unset: service-level
# monitoring + alerting live in netdata (go.d prometheus collector),
# not Alertmanager. This server primarily backs MinIO's console metrics.

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['127.0.0.1:{{ service_ports.prometheus }}']

{% if minio_enabled | default(false) %}
  # minio runs after prometheus in site.yml, so on a first-boot converge
  # this target is down until MinIO binds; it recovers on the next scrape.
  # (MinIO's console reads these metrics back from prometheus.)
  - job_name: 'minio'
    metrics_path: /minio/v2/metrics/cluster
    static_configs:
      - targets: ['127.0.0.1:{{ service_ports.minio_api }}']
{% endif %}
