# {{ ansible_managed }}
# Authelia v4.39+ configuration. All secrets are referenced via *_FILE
# env vars (see authelia.service.j2 + AUTHELIA_*_FILE in the secrets
# docs); this file is templated to /mnt/services/authelia/configuration.yml
# and mounted read-only into the container.
---
theme: 'auto'
# server.address is the listen socket inside the container; nginx on
# the host proxies https://auth.{{ authelia_cookie_domain }} → 127.0.0.1:{{ service_ports.authelia }}.
server:
  address: 'tcp://:9091'
  buffers:
    read: 4096
    write: 4096
  # Override the default CSP to allow inline scripts and styles. The
  # portal SPA dynamically renders inline <style> blocks and emits
  # inline scripts during the React lifecycle (TOTP enrollment, WebAuthn
  # flows, error toasts each render unique content). Whitelisting by
  # SHA-256 hash is whack-a-mole -- the hash changes per page-state, per
  # Authelia release. CSP Level 3 ignores 'unsafe-inline' when a nonce
  # or hash is also present, so we drop both and keep just 'self' +
  # 'unsafe-inline' for script-src/style-src.
  #
  # Trade-off: this weakens defense-in-depth against XSS in the portal.
  # Acceptable because (1) Authelia is a security product with a small
  # audited surface, (2) the portal lives on its own subdomain so a
  # compromise can't pivot to other services via DOM, (3) upstream's
  # own default CSP isn't actually working with their own SPA -- this
  # is fixing their gap, not introducing a new risk.
  headers:
    csp_template: >-
      default-src 'self' 'unsafe-inline';
      base-uri 'self';
      connect-src 'self';
      frame-ancestors 'none';
      frame-src 'none';
      object-src 'none';
      script-src 'self' 'unsafe-inline';
      style-src 'self' 'unsafe-inline'

log:
  level: 'info'
  format: 'text'

totp:
  disable: false
  issuer: '{{ authelia_cookie_domain }}'
  algorithm: 'sha1'
  digits: 6
  period: 30

webauthn:
  disable: false
  # display_name shows up in browser/passkey prompts; keep it short.
  display_name: 'Authelia'
  attestation_conveyance_preference: 'indirect'
  # Cross-platform = USB security keys (Yubikey etc.); platform =
  # OS-bound (Touch ID, Windows Hello); preferred allows both.
  selection_criteria:
    user_verification: 'preferred'

duo_api:
  disable: true

# Identity verification: drives the JWT used in reset-password emails.
identity_validation:
  reset_password:
    # AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET_FILE supplies the value.
    jwt_lifespan: '5m'
    jwt_algorithm: 'HS256'

authentication_backend:
  # Refresh interval for the in-memory user cache. The file backend
  # writes through the in-memory copy on password change, so a long
  # interval is fine for our use case.
  refresh_interval: '5m'
  password_reset:
    disable: false
  file:
    path: '/config/users.yml'
    watch: true
    search:
      email: false
      case_insensitive: false
    # argon2id is the recommended hashing algorithm in v4.38+. Memory
    # and iterations sized for a 1-vCPU container; users.yml hashes
    # generated by `authelia crypto hash generate argon2 --random` at
    # default cost.
    password:
      algorithm: 'argon2'
      argon2:
        variant: 'argon2id'
        iterations: 3
        memory: 65536
        parallelism: 4
        key_length: 32
        salt_length: 16

# Access control: catch-all default_policy lets every subdomain that
# isn't explicitly listed fall back to one_factor (forward-auth users
# must be authenticated, but no 2FA required). Per-domain rules
# elevate to two_factor for higher-stakes services as they migrate
# under Authelia.
access_control:
  default_policy: 'deny'
  rules:
    # Portal itself must be reachable without prior auth.
    - domain: 'auth.{{ authelia_cookie_domain }}'
      policy: 'bypass'
    # Admins land on two_factor for everything. This rule is also the
    # UX trigger that unlocks the TOTP/WebAuthn enrollment buttons in
    # the portal: Authelia hides them unless at least one rule requires
    # a 2nd factor, treating zero-2FA-requirement as "no need to
    # enroll". Match by group keeps family-shared services (Plex,
    # Jellyfin, Overseerr -- once migrated) at one_factor for the
    # non-admin users while still forcing 2FA on operator access.
    - domain: '*.{{ authelia_cookie_domain }}'
      subject: 'group:admins'
      policy: 'two_factor'
    # PR1 default: every other authenticated user (family etc.) goes
    # through one_factor. PR3+ will append per-service overrides
    # above this rule (e.g. *.minio.* → two_factor for everyone).
    - domain: '*.{{ authelia_cookie_domain }}'
      policy: 'one_factor'

session:
  name: 'authelia_session'
  same_site: 'lax'
  inactivity: '1h'
  expiration: '12h'
  remember_me: '1M'
  cookies:
    - domain: '{{ authelia_cookie_domain }}'
      authelia_url: 'https://auth.{{ authelia_cookie_domain }}'
      default_redirection_url: 'https://homepage.{{ inventory_hostname }}.{{ domain }}/'

# Brute-force regulation: 5 failed attempts in 2 min → 5 min lockout.
# Per-user (not per-IP) so a single misbehaving client doesn't
# trigger a lockout on the user's behalf.
regulation:
  max_retries: 5
  find_time: '2m'
  ban_time: '5m'

# SQLite at /db (separate bind mount so the dataset can carry its
# own ZFS recordsize / snapshot policy independently of the config
# dir). Matches the healthchecks pattern.
storage:
  local:
    path: '/db/db.sqlite3'

notifier:
  # disable_startup_check skips the SMTP connect probe at boot.
  # Disabled on the qemu test fixture (stub credentials always fail
  # auth against Mailgun); kept on for prod so a real SMTP misconfig
  # -- rotated-but-not-vaulted password, suspended mailgun domain,
  # mistyped username -- surfaces at startup rather than silently at
  # the first password-reset attempt. The trade-off: a transient
  # Mailgun outage at boot will fail Authelia and block forward-auth
  # for every protected service until systemd's Restart=always
  # cycles a successful probe. We accept that because the catch (a
  # silently-broken email path) is worse than the transient downtime,
  # and Mailgun's uptime is high enough that startup races are rare.
  disable_startup_check: {% if qemu_test %}true{% else %}false{% endif %}

  smtp:
    address: 'submission://{{ smtp_host }}:{{ smtp_port }}'
    timeout: '5s'
    username: 'authelia@{{ email_domain }}'
    sender: 'Authelia <authelia@{{ email_domain }}>'
    identifier: '{{ inventory_hostname }}.{{ domain }}'
    subject: '[Authelia] {title}'
    startup_check_address: '{{ root_email }}'

# OIDC provider lands in PR6 (first OIDC client migration -- MinIO).
# Until then there are no OIDC clients to register and no value in
# turning the provider on; forward-auth (PR2-5) uses the
# /api/authz/auth-request endpoint directly and doesn't touch OIDC.
# When PR6 lands, restore the identity_providers.oidc block (jwks +
# hmac_secret_file + cors endpoints + clients list) and reintroduce
# the matching vault entries / podman secrets / env vars.
