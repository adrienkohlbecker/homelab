# Pinned to the host's primary uplink. Without this, multi-NIC hosts
# (eth0 + macvlan children mac_mgmt/mac_iot sharing one L2, plus
# virbr0/podman*/iot VLAN) hear their own mDNS announcements echoed back via a sibling
# interface and rename to <host>-NNNN every time a netlink address-
# change fires — e.g. keepalived adding the DNS VIP to eth0 on
# MASTER transition.
[server]
allow-interfaces={{ default_interface }}
# Pin avahi's hostname to inventory; without this it reads
# gethostname(2) which can drift from inventory after a DHCP/
# cloud-init rename, and _verify's `getent ahosts {host}.local`
# would then fail opaquely (daemon healthy, wrong answer).
host-name={{ ansible_hostname }}
# Drop incoming mDNS packets whose TTL != 255 -- i.e. anything that
# crossed a router or TTL-decrementing bridge. Belt-and-braces to
# the allow-interfaces pin: catches a sibling-iface echo path that
# slipped past the L2 socket-membership pin, by enforcing direct-
# link multicast at the IP layer.
check-response-ttl=yes
# IPv4-only stance: allow-interfaces above pins one IPv4 iface, but
# avahi otherwise still binds :: and answers AAAA queries over IPv4
# mDNS via publish-aaaa-on-ipv4. Make the v4-only intent explicit so
# AAAA records for podman bridges / virbr0 / macvlan parent don't
# leak through the same echo-loop class the allow-interfaces pin
# defends against, just over a different record type.
use-ipv4=yes
use-ipv6=no
# Refuse to share UDP 5353 with another mDNS responder. Defense-
# in-depth: roles/resolved pins MulticastDNS=no on Ubuntu noble's
# systemd-resolved (whose default `MulticastDNS=resolve` would
# otherwise race avahi for the multicast socket on cold boot). If
# that pin is ever lost, or another mDNS responder lands here, this
# catches the conflict at avahi startup -- loud failure, not the
# silent collision-rename flap that two responders on the same
# socket would otherwise cause.
disallow-other-stacks=yes

[publish]
# Suppress _workstation._tcp (avahi upstream default = yes; Ubuntu's
# packaged conf overrides to no, preserved here). The service-name
# format embeds the publishing interface's MAC address
# (`<host> [aa:bb:cc:dd:ee:ff]._workstation._tcp`), a fingerprinting
# leak across mDNS; on macOS clients it also duplicates the host in
# the Finder sidebar alongside the _device-info-driven entry this
# role already publishes.
publish-workstation=no
# Defensive: pin against a future upstream re-enable of HINFO
# (CPU/arch broadcast); upstream default is already `no`.
publish-hinfo=no
# Match the IPv4-only stance above: don't synthesize AAAA on IPv4 or
# A on IPv6. Upstream defaults are yes for both.
publish-aaaa-on-ipv4=no
publish-a-on-ipv6=no
