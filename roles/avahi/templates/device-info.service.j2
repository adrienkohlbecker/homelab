<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
 <name replace-wildcards="yes">%h</name>
 <service>
   <type>_device-info._tcp</type>
   <port>0</port>
   <txt-record>model={{ avahi_device_model }}</txt-record>
   <!-- osxvers = Darwin major; Apple's mDNSResponder publishes this
        alongside model. Empirically model alone usually drives the
        Finder icon, but publishing both matches the upstream shape.
        Bump as macOS majors release; the value just needs to be
        plausibly recent. -->
   <txt-record>osxvers=24</txt-record>
 </service>
</service-group>
