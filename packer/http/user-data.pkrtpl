#cloud-config
hostname: ubuntu
package_update: false
package_upgrade: false
ssh_pwauth: false
users:
  - name: vagrant
    sudo: "ALL=(ALL) NOPASSWD:SETENV: ALL"
    shell: /bin/bash
    lock_passwd: true
    ssh_authorized_keys:
%{ for k in ssh_keys ~}
      - ${k}
%{ endfor ~}
apt:
  preserve_sources_list: false
  primary:
    - arches: [default]
      uri: "${archive_url}"
  security:
    - arches: [default]
      uri: "${security_url}"
